  1214 00004E24 EB53                <1>     jmp .next_desc
  1215                              <1> 
  1216                              <1> .not_hid_interface:
  1217 00004E26 BB00000000          <1>     mov ebx, 0                   ; Not a usable HID interface
  1218 00004E2B EB4C                <1>     jmp .next_desc
  1219                              <1> 
  1220                              <1> .check_endpoint:
  1221                              <1>     ; Found an endpoint descriptor
