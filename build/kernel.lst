  1112 00004D7C E843F1FFFF          <1>     call xhci_queue_ctrl_trb
  1113                              <1>     
  1114                              <1>     ; 3. Ring Doorbell
  1115 00004D81 0FB63C25[6F050000]  <1>     movzx edi, byte [xhci_slot_id]
  1116 00004D89 BE01000000          <1>     mov esi, 1
