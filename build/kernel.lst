  1123                              <1> ; ============================================================================
  1124                              <1> ; usb_wait_completion - Wait for status stage completion
  1125                              <1> ; ============================================================================
  1126                              <1> usb_wait_completion:
  1127                              <1>     ; PIT-based 1-second timeout + CPU spin fallback
  1128                              <1>     ; Use rsi for deadline - xhci_poll_event saves/restores rsi internally
