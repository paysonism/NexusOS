   559 00006594 89F9                <1>     mov ecx, edi
   560 00006596 83E107              <1>     and ecx, 7                  ; bit shift within byte = bit_offset % 8
   561                              <1> 
   562                              <1>     ; Read up to 4 bytes starting from this position
   563 00006599 31C0                <1>     xor eax, eax
   564 0000659B 0FB616              <1>     movzx edx, byte [rsi]
   565 0000659E 89D0                <1>     mov eax, edx
   566 000065A0 4183F808            <1>     cmp r8d, 8
   567 000065A4 7E27                <1>     jle .shift
   568 000065A6 0FB65601            <1>     movzx edx, byte [rsi + 1]
   569 000065AA C1E208              <1>     shl edx, 8
   570 000065AD 09D0                <1>     or eax, edx
   571 000065AF 4183F810            <1>     cmp r8d, 16
   572 000065B3 7E18                <1>     jle .shift
   573 000065B5 0FB65602            <1>     movzx edx, byte [rsi + 2]
   574 000065B9 C1E210              <1>     shl edx, 16
   575 000065BC 09D0                <1>     or eax, edx
   576 000065BE 4183F818            <1>     cmp r8d, 24
   577 000065C2 7E09                <1>     jle .shift
   578 000065C4 0FB65603            <1>     movzx edx, byte [rsi + 3]
   579 000065C8 C1E218              <1>     shl edx, 24
   580 000065CB 09D0                <1>     or eax, edx
