     8                              <2> ; Output character to COM1 for debugging
     9                              <2> %macro SER 1
    10                              <2>     push rax
    11                              <2>     push rdx
    12                              <2>     mov dx, 0x3F8
    13                              <2>     mov al, %1
    14                              <2>     out dx, al
    15                              <2>     pop rdx
    16                              <2>     pop rax
    17                              <2> %endmacro
    18                              <2> 
    19                              <2> ; Save all general-purpose registers (64-bit)
    20                              <2> %macro PUSH_ALL 0
    21                              <2>     push rax
    22                              <2>     push rbx
    23                              <2>     push rcx
    24                              <2>     push rdx
    25                              <2>     push rsi
    26                              <2>     push rdi
    27                              <2>     push rbp
    28                              <2>     push r8
    29                              <2>     push r9
    30                              <2>     push r10
    31                              <2>     push r11
    32                              <2>     push r12
    33                              <2>     push r13
    34                              <2>     push r14
    35                              <2>     push r15
    36                              <2> %endmacro
    37                              <2> 
    38                              <2> ; Offset of registers in PUSH_ALL frame
    39                              <2> ALL_R15 equ 0
    40                              <2> ALL_R14 equ 8
    41                              <2> ALL_R13 equ 16
    42                              <2> ALL_R12 equ 24
    43                              <2> ALL_R11 equ 32
    44                              <2> ALL_R10 equ 40
    45                              <2> ALL_R9  equ 48
    46                              <2> ALL_R8  equ 56
