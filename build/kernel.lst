     8                              <1> ; --- strlen: Get string length ---
     9                              <1> ; RDI = pointer to null-terminated string
    10                              <1> ; Returns: RAX = length
    11                              <1> global fn_strlen
    12                              <1> fn_strlen:
    13 0000C850 51                  <1>     push rcx
    14 0000C851 57                  <1>     push rdi
    15 0000C852 4831C9              <1>     xor rcx, rcx
    16 0000C855 48FFC9              <1>     dec rcx                  ; RCX = -1 (max count)
    17 0000C858 30C0                <1>     xor al, al              ; Searching for null
    18 0000C85A F2AE                <1>     repne scasb
    19 0000C85C 48F7D1              <1>     not rcx
    20 0000C85F 48FFC9              <1>     dec rcx                  ; RCX = length
