  1301                              <1> ; USB HID keycode -> PS/2 scancode translation table (256 bytes)
  1302                              <1> ; Maps USB HID boot protocol keycodes to PS/2 scancode set 1 equivalents.
  1303                              <1> ; Extended PS/2 scancodes (arrows, nav keys) stored with bit7 set (e.g. 0xC8=Up).
  1304                              <1> usb_hid_to_ps2:
  1305                              <1>     ; 0x00-0x03: no key, error, post fail
  1306 000007DE 00000000            <1>     db 0, 0, 0, 0
  1307                              <1>     ; 0x04-0x1D: a-z (USB alphabetical order -> PS/2 scancodes)
  1308 000007E2 1E302E2012212223    <1>     db 0x1E, 0x30, 0x2E, 0x20, 0x12, 0x21, 0x22, 0x23  ; a b c d e f g h
  1309 000007EA 1724252632311819    <1>     db 0x17, 0x24, 0x25, 0x26, 0x32, 0x31, 0x18, 0x19  ; i j k l m n o p
  1310 000007F2 10131F14162F112D    <1>     db 0x10, 0x13, 0x1F, 0x14, 0x16, 0x2F, 0x11, 0x2D  ; q r s t u v w x
  1311 000007FA 152C                <1>     db 0x15, 0x2C                                        ; y z
  1312                              <1>     ; 0x1E-0x27: 1-9, 0
  1313 000007FC 02030405060708090A- <1>     db 0x02, 0x03, 0x04, 0x05, 0x06, 0x07, 0x08, 0x09, 0x0A, 0x0B
  1313 00000805 0B                  <1>
  1314                              <1>     ; 0x28-0x2C: Enter, Esc, Backspace, Tab, Space
  1315 00000806 1C010E0F39          <1>     db 0x1C, 0x01, 0x0E, 0x0F, 0x39
  1316                              <1>     ; 0x2D-0x38: - = [ ] \ (non-US) ; ' ` , . /
  1317 0000080B 0C0D1A1B2B00272829- <1>     db 0x0C, 0x0D, 0x1A, 0x1B, 0x2B, 0x00, 0x27, 0x28, 0x29, 0x33, 0x34, 0x35
  1317 00000814 333435              <1>
  1318                              <1>     ; 0x39: CapsLock
  1319 00000817 3A                  <1>     db 0x3A
  1320                              <1>     ; 0x3A-0x45: F1-F12
  1321 00000818 3B3C3D3E3F40414243- <1>     db 0x3B, 0x3C, 0x3D, 0x3E, 0x3F, 0x40, 0x41, 0x42, 0x43, 0x44, 0x57, 0x58
  1321 00000821 445758              <1>
