   236 00004483 BF00009900          <1>     mov rdi, XHCI_CTRL_BUF_ADDR
   237 00004488 B909000000          <1>     mov rcx, 9
   238 0000448D 41B880060002        <1>     mov r8d, 0x02000680
   239 00004493 41B900000900        <1>     mov r9d, 0x00090000
