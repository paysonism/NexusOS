  2066 000006B9 C6033A              <1>     mov byte [rbx], ':'
  2067 000006BC 48FFC3              <1>     inc rbx
  2068 000006BF 0FB60425[6B050000]  <1>     movzx eax, byte [xhci_int_cycle]
  2069 000006C7 E817000000          <1>     call .writehex8
