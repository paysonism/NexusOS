   604                              <1> ; Handle click on taskbar / start menu
   605                              <1> ; RDI = Mouse X, RSI = Mouse Y
   606                              <1> ; Returns: RAX = 0 (not handled), 1 (handled, no app), or 2..6 (menu item 0..4 clicked)
   607                              <1> tb_handle_click:
   608 00008644 53                  <1>     push rbx
   609 00008645 51                  <1>     push rcx
   610 00008646 52                  <1>     push rdx
   611 00008647 4154                <1>     push r12
   612 00008649 4155                <1>     push r13
   613                              <1> 
   614                              <1>     ; Check if start menu is open and click is inside it
   615 0000864B 803C25[7B110000]00  <1>     cmp byte [tb_start_menu_open], 0
   616 00008653 7468                <1>     je .check_taskbar
   617                              <1> 
   618                              <1>     ; Check bounds of start menu
   619 00008655 4883FF04            <1>     cmp rdi, START_MENU_X
   620 00008659 7C50                <1>     jl .close_menu
   621 0000865B 4881FFCC000000      <1>     cmp rdi, START_MENU_X + START_MENU_W
   622 00008662 7F47                <1>     jg .close_menu
   623 00008664 4881FE14020000      <1>     cmp rsi, START_MENU_Y
