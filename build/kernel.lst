   150                              <1>     ; --- Save background from back buffer using row pointers ---
   151 00008EC6 4C8B0425[02020000]  <1>     mov r8, [bb_addr]
   152 00008ECE 4C8D0C25[DE890200]  <1>     lea r9, [cursor_bg_save]
   153 00008ED6 48631C25[12020000]  <1>     movsxd rbx, dword [scr_pitch]
   154                              <1> 
