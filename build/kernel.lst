   181                              <1> ; ============================================================================
   182                              <1> spi_hid_get_report_desc:
   183 0000539E 53                  <1>     push rbx
   184 0000539F 51                  <1>     push rcx
   185 000053A0 52                  <1>     push rdx
   186 000053A1 57                  <1>     push rdi
   187 000053A2 56                  <1>     push rsi
   188                              <1> 
   189 000053A3 0FB70C25[E8080000]  <1>     movzx ecx, word [spi_report_desc_len]
   190 000053AB 85C9                <1>     test ecx, ecx
   191 000053AD 0F8490000000        <1>     jz .rdesc_fail
   192                              <1> 
   193                              <1>     ; Request report descriptor: register 0x0001
   194 000053B3 C60425[86870200]FF  <1>     mov byte [spi_tx_buf + 0], SPI_SYNC_HOST
   195 000053BB C60425[87870200]05  <1>     mov byte [spi_tx_buf + 1], SPI_CID_DESC
