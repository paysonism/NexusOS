  1083 00006B74 000000              <1>
  1084                              <1> 
  1085                              <1>     ; --- 3-finger swipe detection ---
  1086 00006B77 83F803              <1>     cmp eax, 3
  1087 00006B7A 7569                <1>     jne .gesture_done
  1088                              <1>     ; Use finger0 X motion vs reference to detect swipe direction
  1089 00006B7C 803C25[4F0D0000]01  <1>     cmp byte [gesture_scroll_active], 1
  1090 00006B84 745F                <1>     je .gesture_done            ; don't swipe while scroll active
  1091 00006B86 8B1C25[E9040000]    <1>     mov ebx, [mouse_x]
  1092 00006B8D 8B0C25[540D0000]    <1>     mov ecx, [gesture_scroll_ref_x]
  1093 00006B94 85C9                <1>     test ecx, ecx
  1094 00006B96 743E                <1>     jz .swipe_set_ref           ; first frame with 3 fingers
  1095 00006B98 29CB                <1>     sub ebx, ecx                ; ebx = X delta from ref
  1096                              <1>     ; Threshold: > 40px horizontal motion = swipe
  1097 00006B9A 83FB28              <1>     cmp ebx, 40
  1098 00006B9D 7D07                <1>     jge .swipe_right
  1099 00006B9F 83FBD8              <1>     cmp ebx, -40
  1100 00006BA2 7E1A                <1>     jle .swipe_left
  1101 00006BA4 EB3F                <1>     jmp .gesture_done
  1102                              <1> .swipe_right:
  1103 00006BA6 C60425[5C0D0000]01  <1>     mov byte [gesture_swipe_dir], 1
  1104 00006BAE 8B1C25[E9040000]    <1>     mov ebx, [mouse_x]
  1105 00006BB5 891C25[540D0000]    <1>     mov [gesture_scroll_ref_x], ebx
  1106 00006BBC EB27                <1>     jmp .gesture_done
  1107                              <1> .swipe_left:
  1108 00006BBE C60425[5C0D0000]FF  <1>     mov byte [gesture_swipe_dir], -1
  1109 00006BC6 8B1C25[E9040000]    <1>     mov ebx, [mouse_x]
  1110 00006BCD 891C25[540D0000]    <1>     mov [gesture_scroll_ref_x], ebx
  1111 00006BD4 EB0F                <1>     jmp .gesture_done
  1112                              <1> .swipe_set_ref:
  1113 00006BD6 891C25[540D0000]    <1>     mov [gesture_scroll_ref_x], ebx
  1114 00006BDD C60425[5C0D0000]00  <1>     mov byte [gesture_swipe_dir], 0
