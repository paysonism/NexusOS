   104 0000C8CB 4989C0              <1>     mov r8, rax
   105 0000C8CE 48C1E020            <1>     shl rax, 32
   106 0000C8D2 4C09C0              <1>     or rax, r8               ; Replicate across qword
   107 0000C8D5 51                  <1>     push rcx
   108 0000C8D6 48C1E903            <1>     shr rcx, 3
   109 0000C8DA F348AB              <1>     rep stosq
   110 0000C8DD 59                  <1>     pop rcx
   111 0000C8DE 4883E107            <1>     and rcx, 7
   112 0000C8E2 4088F0              <1>     mov al, sil
   113 0000C8E5 F3AA                <1>     rep stosb
   114 0000C8E7 59                  <1>     pop rcx
   115 0000C8E8 5F                  <1>     pop rdi
   116 0000C8E9 4889F8              <1>     mov rax, rdi
   117 0000C8EC C3                  <1>     ret
