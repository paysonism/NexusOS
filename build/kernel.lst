    50                              <1> ; --- Mark a rectangle as dirty ---
    51                              <1> ; EDI = x, ESI = y, EDX = w, ECX = h
    52                              <1> render_mark_dirty:
    53 00007484 50                  <1>     push rax
    54                              <1> 
    55                              <1>     ; If too many dirty rects, just do full redraw
    56 00007485 8B0425[C70E0000]    <1>     mov eax, [dirty_count]
