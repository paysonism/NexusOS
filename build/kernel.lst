   202 000053E7 C60425[8B870200]00  <1>     mov byte [spi_tx_buf + 5], 0x00
   203                              <1> 
   204 000053EF 488D3C25[86870200]  <1>     lea rdi, [spi_tx_buf]
   205 000053F7 BE06000000          <1>     mov rsi, 6
   206 000053FC 488D1425[DE870200]  <1>     lea rdx, [spi_rdesc_buf]
