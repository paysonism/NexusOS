   296 00008D39 7404                <1>     je .rem_found
   297 00008D3B FFC1                <1>     inc ecx
   298 00008D3D EBEE                <1>     jmp .rem_loop
   299                              <1> .rem_found:
   300 00008D3F C681[96110000]00    <1>     mov byte [desktop_icons + rcx], 0
   301                              <1>     ; Compact: shift remaining entries down
   302 00008D46 678D5101            <1>     lea edx, [ecx + 1]
   303                              <1> .compact:
   304 00008D4A 83FA08              <1>     cmp edx, MAX_DESK_ICONS
