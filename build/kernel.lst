    84 0000C8AC 4883E107            <1>     and rcx, 7
    85 0000C8B0 F3A4                <1>     rep movsb
    86 0000C8B2 59                  <1>     pop rcx
    87 0000C8B3 5F                  <1>     pop rdi
    88 0000C8B4 4889F8              <1>     mov rax, rdi
