   209 00008F5C 41FFC2              <1>     inc r10d
   210 00008F5F EB92                <1>     jmp .s_row
   211                              <1> .s_done:
   212                              <1> 
   213                              <1>     ; --- Draw cursor using shape table with row pointers ---
   214 00008F61 4C8B0425[FA010000]  <1>     mov r8, [fb_addr]
   215 00008F69 48631C25[12020000]  <1>     movsxd rbx, dword [scr_pitch]
   216                              <1> 
   217                              <1>     ; Compute initial row pointer for draw
   218 00008F71 4489E8              <1>     mov eax, r13d
   219 00008F74 83F800              <1>     cmp eax, 0
   220 00008F77 7D02                <1>     jge .d_y_ok
   221 00008F79 31C0                <1>     xor eax, eax
