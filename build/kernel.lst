   588                              <1> 
   589                              <1>     ; Wait for HCRST to clear - up to 1 second
   590 00003704 488B1C25[D0000000]  <1>     mov rbx, [tick_count]
   591 0000370C 4883C364            <1>     add rbx, 100             ; 100 PIT ticks = 1 second
   592 00003710 B9002D3101          <1>     mov ecx, 20000000
   593                              <1> .wait_rst:
   594 00003715 8B06                <1>     mov eax, [rsi + XHCI_OP_USBCMD]
   595 00003717 A902000000          <1>     test eax, XHCI_CMD_HCRST
   596 0000371C 7415                <1>     jz .rst_done
   597 0000371E FFC9                <1>     dec ecx
   598 00003720 745A                <1>     jz .reset_fail
   599 00003722 488B0425[D0000000]  <1>     mov rax, [tick_count]
   600 0000372A 4839D8              <1>     cmp rax, rbx
   601 0000372D 7D4D                <1>     jge .reset_fail          ; Timeout
