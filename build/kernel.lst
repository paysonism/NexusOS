   119                              <1> ; --- memsetd: Fill memory with dwords ---
   120                              <1> ; RDI = dest, ESI = dword value, RDX = count (number of dwords)
   121                              <1> global fn_memsetd
   122                              <1> fn_memsetd:
   123 0000C8ED 57                  <1>     push rdi
   124 0000C8EE 51                  <1>     push rcx
   125 0000C8EF 50                  <1>     push rax
   126 0000C8F0 89F0                <1>     mov eax, esi
   127 0000C8F2 4889D1              <1>     mov rcx, rdx
   128 0000C8F5 F3AB                <1>     rep stosd
   129 0000C8F7 58                  <1>     pop rax
   130 0000C8F8 59                  <1>     pop rcx
   131 0000C8F9 5F                  <1>     pop rdi
   132 0000C8FA C3                  <1>     ret
