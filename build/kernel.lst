   157                              <2> KEY_F12             equ 0xFC
   158                              <2> 
   159                              <2> ; --- USB/XHCI Memory Layout ---
   160                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   161                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   162                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   163                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   164                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   165                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   166                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   167                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   168                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   169                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   170                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   171                              <2> ; Slot 2 device support
   172                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   173                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   174                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   175                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   176                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   177                              <2> 
   178                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   179                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   180                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   181                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   182                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   183                              <2> XHCI_CAP_DBOFF      equ 0x14
   184                              <2> XHCI_CAP_RTSOFF     equ 0x18
   185                              <2> 
   186                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   187                              <2> XHCI_OP_USBCMD      equ 0x00
   188                              <2> XHCI_OP_USBSTS      equ 0x04
   189                              <2> XHCI_OP_PAGESIZE     equ 0x08
   190                              <2> XHCI_OP_DNCTRL      equ 0x14
   191                              <2> XHCI_OP_CRCR_LO     equ 0x18
   192                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   193                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   194                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   195                              <2> XHCI_OP_CONFIG      equ 0x38
   196                              <2> 
   197                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   198                              <2> XHCI_PORTSC         equ 0x00
   199                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   200                              <2> 
   201                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   202                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   203                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   204                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   205                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   206                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   207                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   208                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   209                              <2> 
   210                              <2> ; --- USBCMD bits ---
   211                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   212                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   213                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   214                              <2> 
   215                              <2> ; --- USBSTS bits ---
   216                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   217                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   218                              <2> 
   219                              <2> ; --- PORTSC bits ---
   220                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   221                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   222                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   223                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   224                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   225                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   226                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   227                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   228                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   229                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   230                              <2> 
   231                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   232                              <2> TRB_NORMAL           equ (1 << 10)
   233                              <2> TRB_SETUP            equ (2 << 10)
   234                              <2> TRB_DATA             equ (3 << 10)
   235                              <2> TRB_STATUS           equ (4 << 10)
   236                              <2> TRB_LINK             equ (6 << 10)
   237                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   238                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   239                              <2> TRB_CONFIG_EP        equ (12 << 10)
   240                              <2> TRB_EVAL_CTX         equ (13 << 10)
   241                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   242                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   243                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   244                              <2> 
   245                              <2> ; --- TRB Flag Bits (dword 3) ---
   246                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   247                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   248                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   249                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   250                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   251                              <2> 
   252                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   253                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   254                              <2> TRB_TRT_OUT          equ (2 << 16)
   255                              <2> TRB_TRT_IN           equ (3 << 16)
   256                              <2> 
   257                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   258                              <2> TRB_DIR_OUT          equ (0 << 16)
   259                              <2> TRB_DIR_IN           equ (1 << 16)
   260                              <2> 
   261                              <2> ; --- Ring sizes ---
   262                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   263                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   264                              <2> 
   265                              <2> ; --- USB Standard Request Codes ---
   266                              <2> USB_REQ_GET_DESC     equ 0x06
   267                              <2> USB_REQ_SET_CONFIG   equ 0x09
   268                              <2> USB_REQ_SET_IFACE    equ 0x0B
   269                              <2> 
   270                              <2> ; --- USB HID Request Codes ---
   271                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   272                              <2> 
   273                              <2> ; --- USB Descriptor Types ---
   274                              <2> USB_DESC_DEVICE      equ 0x01
   275                              <2> USB_DESC_CONFIG      equ 0x02
   276                              <2> USB_DESC_INTERFACE   equ 0x04
   277                              <2> USB_DESC_ENDPOINT    equ 0x05
   278                              <2> USB_DESC_HID         equ 0x21
   279                              <2> 
   280                              <2> ; --- USB Endpoint Types ---
   281                              <2> USB_EP_CONTROL       equ 0
   282                              <2> USB_EP_ISOCH         equ 1
   283                              <2> USB_EP_BULK          equ 2
   284                              <2> USB_EP_INTERRUPT     equ 3
   285                              <2> 
   286                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   287                              <2> XHCI_EP_NOT_VALID    equ 0
   288                              <2> XHCI_EP_ISOCH_OUT    equ 1
   289                              <2> XHCI_EP_BULK_OUT     equ 2
   290                              <2> XHCI_EP_INT_OUT      equ 3
   291                              <2> XHCI_EP_CONTROL      equ 4
   292                              <2> XHCI_EP_ISOCH_IN     equ 5
   293                              <2> XHCI_EP_BULK_IN      equ 6
   294                              <2> XHCI_EP_INT_IN       equ 7
   295                              <2> 
   296                              <2> ; --- XHCI Port Speeds ---
   297                              <2> XHCI_SPEED_FULL      equ 1
   298                              <2> XHCI_SPEED_LOW       equ 2
   299                              <2> XHCI_SPEED_HIGH      equ 3
   300                              <2> XHCI_SPEED_SUPER     equ 4
     8                              <1> 
     9                              <1> section .text
    10                              <1> 
    11                              <1> global fat16_init
    12                              <1> global fat16_list_dir
    13                              <1> global fat16_read_file
    14                              <1> global fat16_write_file
    15                              <1> global fat16_get_file_size
    16                              <1> global fat16_file_count
    17                              <1> global fat16_get_entry
    18                              <1> 
    19                              <1> extern ata_read_sectors
    20                              <1> extern ata_write_sectors
    21                              <1> extern ata_drive_sel
    22                              <1> 
    23                              <1> ; The FAT16 partition starts at this LBA sector on the disk image
    24                              <1> FAT16_PART_LBA  equ 320           ; After MBR + Stage2 + Kernel (sector 320 = byte 163840)
    25                              <1> 
    26                              <1> ; FAT16 BPB offsets (from start of boot sector)
    27                              <1> BPB_BYTES_PER_SECT  equ 11        ; word
    28                              <1> BPB_SECT_PER_CLUS   equ 13        ; byte
    29                              <1> BPB_RESERVED_SECTS  equ 14        ; word
    30                              <1> BPB_NUM_FATS        equ 16        ; byte
    31                              <1> BPB_ROOT_ENTRIES    equ 17        ; word
    32                              <1> BPB_TOTAL_SECTS16   equ 19        ; word
    33                              <1> BPB_FAT_SIZE16      equ 22        ; word
    34                              <1> 
    35                              <1> ; FAT16 directory entry offsets
    36                              <1> DIR_NAME            equ 0          ; 8 bytes filename
    37                              <1> DIR_EXT             equ 8          ; 3 bytes extension
    38                              <1> DIR_ATTR            equ 11         ; 1 byte attributes
    39                              <1> DIR_FIRST_CLUS_HI   equ 20        ; 2 bytes (FAT32 only, 0 for FAT16)
    40                              <1> DIR_FIRST_CLUS_LO   equ 26        ; 2 bytes
    41                              <1> DIR_FILE_SIZE       equ 28         ; 4 bytes
    42                              <1> DIR_ENTRY_SIZE      equ 32
    43                              <1> 
    44                              <1> ; Attributes
    45                              <1> ATTR_READ_ONLY      equ 0x01
    46                              <1> ATTR_HIDDEN         equ 0x02
    47                              <1> ATTR_SYSTEM         equ 0x04
    48                              <1> ATTR_VOLUME_ID      equ 0x08
    49                              <1> ATTR_DIRECTORY      equ 0x10
    50                              <1> ATTR_ARCHIVE        equ 0x20
    51                              <1> ATTR_LFN            equ 0x0F
    52                              <1> 
    53                              <1> ; Temp buffers - moved to 13MB region to avoid XHCI conflict (0x900000-0x9F0000)
    54                              <1> FAT16_SECTOR_BUF    equ 0xD00000   ; 512 byte sector buffer
    55                              <1> FAT16_FAT_CACHE     equ 0xD01000   ; FAT table cache (up to 64KB)
    56                              <1> FAT16_ROOT_CACHE    equ 0xD11000   ; Root directory cache (up to 32 sectors = 16KB)
    57                              <1> FAT16_FILE_BUF      equ 0xD21000   ; File read buffer (up to 64KB)
    58                              <1> FAT16_DIR_CACHE     equ 0xD31000   ; Current directory listing cache
    59                              <1> 
    60                              <1> ; ============================================================================
    61                              <1> ; fat16_init - Initialize FAT16 driver, read BPB and cache FAT + root dir
    62                              <1> ; Returns: eax = 0 on success
    63                              <1> ; ============================================================================
    64                              <1> fat16_init:
    65 00006E59 53                  <1>     push rbx
    66 00006E5A 51                  <1>     push rcx
    67 00006E5B 52                  <1>     push rdx
    68 00006E5C 57                  <1>     push rdi
    69 00006E5D 56                  <1>     push rsi
    70                              <1> 
    71                              <1>     ; Read boot sector of FAT16 partition
    72                              <1>     ; First attempt with default drive (0xE0)
    73 00006E5E BF40010000          <1>     mov rdi, FAT16_PART_LBA
    74 00006E63 BE0000D000          <1>     mov rsi, FAT16_SECTOR_BUF
    75 00006E68 BA01000000          <1>     mov edx, 1
    76 00006E6D E8F3C1FFFF          <1>     call ata_read_sectors
    77 00006E72 85C0                <1>     test eax, eax
    78 00006E74 750C                <1>     jnz .try_next_drive
    79                              <1> 
    80                              <1>     ; Check partition signature
    81 00006E76 66813C25FE01D00055- <1>     cmp word [FAT16_SECTOR_BUF + 510], 0xAA55
    81 00006E7F AA                  <1>
    82 00006E80 743C                <1>     je .bpb_found
    83                              <1> 
    84                              <1> .try_next_drive:
    85                              <1>     ; Toggle drive (0xE0 -> 0xF0 or vice versa)
    86 00006E82 8A0425[0C050000]    <1>     mov al, [ata_drive_sel]
    87 00006E89 3410                <1>     xor al, 0x10
    88 00006E8B 880425[0C050000]    <1>     mov [ata_drive_sel], al
    89                              <1> 
    90                              <1>     ; Try reading again
    91 00006E92 BF40010000          <1>     mov rdi, FAT16_PART_LBA
    92 00006E97 BE0000D000          <1>     mov rsi, FAT16_SECTOR_BUF
    93 00006E9C BA01000000          <1>     mov edx, 1
    94 00006EA1 E8BFC1FFFF          <1>     call ata_read_sectors
    95 00006EA6 85C0                <1>     test eax, eax
    96 00006EA8 0F85FD000000        <1>     jnz .init_fail
    97                              <1> 
    98                              <1>     ; Check signature again
    99 00006EAE 66813C25FE01D00055- <1>     cmp word [FAT16_SECTOR_BUF + 510], 0xAA55
    99 00006EB7 AA                  <1>
   100 00006EB8 0F85ED000000        <1>     jne .init_fail
   101                              <1> 
   102                              <1> .bpb_found:
   103                              <1>     ; Parse BPB
   104 00006EBE BB0000D000          <1>     mov rbx, FAT16_SECTOR_BUF
   105 00006EC3 0FB7430B            <1>     movzx eax, word [rbx + BPB_BYTES_PER_SECT]
   106 00006EC7 66890425[870D0000]  <1>     mov [fat16_bytes_per_sect], ax
   107 00006ECF 0FB6430D            <1>     movzx eax, byte [rbx + BPB_SECT_PER_CLUS]
   108 00006ED3 880425[890D0000]    <1>     mov [fat16_sect_per_clus], al
   109 00006EDA 0FB7430E            <1>     movzx eax, word [rbx + BPB_RESERVED_SECTS]
   110 00006EDE 66890425[8A0D0000]  <1>     mov [fat16_reserved_sects], ax
   111 00006EE6 0FB64310            <1>     movzx eax, byte [rbx + BPB_NUM_FATS]
   112 00006EEA 880425[8C0D0000]    <1>     mov [fat16_num_fats], al
   113 00006EF1 0FB74311            <1>     movzx eax, word [rbx + BPB_ROOT_ENTRIES]
   114 00006EF5 66890425[8D0D0000]  <1>     mov [fat16_root_entries], ax
   115 00006EFD 0FB74316            <1>     movzx eax, word [rbx + BPB_FAT_SIZE16]
   116 00006F01 66890425[8F0D0000]  <1>     mov [fat16_fat_size], ax
   117                              <1> 
   118                              <1>     ; Calculate key offsets (all relative to partition start)
   119                              <1>     ; FAT start = reserved sectors
   120 00006F09 0FB70425[8A0D0000]  <1>     movzx eax, word [fat16_reserved_sects]
   121 00006F11 890425[910D0000]    <1>     mov [fat16_fat_start_sect], eax
   122                              <1> 
   123                              <1>     ; Root dir start = reserved + num_fats * fat_size
   124 00006F18 0FB60C25[8C0D0000]  <1>     movzx ecx, byte [fat16_num_fats]
   125 00006F20 0FB71425[8F0D0000]  <1>     movzx edx, word [fat16_fat_size]
   126 00006F28 0FAFCA              <1>     imul ecx, edx
   127 00006F2B 01C8                <1>     add eax, ecx
   128 00006F2D 890425[950D0000]    <1>     mov [fat16_root_start_sect], eax
   129                              <1> 
   130                              <1>     ; Root dir sectors = (root_entries * 32 + 511) / 512
   131 00006F34 0FB70C25[8D0D0000]  <1>     movzx ecx, word [fat16_root_entries]
   132 00006F3C C1E105              <1>     shl ecx, 5            ; * 32
   133 00006F3F 81C1FF010000        <1>     add ecx, 511
   134 00006F45 C1E909              <1>     shr ecx, 9            ; / 512
   135 00006F48 890C25[990D0000]    <1>     mov [fat16_root_sectors], ecx
   136                              <1> 
   137                              <1>     ; Data region start = root_start + root_sectors
   138 00006F4F 01C8                <1>     add eax, ecx
   139 00006F51 890425[9D0D0000]    <1>     mov [fat16_data_start_sect], eax
   140                              <1> 
   141                              <1>     ; Cache the FAT table
   142 00006F58 8B3C25[910D0000]    <1>     mov edi, [fat16_fat_start_sect]
   143 00006F5F 81C740010000        <1>     add edi, FAT16_PART_LBA
   144 00006F65 BE0010D000          <1>     mov rsi, FAT16_FAT_CACHE
   145 00006F6A 0FB71425[8F0D0000]  <1>     movzx edx, word [fat16_fat_size]
   146                              <1>     ; Limit to 128 sectors (64KB) for safety
   147 00006F72 81FA80000000        <1>     cmp edx, 128
   148 00006F78 7E05                <1>     jle .fat_size_ok
   149 00006F7A BA80000000          <1>     mov edx, 128
   150                              <1> .fat_size_ok:
   151 00006F7F E8E1C0FFFF          <1>     call ata_read_sectors
   152                              <1> 
   153                              <1>     ; Cache the root directory
   154 00006F84 8B3C25[950D0000]    <1>     mov edi, [fat16_root_start_sect]
   155 00006F8B 81C740010000        <1>     add edi, FAT16_PART_LBA
   156 00006F91 BE0010D100          <1>     mov rsi, FAT16_ROOT_CACHE
   157 00006F96 8B1425[990D0000]    <1>     mov edx, [fat16_root_sectors]
   158 00006F9D E8C3C0FFFF          <1>     call ata_read_sectors
   159                              <1> 
   160                              <1>     ; Count files in root dir
   161 00006FA2 E80F000000          <1>     call fat16_count_root_files
   162                              <1> 
   163 00006FA7 31C0                <1>     xor eax, eax
   164 00006FA9 EB05                <1>     jmp .init_ret
   165                              <1> 
   166                              <1> .init_fail:
   167 00006FAB B8FFFFFFFF          <1>     mov eax, -1
   168                              <1> 
   169                              <1> .init_ret:
   170 00006FB0 5E                  <1>     pop rsi
   171 00006FB1 5F                  <1>     pop rdi
   172 00006FB2 5A                  <1>     pop rdx
   173 00006FB3 59                  <1>     pop rcx
   174 00006FB4 5B                  <1>     pop rbx
   175 00006FB5 C3                  <1>     ret
   176                              <1> 
   177                              <1> ; Internal: count valid files in root directory
   178                              <1> fat16_count_root_files:
   179 00006FB6 51                  <1>     push rcx
   180 00006FB7 53                  <1>     push rbx
   181 00006FB8 BB0010D100          <1>     mov rbx, FAT16_ROOT_CACHE
   182 00006FBD 31C9                <1>     xor ecx, ecx           ; count
   183 00006FBF 31D2                <1>     xor edx, edx           ; index
   184 00006FC1 440FB70425-         <1>     movzx r8d, word [fat16_root_entries]
   184 00006FC6 [8D0D0000]          <1>
   185                              <1> .count_loop:
   186 00006FCA 4439C2              <1>     cmp edx, r8d
   187 00006FCD 7D1F                <1>     jge .count_done
   188 00006FCF 803B00              <1>     cmp byte [rbx], 0      ; end of entries
   189 00006FD2 741A                <1>     je .count_done
   190 00006FD4 803BE5              <1>     cmp byte [rbx], 0xE5   ; deleted entry
   191 00006FD7 740D                <1>     je .count_skip
   192 00006FD9 8A430B              <1>     mov al, [rbx + DIR_ATTR]
   193 00006FDC 3C0F                <1>     cmp al, ATTR_LFN          ; LFN entries have attr = 0x0F exactly
   194 00006FDE 7406                <1>     je .count_skip
   195 00006FE0 A808                <1>     test al, ATTR_VOLUME_ID
   196 00006FE2 7502                <1>     jnz .count_skip
   197 00006FE4 FFC1                <1>     inc ecx
   198                              <1> .count_skip:
   199 00006FE6 4883C320            <1>     add rbx, DIR_ENTRY_SIZE
   200 00006FEA FFC2                <1>     inc edx
   201 00006FEC EBDC                <1>     jmp .count_loop
   202                              <1> .count_done:
   203 00006FEE 890C25[A10D0000]    <1>     mov [fat16_file_count_val], ecx
   204 00006FF5 5B                  <1>     pop rbx
   205 00006FF6 59                  <1>     pop rcx
   206 00006FF7 C3                  <1>     ret
   207                              <1> 
   208                              <1> ; ============================================================================
   209                              <1> ; fat16_file_count - Return number of files in root directory
   210                              <1> ; Returns: eax = file count
   211                              <1> ; ============================================================================
   212                              <1> fat16_file_count:
   213 00006FF8 8B0425[A10D0000]    <1>     mov eax, [fat16_file_count_val]
   214 00006FFF C3                  <1>     ret
   215                              <1> 
   216                              <1> ; ============================================================================
   217                              <1> ; fat16_get_entry - Get nth valid directory entry from root dir
   218                              <1> ; edi = index (0-based)
   219                              <1> ; Returns: rax = pointer to 32-byte dir entry, or 0 if not found
   220                              <1> ; ============================================================================
   221                              <1> fat16_get_entry:
   222 00007000 53                  <1>     push rbx
   223 00007001 51                  <1>     push rcx
   224 00007002 52                  <1>     push rdx
   225                              <1> 
   226 00007003 BB0010D100          <1>     mov rbx, FAT16_ROOT_CACHE
   227 00007008 31C9                <1>     xor ecx, ecx           ; valid entry counter
   228 0000700A 31D2                <1>     xor edx, edx           ; raw entry counter
   229 0000700C 440FB70425-         <1>     movzx r8d, word [fat16_root_entries]
   229 00007011 [8D0D0000]          <1>
   230                              <1> 
   231                              <1> .ge_loop:
   232 00007015 4439C2              <1>     cmp edx, r8d
   233 00007018 7D2A                <1>     jge .ge_not_found
   234 0000701A 803B00              <1>     cmp byte [rbx], 0
   235 0000701D 7425                <1>     je .ge_not_found
   236 0000701F 803BE5              <1>     cmp byte [rbx], 0xE5
   237 00007022 7411                <1>     je .ge_skip
   238 00007024 8A430B              <1>     mov al, [rbx + DIR_ATTR]
   239 00007027 A808                <1>     test al, ATTR_VOLUME_ID
   240 00007029 750A                <1>     jnz .ge_skip
   241 0000702B 3C0F                <1>     cmp al, ATTR_LFN
   242 0000702D 7406                <1>     je .ge_skip
   243                              <1>     ; Valid entry
   244 0000702F 39F9                <1>     cmp ecx, edi
   245 00007031 740A                <1>     je .ge_found
   246 00007033 FFC1                <1>     inc ecx
   247                              <1> .ge_skip:
   248 00007035 4883C320            <1>     add rbx, DIR_ENTRY_SIZE
   249 00007039 FFC2                <1>     inc edx
   250 0000703B EBD8                <1>     jmp .ge_loop
   251                              <1> 
   252                              <1> .ge_found:
   253 0000703D 4889D8              <1>     mov rax, rbx
   254 00007040 5A                  <1>     pop rdx
   255 00007041 59                  <1>     pop rcx
   256 00007042 5B                  <1>     pop rbx
   257 00007043 C3                  <1>     ret
   258                              <1> 
   259                              <1> .ge_not_found:
   260 00007044 31C0                <1>     xor eax, eax
   261 00007046 5A                  <1>     pop rdx
   262 00007047 59                  <1>     pop rcx
   263 00007048 5B                  <1>     pop rbx
   264 00007049 C3                  <1>     ret
   265                              <1> 
   266                              <1> ; ============================================================================
   267                              <1> ; fat16_read_file - Read a file by directory entry pointer
   268                              <1> ; rdi = pointer to directory entry (from fat16_get_entry)
   269                              <1> ; rsi = destination buffer
   270                              <1> ; edx = max bytes to read
   271                              <1> ; Returns: eax = bytes read, or -1 on error
   272                              <1> ; ============================================================================
   273                              <1> fat16_read_file:
   274 0000704A 53                  <1>     push rbx
   275 0000704B 51                  <1>     push rcx
   276 0000704C 52                  <1>     push rdx
   277 0000704D 4154                <1>     push r12
   278 0000704F 4155                <1>     push r13
   279 00007051 4156                <1>     push r14
   280 00007053 4157                <1>     push r15
   281 00007055 57                  <1>     push rdi
   282 00007056 56                  <1>     push rsi
   283                              <1> 
   284 00007057 4989FC              <1>     mov r12, rdi           ; dir entry ptr
   285 0000705A 4989F5              <1>     mov r13, rsi           ; dest buffer
   286 0000705D 4189D6              <1>     mov r14d, edx          ; max bytes
   287 00007060 458B7C241C          <1>     mov r15d, [r12 + DIR_FILE_SIZE]  ; actual file size
   288                              <1> 
   289                              <1>     ; Use smaller of max_bytes and file_size
   290 00007065 4539FE              <1>     cmp r14d, r15d
   291 00007068 7E03                <1>     jle .size_ok
   292 0000706A 4589FE              <1>     mov r14d, r15d
   293                              <1> .size_ok:
   294                              <1> 
   295                              <1>     ; Get first cluster
   296 0000706D 410FB75C241A        <1>     movzx ebx, word [r12 + DIR_FIRST_CLUS_LO]
   297 00007073 85DB                <1>     test ebx, ebx
   298 00007075 7469                <1>     jz .rf_empty           ; empty file
   299                              <1> 
   300 00007077 31C9                <1>     xor ecx, ecx           ; bytes read so far
   301 00007079 440FB60425-         <1>     movzx r8d, byte [fat16_sect_per_clus]
   301 0000707E [890D0000]          <1>
   302                              <1> 
   303                              <1> .rf_cluster_loop:
   304                              <1>     ; Check cluster validity
   305 00007082 83FB02              <1>     cmp ebx, 2
   306 00007085 7C5B                <1>     jl .rf_done
   307 00007087 81FBF8FF0000        <1>     cmp ebx, 0xFFF8
   308 0000708D 7D53                <1>     jge .rf_done
   309                              <1> 
   310                              <1>     ; Calculate LBA for this cluster
   311                              <1>     ; LBA = data_start + (cluster - 2) * sect_per_clus + PART_LBA
   312 0000708F 89D8                <1>     mov eax, ebx
   313 00007091 83E802              <1>     sub eax, 2
   314 00007094 0FB61425[890D0000]  <1>     movzx edx, byte [fat16_sect_per_clus]
   315 0000709C 0FAFC2              <1>     imul eax, edx
   316 0000709F 030425[9D0D0000]    <1>     add eax, [fat16_data_start_sect]
   317 000070A6 0540010000          <1>     add eax, FAT16_PART_LBA
   318                              <1> 
   319                              <1>     ; Read all sectors in this cluster
   320 000070AB 51                  <1>     push rcx
   321 000070AC 89C7                <1>     mov edi, eax
   322 000070AE 498D740D00          <1>     lea rsi, [r13 + rcx]   ; dest = buffer + bytes_read
   323 000070B3 0FB61425[890D0000]  <1>     movzx edx, byte [fat16_sect_per_clus]
   324 000070BB E8A5BFFFFF          <1>     call ata_read_sectors
   325 000070C0 59                  <1>     pop rcx
   326                              <1> 
   327                              <1>     ; Update bytes read
   328 000070C1 0FB60425[890D0000]  <1>     movzx eax, byte [fat16_sect_per_clus]
   329 000070C9 C1E009              <1>     shl eax, 9             ; * 512
   330 000070CC 01C1                <1>     add ecx, eax
   331                              <1> 
   332                              <1>     ; Check if we've read enough
   333 000070CE 4439F1              <1>     cmp ecx, r14d
   334 000070D1 7D0F                <1>     jge .rf_done
   335                              <1> 
   336                              <1>     ; Follow FAT chain
   337                              <1>     ; Next cluster = FAT[current_cluster] (16-bit entry)
   338 000070D3 89D8                <1>     mov eax, ebx
   339 000070D5 D1E0                <1>     shl eax, 1             ; * 2 (FAT16 entries are 2 bytes)
   340 000070D7 0FB7980010D000      <1>     movzx ebx, word [FAT16_FAT_CACHE + rax]
   341 000070DE EBA2                <1>     jmp .rf_cluster_loop
   342                              <1> 
   343                              <1> .rf_empty:
   344 000070E0 31C9                <1>     xor ecx, ecx
   345                              <1> 
   346                              <1> .rf_done:
   347                              <1>     ; Return min(bytes_read, requested)
   348 000070E2 4439F1              <1>     cmp ecx, r14d
   349 000070E5 7E03                <1>     jle .rf_ret_ok
   350 000070E7 4489F1              <1>     mov ecx, r14d
   351                              <1> .rf_ret_ok:
   352 000070EA 89C8                <1>     mov eax, ecx
   353                              <1> 
   354 000070EC 5E                  <1>     pop rsi
   355 000070ED 5F                  <1>     pop rdi
   356 000070EE 415F                <1>     pop r15
   357 000070F0 415E                <1>     pop r14
   358 000070F2 415D                <1>     pop r13
   359 000070F4 415C                <1>     pop r12
   360 000070F6 5A                  <1>     pop rdx
   361 000070F7 59                  <1>     pop rcx
   362 000070F8 5B                  <1>     pop rbx
   363 000070F9 C3                  <1>     ret
   364                              <1> 
   365                              <1> ; ============================================================================
   366                              <1> ; fat16_write_file - Write/create a file in root directory
   367                              <1> ; rdi = pointer to 11-char filename (8.3 format, space-padded)
   368                              <1> ; rsi = source buffer
   369                              <1> ; edx = number of bytes to write
   370                              <1> ; Returns: eax = 0 on success, -1 on error
   371                              <1> ; ============================================================================
   372                              <1> fat16_write_file:
   373 000070FA 53                  <1>     push rbx
   374 000070FB 51                  <1>     push rcx
   375 000070FC 52                  <1>     push rdx
   376 000070FD 4154                <1>     push r12
   377 000070FF 4155                <1>     push r13
   378 00007101 4156                <1>     push r14
   379 00007103 4157                <1>     push r15
   380 00007105 57                  <1>     push rdi
