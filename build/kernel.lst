    81                              <1> ; --- Flush dirty rectangles to framebuffer ---
    82                              <1> render_flush:
    83 000074C2 50                  <1>     push rax
    84 000074C3 53                  <1>     push rbx
    85 000074C4 51                  <1>     push rcx
