     1                                  ; ============================================================================
     2                                  ; NexusOS v3.0 - Monolithic Kernel Build Wrapper
     3                                  ; Combines all kernel components into a single binary
     4                                  ; ============================================================================
     5                                  [bits 64]
     6                                  [org 0x100000]
     7                                  
     8                                  ; Define macros to ignore extern/global directives in included files
     9                                  ; Using 1-* allows the macro to ignore any number of arguments (comma separated)
    10                                  %unmacro extern 1-*
    11                                  %macro extern 1-*
    11          ******************       warning: redefining multi-line macro `extern' [-w+pp-macro-redef-multi]
    12                                  %endmacro
    13                                  
    14                                  %unmacro global 1-*
    15                                  %macro global 1-*
    15          ******************       warning: redefining multi-line macro `global' [-w+pp-macro-redef-multi]
    16                                  %endmacro
    17                                  
    18                                  ; --- Core Kernel Entry Point (MUST BE FIRST) ---
    19                                  section .text
    20                                  %include "src/kernel/entry.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - Kernel Entry Point (64-bit Long Mode)
     3                              <1> ; Loaded at 0x100000 by Stage 2
     4                              <1> ; ============================================================================
     5                              <1> bits 64
     6                              <1> 
     7                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> 
    33                              <2> ; --- Stage 2 disk layout ---
    34                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    35                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    36                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    37                              <2> 
    38                              <2> ; --- Screen ---
    39                              <2> SCREEN_WIDTH        equ 1024
    40                              <2> SCREEN_HEIGHT       equ 768
    41                              <2> SCREEN_BPP          equ 32
    42                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    43                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    44                              <2> 
    45                              <2> 
    46                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    47                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    48                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    49                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    50                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    51                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    52                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    53                              <2> 
    54                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    55                              <2> COLOR_BLACK         equ 0x00000000
    56                              <2> COLOR_WHITE         equ 0x00FFFFFF
    57                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    58                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    59                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    60                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    61                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    62                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    63                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    64                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    65                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    66                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    67                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    68                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    69                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    70                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    71                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    72                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    73                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    74                              <2> COLOR_START_HOVER    equ 0x00338833
    75                              <2> 
    76                              <2> ; --- Window Manager ---
    77                              <2> MAX_WINDOWS         equ 8
    78                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    79                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    80                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    81                              <2> TITLEBAR_HEIGHT     equ 24
    82                              <2> BORDER_WIDTH        equ 2
    83                              <2> CLOSE_BTN_SIZE      equ 18
    84                              <2> MIN_BTN_SIZE        equ 18
    85                              <2> MIN_WINDOW_W        equ 200
    86                              <2> MIN_WINDOW_H        equ 100
    87                              <2> 
    88                              <2> ; --- Taskbar ---
    89                              <2> TASKBAR_HEIGHT      equ 36
    90                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    91                              <2> START_BTN_W         equ 70
    92                              <2> START_BTN_H         equ 28
    93                              <2> START_BTN_X         equ 4
    94                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    95                              <2> CLOCK_WIDTH         equ 64
    96                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    97                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    98                              <2> 
    99                              <2> ; --- Keyboard ---
   100                              <2> KB_BUFFER_SIZE      equ 64
   101                              <2> 
   102                              <2> ; --- Mouse ---
   103                              <2> MOUSE_BUFFER_SIZE   equ 64
   104                              <2> CURSOR_WIDTH        equ 12
   105                              <2> CURSOR_HEIGHT       equ 19
   106                              <2> 
   107                              <2> ; --- PIT ---
   108                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   109                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   110                              <2> 
   111                              <2> ; --- PIC vectors ---
   112                              <2> IRQ_BASE_MASTER     equ 32
   113                              <2> IRQ_BASE_SLAVE      equ 40
   114                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   115                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   116                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   117                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   118                              <2> 
   119                              <2> ; --- Font ---
   120                              <2> FONT_WIDTH          equ 8
   121                              <2> FONT_HEIGHT         equ 16
   122                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   123                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   124                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   125                              <2> 
   126                              <2> ; --- Window flags ---
   127                              <2> WF_VISIBLE          equ 0x01
   128                              <2> WF_FOCUSED          equ 0x02
   129                              <2> WF_DRAGGING         equ 0x04
   130                              <2> WF_MINIMIZED        equ 0x08
   131                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   132                              <2> 
   133                              <2> ; --- Mouse event types ---
   134                              <2> MEVT_MOVE           equ 1
   135                              <2> MEVT_LCLICK         equ 2
   136                              <2> MEVT_RCLICK         equ 3
   137                              <2> MEVT_LRELEASE       equ 4
   138                              <2> MEVT_RRELEASE       equ 5
   139                              <2> 
   140                              <2> ; --- Key modifier flags ---
   141                              <2> KMOD_SHIFT          equ 0x01
   142                              <2> KMOD_CTRL           equ 0x02
   143                              <2> KMOD_ALT            equ 0x04
   144                              <2> 
   145                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   146                              <2> KEY_F1              equ 0xF1
   147                              <2> KEY_F2              equ 0xF2
   148                              <2> KEY_F3              equ 0xF3
   149                              <2> KEY_F4              equ 0xF4
   150                              <2> KEY_F5              equ 0xF5
   151                              <2> KEY_F6              equ 0xF6
   152                              <2> KEY_F7              equ 0xF7
   153                              <2> KEY_F8              equ 0xF8
   154                              <2> KEY_F9              equ 0xF9
   155                              <2> KEY_F10             equ 0xFA
   156                              <2> KEY_F11             equ 0xFB
   157                              <2> KEY_F12             equ 0xFC
   158                              <2> 
   159                              <2> ; --- USB/XHCI Memory Layout ---
   160                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   161                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   162                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   163                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   164                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   165                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   166                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   167                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   168                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   169                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   170                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   171                              <2> ; Slot 2 device support
   172                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   173                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   174                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   175                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   176                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   177                              <2> 
   178                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   179                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   180                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   181                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   182                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   183                              <2> XHCI_CAP_DBOFF      equ 0x14
   184                              <2> XHCI_CAP_RTSOFF     equ 0x18
   185                              <2> 
   186                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   187                              <2> XHCI_OP_USBCMD      equ 0x00
   188                              <2> XHCI_OP_USBSTS      equ 0x04
   189                              <2> XHCI_OP_PAGESIZE     equ 0x08
   190                              <2> XHCI_OP_DNCTRL      equ 0x14
   191                              <2> XHCI_OP_CRCR_LO     equ 0x18
   192                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   193                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   194                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   195                              <2> XHCI_OP_CONFIG      equ 0x38
   196                              <2> 
   197                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   198                              <2> XHCI_PORTSC         equ 0x00
   199                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   200                              <2> 
   201                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   202                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   203                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   204                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   205                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   206                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   207                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   208                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   209                              <2> 
   210                              <2> ; --- USBCMD bits ---
   211                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   212                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   213                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   214                              <2> 
   215                              <2> ; --- USBSTS bits ---
   216                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   217                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   218                              <2> 
   219                              <2> ; --- PORTSC bits ---
   220                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   221                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   222                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   223                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   224                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   225                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   226                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   227                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   228                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   229                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   230                              <2> 
   231                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   232                              <2> TRB_NORMAL           equ (1 << 10)
   233                              <2> TRB_SETUP            equ (2 << 10)
   234                              <2> TRB_DATA             equ (3 << 10)
   235                              <2> TRB_STATUS           equ (4 << 10)
   236                              <2> TRB_LINK             equ (6 << 10)
   237                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   238                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   239                              <2> TRB_CONFIG_EP        equ (12 << 10)
   240                              <2> TRB_EVAL_CTX         equ (13 << 10)
   241                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   242                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   243                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   244                              <2> 
   245                              <2> ; --- TRB Flag Bits (dword 3) ---
   246                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   247                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   248                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   249                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   250                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   251                              <2> 
   252                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   253                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   254                              <2> TRB_TRT_OUT          equ (2 << 16)
   255                              <2> TRB_TRT_IN           equ (3 << 16)
   256                              <2> 
   257                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   258                              <2> TRB_DIR_OUT          equ (0 << 16)
   259                              <2> TRB_DIR_IN           equ (1 << 16)
   260                              <2> 
   261                              <2> ; --- Ring sizes ---
   262                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   263                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   264                              <2> 
   265                              <2> ; --- USB Standard Request Codes ---
   266                              <2> USB_REQ_GET_DESC     equ 0x06
   267                              <2> USB_REQ_SET_CONFIG   equ 0x09
   268                              <2> USB_REQ_SET_IFACE    equ 0x0B
   269                              <2> 
   270                              <2> ; --- USB HID Request Codes ---
   271                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   272                              <2> 
   273                              <2> ; --- USB Descriptor Types ---
   274                              <2> USB_DESC_DEVICE      equ 0x01
   275                              <2> USB_DESC_CONFIG      equ 0x02
   276                              <2> USB_DESC_INTERFACE   equ 0x04
   277                              <2> USB_DESC_ENDPOINT    equ 0x05
   278                              <2> USB_DESC_HID         equ 0x21
   279                              <2> 
   280                              <2> ; --- USB Endpoint Types ---
   281                              <2> USB_EP_CONTROL       equ 0
   282                              <2> USB_EP_ISOCH         equ 1
   283                              <2> USB_EP_BULK          equ 2
   284                              <2> USB_EP_INTERRUPT     equ 3
   285                              <2> 
   286                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   287                              <2> XHCI_EP_NOT_VALID    equ 0
   288                              <2> XHCI_EP_ISOCH_OUT    equ 1
   289                              <2> XHCI_EP_BULK_OUT     equ 2
   290                              <2> XHCI_EP_INT_OUT      equ 3
   291                              <2> XHCI_EP_CONTROL      equ 4
   292                              <2> XHCI_EP_ISOCH_IN     equ 5
   293                              <2> XHCI_EP_BULK_IN      equ 6
   294                              <2> XHCI_EP_INT_IN       equ 7
   295                              <2> 
   296                              <2> ; --- XHCI Port Speeds ---
   297                              <2> XHCI_SPEED_FULL      equ 1
   298                              <2> XHCI_SPEED_LOW       equ 2
   299                              <2> XHCI_SPEED_HIGH      equ 3
   300                              <2> XHCI_SPEED_SUPER     equ 4
     8                              <1> %include "structs.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - Structure Definitions
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Window structure (256 bytes) ---
     6                              <2> struc window_t
     7 00000000 ????????            <2>     .id:            resd 1      ; 0x00: Unique window ID
     8 00000004 ????????            <2>     .x:             resd 1      ; 0x04: Position X
     9 00000008 ????????            <2>     .y:             resd 1      ; 0x08: Position Y
    10 0000000C ????????            <2>     .w:             resd 1      ; 0x0C: Total width (including border)
    11 00000010 ????????            <2>     .h:             resd 1      ; 0x10: Total height (including titlebar+border)
    12 00000014 ????????            <2>     .client_x:      resd 1      ; 0x14: Client area X offset from window
    13 00000018 ????????            <2>     .client_y:      resd 1      ; 0x18: Client area Y offset from window
    14 0000001C ????????            <2>     .client_w:      resd 1      ; 0x1C: Client area width
    15 00000020 ????????            <2>     .client_h:      resd 1      ; 0x20: Client area height
    16 00000024 ????????            <2>     .flags:         resd 1      ; 0x24: WF_* flags
    17 00000028 ????????            <2>     .z_order:       resd 1      ; 0x28: Z-order (higher = on top)
    18 0000002C ????????            <2>                     resd 1      ; 0x2C: padding
    19 00000030 ????????????????    <2>     .title:         resq 1      ; 0x30: Pointer to title string
    20 00000038 ????????????????    <2>     .draw_fn:       resq 1      ; 0x38: App draw callback (rdi=window_ptr)
    21 00000040 ????????????????    <2>     .key_fn:        resq 1      ; 0x40: App keypress callback (rdi=window_ptr, esi=key)
    22 00000048 ????????????????    <2>     .click_fn:      resq 1      ; 0x48: App click callback (rdi=window_ptr, esi=x, edx=y)
    23 00000050 ????????????????    <2>     .app_data:      resq 1      ; 0x50: App-private data pointer
    24 00000058 ????????            <2>     .drag_ox:       resd 1      ; 0x58: Drag offset X (mouse_x - window_x at drag start)
    25 0000005C ????????            <2>     .drag_oy:       resd 1      ; 0x5C: Drag offset Y
    26 00000060 <res A0h>           <2>     .padding:       resb 160    ; Pad to 256 bytes
    27                              <2> endstruc
    28                              <2> 
    29                              <2> ; --- Key event (4 bytes) ---
    30                              <2> struc key_event_t
    31 00000000 ??                  <2>     .scancode:      resb 1      ; Raw scancode
    32 00000001 ??                  <2>     .ascii:         resb 1      ; ASCII translation (0 if special key)
    33 00000002 ??                  <2>     .modifiers:     resb 1      ; KMOD_* flags
    34 00000003 ??                  <2>     .pressed:       resb 1      ; 1=pressed, 0=released
    35                              <2> endstruc
    36                              <2> 
    37                              <2> ; --- Mouse event (16 bytes) ---
    38                              <2> struc mouse_event_t
    39 00000000 ????????            <2>     .x:             resd 1      ; Absolute cursor X
    40 00000004 ????????            <2>     .y:             resd 1      ; Absolute cursor Y
    41 00000008 ??                  <2>     .buttons:       resb 1      ; Button state (bit0=left, bit1=right, bit2=middle)
    42 00000009 ??                  <2>     .event_type:    resb 1      ; MEVT_* type
    43 0000000A ????????????        <2>     .padding:       resb 6      ; Pad to 16 bytes
    44                              <2> endstruc
    45                              <2> 
    46                              <2> ; --- Rectangle (16 bytes) ---
    47                              <2> struc rect_t
    48 00000000 ????????            <2>     .x:             resd 1
    49 00000004 ????????            <2>     .y:             resd 1
    50 00000008 ????????            <2>     .w:             resd 1
    51 0000000C ????????            <2>     .h:             resd 1
    52                              <2> endstruc
    53                              <2> 
    54                              <2> ; --- E820 memory map entry (24 bytes) ---
    55                              <2> struc e820_entry_t
    56 00000000 ????????????????    <2>     .base:          resq 1      ; Base address
    57 00000008 ????????????????    <2>     .length:        resq 1      ; Length in bytes
    58 00000010 ????????            <2>     .type:          resd 1      ; 1=usable, 2=reserved, 3=ACPI reclaimable
    59 00000014 ????????            <2>     .acpi:          resd 1      ; ACPI extended attributes
    60                              <2> endstruc
     9                              <1> %include "macros.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - Common Macros
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> %ifndef MACROS_INC
     6                              <2> %define MACROS_INC
     7                              <2> 
     8                              <2> ; Output character to COM1 for debugging
     9                              <2> %macro SER 1
    10                              <2>     push rax
    11                              <2>     push rdx
    12                              <2>     mov dx, 0x3F8
    13                              <2>     mov al, %1
    14                              <2>     out dx, al
    15                              <2>     pop rdx
    16                              <2>     pop rax
    17                              <2> %endmacro
    18                              <2> 
    19                              <2> ; Save all general-purpose registers (64-bit)
    20                              <2> %macro PUSH_ALL 0
    21                              <2>     push rax
    22                              <2>     push rbx
    23                              <2>     push rcx
    24                              <2>     push rdx
    25                              <2>     push rsi
    26                              <2>     push rdi
    27                              <2>     push rbp
    28                              <2>     push r8
    29                              <2>     push r9
    30                              <2>     push r10
    31                              <2>     push r11
    32                              <2>     push r12
    33                              <2>     push r13
    34                              <2>     push r14
    35                              <2>     push r15
    36                              <2> %endmacro
    37                              <2> 
    38                              <2> ; Offset of registers in PUSH_ALL frame
    39                              <2> ALL_R15 equ 0
    40                              <2> ALL_R14 equ 8
    41                              <2> ALL_R13 equ 16
    42                              <2> ALL_R12 equ 24
    43                              <2> ALL_R11 equ 32
    44                              <2> ALL_R10 equ 40
    45                              <2> ALL_R9  equ 48
    46                              <2> ALL_R8  equ 56
    47                              <2> ALL_RBP equ 64
    48                              <2> ALL_RDI equ 72
    49                              <2> ALL_RSI equ 80
    50                              <2> ALL_RDX equ 88
    51                              <2> ALL_RCX equ 96
    52                              <2> ALL_RBX equ 104
    53                              <2> ALL_RAX equ 112
    54                              <2> 
    55                              <2> ; Restore all general-purpose registers (64-bit)
    56                              <2> %macro POP_ALL 0
    57                              <2>     pop r15
    58                              <2>     pop r14
    59                              <2>     pop r13
    60                              <2>     pop r12
    61                              <2>     pop r11
    62                              <2>     pop r10
    63                              <2>     pop r9
    64                              <2>     pop r8
    65                              <2>     pop rbp
    66                              <2>     pop rdi
    67                              <2>     pop rsi
    68                              <2>     pop rdx
    69                              <2>     pop rcx
    70                              <2>     pop rbx
    71                              <2>     pop rax
    72                              <2> %endmacro
    73                              <2> 
    74                              <2> ; Output byte to port with I/O delay
    75                              <2> %macro OUTB 2
    76                              <2>     mov al, %2
    77                              <2>     out %1, al
    78                              <2> %endmacro
    79                              <2> 
    80                              <2> ; Input byte from port
    81                              <2> %macro INB 1
    82                              <2>     in al, %1
    83                              <2> %endmacro
    84                              <2> 
    85                              <2> ; I/O wait (small delay for PIC/PIT programming)
    86                              <2> %macro IO_WAIT 0
    87                              <2>     out 0x80, al
    88                              <2> %endmacro
    89                              <2> 
    90                              <2> ; Bochs magic breakpoint
    91                              <2> %macro BOCHS_BREAK 0
    92                              <2>     xchg bx, bx
    93                              <2> %endmacro
    94                              <2> 
    95                              <2> ; ISR stub that pushes a dummy error code (for exceptions without one)
    96                              <2> %macro ISR_NOERRCODE 1
    97                              <2> global isr_%1
    98                              <2> isr_%1:
    99                              <2>     push qword 0           ; Dummy error code
   100                              <2>     push qword %1          ; Interrupt number
   101                              <2>     jmp isr_common_stub
   102                              <2> %endmacro
   103                              <2> 
   104                              <2> ; ISR stub for exceptions that push their own error code
   105                              <2> %macro ISR_ERRCODE 1
   106                              <2> global isr_%1
   107                              <2> isr_%1:
   108                              <2>     push qword %1          ; Interrupt number (error code already on stack)
   109                              <2>     jmp isr_common_stub
   110                              <2> %endmacro
   111                              <2> 
   112                              <2> ; IRQ stub macro
   113                              <2> %macro IRQ_STUB 2
   114                              <2> global irq_%1
   115                              <2> irq_%1:
   116                              <2>     push qword 0           ; Dummy error code
   117                              <2>     push qword %2          ; Interrupt vector number
   118                              <2>     jmp irq_common_stub
   119                              <2> %endmacro
   120                              <2> 
   121                              <2> %endif
    10                              <1> 
    11                              <1> section .text
    12                              <1> global _start
    13                              <1> extern kmain
    14                              <1> 
    15                              <1> _start:
    16                              <1>     ; Serial debug: Kernel entry reached
    17 00000000 66BAF803            <1>     mov dx, 0x3F8
    18 00000004 B028                <1>     mov al, '('
    19 00000006 EE                  <1>     out dx, al
    20 00000007 B021                <1>     mov al, '!'
    21 00000009 EE                  <1>     out dx, al
    22 0000000A B030                <1>     mov al, '0'
    23 0000000C EE                  <1>     out dx, al
    24 0000000D B02D                <1>     mov al, '-'
    25 0000000F EE                  <1>     out dx, al
    26 00000010 B045                <1>     mov al, 'E'
    27 00000012 EE                  <1>     out dx, al
    28 00000013 B04E                <1>     mov al, 'N'
    29 00000015 EE                  <1>     out dx, al
    30 00000016 B054                <1>     mov al, 'T'
    31 00000018 EE                  <1>     out dx, al
    32 00000019 B052                <1>     mov al, 'R'
    33 0000001B EE                  <1>     out dx, al
    34 0000001C B059                <1>     mov al, 'Y'
    35 0000001E EE                  <1>     out dx, al
    36 0000001F B029                <1>     mov al, ')'
    37 00000021 EE                  <1>     out dx, al
    38                              <1> 
    39                              <1>     ; Dump CR0, CR3, CR4 at kernel entry
    40 00000022 66BAF803            <1>     mov dx, 0x3F8
    41 00000026 B05B                <1>     mov al, '['
    42 00000028 EE                  <1>     out dx, al
    43                              <1> 
    44                              <1>     ; Print CR3 value (first byte as hex to confirm page tables)
    45 00000029 0F20D8              <1>     mov rax, cr3
    46 0000002C 4889C3              <1>     mov rbx, rax
    47 0000002F C0E804              <1>     shr al, 4
    48 00000032 240F                <1>     and al, 0x0F
    49 00000034 0430                <1>     add al, '0'
    50 00000036 3C39                <1>     cmp al, '9'
    51 00000038 7E02                <1>     jle .cr3h
    52 0000003A 0407                <1>     add al, 7
    53                              <1> .cr3h:
    54 0000003C EE                  <1>     out dx, al
    55 0000003D 88D8                <1>     mov al, bl
    56 0000003F 240F                <1>     and al, 0x0F
    57 00000041 0430                <1>     add al, '0'
    58 00000043 3C39                <1>     cmp al, '9'
    59 00000045 7E02                <1>     jle .cr3l
    60 00000047 0407                <1>     add al, 7
    61                              <1> .cr3l:
    62 00000049 EE                  <1>     out dx, al
    63 0000004A B05D                <1>     mov al, ']'
    64 0000004C EE                  <1>     out dx, al
    65                              <1> 
    66                              <1>     ; (!1-SEGS)
    67 0000004D B028                <1>     mov al, '('
    68 0000004F EE                  <1>     out dx, al
    69 00000050 B021                <1>     mov al, '!'
    70 00000052 EE                  <1>     out dx, al
    71 00000053 B031                <1>     mov al, '1'
    72 00000055 EE                  <1>     out dx, al
    73 00000056 B029                <1>     mov al, ')'
    74 00000058 EE                  <1>     out dx, al
    75                              <1> 
    76                              <1>     ; Set up segment registers for long mode
    77 00000059 66B81000            <1>     mov ax, 0x10            ; Data segment selector (GDT64_DATA_SEG)
    78 0000005D 8ED8                <1>     mov ds, ax
    79 0000005F 8EC0                <1>     mov es, ax
    80 00000061 8EE0                <1>     mov fs, ax
    81 00000063 8EE8                <1>     mov gs, ax
    82 00000065 8ED0                <1>     mov ss, ax
    83                              <1> 
    84                              <1>     ; Set up kernel stack
    85 00000067 BC00002000          <1>     mov rsp, KERNEL_STACK_TOP
    86                              <1> 
    87                              <1>     ; Enable SSE/SSE2 (required for fast framebuffer operations)
    88                              <1>     ; CR0: clear EM (bit 2), set MP (bit 1)
    89 0000006C 0F20C0              <1>     mov rax, cr0
    90 0000006F 6683E0FB            <1>     and ax, 0xFFFB          ; Clear EM (bit 2) - no x87 emulation
    91 00000073 6683C802            <1>     or ax, 0x0002           ; Set MP (bit 1) - monitor coprocessor
    92 00000077 0F22C0              <1>     mov cr0, rax
    93                              <1>     ; CR4: set OSFXSR (bit 9) + OSXMMEXCPT (bit 10)
    94 0000007A 0F20E0              <1>     mov rax, cr4
    95 0000007D 660D0006            <1>     or ax, (1 << 9) | (1 << 10)
    96 00000081 0F22E0              <1>     mov cr4, rax
    97                              <1> 
    98                              <1>     ; (!2-STACK)
    99 00000084 66BAF803            <1>     mov dx, 0x3F8
   100 00000088 B028                <1>     mov al, '('
   101 0000008A EE                  <1>     out dx, al
   102 0000008B B021                <1>     mov al, '!'
   103 0000008D EE                  <1>     out dx, al
   104 0000008E B032                <1>     mov al, '2'
   105 00000090 EE                  <1>     out dx, al
   106 00000091 B029                <1>     mov al, ')'
   107 00000093 EE                  <1>     out dx, al
   108                              <1> 
   109                              <1>     ; Verify VBE info at 0x9000 before using it
   110                              <1>     ; Print FB addr low byte as sanity check
   111 00000094 B800900000          <1>     mov rax, 0x9000
   112 00000099 488B00              <1>     mov rax, [rax]           ; FB address
   113                              <1> 
   114                              <1>     ; (!3-FB)
   115 0000009C 66BAF803            <1>     mov dx, 0x3F8
   116 000000A0 B028                <1>     mov al, '('
   117 000000A2 EE                  <1>     out dx, al
   118 000000A3 B021                <1>     mov al, '!'
   119 000000A5 EE                  <1>     out dx, al
   120 000000A6 B033                <1>     mov al, '3'
   121 000000A8 EE                  <1>     out dx, al
   122 000000A9 B03D                <1>     mov al, '='
   123 000000AB EE                  <1>     out dx, al
   124                              <1> 
   125                              <1>     ; Print lower 4 hex digits of FB addr
   126 000000AC 4889C3              <1>     mov rbx, rax
   127 000000AF B904000000          <1>     mov ecx, 4
   128                              <1> .fb_hex:
   129 000000B4 48C1C304            <1>     rol rbx, 4
   130 000000B8 88D8                <1>     mov al, bl
   131 000000BA 240F                <1>     and al, 0x0F
   132 000000BC 0430                <1>     add al, '0'
   133 000000BE 3C39                <1>     cmp al, '9'
   134 000000C0 7E02                <1>     jle .fb_hex_ok
   135 000000C2 0407                <1>     add al, 7
   136                              <1> .fb_hex_ok:
   137 000000C4 EE                  <1>     out dx, al
   138 000000C5 FFC9                <1>     dec ecx
   139 000000C7 75EB                <1>     jnz .fb_hex
   140 000000C9 B029                <1>     mov al, ')'
   141 000000CB EE                  <1>     out dx, al
   142                              <1> 
   143                              <1>     ; Reload rdi from VBE info
   144 000000CC B800900000          <1>     mov rax, 0x9000
   145 000000D1 488B38              <1>     mov rdi, [rax]           ; Get LFB address
   146                              <1> 
   147                              <1>     ; (!4-PAINT)
   148 000000D4 B028                <1>     mov al, '('
   149 000000D6 EE                  <1>     out dx, al
   150 000000D7 B021                <1>     mov al, '!'
   151 000000D9 EE                  <1>     out dx, al
   152 000000DA B034                <1>     mov al, '4'
   153 000000DC EE                  <1>     out dx, al
   154 000000DD B029                <1>     mov al, ')'
   155 000000DF EE                  <1>     out dx, al
   156                              <1> 
   157                              <1>     ; Paint WHITE as proof of Kernel Entry
   158 000000E0 B900000C00          <1>     mov rcx, SCREEN_WIDTH * SCREEN_HEIGHT  ; 1024*768 pixels
   159                              <1> 
   160 000000E5 B8FFFFFF00          <1>     mov eax, 0x00FFFFFF      ; WHITE
   161 000000EA F3AB                <1>     rep stosd
   162                              <1> 
   163                              <1>     ; (!5-PAINTED)
   164 000000EC 66BAF803            <1>     mov dx, 0x3F8
   165 000000F0 B028                <1>     mov al, '('
   166 000000F2 EE                  <1>     out dx, al
   167 000000F3 B021                <1>     mov al, '!'
   168 000000F5 EE                  <1>     out dx, al
   169 000000F6 B035                <1>     mov al, '5'
   170 000000F8 EE                  <1>     out dx, al
   171 000000F9 B029                <1>     mov al, ')'
   172 000000FB EE                  <1>     out dx, al
   173                              <1> 
   174                              <1>     ; (!6-KMAIN)
   175 000000FC B028                <1>     mov al, '('
   176 000000FE EE                  <1>     out dx, al
   177 000000FF B021                <1>     mov al, '!'
   178 00000101 EE                  <1>     out dx, al
   179 00000102 B036                <1>     mov al, '6'
   180 00000104 EE                  <1>     out dx, al
   181 00000105 B029                <1>     mov al, ')'
   182 00000107 EE                  <1>     out dx, al
   183                              <1> 
   184                              <1>     ; Call kernel main
   185 00000108 E8A5000000          <1>     call kmain
   186                              <1> 
   187                              <1>     ; If kmain returns, halt forever
   188                              <1> .halt:
   189 0000010D FA                  <1>     cli
   190 0000010E F4                  <1>     hlt
   191 0000010F EBFC                <1>     jmp .halt
    21                                  %include "src/kernel/main.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - Kernel Main (Free-running render loop)
     3                              <1> ; ============================================================================
     4                              <1> bits 64
     5                              <1> 
     6                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> 
    33                              <2> ; --- Stage 2 disk layout ---
    34                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    35                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    36                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    37                              <2> 
    38                              <2> ; --- Screen ---
    39                              <2> SCREEN_WIDTH        equ 1024
    40                              <2> SCREEN_HEIGHT       equ 768
    41                              <2> SCREEN_BPP          equ 32
    42                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    43                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    44                              <2> 
    45                              <2> 
    46                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    47                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    48                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    49                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    50                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    51                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    52                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    53                              <2> 
    54                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    55                              <2> COLOR_BLACK         equ 0x00000000
    56                              <2> COLOR_WHITE         equ 0x00FFFFFF
    57                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    58                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    59                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    60                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    61                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    62                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    63                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    64                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    65                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    66                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    67                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    68                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    69                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    70                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    71                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    72                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    73                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    74                              <2> COLOR_START_HOVER    equ 0x00338833
    75                              <2> 
    76                              <2> ; --- Window Manager ---
    77                              <2> MAX_WINDOWS         equ 8
    78                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    79                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    80                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    81                              <2> TITLEBAR_HEIGHT     equ 24
    82                              <2> BORDER_WIDTH        equ 2
    83                              <2> CLOSE_BTN_SIZE      equ 18
    84                              <2> MIN_BTN_SIZE        equ 18
    85                              <2> MIN_WINDOW_W        equ 200
    86                              <2> MIN_WINDOW_H        equ 100
    87                              <2> 
    88                              <2> ; --- Taskbar ---
    89                              <2> TASKBAR_HEIGHT      equ 36
    90                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    91                              <2> START_BTN_W         equ 70
    92                              <2> START_BTN_H         equ 28
    93                              <2> START_BTN_X         equ 4
    94                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    95                              <2> CLOCK_WIDTH         equ 64
    96                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    97                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    98                              <2> 
    99                              <2> ; --- Keyboard ---
   100                              <2> KB_BUFFER_SIZE      equ 64
   101                              <2> 
   102                              <2> ; --- Mouse ---
   103                              <2> MOUSE_BUFFER_SIZE   equ 64
   104                              <2> CURSOR_WIDTH        equ 12
   105                              <2> CURSOR_HEIGHT       equ 19
   106                              <2> 
   107                              <2> ; --- PIT ---
   108                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   109                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   110                              <2> 
   111                              <2> ; --- PIC vectors ---
   112                              <2> IRQ_BASE_MASTER     equ 32
   113                              <2> IRQ_BASE_SLAVE      equ 40
   114                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   115                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   116                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   117                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   118                              <2> 
   119                              <2> ; --- Font ---
   120                              <2> FONT_WIDTH          equ 8
   121                              <2> FONT_HEIGHT         equ 16
   122                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   123                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   124                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   125                              <2> 
   126                              <2> ; --- Window flags ---
   127                              <2> WF_VISIBLE          equ 0x01
   128                              <2> WF_FOCUSED          equ 0x02
   129                              <2> WF_DRAGGING         equ 0x04
   130                              <2> WF_MINIMIZED        equ 0x08
   131                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   132                              <2> 
   133                              <2> ; --- Mouse event types ---
   134                              <2> MEVT_MOVE           equ 1
   135                              <2> MEVT_LCLICK         equ 2
   136                              <2> MEVT_RCLICK         equ 3
   137                              <2> MEVT_LRELEASE       equ 4
   138                              <2> MEVT_RRELEASE       equ 5
   139                              <2> 
   140                              <2> ; --- Key modifier flags ---
   141                              <2> KMOD_SHIFT          equ 0x01
   142                              <2> KMOD_CTRL           equ 0x02
   143                              <2> KMOD_ALT            equ 0x04
   144                              <2> 
   145                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   146                              <2> KEY_F1              equ 0xF1
   147                              <2> KEY_F2              equ 0xF2
   148                              <2> KEY_F3              equ 0xF3
   149                              <2> KEY_F4              equ 0xF4
   150                              <2> KEY_F5              equ 0xF5
   151                              <2> KEY_F6              equ 0xF6
   152                              <2> KEY_F7              equ 0xF7
   153                              <2> KEY_F8              equ 0xF8
   154                              <2> KEY_F9              equ 0xF9
   155                              <2> KEY_F10             equ 0xFA
   156                              <2> KEY_F11             equ 0xFB
   157                              <2> KEY_F12             equ 0xFC
   158                              <2> 
   159                              <2> ; --- USB/XHCI Memory Layout ---
   160                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   161                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   162                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   163                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   164                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   165                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   166                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   167                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   168                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   169                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   170                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   171                              <2> ; Slot 2 device support
   172                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   173                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   174                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   175                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   176                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   177                              <2> 
   178                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   179                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   180                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   181                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   182                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   183                              <2> XHCI_CAP_DBOFF      equ 0x14
   184                              <2> XHCI_CAP_RTSOFF     equ 0x18
   185                              <2> 
   186                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   187                              <2> XHCI_OP_USBCMD      equ 0x00
   188                              <2> XHCI_OP_USBSTS      equ 0x04
   189                              <2> XHCI_OP_PAGESIZE     equ 0x08
   190                              <2> XHCI_OP_DNCTRL      equ 0x14
   191                              <2> XHCI_OP_CRCR_LO     equ 0x18
   192                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   193                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   194                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   195                              <2> XHCI_OP_CONFIG      equ 0x38
   196                              <2> 
   197                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   198                              <2> XHCI_PORTSC         equ 0x00
   199                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   200                              <2> 
   201                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   202                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   203                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   204                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   205                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   206                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   207                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   208                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   209                              <2> 
   210                              <2> ; --- USBCMD bits ---
   211                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   212                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   213                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   214                              <2> 
   215                              <2> ; --- USBSTS bits ---
   216                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   217                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   218                              <2> 
   219                              <2> ; --- PORTSC bits ---
   220                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   221                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   222                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   223                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   224                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   225                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   226                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   227                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   228                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   229                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   230                              <2> 
   231                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   232                              <2> TRB_NORMAL           equ (1 << 10)
   233                              <2> TRB_SETUP            equ (2 << 10)
   234                              <2> TRB_DATA             equ (3 << 10)
   235                              <2> TRB_STATUS           equ (4 << 10)
   236                              <2> TRB_LINK             equ (6 << 10)
   237                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   238                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   239                              <2> TRB_CONFIG_EP        equ (12 << 10)
   240                              <2> TRB_EVAL_CTX         equ (13 << 10)
   241                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   242                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   243                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   244                              <2> 
   245                              <2> ; --- TRB Flag Bits (dword 3) ---
   246                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   247                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   248                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   249                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   250                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   251                              <2> 
   252                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   253                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   254                              <2> TRB_TRT_OUT          equ (2 << 16)
   255                              <2> TRB_TRT_IN           equ (3 << 16)
   256                              <2> 
   257                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   258                              <2> TRB_DIR_OUT          equ (0 << 16)
   259                              <2> TRB_DIR_IN           equ (1 << 16)
   260                              <2> 
   261                              <2> ; --- Ring sizes ---
   262                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   263                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   264                              <2> 
   265                              <2> ; --- USB Standard Request Codes ---
   266                              <2> USB_REQ_GET_DESC     equ 0x06
   267                              <2> USB_REQ_SET_CONFIG   equ 0x09
   268                              <2> USB_REQ_SET_IFACE    equ 0x0B
   269                              <2> 
   270                              <2> ; --- USB HID Request Codes ---
   271                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   272                              <2> 
   273                              <2> ; --- USB Descriptor Types ---
   274                              <2> USB_DESC_DEVICE      equ 0x01
   275                              <2> USB_DESC_CONFIG      equ 0x02
   276                              <2> USB_DESC_INTERFACE   equ 0x04
   277                              <2> USB_DESC_ENDPOINT    equ 0x05
   278                              <2> USB_DESC_HID         equ 0x21
   279                              <2> 
   280                              <2> ; --- USB Endpoint Types ---
   281                              <2> USB_EP_CONTROL       equ 0
   282                              <2> USB_EP_ISOCH         equ 1
   283                              <2> USB_EP_BULK          equ 2
   284                              <2> USB_EP_INTERRUPT     equ 3
   285                              <2> 
   286                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   287                              <2> XHCI_EP_NOT_VALID    equ 0
   288                              <2> XHCI_EP_ISOCH_OUT    equ 1
   289                              <2> XHCI_EP_BULK_OUT     equ 2
   290                              <2> XHCI_EP_INT_OUT      equ 3
   291                              <2> XHCI_EP_CONTROL      equ 4
   292                              <2> XHCI_EP_ISOCH_IN     equ 5
   293                              <2> XHCI_EP_BULK_IN      equ 6
   294                              <2> XHCI_EP_INT_IN       equ 7
   295                              <2> 
   296                              <2> ; --- XHCI Port Speeds ---
   297                              <2> XHCI_SPEED_FULL      equ 1
   298                              <2> XHCI_SPEED_LOW       equ 2
   299                              <2> XHCI_SPEED_HIGH      equ 3
   300                              <2> XHCI_SPEED_SUPER     equ 4
     7                              <1> %include "macros.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - Common Macros
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> %ifndef MACROS_INC
     6                              <2> %define MACROS_INC
     7                              <2> 
     8                              <2> ; Output character to COM1 for debugging
     9                              <2> %macro SER 1
    10                              <2>     push rax
    11                              <2>     push rdx
    12                              <2>     mov dx, 0x3F8
    13                              <2>     mov al, %1
    14                              <2>     out dx, al
    15                              <2>     pop rdx
    16                              <2>     pop rax
    17                              <2> %endmacro
    18                              <2> 
    19                              <2> ; Save all general-purpose registers (64-bit)
    20                              <2> %macro PUSH_ALL 0
    21                              <2>     push rax
    22                              <2>     push rbx
    23                              <2>     push rcx
    24                              <2>     push rdx
    25                              <2>     push rsi
    26                              <2>     push rdi
    27                              <2>     push rbp
    28                              <2>     push r8
    29                              <2>     push r9
    30                              <2>     push r10
    31                              <2>     push r11
    32                              <2>     push r12
    33                              <2>     push r13
    34                              <2>     push r14
    35                              <2>     push r15
    36                              <2> %endmacro
    37                              <2> 
    38                              <2> ; Offset of registers in PUSH_ALL frame
    39                              <2> ALL_R15 equ 0
    40                              <2> ALL_R14 equ 8
    41                              <2> ALL_R13 equ 16
    42                              <2> ALL_R12 equ 24
    43                              <2> ALL_R11 equ 32
    44                              <2> ALL_R10 equ 40
    45                              <2> ALL_R9  equ 48
    46                              <2> ALL_R8  equ 56
    47                              <2> ALL_RBP equ 64
    48                              <2> ALL_RDI equ 72
    49                              <2> ALL_RSI equ 80
    50                              <2> ALL_RDX equ 88
    51                              <2> ALL_RCX equ 96
    52                              <2> ALL_RBX equ 104
    53                              <2> ALL_RAX equ 112
    54                              <2> 
    55                              <2> ; Restore all general-purpose registers (64-bit)
    56                              <2> %macro POP_ALL 0
    57                              <2>     pop r15
    58                              <2>     pop r14
    59                              <2>     pop r13
    60                              <2>     pop r12
    61                              <2>     pop r11
    62                              <2>     pop r10
    63                              <2>     pop r9
    64                              <2>     pop r8
    65                              <2>     pop rbp
    66                              <2>     pop rdi
    67                              <2>     pop rsi
    68                              <2>     pop rdx
    69                              <2>     pop rcx
    70                              <2>     pop rbx
    71                              <2>     pop rax
    72                              <2> %endmacro
    73                              <2> 
    74                              <2> ; Output byte to port with I/O delay
    75                              <2> %macro OUTB 2
    76                              <2>     mov al, %2
    77                              <2>     out %1, al
    78                              <2> %endmacro
    79                              <2> 
    80                              <2> ; Input byte from port
    81                              <2> %macro INB 1
    82                              <2>     in al, %1
    83                              <2> %endmacro
    84                              <2> 
    85                              <2> ; I/O wait (small delay for PIC/PIT programming)
    86                              <2> %macro IO_WAIT 0
    87                              <2>     out 0x80, al
    88                              <2> %endmacro
    89                              <2> 
    90                              <2> ; Bochs magic breakpoint
    91                              <2> %macro BOCHS_BREAK 0
    92                              <2>     xchg bx, bx
    93                              <2> %endmacro
    94                              <2> 
    95                              <2> ; ISR stub that pushes a dummy error code (for exceptions without one)
    96                              <2> %macro ISR_NOERRCODE 1
    97                              <2> global isr_%1
    98                              <2> isr_%1:
    99                              <2>     push qword 0           ; Dummy error code
   100                              <2>     push qword %1          ; Interrupt number
   101                              <2>     jmp isr_common_stub
   102                              <2> %endmacro
   103                              <2> 
   104                              <2> ; ISR stub for exceptions that push their own error code
   105                              <2> %macro ISR_ERRCODE 1
   106                              <2> global isr_%1
   107                              <2> isr_%1:
   108                              <2>     push qword %1          ; Interrupt number (error code already on stack)
   109                              <2>     jmp isr_common_stub
   110                              <2> %endmacro
   111                              <2> 
   112                              <2> ; IRQ stub macro
   113                              <2> %macro IRQ_STUB 2
   114                              <2> global irq_%1
   115                              <2> irq_%1:
   116                              <2>     push qword 0           ; Dummy error code
   117                              <2>     push qword %2          ; Interrupt vector number
   118                              <2>     jmp irq_common_stub
   119                              <2> %endmacro
   120                              <2> 
   121                              <2> %endif
