   270 000031C1 240F                <1>     and al, 0x0F
   271 000031C3 0A0425[0C050000]    <1>     or al, [ata_drive_sel]
   272 000031CA 66BAF601            <1>     mov dx, ATA_DRIVE
   273 000031CE EE                  <1>     out dx, al
