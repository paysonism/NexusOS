   152 00007552 660F6F6640          <1>     movdqa xmm4, [rsi + 64]
   153 00007557 660F6F6E50          <1>     movdqa xmm5, [rsi + 80]
   154 0000755C 660F6F7660          <1>     movdqa xmm6, [rsi + 96]
   155 00007561 660F6F7E70          <1>     movdqa xmm7, [rsi + 112]
