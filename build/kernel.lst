  1072                              <1>     
  1073                              <1>     ; Data TRB
  1074 00004D1C 4189F8              <1>     mov r8d, edi             ; Buffer low
  1075 00004D1F 4531C9              <1>     xor r9d, r9d             ; Buffer high
  1076 00004D22 4189CA              <1>     mov r10d, ecx            ; Length
  1077 00004D25 41BB000C0100        <1>     mov r11d, TRB_DATA | TRB_DIR_IN
  1078 00004D2B E894F1FFFF          <1>     call xhci_queue_ctrl_trb
  1079                              <1>     
  1080                              <1> .no_data:
  1081                              <1>     ; 3. Status Stage (OUT)
  1082 00004D30 4531C0              <1>     xor r8d, r8d
  1083 00004D33 4531C9              <1>     xor r9d, r9d
  1084 00004D36 4531D2              <1>     xor r10d, r10d
  1085 00004D39 41BB20100000        <1>     mov r11d, TRB_STATUS | TRB_DIR_OUT | TRB_IOC
  1086 00004D3F E880F1FFFF          <1>     call xhci_queue_ctrl_trb
  1087                              <1>     
  1088                              <1>     ; 4. Ring Doorbell (Slot 1, EP1=Control)
  1089 00004D44 0FB63C25[6F050000]  <1>     movzx edi, byte [xhci_slot_id]
