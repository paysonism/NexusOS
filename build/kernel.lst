   208 00005404 488B0C25[E8080000]  <1>     mov rcx, [spi_report_desc_len]
   209 0000540C 480FB70C25-         <1>     movzx rcx, word [spi_report_desc_len]
   209 00005411 [E8080000]          <1>
   210 00005415 4883C104            <1>     add rcx, 4
