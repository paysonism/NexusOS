   962 000002F3 66BACE01            <1>     mov dx, 0x1CE
   963 000002F7 66B80200            <1>     mov ax, 0x02
   964 000002FB 66EF                <1>     out dx, ax
   965 000002FD 66BACF01            <1>     mov dx, 0x1CF
   966 00000301 6689F0              <1>     mov ax, si
   967 00000304 66EF                <1>     out dx, ax
   968                              <1> 
