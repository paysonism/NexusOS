    80                              <1> 
    81                              <1> .done:
    82 00001DD1 5B                  <1>     pop rbx
    83 00001DD2 58                  <1>     pop rax
    84 00001DD3 C3                  <1>     ret
    85                              <1> 
    86                              <1> ; --- Fill rectangle (SSE2 optimized) ---
    87                              <1> ; EDI = x, ESI = y, EDX = w, ECX = h, R8D = color
    88                              <1> global fill_rect
    89                              <1> fill_rect:
    90 00001DD4 50                  <1>     push rax
    91 00001DD5 53                  <1>     push rbx
