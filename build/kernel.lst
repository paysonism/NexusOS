   126 00007520 5E                  <1>     pop rsi
   127 00007521 5A                  <1>     pop rdx
   128 00007522 59                  <1>     pop rcx
   129 00007523 5B                  <1>     pop rbx
   130 00007524 58                  <1>     pop rax
   131 00007525 C3                  <1>     ret
