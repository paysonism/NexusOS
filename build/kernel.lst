     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - Math Utility Functions
     3                              <1> ; ============================================================================
     4                              <1> bits 64
     5                              <1> 
     6                              <1> section .text
     7                              <1> 
     8                              <1> ; --- clamp: Clamp value to range ---
     9                              <1> ; EDI = value, ESI = min, EDX = max
    10                              <1> ; Returns: EAX = clamped value
    11                              <1> global fn_clamp
    12                              <1> fn_clamp:
    13 0000C98A 89F8                <1>     mov eax, edi
    14 0000C98C 39F0                <1>     cmp eax, esi
    15 0000C98E 0F4CC6              <1>     cmovl eax, esi           ; If value < min, use min
    16 0000C991 39D0                <1>     cmp eax, edx
    17 0000C993 0F4FC2              <1>     cmovg eax, edx           ; If value > max, use max
    18 0000C996 C3                  <1>     ret
    19                              <1> 
    20                              <1> ; --- min: Integer minimum ---
