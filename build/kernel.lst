   188                              <1> ; ============================================================================
   189                              <1> ; Handle desktop clicks: RDI=mouseX, RSI=mouseY
   190                              <1> ; Returns RAX: 0=not handled, 1=handled
   191                              <1> ; ============================================================================
   192                              <1> desktop_handle_click:
   193 00008C80 53                  <1>     push rbx
   194 00008C81 4154                <1>     push r12
   195 00008C83 4155                <1>     push r13
   196                              <1> 
   197                              <1>     ; Close start menu
   198 00008C85 C60425[7B110000]00  <1>     mov byte [tb_start_menu_open], 0
   199                              <1> 
   200                              <1>     ; Check if click is in icon column
   201 00008C8D 83FF18              <1>     cmp edi, ICON_X
   202 00008C90 7C4D                <1>     jl .click_none
   203 00008C92 83FF48              <1>     cmp edi, ICON_X + ICON_SIZE
   204 00008C95 7F48                <1>     jg .click_none
   205                              <1> 
   206                              <1>     ; Find which icon slot
   207 00008C97 4531E4              <1>     xor r12d, r12d
   208 00008C9A 41BD18000000        <1>     mov r13d, ICON_BASE_Y
   209                              <1> 
   210                              <1> .click_loop:
   211 00008CA0 4183FC08            <1>     cmp r12d, MAX_DESK_ICONS
   212 00008CA4 7D39                <1>     jge .click_none
   213                              <1> 
   214 00008CA6 410FB68424-         <1>     movzx eax, byte [desktop_icons + r12]
   214 00008CAB [96110000]          <1>
   215 00008CAF 84C0                <1>     test al, al
   216 00008CB1 7423                <1>     jz .click_next
   217                              <1> 
   218                              <1>     ; Check Y range (icon + label area)
   219 00008CB3 4439EE              <1>     cmp esi, r13d
   220 00008CB6 7C1E                <1>     jl .click_next
   221 00008CB8 67418D4D44          <1>     lea ecx, [r13d + ICON_SIZE + 20]
   222 00008CBD 39CE                <1>     cmp esi, ecx
   223 00008CBF 7F15                <1>     jg .click_next
   224                              <1> 
   225                              <1>     ; Hit! Launch this app
   226 00008CC1 410FB6BC24-         <1>     movzx edi, byte [desktop_icons + r12]
   226 00008CC6 [96110000]          <1>
   227 00008CCA E8EE040000          <1>     call app_launch
   228 00008CCF B801000000          <1>     mov rax, 1
   229 00008CD4 EB0B                <1>     jmp .click_ret
   230                              <1> 
   231                              <1> .click_next:
   232 00008CD6 41FFC4              <1>     inc r12d
   233 00008CD9 4183C554            <1>     add r13d, ICON_STRIDE
   234 00008CDD EBC1                <1>     jmp .click_loop
   235                              <1> 
   236                              <1> .click_none:
   237 00008CDF 31C0                <1>     xor eax, eax
   238                              <1> .click_ret:
   239 00008CE1 415D                <1>     pop r13
   240 00008CE3 415C                <1>     pop r12
   241 00008CE5 5B                  <1>     pop rbx
   242 00008CE6 C3                  <1>     ret
   243                              <1> 
