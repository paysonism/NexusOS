   820 00007EE9 48F7402810000000    <1>     test qword [rax + WIN_OFF_FLAGS], WF_ACTIVE
   821 00007EF1 7433                <1>     jz .scan_all
   822 00007EF3 48F7402801000000    <1>     test qword [rax + WIN_OFF_FLAGS], WF_VISIBLE
   823 00007EFB 7429                <1>     jz .scan_all
   824                              <1>     ; Bounds check
