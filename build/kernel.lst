   182                              <1> ; --- Draw single character (optimized fast path) ---
   183                              <1> ; EDI = x, ESI = y, DL = character, ECX = fg_color, R8D = bg_color
   184                              <1> global draw_char
   185                              <1> draw_char:
   186 00001EA0 50                  <1>     push rax
   187 00001EA1 53                  <1>     push rbx
   188 00001EA2 4151                <1>     push r9
   189 00001EA4 4152                <1>     push r10
   190 00001EA6 4153                <1>     push r11
