   948 000002CC 663DC0B0            <1>     cmp ax, 0xB0C0
   949 000002D0 0F8CB6000000        <1>     jl .set_fail
   950 000002D6 663DD0B0            <1>     cmp ax, 0xB0D0
   951 000002DA 0F8FAC000000        <1>     jg .set_fail
   952                              <1> 
