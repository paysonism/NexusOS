  1323 00000824 000000              <1>     db 0, 0, 0
  1324                              <1>     ; 0x49-0x4E: Insert, Home, PageUp, Delete, End, PageDown
  1325 00000827 D2C7C9D3CFD1        <1>     db 0xD2, 0xC7, 0xC9, 0xD3, 0xCF, 0xD1
  1326                              <1>     ; 0x4F-0x52: Right, Left, Down, Up (extended PS/2)
  1327 0000082D CDCBD0C8            <1>     db 0xCD, 0xCB, 0xD0, 0xC8
  1328                              <1>     ; 0x53: NumLock, 0x54-0x63: numpad / * - + Enter 1-9 0 .
  1329 00000831 45B5374A9C4F50514B- <1>     db 0x45, 0xB5, 0x37, 0x4A, 0x9C, 0x4F, 0x50, 0x51, 0x4B, 0x4C, 0x4D, 0x47, 0x48, 0x49, 0x52, 0x53
