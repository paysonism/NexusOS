   292 000031E8 EC                  <1>     in al, dx
   293 000031E9 EC                  <1>     in al, dx
   294 000031EA 6658                <1>     pop ax
   295 000031EC 665A                <1>     pop dx
   296 000031EE C3                  <1>     ret
