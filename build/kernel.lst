   781 00000DA7 57                  <1>     push rdi
   782 00000DA8 56                  <1>     push rsi
   783 00000DA9 50                  <1>     push rax
   784 00000DAA 53                  <1>     push rbx
   785 00000DAB 51                  <1>     push rcx
   786 00000DAC 52                  <1>     push rdx
   787                              <1> 
   788 00000DAD 4889FB              <1>     mov rbx, rdi              ; RBX = write pointer
   789                              <1> 
   790                              <1>     ; Header
   791 00000DB0 488D3425[9A0E0000]  <1>     lea rsi, [.hdr]
   792 00000DB8 E887000000          <1>     call .copystr
   793                              <1> 
   794                              <1>     ; Drive Selection
   795 00000DBD 488D3425[A60E0000]  <1>     lea rsi, [.s_drive]
   796 00000DC5 E87A000000          <1>     call .copystr
   797 00000DCA 0FB60425[0C050000]  <1>     movzx eax, byte [ata_drive_sel]
   798 00000DD2 E87A000000          <1>     call .writehex8
   799                              <1> 
   800                              <1>     ; Partition LBA
   801 00000DD7 488D3425[AC0E0000]  <1>     lea rsi, [.s_lba]
   802 00000DDF E860000000          <1>     call .copystr
   803 00000DE4 B840010000          <1>     mov eax, FAT16_PART_LBA
   804 00000DE9 E88A000000          <1>     call .writehex32
   805                              <1> 
   806                              <1>     ; Signature check (from buffer)
   807 00000DEE 488D3425[B20E0000]  <1>     lea rsi, [.s_sig]
   808 00000DF6 E849000000          <1>     call .copystr
   809 00000DFB 0FB70425FE01D000    <1>     movzx eax, word [FAT16_SECTOR_BUF + 510]
   810 00000E03 E85D000000          <1>     call .writehex16
   811                              <1> 
   812                              <1>     ; File Count
   813 00000E08 488D3425[B80E0000]  <1>     lea rsi, [.s_files]
   814 00000E10 E82F000000          <1>     call .copystr
   815 00000E15 8B0425[A10D0000]    <1>     mov eax, [fat16_file_count_val]
   816 00000E1C E857000000          <1>     call .writehex32
   817                              <1> 
   818                              <1>     ; Root Start Sector
   819 00000E21 488D3425[C00E0000]  <1>     lea rsi, [.s_root]
   820 00000E29 E816000000          <1>     call .copystr
   821 00000E2E 8B0425[950D0000]    <1>     mov eax, [fat16_root_start_sect]
   822 00000E35 E83E000000          <1>     call .writehex32
   823                              <1>     
   824                              <1>     ; Null terminate
   825 00000E3A C60300              <1>     mov byte [rbx], 0
   826                              <1> 
   827 00000E3D 5A                  <1>     pop rdx
   828 00000E3E 59                  <1>     pop rcx
   829 00000E3F 5B                  <1>     pop rbx
   830 00000E40 58                  <1>     pop rax
   831 00000E41 5E                  <1>     pop rsi
   832 00000E42 5F                  <1>     pop rdi
   833 00000E43 C3                  <1>     ret
   834                              <1> 
   835                              <1> ; -- internal helpers --
   836                              <1> .copystr:
   837 00000E44 AC                  <1>     lodsb
   838 00000E45 84C0                <1>     test al, al
   839 00000E47 7407                <1>     jz .cs_done
   840 00000E49 8803                <1>     mov [rbx], al
   841 00000E4B 48FFC3              <1>     inc rbx
   842 00000E4E EBF4                <1>     jmp .copystr
   843                              <1> .cs_done:
   844 00000E50 C3                  <1>     ret
   845                              <1> 
   846                              <1> .writehex8:
   847 00000E51 50                  <1>     push rax
   848 00000E52 C0E804              <1>     shr al, 4
   849 00000E55 E830000000          <1>     call .nib
   850 00000E5A 58                  <1>     pop rax
   851 00000E5B 50                  <1>     push rax
   852 00000E5C 240F                <1>     and al, 0x0F
   853 00000E5E E827000000          <1>     call .nib
   854 00000E63 58                  <1>     pop rax
   855 00000E64 C3                  <1>     ret
   856                              <1> 
   857                              <1> .writehex16:
   858 00000E65 50                  <1>     push rax
   859 00000E66 66C1E808            <1>     shr ax, 8
   860 00000E6A E8E2FFFFFF          <1>     call .writehex8
   861 00000E6F 58                  <1>     pop rax
   862 00000E70 50                  <1>     push rax
   863 00000E71 E8DBFFFFFF          <1>     call .writehex8
   864 00000E76 58                  <1>     pop rax
   865 00000E77 C3                  <1>     ret
   866                              <1> 
   867                              <1> .writehex32:
   868 00000E78 50                  <1>     push rax
   869 00000E79 C1E810              <1>     shr eax, 16
   870 00000E7C E8E4FFFFFF          <1>     call .writehex16
   871 00000E81 58                  <1>     pop rax
   872 00000E82 50                  <1>     push rax
   873 00000E83 E8DDFFFFFF          <1>     call .writehex16
   874 00000E88 58                  <1>     pop rax
   875 00000E89 C3                  <1>     ret
   876                              <1>     
   877                              <1> .nib:
   878 00000E8A 3C0A                <1>     cmp al, 10
   879 00000E8C 7204                <1>     jb .nib_digit
   880 00000E8E 0437                <1>     add al, 'A' - 10
   881 00000E90 EB02                <1>     jmp .nib_out
   882                              <1> .nib_digit:
   883 00000E92 0430                <1>     add al, '0'
   884                              <1> .nib_out:
   885 00000E94 8803                <1>     mov [rbx], al
   886 00000E96 48FFC3              <1>     inc rbx
   887 00000E99 C3                  <1>     ret
