   815 00007ED3 4883F808            <1>     cmp rax, MAX_WINDOWS
   816 00007ED7 7D4D                <1>     jge .scan_all
   817 00007ED9 4989C4              <1>     mov r12, rax
   818 00007EDC 4869C000010000      <1>     imul rax, WINDOW_STRUCT_SIZE
