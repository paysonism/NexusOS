  1350                              <1>     ; 1. Map USB HID modifier byte to KMOD_* and update kb_modifiers
  1351 00004E91 440FB60E            <1>     movzx r9d, byte [rsi]       ; r9 = current modifier byte
  1352 00004E95 B300                <1>     mov bl, 0
  1353 00004E97 41F6C102            <1>     test r9b, 0x02              ; LShift
  1354 00004E9B 7403                <1>     jz .no_ls
  1355 00004E9D 80CB01              <1>     or bl, KMOD_SHIFT
  1356                              <1> .no_ls:
  1357 00004EA0 41F6C120            <1>     test r9b, 0x20              ; RShift
  1358 00004EA4 7403                <1>     jz .no_rs
  1359 00004EA6 80CB01              <1>     or bl, KMOD_SHIFT
  1360                              <1> .no_rs:
  1361 00004EA9 41F6C101            <1>     test r9b, 0x01              ; LCtrl
  1362 00004EAD 7403                <1>     jz .no_lc
  1363 00004EAF 80CB02              <1>     or bl, KMOD_CTRL
  1364                              <1> .no_lc:
  1365 00004EB2 41F6C110            <1>     test r9b, 0x10              ; RCtrl
  1366 00004EB6 7403                <1>     jz .no_rc
  1367 00004EB8 80CB02              <1>     or bl, KMOD_CTRL
  1368                              <1> .no_rc:
  1369 00004EBB 41F6C104            <1>     test r9b, 0x04              ; LAlt
  1370 00004EBF 7403                <1>     jz .no_la
  1371 00004EC1 80CB04              <1>     or bl, KMOD_ALT
  1372                              <1> .no_la:
  1373 00004EC4 41F6C140            <1>     test r9b, 0x40              ; RAlt
  1374 00004EC8 7403                <1>     jz .no_ra
