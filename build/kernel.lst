    50 00001D86 48C70425[02020000]- <1>     mov qword [bb_addr], BACK_BUFFER_ADDR
    50 00001D8E 00004000            <1>
    51                              <1> 
    52                              <1>     ; Clear back buffer
    53 00001D92 31FF                <1>     xor edi, edi             ; Black (color arg in edi)
    54 00001D94 E834060000          <1>     call display_clear
    55                              <1> 
    56 00001D99 C3                  <1>     ret
    57                              <1> 
    58                              <1> ; --- Set pixel ---
    59                              <1> ; EDI = x, ESI = y, EDX = color (0x00RRGGBB)
    60                              <1> global pixel_set
    61                              <1> pixel_set:
    62 00001D9A 50                  <1>     push rax
    63 00001D9B 53                  <1>     push rbx
    64                              <1>     ; Bounds check
    65 00001D9C 83FF00              <1>     cmp edi, 0
