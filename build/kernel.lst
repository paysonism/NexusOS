   109                              <1> ; --- Allocate one physical page ---
   110                              <1> ; Returns: RAX = physical address of 4KB page, or 0 if out of memory
   111                              <1> global page_alloc
   112                              <1> page_alloc:
   113 000010F0 53                  <1>     push rbx
   114 000010F1 51                  <1>     push rcx
   115 000010F2 52                  <1>     push rdx
   116                              <1> 
   117                              <1>     ; Scan bitmap for first free bit (0 = free)
   118 000010F3 BF00003000          <1>     mov rdi, PAGE_BITMAP_ADDR
   119 000010F8 B900001000          <1>     mov rcx, 0x100000        ; Bitmap size in bytes
   120                              <1> 
   121                              <1> .scan:
   122 000010FD 803FFF              <1>     cmp byte [rdi], 0xFF     ; All used?
   123 00001100 750D                <1>     jne .found_byte
   124 00001102 48FFC7              <1>     inc rdi
   125 00001105 48FFC9              <1>     dec rcx
   126 00001108 75F3                <1>     jnz .scan
   127                              <1>     ; Out of memory
   128 0000110A 4831C0              <1>     xor rax, rax
   129 0000110D EB38                <1>     jmp .alloc_done
   130                              <1> 
   131                              <1> .found_byte:
   132                              <1>     ; Find which bit is 0 in this byte
   133 0000110F 8A07                <1>     mov al, [rdi]
