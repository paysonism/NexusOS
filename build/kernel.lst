   584 000005B5 E828720000          <1>     call wm_draw_desktop
   585                              <1>     SER '2'
    10 000005BA 50                  <2>  push rax
    11 000005BB 52                  <2>  push rdx
    12 000005BC 66BAF803            <2>  mov dx, 0x3F8
    13 000005C0 B032                <2>  mov al, %1
    14 000005C2 EE                  <2>  out dx, al
