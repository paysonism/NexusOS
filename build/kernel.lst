  1078                              <1> .check_3finger:
  1079                              <1>     ; Clear pinch distance when not 2 fingers
  1080 00006B58 83F802              <1>     cmp eax, 2
  1081 00006B5B 0F8484000000        <1>     je .gesture_done
  1082 00006B61 C70425[580D0000]00- <1>     mov dword [gesture_pinch_dist_prev], 0
  1082 00006B69 000000              <1>
