  1131 00004D9B 56                  <1>     push rsi
  1132 00004D9C 488B3425[D0000000]  <1>     mov rsi, [tick_count]
  1133 00004DA4 4883C664            <1>     add rsi, 100                 ; 100 ticks = 1 second at 100Hz
  1134 00004DA8 B9002D3101          <1>     mov ecx, 20000000            ; ~10M iterations max spin fallback
  1135                              <1> .poll:
  1136 00004DAD E8CEEBFFFF          <1>     call xhci_poll_event         ; rsi preserved by xhci_poll_event (push/pop rsi inside)
