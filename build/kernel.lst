   115 00001DFF 4489C8              <1>     mov eax, r9d
   116 00001E02 4401D8              <1>     add eax, r11d
   117 00001E05 3B0425[0A020000]    <1>     cmp eax, [scr_width]
   118 00001E0C 7E0B                <1>     jle .clip_top
   119 00001E0E 448B1C25[0A020000]  <1>     mov r11d, [scr_width]
   120 00001E16 4529CB              <1>     sub r11d, r9d
   121                              <1> .clip_top:
   122 00001E19 4183FA00            <1>     cmp r10d, 0
   123 00001E1D 7D06                <1>     jge .clip_bottom
   124 00001E1F 4501D4              <1>     add r12d, r10d
