   569 000036D9 0F849D000000        <1>     jz .reset_fail
   570 000036DF 488B0425[D0000000]  <1>     mov rax, [tick_count]
   571 000036E7 4839D8              <1>     cmp rax, rbx
   572 000036EA 0F8D8C000000        <1>     jge .reset_fail          ; Timeout
   573 000036F0 F390                <1>     pause
   574 000036F2 EBD9                <1>     jmp .wait_halt
   575                              <1> .halted:
   576                              <1> 
   577                              <1>     ; Serial: 'b' (halted)
   578 000036F4 52                  <1>     push rdx
   579 000036F5 66BAF803            <1>     mov dx, 0x3F8
   580 000036F9 B062                <1>     mov al, 'b'
