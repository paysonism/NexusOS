   161 00003114 EE                  <1>     out dx, al
   162 00003115 4489E0              <1>     mov eax, r12d
   163 00003118 C1E808              <1>     shr eax, 8
   164 0000311B 66BAF401            <1>     mov dx, ATA_LBA_MID
   165 0000311F EE                  <1>     out dx, al
   166 00003120 4489E0              <1>     mov eax, r12d
   167 00003123 C1E810              <1>     shr eax, 16
