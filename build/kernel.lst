   157 0000756A 660F7F4F10          <1>     movdqa [rdi + 16], xmm1
   158 0000756F 660F7F5720          <1>     movdqa [rdi + 32], xmm2
   159 00007574 660F7F5F30          <1>     movdqa [rdi + 48], xmm3
   160 00007579 660F7F6740          <1>     movdqa [rdi + 64], xmm4
   161 0000757E 660F7F6F50          <1>     movdqa [rdi + 80], xmm5
   162 00007583 660F7F7760          <1>     movdqa [rdi + 96], xmm6
   163 00007588 660F7F7F70          <1>     movdqa [rdi + 112], xmm7
   164 0000758D 4881C680000000      <1>     add rsi, 128
   165 00007594 4881C780000000      <1>     add rdi, 128
   166 0000759B FFC9                <1>     dec ecx
