   213 00004447 B048                <1>     mov al, 'H'
   214 00004449 EE                  <1>     out dx, al
   215                              <1> 
   216                              <1>     ; 4. Get Device Descriptor (to verify it's a mouse? or just to debug)
   217                              <1>     ; Request: 80 06 00 01 00 00 12 00 (Get Descriptor Device, len 18)
   218 0000444A BF00009900          <1>     mov rdi, XHCI_CTRL_BUF_ADDR
   219 0000444F B912000000          <1>     mov rcx, 18
   220 00004454 41B880060001        <1>     mov r8d, 0x01000680      ; Low dword of setup packet (GetDesc Device)
   221 0000445A 41B900001200        <1>     mov r9d, 0x00120000      ; High dword (Len 18)
   222 00004460 E89C080000          <1>     call usb_control_transfer_in
   223 00004465 85C0                <1>     test eax, eax
   224 00004467 0F8453FFFFFF        <1>     jz .try_next_controller  ; Failed to get descriptor - try next
   225                              <1> 
