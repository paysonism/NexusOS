   648 000086AB C60425[7B110000]00  <1>     mov byte [tb_start_menu_open], 0
   649 000086B3 B801000000          <1>     mov rax, 1
   650 000086B8 E904010000          <1>     jmp .tb_click_ret
   651                              <1> 
   652                              <1> .check_taskbar:
   653                              <1>     ; Check if within taskbar Y range
   654 000086BD 4881FEDC020000      <1>     cmp rsi, TASKBAR_Y
   655 000086C4 0F8CF4000000        <1>     jl .not_handled
   656                              <1> 
   657                              <1>     ; Check Start Button
   658 000086CA 4883FF04            <1>     cmp rdi, START_BTN_X
