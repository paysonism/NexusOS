     9                              <1> section .data
    10                              <1> global mcfg_base
    11 000001F2 0000000000000000    <1> mcfg_base dq 0
    12                              <1> 
    13                              <1> section .text
    14                              <1> global acpi_pci_init
    15                              <1> 
    16                              <1> ; RSI = pointer to MCFG table
    17                              <1> acpi_pci_init:
    18 00001C4C 53                  <1>     push rbx
    19 00001C4D 51                  <1>     push rcx
    20 00001C4E 52                  <1>     push rdx
    21                              <1>     
    22                              <1>     ; TableLength is at offset 4
    23 00001C4F 8B4E04              <1>     mov ecx, [rsi + 4]
    24                              <1>     
    25                              <1>     ; Base of Configuration space allocation structures is at offset 44
    26 00001C52 488D5E2C            <1>     lea rbx, [rsi + 44]
    27 00001C56 4801F1              <1>     add rcx, rsi    ; End of table
    28                              <1>     
    29                              <1> .scan:
    30 00001C59 4839CB              <1>     cmp rbx, rcx
    31 00001C5C 7311                <1>     jae .done
    32                              <1>     
    33                              <1>     ; struct size = 16 bytes
    34                              <1>     ; +0: Base address (8 bytes)
    35                              <1>     ; +8: PCI Segment Group Number (2 bytes)
    36                              <1>     ; +10: Start Bus Number (1 byte)
    37                              <1>     ; +11: End Bus Number (1 byte)
    38                              <1>     ; +12: Reserved (4 bytes)
    39                              <1>     
    40 00001C5E 488B03              <1>     mov rax, [rbx]
    41                              <1>     ; just store the first one for now (Segment 0)
    42 00001C61 48890425[F2010000]  <1>     mov [mcfg_base], rax
    43                              <1>     
    44 00001C69 4883C310            <1>     add rbx, 16
    45 00001C6D EBEA                <1>     jmp .scan
    46                              <1> 
    47                              <1> .done:
    48 00001C6F 5A                  <1>     pop rdx
    49 00001C70 59                  <1>     pop rcx
    50 00001C71 5B                  <1>     pop rbx
    51 00001C72 C3                  <1>     ret
