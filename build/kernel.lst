   308 00008D5C C682[96110000]00    <1>     mov byte [desktop_icons + rdx], 0
   309 00008D63 FFC1                <1>     inc ecx
   310 00008D65 FFC2                <1>     inc edx
   311 00008D67 EBE1                <1>     jmp .compact
   312                              <1> .compact_zero:
   313 00008D69 C681[96110000]00    <1>     mov byte [desktop_icons + rcx], 0
   314                              <1> .rem_done:
   315 00008D70 C3                  <1>     ret
