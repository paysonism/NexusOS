   607 00003733 52                  <1>     push rdx
   608 00003734 66BAF803            <1>     mov dx, 0x3F8
   609 00003738 B063                <1>     mov al, 'c'
   610 0000373A EE                  <1>     out dx, al
   611 0000373B 5A                  <1>     pop rdx
   612                              <1> 
   613                              <1>     ; Wait for CNR = 0 - up to 1 second
   614 0000373C 488B1C25[D0000000]  <1>     mov rbx, [tick_count]
   615 00003744 4883C364            <1>     add rbx, 100
   616 00003748 B9002D3101          <1>     mov ecx, 20000000
   617                              <1> .wait_cnr:
   618 0000374D 8B4604              <1>     mov eax, [rsi + XHCI_OP_USBSTS]
   619 00003750 A900080000          <1>     test eax, XHCI_STS_CNR
   620 00003755 7415                <1>     jz .reset_ok
   621 00003757 FFC9                <1>     dec ecx
   622 00003759 7421                <1>     jz .reset_fail
   623 0000375B 488B0425[D0000000]  <1>     mov rax, [tick_count]
   624 00003763 4839D8              <1>     cmp rax, rbx
   625 00003766 7D14                <1>     jge .reset_fail
   626 00003768 F390                <1>     pause
   627 0000376A EBE1                <1>     jmp .wait_cnr
   628                              <1> 
   629                              <1> .reset_ok:
   630                              <1>     ; Serial: 'd' (CNR clear)
   631 0000376C 52                  <1>     push rdx
   632 0000376D 66BAF803            <1>     mov dx, 0x3F8
   633 00003771 B064                <1>     mov al, 'd'
   634 00003773 EE                  <1>     out dx, al
   635 00003774 5A                  <1>     pop rdx
   636 00003775 B801000000          <1>     mov eax, 1
   637 0000377A EB0B                <1>     jmp .reset_ret
   638                              <1> .reset_fail:
   639                              <1>     ; Serial: 'e' (reset fail)
   640 0000377C 52                  <1>     push rdx
   641 0000377D 66BAF803            <1>     mov dx, 0x3F8
   642 00003781 B065                <1>     mov al, 'e'
   643 00003783 EE                  <1>     out dx, al
   644 00003784 5A                  <1>     pop rdx
   645 00003785 31C0                <1>     xor eax, eax
   646                              <1> .reset_ret:
   647 00003787 5B                  <1>     pop rbx
   648 00003788 59                  <1>     pop rcx
   649 00003789 5E                  <1>     pop rsi
   650 0000378A C3                  <1>     ret
   651                              <1> 
   652                              <1> ; ============================================================================
   653                              <1> ; xhci_setup_scratchpad - Allocate scratchpad buffers if needed
   654                              <1> ; ============================================================================
   655                              <1> xhci_setup_scratchpad:
   656 0000378B 51                  <1>     push rcx
   657 0000378C 57                  <1>     push rdi
   658                              <1> 
   659 0000378D 0FB60C25[3E050000]  <1>     movzx ecx, byte [xhci_scratchpad_count]
   660 00003795 85C9                <1>     test ecx, ecx
   661 00003797 7435                <1>     jz .scratch_done              ; No scratchpads needed
   662                              <1> 
   663                              <1>     ; Cap at 4 (we have space for 4 buffer pages)
   664 00003799 83F904              <1>     cmp ecx, 4
   665 0000379C 7E05                <1>     jle .scratch_ok
   666 0000379E B904000000          <1>     mov ecx, 4
   667                              <1> .scratch_ok:
   668                              <1> 
   669                              <1>     ; Scratchpad array at XHCI_SCRATCH_ADDR
   670                              <1>     ; Buffers at XHCI_SCRATCH_ADDR + 0x1000, +0x2000, etc.
   671 000037A3 BF00009400          <1>     mov rdi, XHCI_SCRATCH_ADDR
   672 000037A8 31D2                <1>     xor edx, edx
   673                              <1> .scratch_loop:
   674 000037AA 39CA                <1>     cmp edx, ecx
   675 000037AC 7D14                <1>     jge .scratch_set_dcbaa
   676                              <1>     ; Buffer address = XHCI_SCRATCH_ADDR + 0x1000 * (edx + 1)
   677 000037AE 89D0                <1>     mov eax, edx
   678 000037B0 FFC0                <1>     inc eax
   679 000037B2 C1E00C              <1>     shl eax, 12                   ; * 4096
   680 000037B5 0500009400          <1>     add eax, XHCI_SCRATCH_ADDR
   681 000037BA 488904D7            <1>     mov [rdi + rdx * 8], rax      ; Write 64-bit pointer to array
   682 000037BE FFC2                <1>     inc edx
   683 000037C0 EBE8                <1>     jmp .scratch_loop
   684                              <1> 
   685                              <1> .scratch_set_dcbaa:
   686                              <1>     ; DCBAA[0] = scratchpad array pointer
   687 000037C2 BF00009000          <1>     mov rdi, XHCI_DCBAA_ADDR
   688 000037C7 48C70700009400      <1>     mov qword [rdi], XHCI_SCRATCH_ADDR
   689                              <1> 
   690                              <1> .scratch_done:
   691 000037CE 5F                  <1>     pop rdi
   692 000037CF 59                  <1>     pop rcx
   693 000037D0 C3                  <1>     ret
   694                              <1> 
   695                              <1> ; ============================================================================
   696                              <1> ; xhci_setup_dcbaa - Setup Device Context Base Address Array
   697                              <1> ; ============================================================================
   698                              <1> xhci_setup_dcbaa:
   699                              <1>     ; DCBAA already zeroed. Scratchpad pointer set if needed.
   700                              <1>     ; Slot 1 device context will be set during address_device.
   701 000037D1 C3                  <1>     ret
   702                              <1> 
   703                              <1> ; ============================================================================
   704                              <1> ; xhci_setup_cmd_ring - Initialize Command Ring
   705                              <1> ; ============================================================================
   706                              <1> xhci_setup_cmd_ring:
   707 000037D2 57                  <1>     push rdi
   708                              <1> 
   709                              <1>     ; Command Ring at XHCI_CMD_RING_ADDR, already zeroed
   710                              <1>     ; Set last TRB as Link TRB pointing back to start
   711 000037D3 BF00009100          <1>     mov rdi, XHCI_CMD_RING_ADDR
   712                              <1>     ; Link TRB at entry 255 (offset 255 * 16)
   713 000037D8 488D87F0FF0000      <1>     lea rax, [rdi + (XHCI_RING_SIZE - 1) * XHCI_TRB_SIZE]
   714                              <1>     ; DWord 0-1: Ring Segment Pointer (64-bit) = start of ring
   715 000037DF 48C70000009100      <1>     mov qword [rax], XHCI_CMD_RING_ADDR
   716                              <1>     ; DWord 2: 0 (Interrupter Target)
   717 000037E6 C7400800000000      <1>     mov dword [rax + 8], 0
   718                              <1>     ; DWord 3: Type=Link (6), TC=1 (Toggle Cycle), Cycle=1
   719 000037ED C7400C03180000      <1>     mov dword [rax + 12], TRB_LINK | TRB_TC | TRB_CYCLE
   720                              <1> 
   721                              <1>     ; Initialize cmd ring state
   722 000037F4 C70425[50050000]00- <1>     mov dword [xhci_cmd_enqueue], 0
   722 000037FC 000000              <1>
   723 000037FF C60425[54050000]01  <1>     mov byte [xhci_cmd_cycle], 1
   724                              <1> 
   725 00003807 5F                  <1>     pop rdi
   726 00003808 C3                  <1>     ret
   727                              <1> 
   728                              <1> ; ============================================================================
   729                              <1> ; xhci_setup_event_ring - Initialize Event Ring and ERST
   730                              <1> ; ============================================================================
   731                              <1> xhci_setup_event_ring:
   732 00003809 56                  <1>     push rsi
   733                              <1> 
   734                              <1>     ; ERST entry 0: base = event ring address, size = 256
   735 0000380A BF00009200          <1>     mov rdi, XHCI_ERST_ADDR
   736 0000380F 48C70700009300      <1>     mov qword [rdi + 0], XHCI_EVT_RING_ADDR    ; Ring Segment Base Address
   737 00003816 C7470800100000      <1>     mov dword [rdi + 8], XHCI_RING_SIZE         ; Ring Segment Size
   738 0000381D C7470C00000000      <1>     mov dword [rdi + 12], 0                      ; Reserved
   739                              <1> 
   740                              <1>     ; Initialize event ring state
   741 00003824 C70425[5D050000]00- <1>     mov dword [xhci_evt_dequeue], 0
   741 0000382C 000000              <1>
   742 0000382F C60425[61050000]01  <1>     mov byte [xhci_evt_cycle], 1
   743                              <1> 
   744                              <1>     ; Program Runtime Registers for Interrupter 0
   745 00003837 488B3425[32050000]  <1>     mov rsi, [xhci_rt_base]
   746                              <1> 
   747                              <1>     ; ERSTSZ = 1
   748 0000383F C7462801000000      <1>     mov dword [rsi + XHCI_RT_IR0_ERSTSZ], 1
   749                              <1> 
   750                              <1>     ; ERDP = event ring start
   751 00003846 C7463800009300      <1>     mov dword [rsi + XHCI_RT_IR0_ERDP_LO], XHCI_EVT_RING_ADDR
   752 0000384D C7463C00000000      <1>     mov dword [rsi + XHCI_RT_IR0_ERDP_HI], 0
   753                              <1> 
   754                              <1>     ; ERSTBA = ERST address (must be written AFTER ERSTSZ)
   755 00003854 C7463000009200      <1>     mov dword [rsi + XHCI_RT_IR0_ERSTBA_LO], XHCI_ERST_ADDR
   756 0000385B C7463400000000      <1>     mov dword [rsi + XHCI_RT_IR0_ERSTBA_HI], 0
   757                              <1> 
   758 00003862 5E                  <1>     pop rsi
   759 00003863 C3                  <1>     ret
   760                              <1> 
   761                              <1> ; ============================================================================
   762                              <1> ; xhci_submit_cmd - Submit a TRB to command ring and wait for completion
   763                              <1> ; Input: R8 = dword0, R9 = dword1, R10 = dword2, R11 = dword3 (type|flags, no cycle)
   764                              <1> ; Returns: EAX = completion code (1=success), 0 on timeout
   765                              <1> ;          RBX = completion TRB dword3 (contains slot ID etc)
   766                              <1> ; ============================================================================
   767                              <1> global xhci_submit_cmd
   768                              <1> xhci_submit_cmd:
   769                              <1>     ; NOTE: RBX is a return value (DWord3 of completion event) - do NOT save/restore it
   770 00003864 51                  <1>     push rcx
   771 00003865 52                  <1>     push rdx
   772 00003866 56                  <1>     push rsi
   773 00003867 57                  <1>     push rdi
   774                              <1> 
   775                              <1>     ; Get enqueue pointer
   776 00003868 8B3C25[50050000]    <1>     mov edi, [xhci_cmd_enqueue]
   777                              <1> 
   778                              <1>     ; Check for Link TRB (entry 255)
   779 0000386F 81FFFF0F0000        <1>     cmp edi, XHCI_RING_SIZE - 1
   780 00003875 7C3F                <1>     jl .no_wrap
   781                              <1> 
   782                              <1>     ; We hit the Link TRB - toggle cycle and wrap
   783                              <1>     
   784                              <1>     ; Debug: 'C'
   785 00003877 50                  <1>     push rax
   786 00003878 52                  <1>     push rdx
   787 00003879 66BAF803            <1>     mov dx, 0x3F8
   788 0000387D B043                <1>     mov al, 'C'
   789 0000387F EE                  <1>     out dx, al
   790 00003880 5A                  <1>     pop rdx
   791 00003881 58                  <1>     pop rax
   792                              <1>     
   793                              <1>     ; Update Link TRB cycle bit
   794 00003882 BE00009100          <1>     mov rsi, XHCI_CMD_RING_ADDR
   795 00003887 488D86F0FF0000      <1>     lea rax, [rsi + (XHCI_RING_SIZE - 1) * XHCI_TRB_SIZE]
   796 0000388E 8B480C              <1>     mov ecx, [rax + 12]
   797                              <1>     ; Set/clear cycle bit based on current cmd_cycle
   798 00003891 83E1FE              <1>     and ecx, ~1                   ; Clear cycle
   799 00003894 0FB61425[54050000]  <1>     movzx edx, byte [xhci_cmd_cycle]
   800 0000389C 09D1                <1>     or ecx, edx
   801 0000389E 89480C              <1>     mov [rax + 12], ecx
   802                              <1> 
   803                              <1>     ; Toggle cycle
   804 000038A1 803425[54050000]01  <1>     xor byte [xhci_cmd_cycle], 1
   805 000038A9 C70425[50050000]00- <1>     mov dword [xhci_cmd_enqueue], 0
   805 000038B1 000000              <1>
   806 000038B4 31FF                <1>     xor edi, edi
   807                              <1> 
   808                              <1> .no_wrap:
   809                              <1>     ; Write TRB at enqueue position
   810 000038B6 BE00009100          <1>     mov rsi, XHCI_CMD_RING_ADDR
   811 000038BB 6BC710              <1>     imul eax, edi, XHCI_TRB_SIZE
   812 000038BE 4801C6              <1>     add rsi, rax
   813                              <1> 
   814 000038C1 448906              <1>     mov [rsi + 0], r8d            ; DWord 0
   815 000038C4 44894E04            <1>     mov [rsi + 4], r9d            ; DWord 1
   816 000038C8 44895608            <1>     mov [rsi + 8], r10d           ; DWord 2
   817                              <1>     ; DWord 3: OR in cycle bit
   818 000038CC 4489D8              <1>     mov eax, r11d
   819 000038CF 0FB60C25[54050000]  <1>     movzx ecx, byte [xhci_cmd_cycle]
   820 000038D7 09C8                <1>     or eax, ecx
   821 000038D9 89460C              <1>     mov [rsi + 12], eax
   822                              <1> 
   823                              <1>     ; Advance enqueue
   824 000038DC FFC7                <1>     inc edi
   825 000038DE 893C25[50050000]    <1>     mov [xhci_cmd_enqueue], edi
   826                              <1> 
   827                              <1>     ; Ring doorbell 0 (host controller command)
   828 000038E5 488B3425[2A050000]  <1>     mov rsi, [xhci_db_base]
   829 000038ED C70600000000        <1>     mov dword [rsi], 0
   830                              <1> 
   831                              <1>     ; Serial: 'v' = doorbell rung
   832 000038F3 50                  <1>     push rax
   833 000038F4 52                  <1>     push rdx
   834 000038F5 66BAF803            <1>     mov dx, 0x3F8
   835 000038F9 B076                <1>     mov al, 'v'
   836 000038FB EE                  <1>     out dx, al
   837 000038FC 5A                  <1>     pop rdx
   838 000038FD 58                  <1>     pop rax
   839                              <1> 
   840                              <1>     ; Poll event ring for Command Completion (PIT-based 2-second timeout + spin fallback)
   841 000038FE 488B0425[D0000000]  <1>     mov rax, [tick_count]
   842 00003906 4805C8000000        <1>     add rax, 200                  ; 200 ticks = 2 seconds at 100Hz
   843 0000390C 48890425[55050000]  <1>     mov [xhci_cmd_deadline], rax  ; store deadline (not rbx - rbx is return value)
   844 00003914 B9005A6202          <1>     mov ecx, 40000000             ; ~20M iterations spin fallback
   845                              <1> .poll:
   846 00003919 51                  <1>     push rcx
   847 0000391A E861000000          <1>     call xhci_poll_event
   848 0000391F 59                  <1>     pop rcx
   849 00003920 85C0                <1>     test eax, eax
   850 00003922 7532                <1>     jnz .got_event
   851                              <1> 
   852 00003924 FFC9                <1>     dec ecx
   853 00003926 741F                <1>     jz .cmd_fail_spin
   854                              <1> 
   855 00003928 488B0425[D0000000]  <1>     mov rax, [tick_count]
   856 00003930 483B0425[55050000]  <1>     cmp rax, [xhci_cmd_deadline]
   857 00003938 7CDF                <1>     jl .poll
   858                              <1> 
   859                              <1>     ; PIT timeout
   860 0000393A 50                  <1>     push rax
   861 0000393B 52                  <1>     push rdx
   862 0000393C 66BAF803            <1>     mov dx, 0x3F8
   863 00003940 B05A                <1>     mov al, 'Z'
   864 00003942 EE                  <1>     out dx, al
   865 00003943 5A                  <1>     pop rdx
   866 00003944 58                  <1>     pop rax
   867 00003945 EB0B                <1>     jmp .cmd_fail
   868                              <1> 
   869                              <1> .cmd_fail_spin:
   870                              <1>     ; Spin counter timeout
   871 00003947 50                  <1>     push rax
   872 00003948 52                  <1>     push rdx
   873 00003949 66BAF803            <1>     mov dx, 0x3F8
   874 0000394D B07A                <1>     mov al, 'z'
   875 0000394F EE                  <1>     out dx, al
   876 00003950 5A                  <1>     pop rdx
   877 00003951 58                  <1>     pop rax
   878                              <1> 
   879                              <1> .cmd_fail:
   880                              <1>     ; Timeout
   881 00003952 31C0                <1>     xor eax, eax
   882 00003954 EB25                <1>     jmp .cmd_ret
   883                              <1> 
   884                              <1> .got_event:
   885                              <1>     ; EAX = completion code, EBX = dword3
   886                              <1>     ; Check TRB type in dword3 - should be CMD_COMPLETION
   887 00003956 89D9                <1>     mov ecx, ebx
   888 00003958 81E100FC0000        <1>     and ecx, (0x3F << 10)         ; Type mask
   889 0000395E 81F900840000        <1>     cmp ecx, TRB_CMD_COMPLETION
   890 00003964 75B3                <1>     jne .poll                     ; Not our event, keep polling
   891                              <1> 
   892                              <1>     ; Serial: print completion code digit
   893 00003966 50                  <1>     push rax
   894 00003967 52                  <1>     push rdx
   895 00003968 66BAF803            <1>     mov dx, 0x3F8
   896 0000396C 50                  <1>     push rax
   897 0000396D 240F                <1>     and al, 0x0F
   898 0000396F 0430                <1>     add al, '0'
   899 00003971 3C39                <1>     cmp al, '9'
   900 00003973 7E02                <1>     jle .cc_ok
   901 00003975 0407                <1>     add al, 7
   902                              <1> .cc_ok:
   903 00003977 EE                  <1>     out dx, al
   904 00003978 58                  <1>     pop rax
   905 00003979 5A                  <1>     pop rdx
   906 0000397A 58                  <1>     pop rax
   907                              <1> 
   908                              <1>     ; Return completion code
   909                              <1>     ; (already in EAX from xhci_poll_event)
   910                              <1> 
   911                              <1> .cmd_ret:
   912 0000397B 5F                  <1>     pop rdi
   913 0000397C 5E                  <1>     pop rsi
   914 0000397D 5A                  <1>     pop rdx
   915 0000397E 59                  <1>     pop rcx
   916                              <1>     ; NOTE: rbx is NOT restored - it holds the return value (DWord3 of completion event)
   917 0000397F C3                  <1>     ret
   918                              <1> 
   919                              <1> ; ============================================================================
   920                              <1> ; xhci_poll_event - Check event ring for one event
   921                              <1> ; Returns: EAX = completion code (0 if no event), EBX = dword3, ECX = dword0
   922                              <1> ; ============================================================================
   923                              <1> global xhci_poll_event
   924                              <1> xhci_poll_event:
   925 00003980 56                  <1>     push rsi
   926 00003981 57                  <1>     push rdi
   927                              <1> 
   928 00003982 8B3C25[5D050000]    <1>     mov edi, [xhci_evt_dequeue]
   929 00003989 BE00009300          <1>     mov rsi, XHCI_EVT_RING_ADDR
   930 0000398E 6BC710              <1>     imul eax, edi, XHCI_TRB_SIZE
   931 00003991 4801C6              <1>     add rsi, rax
   932                              <1> 
   933                              <1>     ; Check cycle bit
   934 00003994 8B460C              <1>     mov eax, [rsi + 12]
   935 00003997 89C3                <1>     mov ebx, eax
   936 00003999 83E001              <1>     and eax, 1                    ; Cycle bit of TRB
   937 0000399C 0FB60C25[61050000]  <1>     movzx ecx, byte [xhci_evt_cycle]
   938 000039A4 39C8                <1>     cmp eax, ecx
   939 000039A6 7556                <1>     jne .no_event                 ; Cycle doesn't match, no new event
   940                              <1> 
   941                              <1>     ; We have an event!
   942 000039A8 8B0E                <1>     mov ecx, [rsi + 0]            ; DWord 0 (TRB pointer low or slot-specific)
   943 000039AA 8B5E0C              <1>     mov ebx, [rsi + 12]           ; DWord 3 (type, slot ID, etc.)
   944                              <1> 
   945                              <1>     ; Completion code from DWord 2, bits 31:24
   946 000039AD 8B4608              <1>     mov eax, [rsi + 8]
   947 000039B0 C1E818              <1>     shr eax, 24                   ; Completion code
   948                              <1> 
   949                              <1>     ; Advance dequeue
   950 000039B3 FFC7                <1>     inc edi
   951 000039B5 81FF00100000        <1>     cmp edi, XHCI_RING_SIZE
   952 000039BB 7C15                <1>     jl .no_evt_wrap
   953 000039BD 31FF                <1>     xor edi, edi
   954 000039BF 803425[61050000]01  <1>     xor byte [xhci_evt_cycle], 1  ; Toggle cycle on wrap
   955                              <1>     
   956                              <1>     ; Debug: 'W' (Event Wrap)
   957 000039C7 50                  <1>     push rax
   958 000039C8 52                  <1>     push rdx
   959 000039C9 66BAF803            <1>     mov dx, 0x3F8
   960 000039CD B057                <1>     mov al, 'W'
   961 000039CF EE                  <1>     out dx, al
   962 000039D0 5A                  <1>     pop rdx
   963 000039D1 58                  <1>     pop rax
   964                              <1> 
   965                              <1> .no_evt_wrap:
   966 000039D2 893C25[5D050000]    <1>     mov [xhci_evt_dequeue], edi
   967                              <1> 
   968                              <1>     ; Update ERDP
   969 000039D9 50                  <1>     push rax
   970 000039DA 53                  <1>     push rbx
   971 000039DB 488B3425[32050000]  <1>     mov rsi, [xhci_rt_base]
   972                              <1>     ; ERDP = address of next TRB to process
   973 000039E3 89F8                <1>     mov eax, edi
   974 000039E5 C1E004              <1>     shl eax, 4                    ; * 16
   975 000039E8 0500009300          <1>     add eax, XHCI_EVT_RING_ADDR
   976 000039ED 83C808              <1>     or eax, (1 << 3)             ; EHB (Event Handler Busy) clear
   977 000039F0 894638              <1>     mov [rsi + XHCI_RT_IR0_ERDP_LO], eax
   978 000039F3 C7463C00000000      <1>     mov dword [rsi + XHCI_RT_IR0_ERDP_HI], 0
   979 000039FA 5B                  <1>     pop rbx
   980 000039FB 58                  <1>     pop rax
   981                              <1> 
   982 000039FC EB06                <1>     jmp .evt_ret
   983                              <1> 
   984                              <1> .no_event:
   985 000039FE 31C0                <1>     xor eax, eax
   986 00003A00 31DB                <1>     xor ebx, ebx
   987 00003A02 31C9                <1>     xor ecx, ecx
   988                              <1> 
   989                              <1> .evt_ret:
   990 00003A04 5F                  <1>     pop rdi
   991 00003A05 5E                  <1>     pop rsi
   992 00003A06 C3                  <1>     ret
   993                              <1> 
   994                              <1> ; ============================================================================
