   147 00004377 EBC3                <1>     jmp .tport_wait_prc
   148                              <1> .tport_reset_done:
   149                              <1>     ; Clear PRC
   150 00004379 0FB60425[6C050000]  <1>     movzx eax, byte [xhci_port_num]
   151 00004381 FFC8                <1>     dec eax
   152 00004383 C1E004              <1>     shl eax, 4
   153 00004386 488B3425[22050000]  <1>     mov rsi, [xhci_op_base]
   154 0000438E 4881C600040000      <1>     add rsi, 0x400
   155 00004395 8B1C06              <1>     mov ebx, [rsi + rax + XHCI_PORTSC]
   156 00004398 81E3FFFF09FF        <1>     and ebx, ~XHCI_PORTSC_CHANGE_BITS
   157 0000439E 81CB00002000        <1>     or  ebx, XHCI_PORTSC_PRC
   158 000043A4 891C06              <1>     mov [rsi + rax + XHCI_PORTSC], ebx
   159                              <1>     ; Read updated speed after reset
   160 000043A7 8B1C06              <1>     mov ebx, [rsi + rax + XHCI_PORTSC]
   161 000043AA C1EB0A              <1>     shr ebx, XHCI_PORTSC_SPEED_SHIFT
   162 000043AD 83E30F              <1>     and ebx, 0x0F
   163 000043B0 881C25[6E050000]    <1>     mov [xhci_port_speed], bl
   164 000043B7 EB4B                <1>     jmp .do_enable_slot
   165                              <1> .tport_next:
   166 000043B9 FFC2                <1>     inc edx
   167 000043BB E913FFFFFF          <1>     jmp .tport_scan
   168                              <1> 
   169                              <1> .try_next_controller:
   170 000043C0 FE0425[D1070000]    <1>     inc byte [usb_ctrl_attempts]
   171 000043C7 803C25[D1070000]04  <1>     cmp byte [usb_ctrl_attempts], 4    ; Max 4 XHCI controllers to try
   172 000043CF 0F8F1E020000        <1>     jg .fail
   173                              <1> 
   174 000043D5 E83BEEFFFF          <1>     call xhci_init
   175 000043DA 85C0                <1>     test eax, eax
