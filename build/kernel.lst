   110 000042F3 880C25[6C050000]    <1>     mov [xhci_port_num], cl             ; Save 1-based port number
   111                              <1>     ; Save speed
   112 000042FA C1EB0A              <1>     shr ebx, XHCI_PORTSC_SPEED_SHIFT
   113 000042FD 83E30F              <1>     and ebx, 0x0F
   114 00004300 881C25[6E050000]    <1>     mov [xhci_port_speed], bl
   115                              <1>     ; Reset the port so device can be enumerated
   116 00004307 50                  <1>     push rax                            ; save port byte offset across reload
   117 00004308 488B3425[22050000]  <1>     mov rsi, [xhci_op_base]
   118 00004310 4881C600040000      <1>     add rsi, 0x400
   119 00004317 58                  <1>     pop rax
   120 00004318 8B1C06              <1>     mov ebx, [rsi + rax + XHCI_PORTSC]
   121 0000431B 81E3FFFF09FF        <1>     and ebx, ~XHCI_PORTSC_CHANGE_BITS
   122 00004321 83E3FD              <1>     and ebx, ~XHCI_PORTSC_PED
   123 00004324 83CB10              <1>     or  ebx, XHCI_PORTSC_PR
   124 00004327 891C06              <1>     mov [rsi + rax + XHCI_PORTSC], ebx
   125                              <1>     ; Wait for PRC (Port Reset Change) with 50-tick timeout
   126                              <1>     ; Recompute port offset each iteration from xhci_port_num
   127 0000432A 488B1C25[D0000000]  <1>     mov rbx, [tick_count]
   128 00004332 4883C332            <1>     add rbx, 50
   129 00004336 41B980969800        <1>     mov r9d, 10000000
   130                              <1> .tport_wait_prc:
   131 0000433C 0FB60425[6C050000]  <1>     movzx eax, byte [xhci_port_num]
   132 00004344 FFC8                <1>     dec eax
   133 00004346 C1E004              <1>     shl eax, 4
   134 00004349 488B3425[22050000]  <1>     mov rsi, [xhci_op_base]
   135 00004351 4881C600040000      <1>     add rsi, 0x400
   136 00004358 8B1406              <1>     mov edx, [rsi + rax + XHCI_PORTSC]
   137 0000435B F7C200002000        <1>     test edx, XHCI_PORTSC_PRC
   138 00004361 7516                <1>     jnz .tport_reset_done
   139                              <1>     
   140 00004363 41FFC9              <1>     dec r9d
   141 00004366 7411                <1>     jz .tport_reset_done
   142                              <1>     
   143 00004368 488B0425[D0000000]  <1>     mov rax, [tick_count]
   144 00004370 4839D8              <1>     cmp rax, rbx
