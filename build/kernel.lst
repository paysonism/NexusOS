   166                              <1> ; --- Free a physical page ---
   167                              <1> ; RDI = physical address
   168                              <1> global page_free
   169                              <1> page_free:
   170 0000114B 50                  <1>     push rax
   171 0000114C 51                  <1>     push rcx
   172                              <1> 
   173 0000114D 48C1EF0C            <1>     shr rdi, 12              ; Convert to page number
   174 00001151 4889F8              <1>     mov rax, rdi
   175 00001154 48C1E803            <1>     shr rax, 3               ; Byte index
   176 00001158 4889F9              <1>     mov rcx, rdi
   177 0000115B 4883E107            <1>     and rcx, 7               ; Bit index
