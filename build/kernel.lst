   134                              <1> ; --- itoa: Convert integer to ASCII string ---
   135                              <1> ; RDI = value (unsigned 64-bit), RSI = buffer, EDX = radix (10 or 16)
   136                              <1> ; Returns: RAX = pointer to buffer
   137                              <1> global fn_itoa
   138                              <1> fn_itoa:
   139 0000C8FB 53                  <1>     push rbx
   140 0000C8FC 51                  <1>     push rcx
   141 0000C8FD 57                  <1>     push rdi
   142 0000C8FE 56                  <1>     push rsi
   143 0000C8FF 4150                <1>     push r8
   144                              <1> 
   145 0000C901 4889F8              <1>     mov rax, rdi             ; Value
   146 0000C904 4989F0              <1>     mov r8, rsi              ; Buffer start
   147 0000C907 4889F3              <1>     mov rbx, rsi             ; Working pointer
   148 0000C90A 89D1                <1>     mov ecx, edx             ; Radix
   149                              <1> 
   150                              <1>     ; Special case: 0
   151 0000C90C 4885C0              <1>     test rax, rax
   152 0000C90F 7508                <1>     jnz .itoa_loop
   153 0000C911 C60330              <1>     mov byte [rbx], '0'
   154 0000C914 48FFC3              <1>     inc rbx
   155 0000C917 EB3C                <1>     jmp .itoa_terminate
   156                              <1> 
   157                              <1> .itoa_loop:
   158 0000C919 4885C0              <1>     test rax, rax
   159 0000C91C 7419                <1>     jz .itoa_reverse
   160 0000C91E 31D2                <1>     xor edx, edx
   161 0000C920 48F7F1              <1>     div rcx                  ; RAX = quotient, RDX = remainder
   162 0000C923 80FA0A              <1>     cmp dl, 10
   163 0000C926 7C05                <1>     jl .digit
   164 0000C928 80C237              <1>     add dl, 'A' - 10
   165 0000C92B EB03                <1>     jmp .store
   166                              <1> .digit:
   167 0000C92D 80C230              <1>     add dl, '0'
   168                              <1> .store:
   169 0000C930 8813                <1>     mov [rbx], dl
   170 0000C932 48FFC3              <1>     inc rbx
   171 0000C935 EBE2                <1>     jmp .itoa_loop
   172                              <1> 
   173                              <1> .itoa_reverse:
   174                              <1>     ; Null-terminate
   175 0000C937 C60300              <1>     mov byte [rbx], 0
   176 0000C93A 48FFCB              <1>     dec rbx                  ; Point to last digit
   177                              <1> 
   178                              <1>     ; Reverse the string
   179 0000C93D 4C89C7              <1>     mov rdi, r8              ; Start
   180                              <1> .rev_loop:
   181 0000C940 4839DF              <1>     cmp rdi, rbx
   182 0000C943 7D13                <1>     jge .itoa_done
   183 0000C945 8A07                <1>     mov al, [rdi]
   184 0000C947 8A0B                <1>     mov cl, [rbx]
   185 0000C949 880F                <1>     mov [rdi], cl
   186 0000C94B 8803                <1>     mov [rbx], al
   187 0000C94D 48FFC7              <1>     inc rdi
   188 0000C950 48FFCB              <1>     dec rbx
   189 0000C953 EBEB                <1>     jmp .rev_loop
   190                              <1> 
   191                              <1> .itoa_terminate:
   192 0000C955 C60300              <1>     mov byte [rbx], 0
   193                              <1> 
   194                              <1> .itoa_done:
   195 0000C958 4C89C0              <1>     mov rax, r8              ; Return buffer pointer
   196                              <1> 
   197 0000C95B 4158                <1>     pop r8
   198 0000C95D 5E                  <1>     pop rsi
   199 0000C95E 5F                  <1>     pop rdi
   200 0000C95F 59                  <1>     pop rcx
   201 0000C960 5B                  <1>     pop rbx
   202 0000C961 C3                  <1>     ret
   203                              <1> 
   204                              <1> ; --- itoa_dec2: Format a number as 2-digit decimal with leading zero ---
   205                              <1> ; EDI = value (0-99), RSI = buffer (at least 3 bytes)
   206                              <1> global fn_itoa_dec2
   207                              <1> fn_itoa_dec2:
   208 0000C962 50                  <1>     push rax
   209 0000C963 52                  <1>     push rdx
   210                              <1> 
   211 0000C964 89F8                <1>     mov eax, edi
   212 0000C966 31D2                <1>     xor edx, edx
   213 0000C968 B90A000000          <1>     mov ecx, 10
   214 0000C96D F7F1                <1>     div ecx                  ; EAX = tens, EDX = ones
   215                              <1> 
   216 0000C96F 0430                <1>     add al, '0'
   217 0000C971 8806                <1>     mov [rsi], al
   218 0000C973 80C230              <1>     add dl, '0'
   219 0000C976 885601              <1>     mov [rsi + 1], dl
   220 0000C979 C6460200            <1>     mov byte [rsi + 2], 0
   221                              <1> 
   222 0000C97D 5A                  <1>     pop rdx
   223 0000C97E 58                  <1>     pop rax
   224 0000C97F C3                  <1>     ret
   225                              <1> 
   226                              <1> ; --- uint32_to_str: Wrapper for fn_itoa (decimal) ---
   227                              <1> global uint32_to_str
   228                              <1> uint32_to_str:
   229 0000C980 BA0A000000          <1>     mov edx, 10
   230 0000C985 E971FFFFFF          <1>     jmp fn_itoa
