  1190                              <1>     
  1191 00004E03 3C04                <1>     cmp al, USB_DESC_INTERFACE
  1192 00004E05 7406                <1>     je .check_interface
  1193                              <1>     
  1194 00004E07 3C05                <1>     cmp al, USB_DESC_ENDPOINT
