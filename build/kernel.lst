    16                              <1> ; --- Initialize display driver ---
    17                              <1> ; Reads VBE info from 0x9000 (set by stage2)
    18                              <1> global display_init
    19                              <1> display_init:
    20                              <1>     ; Read framebuffer address (full 64-bit for UEFI compatibility)
    21 00001D07 488B042500900000    <1>     mov rax, [0x9000]
    22 00001D0F 48890425[FA010000]  <1>     mov [fb_addr], rax
    23                              <1> 
    24                              <1>     ; Read dimensions
    25 00001D17 8B042508900000      <1>     mov eax, [0x9008]
