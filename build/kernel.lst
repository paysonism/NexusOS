   524 00003694 0D00000001          <1>     or eax, (1 << 24)
   525 00003699 8906                <1>     mov [rsi], eax
   526                              <1> .own_done_pop:
   527 0000369B 59                  <1>     pop rcx
   528 0000369C 5A                  <1>     pop rdx
   529                              <1> 
   530                              <1> .own_done:
