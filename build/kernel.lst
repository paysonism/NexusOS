   123                              <1> ; --- Simpler cursor draw: directly plot pixels ---
   124                              <1> ; EDI = x, ESI = y - draws a standard arrow cursor (or move cursor if cursor_mode=1)
   125                              <1> global cursor_draw
   126                              <1> cursor_draw:
   127 00008E76 50                  <1>     push rax
   128 00008E77 53                  <1>     push rbx
   129 00008E78 51                  <1>     push rcx
   130 00008E79 52                  <1>     push rdx
   131 00008E7A 4150                <1>     push r8
   132 00008E7C 4151                <1>     push r9
   133 00008E7E 4152                <1>     push r10
   134 00008E80 4153                <1>     push r11
   135 00008E82 4154                <1>     push r12
   136 00008E84 4155                <1>     push r13
