   151 00001132 0FAB0F              <1>     bts dword [rdi], ecx
   152                              <1> 
   153                              <1>     ; Calculate physical address
   154 00001135 4801CB              <1>     add rbx, rcx              ; Page number
   155 00001138 48C1E30C            <1>     shl rbx, 12               ; * 4096 = physical address
