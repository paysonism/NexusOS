   829 00007F0A 4C39C7              <1>     cmp rdi, r8
   830 00007F0D 7D17                <1>     jge .scan_all
   831 00007F0F 4C8B4810            <1>     mov r9, [rax + WIN_OFF_Y]
   832 00007F13 4C39CE              <1>     cmp rsi, r9
   833 00007F16 7C0E                <1>     jl .scan_all
