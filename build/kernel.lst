     9                              <1> section .text
    10                              <1> 
    11                              <1> global ata_read_sectors
    12                              <1> global ata_write_sectors
    13                              <1> global ata_drive_select_byte
    14                              <1> global ata_drive_sel
    15                              <1> 
    16                              <1> ; ATA PIO ports (primary controller)
    17                              <1> ATA_DATA        equ 0x1F0
    18                              <1> ATA_ERROR       equ 0x1F1
    19                              <1> ATA_SECT_COUNT  equ 0x1F2
    20                              <1> ATA_LBA_LO     equ 0x1F3
    21                              <1> ATA_LBA_MID     equ 0x1F4
    22                              <1> ATA_LBA_HI      equ 0x1F5
    23                              <1> ATA_DRIVE       equ 0x1F6
    24                              <1> ATA_CMD         equ 0x1F7
    25                              <1> ATA_STATUS      equ 0x1F7
    26                              <1> 
    27                              <1> ATA_CMD_READ    equ 0x20
    28                              <1> ATA_CMD_WRITE   equ 0x30
    29                              <1> 
    30                              <1> ATA_SR_BSY      equ 0x80
    31                              <1> ATA_SR_DRQ      equ 0x08
    32                              <1> ATA_SR_ERR      equ 0x01
    33                              <1> 
    34                              <1> ; ============================================================================
    35                              <1> ; ata_read_sectors - Read sectors from disk using LBA28 PIO
    36                              <1> ; rdi = LBA (sector number)
    37                              <1> ; rsi = pointer to destination buffer
    38                              <1> ; edx = number of sectors to read
    39                              <1> ; Returns: eax = 0 on success, -1 on error
    40                              <1> ; ============================================================================
    41                              <1> ata_read_sectors:
    42 00003065 53                  <1>     push rbx
    43 00003066 51                  <1>     push rcx
    44 00003067 52                  <1>     push rdx
    45 00003068 57                  <1>     push rdi
    46 00003069 56                  <1>     push rsi
    47 0000306A 4154                <1>     push r12
    48 0000306C 4155                <1>     push r13
    49                              <1> 
    50 0000306E 4989FC              <1>     mov r12, rdi         ; LBA
    51 00003071 4989F5              <1>     mov r13, rsi         ; buffer
    52 00003074 89D3                <1>     mov ebx, edx         ; sector count
    53                              <1> 
    54                              <1> .read_loop:
    55 00003076 85DB                <1>     test ebx, ebx
    56 00003078 745B                <1>     jz .read_done
    57                              <1> 
    58                              <1>     ; Select drive and wait for it to be ready
    59 0000307A E838010000          <1>     call ata_select_drive
    60 0000307F 85C0                <1>     test eax, eax
    61 00003081 7556                <1>     jnz .read_error
