   166 00001E8D 75EF                <1>     jnz .row_loop
   167                              <1> 
   168                              <1> .rect_done:
   169 00001E8F 415D                <1>     pop r13
   170 00001E91 415C                <1>     pop r12
   171 00001E93 415B                <1>     pop r11
   172 00001E95 415A                <1>     pop r10
   173 00001E97 4159                <1>     pop r9
   174 00001E99 5E                  <1>     pop rsi
   175 00001E9A 5F                  <1>     pop rdi
   176 00001E9B 5A                  <1>     pop rdx
   177 00001E9C 59                  <1>     pop rcx
   178 00001E9D 5B                  <1>     pop rbx
   179 00001E9E 58                  <1>     pop rax
   180 00001E9F C3                  <1>     ret
