   243                              <1>     ; === FAST PATH: No clipping needed ===
   244                              <1>     ; Pre-calculate row start in back buffer
   245 00001F5B 4489D8              <1>     mov eax, r11d
   246 00001F5E 0FAF0425[12020000]  <1>     imul eax, [scr_pitch]
   247 00001F66 67428D0490          <1>     lea eax, [eax + r10d * 4]
