    50                                  %include "src/drivers/spi.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - SPI Controller Driver
     3                              <1> ; Supports:
     4                              <1> ;   - AMD FCH GSPI (fixed MMIO 0xFEC00000)
     5                              <1> ;   - AMD Sensor Fusion Hub (PCI 0x1022:0x15E4, BAR0)
     6                              <1> ;   - Intel GSPI (PCI 0x8086:various, BAR0 = DW SPI MMIO)
     7                              <1> ; ============================================================================
     8                              <1> bits 64
     9                              <1> 
    10                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> 
    33                              <2> ; --- Stage 2 disk layout ---
    34                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    35                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    36                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    37                              <2> 
    38                              <2> ; --- Screen ---
    39                              <2> SCREEN_WIDTH        equ 1024
    40                              <2> SCREEN_HEIGHT       equ 768
    41                              <2> SCREEN_BPP          equ 32
    42                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    43                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    44                              <2> 
    45                              <2> 
    46                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    47                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    48                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    49                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    50                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    51                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    52                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    53                              <2> 
    54                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    55                              <2> COLOR_BLACK         equ 0x00000000
    56                              <2> COLOR_WHITE         equ 0x00FFFFFF
    57                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    58                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    59                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    60                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    61                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    62                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    63                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    64                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    65                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    66                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    67                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    68                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    69                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    70                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    71                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    72                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    73                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    74                              <2> COLOR_START_HOVER    equ 0x00338833
    75                              <2> 
    76                              <2> ; --- Window Manager ---
    77                              <2> MAX_WINDOWS         equ 8
    78                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    79                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    80                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    81                              <2> TITLEBAR_HEIGHT     equ 24
    82                              <2> BORDER_WIDTH        equ 2
    83                              <2> CLOSE_BTN_SIZE      equ 18
    84                              <2> MIN_BTN_SIZE        equ 18
    85                              <2> MIN_WINDOW_W        equ 200
    86                              <2> MIN_WINDOW_H        equ 100
    87                              <2> 
    88                              <2> ; --- Taskbar ---
    89                              <2> TASKBAR_HEIGHT      equ 36
    90                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    91                              <2> START_BTN_W         equ 70
    92                              <2> START_BTN_H         equ 28
    93                              <2> START_BTN_X         equ 4
    94                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    95                              <2> CLOCK_WIDTH         equ 64
    96                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    97                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    98                              <2> 
    99                              <2> ; --- Keyboard ---
   100                              <2> KB_BUFFER_SIZE      equ 64
   101                              <2> 
   102                              <2> ; --- Mouse ---
   103                              <2> MOUSE_BUFFER_SIZE   equ 64
   104                              <2> CURSOR_WIDTH        equ 12
   105                              <2> CURSOR_HEIGHT       equ 19
   106                              <2> 
   107                              <2> ; --- PIT ---
   108                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   109                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   110                              <2> 
   111                              <2> ; --- PIC vectors ---
   112                              <2> IRQ_BASE_MASTER     equ 32
   113                              <2> IRQ_BASE_SLAVE      equ 40
   114                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   115                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   116                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   117                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   118                              <2> 
   119                              <2> ; --- Font ---
   120                              <2> FONT_WIDTH          equ 8
   121                              <2> FONT_HEIGHT         equ 16
   122                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   123                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   124                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   125                              <2> 
   126                              <2> ; --- Window flags ---
   127                              <2> WF_VISIBLE          equ 0x01
   128                              <2> WF_FOCUSED          equ 0x02
   129                              <2> WF_DRAGGING         equ 0x04
   130                              <2> WF_MINIMIZED        equ 0x08
   131                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   132                              <2> 
   133                              <2> ; --- Mouse event types ---
   134                              <2> MEVT_MOVE           equ 1
   135                              <2> MEVT_LCLICK         equ 2
   136                              <2> MEVT_RCLICK         equ 3
   137                              <2> MEVT_LRELEASE       equ 4
   138                              <2> MEVT_RRELEASE       equ 5
   139                              <2> 
   140                              <2> ; --- Key modifier flags ---
   141                              <2> KMOD_SHIFT          equ 0x01
   142                              <2> KMOD_CTRL           equ 0x02
   143                              <2> KMOD_ALT            equ 0x04
   144                              <2> 
   145                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   146                              <2> KEY_F1              equ 0xF1
   147                              <2> KEY_F2              equ 0xF2
   148                              <2> KEY_F3              equ 0xF3
   149                              <2> KEY_F4              equ 0xF4
   150                              <2> KEY_F5              equ 0xF5
   151                              <2> KEY_F6              equ 0xF6
   152                              <2> KEY_F7              equ 0xF7
   153                              <2> KEY_F8              equ 0xF8
   154                              <2> KEY_F9              equ 0xF9
   155                              <2> KEY_F10             equ 0xFA
   156                              <2> KEY_F11             equ 0xFB
   157                              <2> KEY_F12             equ 0xFC
   158                              <2> 
   159                              <2> ; --- USB/XHCI Memory Layout ---
   160                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   161                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   162                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   163                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   164                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   165                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   166                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   167                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   168                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   169                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   170                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   171                              <2> ; Slot 2 device support
   172                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   173                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   174                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   175                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   176                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   177                              <2> 
   178                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   179                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   180                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   181                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   182                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   183                              <2> XHCI_CAP_DBOFF      equ 0x14
   184                              <2> XHCI_CAP_RTSOFF     equ 0x18
   185                              <2> 
   186                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   187                              <2> XHCI_OP_USBCMD      equ 0x00
   188                              <2> XHCI_OP_USBSTS      equ 0x04
   189                              <2> XHCI_OP_PAGESIZE     equ 0x08
   190                              <2> XHCI_OP_DNCTRL      equ 0x14
   191                              <2> XHCI_OP_CRCR_LO     equ 0x18
   192                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   193                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   194                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   195                              <2> XHCI_OP_CONFIG      equ 0x38
   196                              <2> 
   197                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   198                              <2> XHCI_PORTSC         equ 0x00
   199                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   200                              <2> 
   201                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   202                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   203                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   204                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   205                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   206                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   207                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   208                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   209                              <2> 
   210                              <2> ; --- USBCMD bits ---
   211                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   212                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   213                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   214                              <2> 
   215                              <2> ; --- USBSTS bits ---
   216                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   217                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   218                              <2> 
   219                              <2> ; --- PORTSC bits ---
   220                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   221                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   222                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   223                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   224                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   225                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   226                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   227                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   228                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   229                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   230                              <2> 
   231                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   232                              <2> TRB_NORMAL           equ (1 << 10)
   233                              <2> TRB_SETUP            equ (2 << 10)
   234                              <2> TRB_DATA             equ (3 << 10)
   235                              <2> TRB_STATUS           equ (4 << 10)
   236                              <2> TRB_LINK             equ (6 << 10)
   237                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   238                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   239                              <2> TRB_CONFIG_EP        equ (12 << 10)
   240                              <2> TRB_EVAL_CTX         equ (13 << 10)
   241                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   242                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   243                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   244                              <2> 
   245                              <2> ; --- TRB Flag Bits (dword 3) ---
   246                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   247                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   248                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   249                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   250                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   251                              <2> 
   252                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   253                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   254                              <2> TRB_TRT_OUT          equ (2 << 16)
   255                              <2> TRB_TRT_IN           equ (3 << 16)
   256                              <2> 
   257                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   258                              <2> TRB_DIR_OUT          equ (0 << 16)
   259                              <2> TRB_DIR_IN           equ (1 << 16)
   260                              <2> 
   261                              <2> ; --- Ring sizes ---
   262                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   263                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   264                              <2> 
   265                              <2> ; --- USB Standard Request Codes ---
   266                              <2> USB_REQ_GET_DESC     equ 0x06
   267                              <2> USB_REQ_SET_CONFIG   equ 0x09
   268                              <2> USB_REQ_SET_IFACE    equ 0x0B
   269                              <2> 
   270                              <2> ; --- USB HID Request Codes ---
   271                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   272                              <2> 
   273                              <2> ; --- USB Descriptor Types ---
   274                              <2> USB_DESC_DEVICE      equ 0x01
   275                              <2> USB_DESC_CONFIG      equ 0x02
   276                              <2> USB_DESC_INTERFACE   equ 0x04
   277                              <2> USB_DESC_ENDPOINT    equ 0x05
   278                              <2> USB_DESC_HID         equ 0x21
   279                              <2> 
   280                              <2> ; --- USB Endpoint Types ---
   281                              <2> USB_EP_CONTROL       equ 0
   282                              <2> USB_EP_ISOCH         equ 1
   283                              <2> USB_EP_BULK          equ 2
   284                              <2> USB_EP_INTERRUPT     equ 3
   285                              <2> 
   286                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   287                              <2> XHCI_EP_NOT_VALID    equ 0
   288                              <2> XHCI_EP_ISOCH_OUT    equ 1
   289                              <2> XHCI_EP_BULK_OUT     equ 2
   290                              <2> XHCI_EP_INT_OUT      equ 3
   291                              <2> XHCI_EP_CONTROL      equ 4
   292                              <2> XHCI_EP_ISOCH_IN     equ 5
   293                              <2> XHCI_EP_BULK_IN      equ 6
   294                              <2> XHCI_EP_INT_IN       equ 7
   295                              <2> 
   296                              <2> ; --- XHCI Port Speeds ---
   297                              <2> XHCI_SPEED_FULL      equ 1
   298                              <2> XHCI_SPEED_LOW       equ 2
   299                              <2> XHCI_SPEED_HIGH      equ 3
   300                              <2> XHCI_SPEED_SUPER     equ 4
    11                              <1> 
    12                              <1> extern pci_read_conf_dword
    13                              <1> extern debug_print
    14                              <1> 
    15                              <1> ; DesignWare SPI register offsets
    16                              <1> %define DW_SPI_CTRLR0     0x00   ; Control 0
    17                              <1> %define DW_SPI_CTRLR1     0x04   ; Control 1 (NDF-1 for receive-only)
    18                              <1> %define DW_SPI_SSIENR     0x08   ; Enable (1=enabled)
    19                              <1> %define DW_SPI_SER        0x10   ; Slave enable register
    20                              <1> %define DW_SPI_BAUDR      0x14   ; Baud rate (div = ssi_clk / SCLK)
    21                              <1> %define DW_SPI_TXFTLR     0x18   ; TX FIFO threshold
    22                              <1> %define DW_SPI_RXFTLR     0x1C   ; RX FIFO threshold
    23                              <1> %define DW_SPI_TXFLR      0x20   ; TX FIFO level
    24                              <1> %define DW_SPI_RXFLR      0x24   ; RX FIFO level
    25                              <1> %define DW_SPI_SR         0x28   ; Status (bit0=busy, bit1=TFNF, bit2=TFE, bit3=RFNE)
    26                              <1> %define DW_SPI_DR         0x60   ; Data register (FIFO read/write)
    27                              <1> 
    28                              <1> ; CTRLR0 fields: DFS[3:0]=7 (8-bit), TMOD[9:8]=0 (TX+RX), SCPOL=0, SCPH=0
    29                              <1> %define SPI_CTRLR0_8BIT   0x00000007
    30                              <1> ; AMD FCH GSPI fixed base
    31                              <1> %define AMD_FCH_GSPI_BASE  0xFEC00000
    32                              <1> 
    33                              <1> ; Intel GSPI PCI vendor/device
    34                              <1> %define INTEL_VENDOR       0x8086
    35                              <1> ; AMD Sensor Fusion Hub PCI ID
    36                              <1> %define AMD_VENDOR         0x1022
    37                              <1> %define AMD_SFH_DEVID      0x15E4
    38                              <1> 
    39                              <1> section .text
    40                              <1> global spi_init
    41                              <1> global spi_transfer
    42                              <1> global spi_type
    43                              <1> 
    44                              <1> ; ============================================================================
    45                              <1> ; spi_init - Detect and initialize SPI controller
    46                              <1> ; Returns: EAX = 1 success, 0 fail
    47                              <1> ; Sets spi_base and spi_type
    48                              <1> ; ============================================================================
    49                              <1> spi_init:
    50 0000502B 53                  <1>     push rbx
    51 0000502C 51                  <1>     push rcx
    52 0000502D 52                  <1>     push rdx
    53 0000502E 57                  <1>     push rdi
    54 0000502F 4155                <1>     push r13
    55 00005031 4156                <1>     push r14
    56 00005033 4157                <1>     push r15
    57                              <1> 
    58 00005035 C60425[E5080000]00  <1>     mov byte [spi_type], 0
    59 0000503D 48C70425[DD080000]- <1>     mov qword [spi_base], 0
    59 00005045 00000000            <1>
    60                              <1> 
    61                              <1>     ; === Phase 1: Try AMD FCH GSPI at fixed MMIO ===
    62                              <1>     ; NOTE: 0xFEC00000 is also the IOAPIC base in QEMU - must verify DW SPI signature.
    63                              <1>     ; A real idle DW SPI SR has TFE(bit2)+TFNF(bit1) set = bits [2:1] = 0x06.
    64                              <1>     ; The IOAPIC at this address returns values without this pattern.
    65 00005049 41BF0000C0FE        <1>     mov r15, AMD_FCH_GSPI_BASE
    66 0000504F 418B4728            <1>     mov eax, [r15 + DW_SPI_SR]
    67 00005053 83F8FF              <1>     cmp eax, 0xFFFFFFFF
    68 00005056 741F                <1>     je .try_pci
    69                              <1>     ; Verify DW SPI idle signature: bits [2:1] must be set (TFE+TFNF)
    70 00005058 89C1                <1>     mov ecx, eax
    71 0000505A 83E106              <1>     and ecx, 0x06
    72 0000505D 83F906              <1>     cmp ecx, 0x06
    73 00005060 7515                <1>     jne .try_pci
    74                              <1> 
    75                              <1>     ; Confirmed DW SPI - init it
    76 00005062 4C893C25[DD080000]  <1>     mov [spi_base], r15
    77 0000506A C60425[E5080000]01  <1>     mov byte [spi_type], SPI_TYPE_AMD_FCH
    78 00005072 E9F3000000          <1>     jmp .init_dw_spi
    79                              <1> 
    80                              <1> .try_pci:
    81                              <1>     ; === Phase 2: PCI scan for AMD SFH and Intel GSPI ===
    82 00005077 4531ED              <1>     xor r13d, r13d          ; bus
    83                              <1> .pci_bus:
    84 0000507A 4181FD00010000      <1>     cmp r13d, 256
    85 00005081 0F8DDF000000        <1>     jge .fail
    86 00005087 4531F6              <1>     xor r14d, r14d          ; device
    87                              <1> .pci_dev:
    88 0000508A 4183FE20            <1>     cmp r14d, 32
    89 0000508E 0F8DCA000000        <1>     jge .next_bus
    90                              <1>     ; Read vendor/device at func 0
    91 00005094 4489E8              <1>     mov eax, r13d
    92 00005097 C1E010              <1>     shl eax, 16
    93 0000509A 4489F1              <1>     mov ecx, r14d
    94 0000509D C1E10B              <1>     shl ecx, 11
    95 000050A0 09C8                <1>     or eax, ecx
    96                              <1>     ; reg 0 = vendorID:deviceID
    97 000050A2 50                  <1>     push rax
    98 000050A3 E847E1FFFF          <1>     call pci_read_conf_dword
    99 000050A8 83F8FF              <1>     cmp eax, 0xFFFFFFFF
   100 000050AB 0F84A4000000        <1>     je .pci_next
   101                              <1> 
   102                              <1>     ; Check AMD SFH
   103 000050B1 89C1                <1>     mov ecx, eax
   104 000050B3 81E1FFFF0000        <1>     and ecx, 0xFFFF         ; vendor
   105 000050B9 81F922100000        <1>     cmp ecx, AMD_VENDOR
   106 000050BF 7535                <1>     jne .check_intel
   107 000050C1 C1E810              <1>     shr eax, 16             ; device ID
   108 000050C4 3DE4150000          <1>     cmp eax, AMD_SFH_DEVID
   109 000050C9 0F8586000000        <1>     jne .pci_next
   110                              <1>     ; Found AMD SFH - get BAR0
   111 000050CF 58                  <1>     pop rax
   112 000050D0 50                  <1>     push rax
   113 000050D1 83C810              <1>     or eax, 0x10            ; BAR0 register
   114 000050D4 E816E1FFFF          <1>     call pci_read_conf_dword
   115 000050D9 83E0F0              <1>     and eax, 0xFFFFFFF0
   116 000050DC 85C0                <1>     test eax, eax
   117 000050DE 7475                <1>     jz .pci_next
   118 000050E0 4189C7              <1>     mov r15d, eax          ; BAR0 as 32-bit (< 4GB)
   119 000050E3 4C893C25[DD080000]  <1>     mov [spi_base], r15
   120 000050EB C60425[E5080000]02  <1>     mov byte [spi_type], SPI_TYPE_AMD_SFH
   121 000050F3 58                  <1>     pop rax
   122 000050F4 EB74                <1>     jmp .init_dw_spi
   123                              <1> 
   124                              <1> .check_intel:
   125                              <1>     ; Check Intel GSPI: vendor 0x8086, class 0x0C80 or specific device IDs
   126 000050F6 25FFFF0000          <1>     and eax, 0xFFFF         ; restore vendor
   127 000050FB 3D86800000          <1>     cmp eax, INTEL_VENDOR
   128 00005100 7553                <1>     jne .pci_next
   129                              <1>     ; Read class code
   130 00005102 58                  <1>     pop rax
   131 00005103 50                  <1>     push rax
   132 00005104 83C808              <1>     or eax, 0x08
   133 00005107 E8E3E0FFFF          <1>     call pci_read_conf_dword
   134 0000510C C1E808              <1>     shr eax, 8              ; class:subclass:prog_if
   135 0000510F 25FFFF0000          <1>     and eax, 0xFFFF
   136 00005114 3D800C0000          <1>     cmp eax, 0x0C80         ; Serial Bus / Other
   137 00005119 7407                <1>     je .intel_spi_candidate
   138                              <1>     ; Also accept class 0x0C00 SPI
   139 0000511B 3D000C0000          <1>     cmp eax, 0x0C00
   140 00005120 7533                <1>     jne .pci_next
   141                              <1> .intel_spi_candidate:
   142                              <1>     ; Read BAR0
   143 00005122 58                  <1>     pop rax
   144 00005123 50                  <1>     push rax
   145 00005124 83C810              <1>     or eax, 0x10
   146 00005127 E8C3E0FFFF          <1>     call pci_read_conf_dword
   147 0000512C 83E0F0              <1>     and eax, 0xFFFFFFF0
   148 0000512F 85C0                <1>     test eax, eax
   149 00005131 7422                <1>     jz .pci_next
   150                              <1>     ; Verify DW SPI signature: SR should read 0x00000006 when idle (TFE+TFNF)
   151 00005133 4189C7              <1>     mov r15d, eax
   152 00005136 418B4F28            <1>     mov ecx, [r15 + DW_SPI_SR]
   153 0000513A 83E106              <1>     and ecx, 0x06
   154 0000513D 83F906              <1>     cmp ecx, 0x06
   155 00005140 7513                <1>     jne .pci_next
   156 00005142 4C893C25[DD080000]  <1>     mov [spi_base], r15
   157 0000514A C60425[E5080000]03  <1>     mov byte [spi_type], SPI_TYPE_INTEL_GSPI
   158 00005152 58                  <1>     pop rax
   159 00005153 EB15                <1>     jmp .init_dw_spi
   160                              <1> 
   161                              <1> .pci_next:
   162 00005155 58                  <1>     pop rax
   163 00005156 41FFC6              <1>     inc r14d
   164 00005159 E92CFFFFFF          <1>     jmp .pci_dev
   165                              <1> .next_bus:
   166 0000515E 41FFC5              <1>     inc r13d
   167 00005161 E914FFFFFF          <1>     jmp .pci_bus
   168                              <1> 
   169                              <1> .fail:
   170 00005166 31C0                <1>     xor eax, eax
   171 00005168 EB4D                <1>     jmp .ret
   172                              <1> 
   173                              <1> .init_dw_spi:
   174                              <1>     ; Disable SPI controller
   175 0000516A 4C8B3C25[DD080000]  <1>     mov r15, [spi_base]
   176 00005172 41C7470800000000    <1>     mov dword [r15 + DW_SPI_SSIENR], 0
   177                              <1> 
   178                              <1>     ; Configure: 8-bit, master, Motorola mode 0 (CPOL=0, CPHA=0)
   179 0000517A 41C70707000000      <1>     mov dword [r15 + DW_SPI_CTRLR0], SPI_CTRLR0_8BIT
   180                              <1> 
   181                              <1>     ; Baud rate: safe slow rate for init (div=64)
   182 00005181 41C7471440000000    <1>     mov dword [r15 + DW_SPI_BAUDR], 64
   183                              <1> 
   184                              <1>     ; Slave select: CS0
   185 00005189 41C7471001000000    <1>     mov dword [r15 + DW_SPI_SER], 1
   186                              <1> 
   187                              <1>     ; FIFO thresholds
   188 00005191 41C7471800000000    <1>     mov dword [r15 + DW_SPI_TXFTLR], 0
   189 00005199 41C7471C00000000    <1>     mov dword [r15 + DW_SPI_RXFTLR], 0
   190                              <1> 
   191                              <1>     ; Enable
   192 000051A1 41C7470801000000    <1>     mov dword [r15 + DW_SPI_SSIENR], 1
   193                              <1> 
   194                              <1>     ; Verify not frozen
   195 000051A9 418B4728            <1>     mov eax, [r15 + DW_SPI_SR]
   196 000051AD 83F8FF              <1>     cmp eax, 0xFFFFFFFF
   197 000051B0 74B4                <1>     je .fail
   198                              <1> 
   199 000051B2 B801000000          <1>     mov eax, 1
   200                              <1> .ret:
   201 000051B7 415F                <1>     pop r15
   202 000051B9 415E                <1>     pop r14
   203 000051BB 415D                <1>     pop r13
   204 000051BD 5F                  <1>     pop rdi
   205 000051BE 5A                  <1>     pop rdx
   206 000051BF 59                  <1>     pop rcx
   207 000051C0 5B                  <1>     pop rbx
   208 000051C1 C3                  <1>     ret
   209                              <1> 
   210                              <1> ; ============================================================================
   211                              <1> ; spi_transfer - Full-duplex SPI transfer (polled)
   212                              <1> ; RDI = TX buffer (or NULL for dummy TX)
   213                              <1> ; RSI = TX length
   214                              <1> ; RDX = RX buffer (or NULL to discard)
   215                              <1> ; RCX = RX length
   216                              <1> ; Returns: EAX = 1 success, 0 fail
   217                              <1> ; ============================================================================
   218                              <1> spi_transfer:
   219 000051C2 53                  <1>     push rbx
   220 000051C3 4150                <1>     push r8
   221 000051C5 4151                <1>     push r9
   222 000051C7 4152                <1>     push r10
   223 000051C9 4153                <1>     push r11
   224 000051CB 4154                <1>     push r12
   225                              <1> 
   226 000051CD 4C8B0425[DD080000]  <1>     mov r8, [spi_base]
   227 000051D5 4D85C0              <1>     test r8, r8
   228 000051D8 0F8490000000        <1>     jz .fail_xfer
   229                              <1> 
   230                              <1>     ; Total bytes = max(TX, RX)
   231 000051DE 4989F3              <1>     mov r11, rsi
   232 000051E1 4839F1              <1>     cmp rcx, rsi
   233 000051E4 7E03                <1>     jle .tx_start
   234 000051E6 4989CB              <1>     mov r11, rcx
   235                              <1> 
   236                              <1> .tx_start:
   237 000051E9 4D31C9              <1>     xor r9, r9              ; TX index
   238 000051EC 4D31D2              <1>     xor r10, r10            ; RX index
   239                              <1> 
   240                              <1> .xfer_loop:
   241 000051EF 4D39DA              <1>     cmp r10, r11
   242 000051F2 735D                <1>     jae .xfer_done
   243                              <1> 
   244                              <1>     ; --- TX: write byte if TX FIFO not full ---
   245 000051F4 418B4028            <1>     mov eax, [r8 + DW_SPI_SR]
   246 000051F8 A902000000          <1>     test eax, 0x02          ; TFNF (TX FIFO not full)
   247 000051FD 7420                <1>     jz .try_rx
   248                              <1> 
   249 000051FF 4D39D9              <1>     cmp r9, r11
   250 00005202 731B                <1>     jae .try_rx             ; Nothing more to send
   251                              <1> 
   252                              <1>     ; Pick byte: from TX buffer or dummy 0
   253 00005204 31C0                <1>     xor eax, eax
   254 00005206 4885FF              <1>     test rdi, rdi
   255 00005209 740B                <1>     jz .send_dummy
   256 0000520B 4939F1              <1>     cmp r9, rsi
   257 0000520E 7306                <1>     jae .send_dummy
   258 00005210 428A040F            <1>     mov al, byte [rdi + r9]
   259 00005214 EB02                <1>     jmp .do_tx
   260                              <1> .send_dummy:
   261 00005216 31C0                <1>     xor eax, eax
   262                              <1> .do_tx:
   263 00005218 41894060            <1>     mov [r8 + DW_SPI_DR], eax
   264 0000521C 49FFC1              <1>     inc r9
   265                              <1> 
   266                              <1> .try_rx:
   267                              <1>     ; --- RX: read byte if RX FIFO not empty ---
   268                              <1>     ; Use timeout to avoid infinite loop when hardware is stuck or missing
   269 0000521F 41BC10270000        <1>     mov r12d, 10000 ; Skip if no data after reasonable spin
   270                              <1> .wait_rx:
   271 00005225 418B4028            <1>     mov eax, [r8 + DW_SPI_SR]
   272 00005229 A908000000          <1>     test eax, 0x08          ; RFNE (RX FIFO not empty)
   273 0000522E 750A                <1>     jnz .do_rx
   274 00005230 41FFCC              <1>     dec r12d
   275 00005233 75F0                <1>     jnz .wait_rx
   276                              <1>     ; Timeout: count this as a missed byte (0) so loop terminates
   277 00005235 49FFC2              <1>     inc r10
   278 00005238 EBB5                <1>     jmp .xfer_loop
   279                              <1> 
   280                              <1> .do_rx:
   281 0000523A 418B4060            <1>     mov eax, [r8 + DW_SPI_DR]
   282 0000523E 4885D2              <1>     test rdx, rdx
   283 00005241 7409                <1>     jz .skip_store
   284 00005243 4939CA              <1>     cmp r10, rcx
   285 00005246 7304                <1>     jae .skip_store
   286 00005248 42880412            <1>     mov byte [rdx + r10], al
   287                              <1> .skip_store:
   288 0000524C 49FFC2              <1>     inc r10
   289 0000524F EB9E                <1>     jmp .xfer_loop
   290                              <1> 
   291                              <1> .xfer_done:
   292                              <1>     ; Wait for not-busy
   293 00005251 41BCA0860100        <1>     mov r12d, 100000
   294                              <1> .wait_idle:
   295 00005257 418B4028            <1>     mov eax, [r8 + DW_SPI_SR]
   296 0000525B A901000000          <1>     test eax, 0x01          ; BSY
   297 00005260 7405                <1>     jz .xfer_ok
   298 00005262 41FFCC              <1>     dec r12d
   299 00005265 75F0                <1>     jnz .wait_idle
   300                              <1> .xfer_ok:
   301 00005267 B801000000          <1>     mov eax, 1
   302 0000526C EB02                <1>     jmp .xfer_ret
   303                              <1> .fail_xfer:
   304 0000526E 31C0                <1>     xor eax, eax
   305                              <1> .xfer_ret:
   306 00005270 415C                <1>     pop r12
   307 00005272 415B                <1>     pop r11
   308 00005274 415A                <1>     pop r10
   309 00005276 4159                <1>     pop r9
   310 00005278 4158                <1>     pop r8
   311 0000527A 5B                  <1>     pop rbx
   312 0000527B C3                  <1>     ret
   313                              <1> 
   314                              <1> section .data
   315                              <1> global spi_base
   316                              <1> global spi_type
   317                              <1> 
   318                              <1> ; SPI type constants
   319                              <1> SPI_TYPE_AMD_FCH    equ 1
   320                              <1> SPI_TYPE_AMD_SFH    equ 2
   321                              <1> SPI_TYPE_INTEL_GSPI equ 3
   322                              <1> 
   323 000008DD 0000000000000000    <1> spi_base:   dq 0            ; MMIO base address of active SPI controller
   324 000008E5 00                  <1> spi_type:   db 0            ; SPI_TYPE_* above
    51                                  %include "src/drivers/spi_hid.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - SPI HID Touchpad Driver
     3                              <1> ; Implements Microsoft HID-over-SPI protocol (Windows Precision Touchpad)
     4                              <1> ;
     5                              <1> ; Protocol (per Microsoft HID-over-SPI spec):
     6                              <1> ;   Each transaction: [SYNC_BYTE][CONTENT_ID][LENGTH_LO][LENGTH_HI][DATA...]
     7                              <1> ;   SYNC_BYTE = 0xFF (host-to-device) or 0x80 (device-to-host)
     8                              <1> ;   CONTENT_ID:  0x0F = input report, 0x04 = command, 0x05 = descriptor
     9                              <1> ;   HOST_WRITE triggers: host sends 0xFF+0x0F to request input report
    10                              <1> ;
    11                              <1> ; Supports:
    12                              <1> ;   - SPI device descriptor fetch
    13                              <1> ;   - HID report descriptor parsing (via hid_parser.asm)
    14                              <1> ;   - Variable-length input report read
    15                              <1> ;   - Absolute + relative modes via parsed layout
    16                              <1> ; ============================================================================
    17                              <1> bits 64
    18                              <1> 
    19                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> 
    33                              <2> ; --- Stage 2 disk layout ---
    34                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    35                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    36                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    37                              <2> 
    38                              <2> ; --- Screen ---
    39                              <2> SCREEN_WIDTH        equ 1024
    40                              <2> SCREEN_HEIGHT       equ 768
    41                              <2> SCREEN_BPP          equ 32
    42                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    43                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    44                              <2> 
    45                              <2> 
    46                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    47                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    48                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    49                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    50                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    51                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    52                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    53                              <2> 
    54                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    55                              <2> COLOR_BLACK         equ 0x00000000
    56                              <2> COLOR_WHITE         equ 0x00FFFFFF
    57                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    58                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    59                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    60                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    61                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    62                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    63                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    64                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    65                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    66                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    67                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    68                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    69                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    70                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    71                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    72                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    73                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    74                              <2> COLOR_START_HOVER    equ 0x00338833
    75                              <2> 
    76                              <2> ; --- Window Manager ---
    77                              <2> MAX_WINDOWS         equ 8
    78                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    79                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    80                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    81                              <2> TITLEBAR_HEIGHT     equ 24
    82                              <2> BORDER_WIDTH        equ 2
    83                              <2> CLOSE_BTN_SIZE      equ 18
    84                              <2> MIN_BTN_SIZE        equ 18
    85                              <2> MIN_WINDOW_W        equ 200
    86                              <2> MIN_WINDOW_H        equ 100
    87                              <2> 
    88                              <2> ; --- Taskbar ---
    89                              <2> TASKBAR_HEIGHT      equ 36
    90                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    91                              <2> START_BTN_W         equ 70
    92                              <2> START_BTN_H         equ 28
    93                              <2> START_BTN_X         equ 4
    94                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    95                              <2> CLOCK_WIDTH         equ 64
    96                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    97                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    98                              <2> 
    99                              <2> ; --- Keyboard ---
   100                              <2> KB_BUFFER_SIZE      equ 64
   101                              <2> 
   102                              <2> ; --- Mouse ---
   103                              <2> MOUSE_BUFFER_SIZE   equ 64
   104                              <2> CURSOR_WIDTH        equ 12
   105                              <2> CURSOR_HEIGHT       equ 19
   106                              <2> 
   107                              <2> ; --- PIT ---
   108                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   109                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   110                              <2> 
   111                              <2> ; --- PIC vectors ---
   112                              <2> IRQ_BASE_MASTER     equ 32
   113                              <2> IRQ_BASE_SLAVE      equ 40
   114                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   115                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   116                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   117                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   118                              <2> 
   119                              <2> ; --- Font ---
   120                              <2> FONT_WIDTH          equ 8
   121                              <2> FONT_HEIGHT         equ 16
   122                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   123                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   124                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   125                              <2> 
   126                              <2> ; --- Window flags ---
   127                              <2> WF_VISIBLE          equ 0x01
   128                              <2> WF_FOCUSED          equ 0x02
   129                              <2> WF_DRAGGING         equ 0x04
   130                              <2> WF_MINIMIZED        equ 0x08
   131                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   132                              <2> 
   133                              <2> ; --- Mouse event types ---
   134                              <2> MEVT_MOVE           equ 1
   135                              <2> MEVT_LCLICK         equ 2
   136                              <2> MEVT_RCLICK         equ 3
   137                              <2> MEVT_LRELEASE       equ 4
   138                              <2> MEVT_RRELEASE       equ 5
   139                              <2> 
   140                              <2> ; --- Key modifier flags ---
   141                              <2> KMOD_SHIFT          equ 0x01
   142                              <2> KMOD_CTRL           equ 0x02
   143                              <2> KMOD_ALT            equ 0x04
   144                              <2> 
   145                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   146                              <2> KEY_F1              equ 0xF1
   147                              <2> KEY_F2              equ 0xF2
   148                              <2> KEY_F3              equ 0xF3
   149                              <2> KEY_F4              equ 0xF4
   150                              <2> KEY_F5              equ 0xF5
   151                              <2> KEY_F6              equ 0xF6
   152                              <2> KEY_F7              equ 0xF7
   153                              <2> KEY_F8              equ 0xF8
   154                              <2> KEY_F9              equ 0xF9
   155                              <2> KEY_F10             equ 0xFA
   156                              <2> KEY_F11             equ 0xFB
   157                              <2> KEY_F12             equ 0xFC
   158                              <2> 
   159                              <2> ; --- USB/XHCI Memory Layout ---
   160                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   161                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   162                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   163                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   164                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   165                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   166                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   167                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   168                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   169                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   170                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   171                              <2> ; Slot 2 device support
   172                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   173                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   174                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   175                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   176                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   177                              <2> 
   178                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   179                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   180                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   181                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   182                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   183                              <2> XHCI_CAP_DBOFF      equ 0x14
   184                              <2> XHCI_CAP_RTSOFF     equ 0x18
   185                              <2> 
   186                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   187                              <2> XHCI_OP_USBCMD      equ 0x00
   188                              <2> XHCI_OP_USBSTS      equ 0x04
   189                              <2> XHCI_OP_PAGESIZE     equ 0x08
   190                              <2> XHCI_OP_DNCTRL      equ 0x14
   191                              <2> XHCI_OP_CRCR_LO     equ 0x18
   192                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   193                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   194                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   195                              <2> XHCI_OP_CONFIG      equ 0x38
   196                              <2> 
   197                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   198                              <2> XHCI_PORTSC         equ 0x00
   199                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   200                              <2> 
   201                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   202                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   203                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   204                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   205                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   206                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   207                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   208                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   209                              <2> 
   210                              <2> ; --- USBCMD bits ---
   211                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   212                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   213                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   214                              <2> 
   215                              <2> ; --- USBSTS bits ---
   216                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   217                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   218                              <2> 
   219                              <2> ; --- PORTSC bits ---
   220                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   221                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   222                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   223                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   224                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   225                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   226                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   227                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   228                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   229                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   230                              <2> 
   231                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   232                              <2> TRB_NORMAL           equ (1 << 10)
   233                              <2> TRB_SETUP            equ (2 << 10)
   234                              <2> TRB_DATA             equ (3 << 10)
   235                              <2> TRB_STATUS           equ (4 << 10)
   236                              <2> TRB_LINK             equ (6 << 10)
   237                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   238                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   239                              <2> TRB_CONFIG_EP        equ (12 << 10)
   240                              <2> TRB_EVAL_CTX         equ (13 << 10)
   241                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   242                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   243                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   244                              <2> 
   245                              <2> ; --- TRB Flag Bits (dword 3) ---
   246                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   247                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   248                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   249                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   250                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   251                              <2> 
   252                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   253                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   254                              <2> TRB_TRT_OUT          equ (2 << 16)
   255                              <2> TRB_TRT_IN           equ (3 << 16)
   256                              <2> 
   257                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   258                              <2> TRB_DIR_OUT          equ (0 << 16)
   259                              <2> TRB_DIR_IN           equ (1 << 16)
   260                              <2> 
   261                              <2> ; --- Ring sizes ---
   262                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   263                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   264                              <2> 
   265                              <2> ; --- USB Standard Request Codes ---
   266                              <2> USB_REQ_GET_DESC     equ 0x06
   267                              <2> USB_REQ_SET_CONFIG   equ 0x09
   268                              <2> USB_REQ_SET_IFACE    equ 0x0B
   269                              <2> 
   270                              <2> ; --- USB HID Request Codes ---
   271                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   272                              <2> 
   273                              <2> ; --- USB Descriptor Types ---
   274                              <2> USB_DESC_DEVICE      equ 0x01
   275                              <2> USB_DESC_CONFIG      equ 0x02
   276                              <2> USB_DESC_INTERFACE   equ 0x04
   277                              <2> USB_DESC_ENDPOINT    equ 0x05
   278                              <2> USB_DESC_HID         equ 0x21
   279                              <2> 
   280                              <2> ; --- USB Endpoint Types ---
   281                              <2> USB_EP_CONTROL       equ 0
   282                              <2> USB_EP_ISOCH         equ 1
   283                              <2> USB_EP_BULK          equ 2
   284                              <2> USB_EP_INTERRUPT     equ 3
   285                              <2> 
   286                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   287                              <2> XHCI_EP_NOT_VALID    equ 0
   288                              <2> XHCI_EP_ISOCH_OUT    equ 1
   289                              <2> XHCI_EP_BULK_OUT     equ 2
   290                              <2> XHCI_EP_INT_OUT      equ 3
   291                              <2> XHCI_EP_CONTROL      equ 4
   292                              <2> XHCI_EP_ISOCH_IN     equ 5
   293                              <2> XHCI_EP_BULK_IN      equ 6
   294                              <2> XHCI_EP_INT_IN       equ 7
   295                              <2> 
   296                              <2> ; --- XHCI Port Speeds ---
   297                              <2> XHCI_SPEED_FULL      equ 1
   298                              <2> XHCI_SPEED_LOW       equ 2
   299                              <2> XHCI_SPEED_HIGH      equ 3
   300                              <2> XHCI_SPEED_SUPER     equ 4
    20                              <1> 
    21                              <1> extern mouse_x
    22                              <1> extern mouse_y
    23                              <1> extern mouse_buttons
    24                              <1> extern mouse_moved
    25                              <1> extern mouse_scroll_y
    26                              <1> extern scr_width
    27                              <1> extern scr_height
    28                              <1> 
    29                              <1> extern spi_init
    30                              <1> extern spi_transfer
    31                              <1> extern spi_type
    32                              <1> 
    33                              <1> ; HID parser
    34                              <1> extern hid_parse_report_desc
    35                              <1> extern hid_process_touchpad_report
    36                              <1> extern hid_parsed_is_absolute
    37                              <1> extern hid_parsed_report_bytes
    38                              <1> extern hid_parsed_has_report_id
    39                              <1> 
    40                              <1> ; SPI-HID packet constants
    41                              <1> SPI_SYNC_HOST       equ 0xFF    ; host->device sync byte
    42                              <1> SPI_SYNC_DEV        equ 0x80    ; device->host sync byte (when data ready)
    43                              <1> SPI_SYNC_IDLE       equ 0x00    ; bus idle
    44                              <1> 
    45                              <1> SPI_CID_OUTPUT      equ 0x0F    ; input report request
    46                              <1> SPI_CID_RESET       equ 0x04    ; reset/command
    47                              <1> SPI_CID_DESC        equ 0x05    ; device descriptor
    48                              <1> 
    49                              <1> ; Poll state
    50                              <1> SPI_STATE_IDLE      equ 0
    51                              <1> SPI_STATE_WAIT      equ 1       ; waiting for device ready
    52                              <1> 
    53                              <1> section .text
    54                              <1> global spi_hid_init
    55                              <1> global spi_hid_poll
    56                              <1> 
    57                              <1> ; ============================================================================
    58                              <1> ; spi_hid_init - Initialize SPI HID touchpad
    59                              <1> ; Returns: EAX = 1 if found and initialized, 0 otherwise
    60                              <1> ; ============================================================================
    61                              <1> spi_hid_init:
    62 0000527C 53                  <1>     push rbx
    63 0000527D 51                  <1>     push rcx
    64 0000527E 52                  <1>     push rdx
    65 0000527F 57                  <1>     push rdi
    66 00005280 56                  <1>     push rsi
    67                              <1> 
    68 00005281 C60425[E6080000]00  <1>     mov byte [spi_hid_active], 0
    69 00005289 C60425[E7080000]00  <1>     mov byte [spi_poll_state], SPI_STATE_IDLE
    70                              <1> 
    71                              <1>     ; Init SPI controller
    72 00005291 E895FDFFFF          <1>     call spi_init
    73 00005296 85C0                <1>     test eax, eax
    74 00005298 742B                <1>     jz .fail
    75                              <1> 
    76                              <1>     ; Send reset
    77 0000529A E82E000000          <1>     call spi_hid_send_reset
    78                              <1>     ; Wait for device ready (~20ms equivalent in loops)
    79 0000529F B980841E00          <1>     mov ecx, 2000000
    80                              <1> .reset_wait:
    81 000052A4 FFC9                <1>     dec ecx
    82 000052A6 75FC                <1>     jnz .reset_wait
    83                              <1> 
    84                              <1>     ; Fetch HID device descriptor
    85 000052A8 E86B000000          <1>     call spi_hid_get_device_desc
    86 000052AD 85C0                <1>     test eax, eax
    87 000052AF 7414                <1>     jz .fail
    88                              <1> 
    89                              <1>     ; Fetch and parse HID report descriptor
    90 000052B1 E8E8000000          <1>     call spi_hid_get_report_desc
    91                              <1>     ; Ignore parse failure - will use fallback
    92                              <1> 
    93 000052B6 C60425[E6080000]01  <1>     mov byte [spi_hid_active], 1
    94 000052BE B801000000          <1>     mov eax, 1
    95 000052C3 EB02                <1>     jmp .ret
    96                              <1> 
    97                              <1> .fail:
    98 000052C5 31C0                <1>     xor eax, eax
    99                              <1> .ret:
   100 000052C7 5E                  <1>     pop rsi
   101 000052C8 5F                  <1>     pop rdi
   102 000052C9 5A                  <1>     pop rdx
   103 000052CA 59                  <1>     pop rcx
   104 000052CB 5B                  <1>     pop rbx
   105 000052CC C3                  <1>     ret
   106                              <1> 
   107                              <1> ; ============================================================================
   108                              <1> ; spi_hid_send_reset - Send HID RESET command over SPI
   109                              <1> ; ============================================================================
   110                              <1> spi_hid_send_reset:
   111 000052CD 53                  <1>     push rbx
   112                              <1>     ; Build reset packet: SYNC + CID_RESET + LENGTH=0x0002 + OPCODE_RESET=0x0001
