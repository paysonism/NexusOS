    67 00001DA1 3B3C25[0A020000]    <1>     cmp edi, [scr_width]
    68 00001DA8 7D27                <1>     jge .done
    69 00001DAA 83FE00              <1>     cmp esi, 0
    70 00001DAD 7C22                <1>     jl .done
    71 00001DAF 3B3425[0E020000]    <1>     cmp esi, [scr_height]
