   126                              <1> .clip_bottom:
   127 00001E25 4489D0              <1>     mov eax, r10d
   128 00001E28 4401E0              <1>     add eax, r12d
   129 00001E2B 3B0425[0E020000]    <1>     cmp eax, [scr_height]
   130 00001E32 7E0B                <1>     jle .clip_done
   131 00001E34 448B2425[0E020000]  <1>     mov r12d, [scr_height]
   132 00001E3C 4529D4              <1>     sub r12d, r10d
   133                              <1> .clip_done:
   134                              <1>     ; Validate dimensions
   135 00001E3F 4183FB00            <1>     cmp r11d, 0
   136 00001E43 7E4A                <1>     jle .rect_done
   137 00001E45 4183FC00            <1>     cmp r12d, 0
   138 00001E49 7E44                <1>     jle .rect_done
   139                              <1> 
   140                              <1>     ; Calculate starting offset
   141 00001E4B 4489D0              <1>     mov eax, r10d
   142 00001E4E 0FAF0425[12020000]  <1>     imul eax, [scr_pitch]
   143 00001E56 67428D0488          <1>     lea eax, [eax + r9d * 4]
   144 00001E5B 488B1C25[02020000]  <1>     mov rbx, [bb_addr]
   145 00001E63 4801C3              <1>     add rbx, rax
   146                              <1> 
   147                              <1>     ; Prepare SSE2 color vector: broadcast color to all 4 dword lanes
   148 00001E66 66410F6EC5          <1>     movd xmm0, r13d
   149 00001E6B 660F70C000          <1>     pshufd xmm0, xmm0, 0    ; xmm0 = [color, color, color, color]
   150                              <1> 
   151 00001E70 48633425[12020000]  <1>     movsxd rsi, dword [scr_pitch]
   152                              <1> 
   153                              <1>     ; Simple robust fill using rep stosd
   154 00001E78 4889DF              <1>     mov rdi, rbx             ; RDI = starting address in back buffer
   155 00001E7B 4489D9              <1>     mov ecx, r11d            ; ECX = width in pixels
   156                              <1> .row_loop:
   157 00001E7E 57                  <1>     push rdi
   158 00001E7F 51                  <1>     push rcx
   159 00001E80 4489E8              <1>     mov eax, r13d            ; Color
