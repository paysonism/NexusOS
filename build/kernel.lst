  1267                              <1> section .data
  1268                              <1> 
  1269                              <1> ; AMD FCH I2C base addresses - all blocks seen on Strix Point real hardware
  1270                              <1> ; Order: higher indices first (I2CD = instance 3 likely at 0xFEDC5000 or 0xFEDC6000)
  1271                              <1> i2c_amd_bases:
  1272 000008EA 0050DCFE00000000    <1>     dq I2C_BASE_2               ; 0xFEDC5000 - most likely I2CD on Strix Point
  1273 000008F2 0060DCFE00000000    <1>     dq I2C_BASE_3               ; 0xFEDC6000 - fallback I2CD candidate
  1274 000008FA 0030DCFE00000000    <1>     dq I2C_BASE_1               ; 0xFEDC3000 - I2CB
  1275 00000902 0020DCFE00000000    <1>     dq I2C_BASE_0               ; 0xFEDC2000 - I2CA
  1276 0000090A 0000DCFE00000000    <1>     dq I2C_BASE_4               ; 0xFEDC0000 - additional FCH block
  1277                              <1> 
  1278                              <1> ; Touchpad I2C addresses to probe (most-common first)
  1279                              <1> i2c_tp_addrs:
  1280 00000912 15                  <1>     db 0x15             ; ELAN primary (Acer Nitro / AMD Ryzen)
  1281 00000913 17                  <1>     db 0x17             ; ELAN variant (Nitro V16 AI / Strix Point)
  1282 00000914 2C                  <1>     db 0x2C             ; Synaptics / ALPS
  1283 00000915 38                  <1>     db 0x38             ; ELAN variant
  1284 00000916 10                  <1>     db 0x10             ; ELAN alt
  1285 00000917 14                  <1>     db 0x14             ; Goodix
  1286 00000918 5D                  <1>     db 0x5D             ; Goodix alternate
  1287 00000919 2A                  <1>     db 0x2A             ; Synaptics secondary
  1288 0000091A 3C                  <1>     db 0x3C             ; ALPS I2C-HID
  1289 0000091B 20                  <1>     db 0x20             ; Pixart
  1290 0000091C 34                  <1>     db 0x34             ; FocalTech
  1291 0000091D 16                  <1>     db 0x16             ; ELAN variant 2
  1292 0000091E 2D                  <1>     db 0x2D             ; Synaptics variant
  1293                              <1> I2C_TP_ADDR_COUNT   equ ($ - i2c_tp_addrs)
  1294                              <1> 
  1295                              <1> ; I2C-HID state
  1296                              <1> global i2c_hid_active
  1297 0000091F 00                  <1> i2c_hid_active:     db 0
  1298 00000920 00                  <1> i2c_dev_addr:       db 0
  1299 00000921 00                  <1> i2c_poll_state:     db 0        ; 0=issue, 1=read header, 2=read data
  1300 00000922 00                  <1> i2c_is_intel:       db 0        ; 1 if controller found via PCI (Intel LPSS)
  1301 00000923 00                  <1> i2c_use_parsed:     db 0        ; 1 if HID report descriptor was parsed successfully
