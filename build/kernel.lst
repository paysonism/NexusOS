   128                              <1> ; ============================================================================
   129                              <1> ; spi_hid_get_device_desc - Fetch 22-byte HID device descriptor
   130                              <1> ; Returns: EAX = 1 success, 0 fail
   131                              <1> ; ============================================================================
   132                              <1> spi_hid_get_device_desc:
   133 00005318 53                  <1>     push rbx
   134 00005319 51                  <1>     push rcx
   135                              <1> 
   136                              <1>     ; Request device descriptor: SYNC + CID_DESC + length + register 0x0000
   137 0000531A C60425[86870200]FF  <1>     mov byte [spi_tx_buf + 0], SPI_SYNC_HOST
   138 00005322 C60425[87870200]05  <1>     mov byte [spi_tx_buf + 1], SPI_CID_DESC
   139 0000532A C60425[88870200]04  <1>     mov byte [spi_tx_buf + 2], 0x04
   140 00005332 C60425[89870200]00  <1>     mov byte [spi_tx_buf + 3], 0x00
   141 0000533A C60425[8A870200]00  <1>     mov byte [spi_tx_buf + 4], 0x00    ; wDescriptorAddress low
   142 00005342 C60425[8B870200]00  <1>     mov byte [spi_tx_buf + 5], 0x00    ; wDescriptorAddress high
   143                              <1> 
   144 0000534A 488D3C25[86870200]  <1>     lea rdi, [spi_tx_buf]
   145 00005352 BE06000000          <1>     mov rsi, 6
   146 00005357 488D1425[96870200]  <1>     lea rdx, [spi_rx_buf]
   147 0000535F B91E000000          <1>     mov rcx, 30
   148 00005364 E859FEFFFF          <1>     call spi_transfer
   149 00005369 85C0                <1>     test eax, eax
   150 0000536B 742C                <1>     jz .fail_desc
   151                              <1> 
   152                              <1>     ; Validate: device byte 0 should be SPI_SYNC_DEV (0x80)
   153 0000536D 803C25[96870200]80  <1>     cmp byte [spi_rx_buf + 0], SPI_SYNC_DEV
   154 00005375 7522                <1>     jne .fail_desc
   155                              <1> 
   156                              <1>     ; Parse device descriptor response
   157                              <1>     ; [0] sync [1] CID [2-3] length [4-5] wHIDDescLength
   158                              <1>     ; [6-7] bcdVersion [8-9] wReportDescLength
   159                              <1>     ; [10-11] wInputRegister [12-13] wOutputRegister
   160                              <1>     ; [14-15] wCommandRegister [16-17] wDataRegister
   161                              <1>     ; [18-19] wVendorID [20-21] wProductID
   162                              <1> 
   163 00005377 0FB70425[9E870200]  <1>     movzx eax, word [spi_rx_buf + 8]   ; wReportDescLength
   164 0000537F 85C0                <1>     test eax, eax
   165 00005381 7416                <1>     jz .fail_desc
   166 00005383 3D00020000          <1>     cmp eax, SPI_RDESC_BUF_SIZE
   167 00005388 7F0F                <1>     jg .fail_desc
   168 0000538A 66890425[E8080000]  <1>     mov [spi_report_desc_len], ax
   169                              <1> 
   170 00005392 B801000000          <1>     mov eax, 1
   171 00005397 EB02                <1>     jmp .desc_ret
   172                              <1> .fail_desc:
   173 00005399 31C0                <1>     xor eax, eax
   174                              <1> .desc_ret:
   175 0000539B 59                  <1>     pop rcx
   176 0000539C 5B                  <1>     pop rbx
   177 0000539D C3                  <1>     ret
   178                              <1> 
   179                              <1> ; ============================================================================
