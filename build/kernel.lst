    41 00001D67 040000              <1>
    42 00001D6A C70425[0E020000]00- <1>     mov dword [scr_height], 768
    42 00001D72 030000              <1>
    43                              <1> .fix_pitch_only:
    44 00001D75 8B0425[0A020000]    <1>     mov eax, [scr_width]
