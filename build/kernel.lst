    54                                  %include "src/drivers/battery.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - ACPI EC Battery Driver
     3                              <1> ;
     4                              <1> ; EC I/O: 0x62 = data port, 0x66 = command/status port
     5                              <1> ; Protocol: wait IBF=0, write 0x80 to cmd port, wait IBF=0,
     6                              <1> ;           write reg addr to data port, wait OBF=1, read data from data port
     7                              <1> ;
     8                              <1> ; Acer Nitro ANV16-42 (ITE EC) register layout (probed at init):
     9                              <1> ;
    10                              <1> ;   Layout A (common Acer Nitro ITE, older):
    11                              <1> ;     0xA2 = battery remaining % (0-100)
    12                              <1> ;     0xA3 = battery status (bit1=charging, bit0=discharging)
    13                              <1> ;     0xA4 = AC adapter (bit0=1 = AC plugged)
    14                              <1> ;
    15                              <1> ;   Layout B (Acer Nitro 2023/2024 ITE8696/ITE8297):
    16                              <1> ;     0x42 = battery remaining % (0-100)
    17                              <1> ;     0x40 = battery status flags (bit0=discharging, bit1=charging)
    18                              <1> ;     0x41 = AC adapter (bit0=1 = AC plugged)
    19                              <1> ;
    20                              <1> ;   Layout C (some Acer with design/full/remaining in mWh):
    21                              <1> ;     0xB4 = design capacity low byte
    22                              <1> ;     0xB5 = design capacity high byte
    23                              <1> ;     0xB2 = remaining capacity low byte
    24                              <1> ;     0xB3 = remaining capacity high byte
    25                              <1> ;     0xA0 = status (bit0=discharging, bit1=charging)
    26                              <1> ;     0xA1 = AC present (bit0=1 = AC)
    27                              <1> ;
    28                              <1> ; We probe layout A first, then B, then C.
    29                              <1> ;
    30                              <1> ; Exported:
    31                              <1> ;   battery_state   (byte): 0=unknown, 1=AC, 2=discharging, 3=charging
    32                              <1> ;   battery_percent (byte): 0-100
    33                              <1> ;   battery_init    : call once at boot
    34                              <1> ;   battery_poll    : call from main loop (throttled internally)
    35                              <1> ; ============================================================================
    36                              <1> bits 64
    37                              <1> 
    38                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> 
    33                              <2> ; --- Stage 2 disk layout ---
    34                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    35                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    36                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    37                              <2> 
    38                              <2> ; --- Screen ---
    39                              <2> SCREEN_WIDTH        equ 1024
    40                              <2> SCREEN_HEIGHT       equ 768
    41                              <2> SCREEN_BPP          equ 32
    42                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    43                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    44                              <2> 
    45                              <2> 
    46                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    47                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    48                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    49                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    50                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    51                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    52                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    53                              <2> 
    54                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    55                              <2> COLOR_BLACK         equ 0x00000000
    56                              <2> COLOR_WHITE         equ 0x00FFFFFF
    57                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    58                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    59                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    60                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    61                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    62                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    63                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    64                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    65                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    66                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    67                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    68                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    69                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    70                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    71                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    72                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    73                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    74                              <2> COLOR_START_HOVER    equ 0x00338833
    75                              <2> 
    76                              <2> ; --- Window Manager ---
    77                              <2> MAX_WINDOWS         equ 8
    78                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    79                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    80                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    81                              <2> TITLEBAR_HEIGHT     equ 24
    82                              <2> BORDER_WIDTH        equ 2
    83                              <2> CLOSE_BTN_SIZE      equ 18
    84                              <2> MIN_BTN_SIZE        equ 18
    85                              <2> MIN_WINDOW_W        equ 200
    86                              <2> MIN_WINDOW_H        equ 100
    87                              <2> 
    88                              <2> ; --- Taskbar ---
    89                              <2> TASKBAR_HEIGHT      equ 36
    90                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    91                              <2> START_BTN_W         equ 70
    92                              <2> START_BTN_H         equ 28
    93                              <2> START_BTN_X         equ 4
    94                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    95                              <2> CLOCK_WIDTH         equ 64
    96                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    97                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    98                              <2> 
    99                              <2> ; --- Keyboard ---
   100                              <2> KB_BUFFER_SIZE      equ 64
   101                              <2> 
   102                              <2> ; --- Mouse ---
   103                              <2> MOUSE_BUFFER_SIZE   equ 64
   104                              <2> CURSOR_WIDTH        equ 12
   105                              <2> CURSOR_HEIGHT       equ 19
   106                              <2> 
   107                              <2> ; --- PIT ---
   108                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   109                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   110                              <2> 
   111                              <2> ; --- PIC vectors ---
   112                              <2> IRQ_BASE_MASTER     equ 32
   113                              <2> IRQ_BASE_SLAVE      equ 40
   114                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   115                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   116                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   117                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   118                              <2> 
   119                              <2> ; --- Font ---
   120                              <2> FONT_WIDTH          equ 8
   121                              <2> FONT_HEIGHT         equ 16
   122                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   123                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   124                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   125                              <2> 
   126                              <2> ; --- Window flags ---
   127                              <2> WF_VISIBLE          equ 0x01
   128                              <2> WF_FOCUSED          equ 0x02
   129                              <2> WF_DRAGGING         equ 0x04
   130                              <2> WF_MINIMIZED        equ 0x08
   131                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   132                              <2> 
   133                              <2> ; --- Mouse event types ---
   134                              <2> MEVT_MOVE           equ 1
   135                              <2> MEVT_LCLICK         equ 2
   136                              <2> MEVT_RCLICK         equ 3
   137                              <2> MEVT_LRELEASE       equ 4
   138                              <2> MEVT_RRELEASE       equ 5
   139                              <2> 
   140                              <2> ; --- Key modifier flags ---
   141                              <2> KMOD_SHIFT          equ 0x01
   142                              <2> KMOD_CTRL           equ 0x02
   143                              <2> KMOD_ALT            equ 0x04
   144                              <2> 
   145                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   146                              <2> KEY_F1              equ 0xF1
   147                              <2> KEY_F2              equ 0xF2
   148                              <2> KEY_F3              equ 0xF3
   149                              <2> KEY_F4              equ 0xF4
   150                              <2> KEY_F5              equ 0xF5
   151                              <2> KEY_F6              equ 0xF6
   152                              <2> KEY_F7              equ 0xF7
   153                              <2> KEY_F8              equ 0xF8
   154                              <2> KEY_F9              equ 0xF9
   155                              <2> KEY_F10             equ 0xFA
   156                              <2> KEY_F11             equ 0xFB
   157                              <2> KEY_F12             equ 0xFC
   158                              <2> 
   159                              <2> ; --- USB/XHCI Memory Layout ---
   160                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   161                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   162                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   163                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   164                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   165                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   166                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   167                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   168                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   169                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   170                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   171                              <2> ; Slot 2 device support
   172                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   173                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   174                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   175                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   176                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   177                              <2> 
   178                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   179                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   180                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   181                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   182                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   183                              <2> XHCI_CAP_DBOFF      equ 0x14
   184                              <2> XHCI_CAP_RTSOFF     equ 0x18
   185                              <2> 
   186                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   187                              <2> XHCI_OP_USBCMD      equ 0x00
   188                              <2> XHCI_OP_USBSTS      equ 0x04
   189                              <2> XHCI_OP_PAGESIZE     equ 0x08
   190                              <2> XHCI_OP_DNCTRL      equ 0x14
   191                              <2> XHCI_OP_CRCR_LO     equ 0x18
   192                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   193                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   194                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   195                              <2> XHCI_OP_CONFIG      equ 0x38
   196                              <2> 
   197                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   198                              <2> XHCI_PORTSC         equ 0x00
   199                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   200                              <2> 
   201                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   202                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   203                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   204                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   205                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   206                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   207                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   208                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   209                              <2> 
   210                              <2> ; --- USBCMD bits ---
   211                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   212                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   213                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   214                              <2> 
   215                              <2> ; --- USBSTS bits ---
   216                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   217                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   218                              <2> 
   219                              <2> ; --- PORTSC bits ---
   220                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   221                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   222                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   223                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   224                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   225                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   226                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   227                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   228                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   229                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   230                              <2> 
   231                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   232                              <2> TRB_NORMAL           equ (1 << 10)
   233                              <2> TRB_SETUP            equ (2 << 10)
   234                              <2> TRB_DATA             equ (3 << 10)
   235                              <2> TRB_STATUS           equ (4 << 10)
   236                              <2> TRB_LINK             equ (6 << 10)
   237                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   238                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   239                              <2> TRB_CONFIG_EP        equ (12 << 10)
   240                              <2> TRB_EVAL_CTX         equ (13 << 10)
   241                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   242                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   243                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   244                              <2> 
   245                              <2> ; --- TRB Flag Bits (dword 3) ---
   246                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   247                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   248                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   249                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   250                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   251                              <2> 
   252                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   253                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   254                              <2> TRB_TRT_OUT          equ (2 << 16)
   255                              <2> TRB_TRT_IN           equ (3 << 16)
   256                              <2> 
   257                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   258                              <2> TRB_DIR_OUT          equ (0 << 16)
   259                              <2> TRB_DIR_IN           equ (1 << 16)
   260                              <2> 
   261                              <2> ; --- Ring sizes ---
   262                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   263                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   264                              <2> 
   265                              <2> ; --- USB Standard Request Codes ---
   266                              <2> USB_REQ_GET_DESC     equ 0x06
   267                              <2> USB_REQ_SET_CONFIG   equ 0x09
   268                              <2> USB_REQ_SET_IFACE    equ 0x0B
   269                              <2> 
   270                              <2> ; --- USB HID Request Codes ---
   271                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   272                              <2> 
   273                              <2> ; --- USB Descriptor Types ---
   274                              <2> USB_DESC_DEVICE      equ 0x01
   275                              <2> USB_DESC_CONFIG      equ 0x02
   276                              <2> USB_DESC_INTERFACE   equ 0x04
   277                              <2> USB_DESC_ENDPOINT    equ 0x05
   278                              <2> USB_DESC_HID         equ 0x21
   279                              <2> 
   280                              <2> ; --- USB Endpoint Types ---
   281                              <2> USB_EP_CONTROL       equ 0
   282                              <2> USB_EP_ISOCH         equ 1
   283                              <2> USB_EP_BULK          equ 2
   284                              <2> USB_EP_INTERRUPT     equ 3
   285                              <2> 
   286                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   287                              <2> XHCI_EP_NOT_VALID    equ 0
   288                              <2> XHCI_EP_ISOCH_OUT    equ 1
   289                              <2> XHCI_EP_BULK_OUT     equ 2
   290                              <2> XHCI_EP_INT_OUT      equ 3
   291                              <2> XHCI_EP_CONTROL      equ 4
   292                              <2> XHCI_EP_ISOCH_IN     equ 5
   293                              <2> XHCI_EP_BULK_IN      equ 6
   294                              <2> XHCI_EP_INT_IN       equ 7
   295                              <2> 
   296                              <2> ; --- XHCI Port Speeds ---
   297                              <2> XHCI_SPEED_FULL      equ 1
   298                              <2> XHCI_SPEED_LOW       equ 2
   299                              <2> XHCI_SPEED_HIGH      equ 3
   300                              <2> XHCI_SPEED_SUPER     equ 4
    39                              <1> 
    40                              <1> EC_DATA     equ 0x62
    41                              <1> EC_CMD      equ 0x66
    42                              <1> EC_IBF      equ (1 << 1)   ; Input buffer full  (busy, can't write)
    43                              <1> EC_OBF      equ (1 << 0)   ; Output buffer full (data ready to read)
    44                              <1> EC_READ_CMD equ 0x80       ; EC "read register" command
    45                              <1> 
    46                              <1> ; Layout A registers
    47                              <1> EC_REG_A_BAT_CAP    equ 0xA2
    48                              <1> EC_REG_A_BAT_FLAGS  equ 0xA3
    49                              <1> EC_REG_A_AC_STATUS  equ 0xA4
    50                              <1> 
    51                              <1> ; Layout B registers (Acer Nitro 2023/2024)
    52                              <1> EC_REG_B_BAT_CAP    equ 0x42
    53                              <1> EC_REG_B_BAT_FLAGS  equ 0x40
    54                              <1> EC_REG_B_AC_STATUS  equ 0x41
    55                              <1> 
    56                              <1> ; Layout C registers (mWh-based)
    57                              <1> EC_REG_C_REM_LO     equ 0xB2
    58                              <1> EC_REG_C_REM_HI     equ 0xB3
    59                              <1> EC_REG_C_DES_LO     equ 0xB4
    60                              <1> EC_REG_C_DES_HI     equ 0xB5
    61                              <1> EC_REG_C_STATUS     equ 0xA0
    62                              <1> EC_REG_C_AC         equ 0xA1
    63                              <1> 
    64                              <1> BAT_STATE_UNKNOWN  equ 0
    65                              <1> BAT_STATE_AC       equ 1
    66                              <1> BAT_STATE_DISCHARGE equ 2
    67                              <1> BAT_STATE_CHARGING equ 3
    68                              <1> 
    69                              <1> EC_LAYOUT_NONE  equ 0
    70                              <1> EC_LAYOUT_A     equ 1
    71                              <1> EC_LAYOUT_B     equ 2
    72                              <1> EC_LAYOUT_C     equ 3
    73                              <1> 
    74                              <1> section .text
    75                              <1> 
    76                              <1> global battery_init
    77                              <1> global battery_poll
    78                              <1> 
    79                              <1> extern acpi_ec_read
    80                              <1> 
    81                              <1> ; ============================================================================
    82                              <1> ; ec_read_reg - wrapper for the ACPI EC read function
    83                              <1> ; Input:  DL = register address
    84                              <1> ; Output: AL = register value, CF=0 on success; CF=1 on timeout
    85                              <1> ; ============================================================================
    86                              <1> ec_read_reg:
    87 00006BF1 88D1                <1>     mov cl, dl
    88 00006BF3 E8AEB0FFFF          <1>     call acpi_ec_read
    89 00006BF8 C3                  <1>     ret
    90                              <1> 
    91                              <1> ; ============================================================================
    92                              <1> ; battery_probe_layout - probe EC to find correct register layout
    93                              <1> ; Sets bat_layout and primes battery_state/battery_percent
    94                              <1> ; Returns: AL = layout found (0=none)
    95                              <1> ; ============================================================================
    96                              <1> battery_probe_layout:
    97 00006BF9 53                  <1>     push rbx
    98 00006BFA 52                  <1>     push rdx
    99                              <1> 
   100                              <1>     ; --- Try Layout A: reg 0xA2 should be 0-100 ---
   101 00006BFB B2A2                <1>     mov dl, EC_REG_A_BAT_CAP
   102 00006BFD E8EFFFFFFF          <1>     call ec_read_reg
   103 00006C02 7226                <1>     jc .try_layout_b
   104 00006C04 0FB6D8              <1>     movzx ebx, al
   105 00006C07 80FB00              <1>     cmp bl, 0
   106 00006C0A 7C1E                <1>     jl .try_layout_b
   107 00006C0C 80FB64              <1>     cmp bl, 100
   108 00006C0F 7602                <1>     jbe .layout_a_cap_ok
   109                              <1>     ; Value > 100 - could be mWh or wrong register - not layout A
   110 00006C11 EB17                <1>     jmp .try_layout_b
   111                              <1> .layout_a_cap_ok:
   112                              <1>     ; Verify AC register too - bit0 should be 0 or 1
   113 00006C13 B2A4                <1>     mov dl, EC_REG_A_AC_STATUS
   114 00006C15 E8D7FFFFFF          <1>     call ec_read_reg
   115 00006C1A 720E                <1>     jc .try_layout_b
   116 00006C1C 24FE                <1>     and al, 0xFE             ; mask off bit0 - rest should be 0 or predictable
   117                              <1>     ; Accept layout A
   118 00006C1E C60425[800D0000]01  <1>     mov byte [bat_layout], EC_LAYOUT_A
   119 00006C26 B001                <1>     mov al, EC_LAYOUT_A
   120 00006C28 EB65                <1>     jmp .probe_done
   121                              <1> 
   122                              <1> .try_layout_b:
   123                              <1>     ; --- Try Layout B: reg 0x42 should be 0-100 ---
   124 00006C2A B242                <1>     mov dl, EC_REG_B_BAT_CAP
   125 00006C2C E8C0FFFFFF          <1>     call ec_read_reg
   126 00006C31 7214                <1>     jc .try_layout_c
   127 00006C33 0FB6D8              <1>     movzx ebx, al
   128 00006C36 80FB64              <1>     cmp bl, 100
   129 00006C39 770C                <1>     ja .try_layout_c
   130                              <1>     ; Looks like a valid percentage
   131 00006C3B C60425[800D0000]02  <1>     mov byte [bat_layout], EC_LAYOUT_B
   132 00006C43 B002                <1>     mov al, EC_LAYOUT_B
   133 00006C45 EB48                <1>     jmp .probe_done
   134                              <1> 
   135                              <1> .try_layout_c:
   136                              <1>     ; --- Try Layout C: read design cap (16-bit) and remaining cap ---
   137 00006C47 B2B4                <1>     mov dl, EC_REG_C_DES_LO
   138 00006C49 E8A3FFFFFF          <1>     call ec_read_reg
   139 00006C4E 7235                <1>     jc .probe_fail
   140 00006C50 0FB6D8              <1>     movzx ebx, al            ; design_lo
   141 00006C53 B2B5                <1>     mov dl, EC_REG_C_DES_HI
   142 00006C55 E897FFFFFF          <1>     call ec_read_reg
   143 00006C5A 7229                <1>     jc .probe_fail
   144 00006C5C 0FB6C0              <1>     movzx eax, al
   145 00006C5F C1E008              <1>     shl eax, 8
   146 00006C62 09C3                <1>     or ebx, eax              ; ebx = design capacity (mWh/10 typically)
   147                              <1>     ; Must be non-zero and reasonable (e.g. 200-10000 range = 2Wh-100Wh)
   148 00006C64 83FB0A              <1>     cmp ebx, 10
   149 00006C67 7C1C                <1>     jl .probe_fail
   150 00006C69 81FBE8FD0000        <1>     cmp ebx, 65000
   151 00006C6F 7F14                <1>     jg .probe_fail
   152                              <1>     ; Store design capacity for % calculation
   153 00006C71 66891C25[810D0000]  <1>     mov [bat_design_cap], bx
   154 00006C79 C60425[800D0000]03  <1>     mov byte [bat_layout], EC_LAYOUT_C
   155 00006C81 B003                <1>     mov al, EC_LAYOUT_C
   156 00006C83 EB0A                <1>     jmp .probe_done
   157                              <1> 
   158                              <1> .probe_fail:
   159 00006C85 C60425[800D0000]00  <1>     mov byte [bat_layout], EC_LAYOUT_NONE
   160 00006C8D 30C0                <1>     xor al, al
   161                              <1> 
   162                              <1> .probe_done:
   163 00006C8F 5A                  <1>     pop rdx
   164 00006C90 5B                  <1>     pop rbx
   165 00006C91 C3                  <1>     ret
   166                              <1> 
   167                              <1> ; ============================================================================
   168                              <1> ; battery_do_read - read all EC registers and update state
   169                              <1> ; Uses layout stored in bat_layout
   170                              <1> ; ============================================================================
   171                              <1> battery_do_read:
   172 00006C92 50                  <1>     push rax
   173 00006C93 53                  <1>     push rbx
   174 00006C94 52                  <1>     push rdx
   175                              <1> 
   176 00006C95 0FB60425[800D0000]  <1>     movzx eax, byte [bat_layout]
   177 00006C9D 3C01                <1>     cmp al, EC_LAYOUT_A
   178 00006C9F 7411                <1>     je .read_layout_a
   179 00006CA1 3C02                <1>     cmp al, EC_LAYOUT_B
   180 00006CA3 744C                <1>     je .read_layout_b
   181 00006CA5 3C03                <1>     cmp al, EC_LAYOUT_C
   182 00006CA7 0F8480000000        <1>     je .read_layout_c
   183 00006CAD E907010000          <1>     jmp .done              ; EC_LAYOUT_NONE
   184                              <1> 
   185                              <1> ; --- Layout A: 0xA2=cap%, 0xA3=flags, 0xA4=AC ---
   186                              <1> .read_layout_a:
   187 00006CB2 B2A4                <1>     mov dl, EC_REG_A_AC_STATUS
   188 00006CB4 E838FFFFFF          <1>     call ec_read_reg
   189 00006CB9 0F82FA000000        <1>     jc .done
   190 00006CBF 0FB6D8              <1>     movzx ebx, al               ; bit0=AC present
   191                              <1> 
   192 00006CC2 B2A2                <1>     mov dl, EC_REG_A_BAT_CAP
   193 00006CC4 E828FFFFFF          <1>     call ec_read_reg
   194 00006CC9 0F82EA000000        <1>     jc .done
   195 00006CCF 3C64                <1>     cmp al, 100
   196 00006CD1 7602                <1>     jbe .la_cap_ok
   197 00006CD3 B064                <1>     mov al, 100
   198                              <1> .la_cap_ok:
   199 00006CD5 880425[7E0D0000]    <1>     mov [battery_percent], al
   200                              <1> 
   201 00006CDC B2A3                <1>     mov dl, EC_REG_A_BAT_FLAGS
   202 00006CDE E80EFFFFFF          <1>     call ec_read_reg
   203 00006CE3 0F82D0000000        <1>     jc .done
   204 00006CE9 0FB6C0              <1>     movzx eax, al               ; bit1=charging
   205                              <1> 
   206 00006CEC E9A3000000          <1>     jmp .determine_state
   207                              <1> 
   208                              <1> ; --- Layout B: 0x40=flags, 0x41=AC, 0x42=cap% ---
   209                              <1> .read_layout_b:
   210 00006CF1 B241                <1>     mov dl, EC_REG_B_AC_STATUS
   211 00006CF3 E8F9FEFFFF          <1>     call ec_read_reg
   212 00006CF8 0F82BB000000        <1>     jc .done
   213 00006CFE 0FB6D8              <1>     movzx ebx, al               ; bit0=AC present
   214                              <1> 
   215 00006D01 B242                <1>     mov dl, EC_REG_B_BAT_CAP
   216 00006D03 E8E9FEFFFF          <1>     call ec_read_reg
   217 00006D08 0F82AB000000        <1>     jc .done
   218 00006D0E 3C64                <1>     cmp al, 100
   219 00006D10 7602                <1>     jbe .lb_cap_ok
   220 00006D12 B064                <1>     mov al, 100
   221                              <1> .lb_cap_ok:
   222 00006D14 880425[7E0D0000]    <1>     mov [battery_percent], al
   223                              <1> 
   224 00006D1B B240                <1>     mov dl, EC_REG_B_BAT_FLAGS
   225 00006D1D E8CFFEFFFF          <1>     call ec_read_reg
   226 00006D22 0F8291000000        <1>     jc .done
   227 00006D28 0FB6C0              <1>     movzx eax, al               ; bit1=charging
   228                              <1> 
   229 00006D2B EB67                <1>     jmp .determine_state
   230                              <1> 
   231                              <1> ; --- Layout C: mWh-based, compute % from remaining/design ---
   232                              <1> .read_layout_c:
   233 00006D2D B2A1                <1>     mov dl, EC_REG_C_AC
   234 00006D2F E8BDFEFFFF          <1>     call ec_read_reg
   235 00006D34 0F827F000000        <1>     jc .done
   236 00006D3A 0FB6D8              <1>     movzx ebx, al               ; bit0=AC present
   237                              <1> 
   238 00006D3D B2B2                <1>     mov dl, EC_REG_C_REM_LO
   239 00006D3F E8ADFEFFFF          <1>     call ec_read_reg
   240 00006D44 7273                <1>     jc .done
   241 00006D46 0FB6C8              <1>     movzx ecx, al
   242 00006D49 B2B3                <1>     mov dl, EC_REG_C_REM_HI
   243 00006D4B E8A1FEFFFF          <1>     call ec_read_reg
   244 00006D50 7267                <1>     jc .done
   245 00006D52 0FB6C0              <1>     movzx eax, al
   246 00006D55 C1E008              <1>     shl eax, 8
   247 00006D58 09C1                <1>     or ecx, eax                 ; ecx = remaining mWh/10
   248                              <1> 
   249                              <1>     ; Compute percent: remaining * 100 / design
   250 00006D5A 0FB70425[810D0000]  <1>     movzx eax, word [bat_design_cap]
   251 00006D62 85C0                <1>     test eax, eax
   252 00006D64 7453                <1>     jz .done
   253 00006D66 89C8                <1>     mov eax, ecx
   254 00006D68 6BC064              <1>     imul eax, 100
   255 00006D6B 31D2                <1>     xor edx, edx
   256 00006D6D 0FB70C25[810D0000]  <1>     movzx ecx, word [bat_design_cap]
   257 00006D75 F7F1                <1>     div ecx                     ; eax = percent
   258 00006D77 83F864              <1>     cmp eax, 100
   259 00006D7A 7605                <1>     jbe .lc_cap_ok
   260 00006D7C B864000000          <1>     mov eax, 100
   261                              <1> .lc_cap_ok:
   262 00006D81 880425[7E0D0000]    <1>     mov [battery_percent], al
   263                              <1> 
   264 00006D88 B2A0                <1>     mov dl, EC_REG_C_STATUS
   265 00006D8A E862FEFFFF          <1>     call ec_read_reg
   266 00006D8F 7228                <1>     jc .done
   267 00006D91 0FB6C0              <1>     movzx eax, al               ; bit1=charging
   268                              <1> 
   269                              <1>     ; Fall through to determine_state
   270                              <1> 
   271                              <1> ; --- Determine state from EBX (AC bit0) and EAX (charging bit1) ---
   272                              <1> .determine_state:
   273 00006D94 F6C301              <1>     test bl, 0x01               ; AC present?
   274 00006D97 7418                <1>     jz .on_battery
   275                              <1> 
   276 00006D99 A802                <1>     test al, 0x02               ; Charging?
   277 00006D9B 750A                <1>     jnz .state_charging
   278                              <1> 
   279 00006D9D C60425[7D0D0000]01  <1>     mov byte [battery_state], BAT_STATE_AC
   280 00006DA5 EB12                <1>     jmp .done
   281                              <1> 
   282                              <1> .state_charging:
   283 00006DA7 C60425[7D0D0000]03  <1>     mov byte [battery_state], BAT_STATE_CHARGING
   284 00006DAF EB08                <1>     jmp .done
   285                              <1> 
   286                              <1> .on_battery:
   287 00006DB1 C60425[7D0D0000]02  <1>     mov byte [battery_state], BAT_STATE_DISCHARGE
   288                              <1> 
   289                              <1> .done:
   290 00006DB9 5A                  <1>     pop rdx
   291 00006DBA 5B                  <1>     pop rbx
   292 00006DBB 58                  <1>     pop rax
   293 00006DBC C3                  <1>     ret
   294                              <1> 
   295                              <1> ; ============================================================================
   296                              <1> ; battery_init
   297                              <1> ; ============================================================================
   298                              <1> battery_init:
   299 00006DBD 50                  <1>     push rax
   300 00006DBE 52                  <1>     push rdx
   301                              <1> 
   302 00006DBF C60425[7D0D0000]00  <1>     mov byte [battery_state], BAT_STATE_UNKNOWN
   303 00006DC7 C60425[7E0D0000]00  <1>     mov byte [battery_percent], 0
   304 00006DCF C60425[7F0D0000]00  <1>     mov byte [bat_ec_ok], 0
   305 00006DD7 C60425[800D0000]00  <1>     mov byte [bat_layout], EC_LAYOUT_NONE
   306 00006DDF C70425[830D0000]00- <1>     mov dword [bat_poll_counter], 0
   306 00006DE7 000000              <1>
   307                              <1> 
   308                              <1>     ; Serial: 'B'
   309 00006DEA 66BAF803            <1>     mov dx, 0x3F8
   310 00006DEE B042                <1>     mov al, 'B'
   311 00006DF0 EE                  <1>     out dx, al
   312                              <1> 
   313                              <1>     ; Probe EC to find working register layout
   314 00006DF1 E803FEFFFF          <1>     call battery_probe_layout
   315 00006DF6 84C0                <1>     test al, al
   316 00006DF8 7416                <1>     jz .ec_fail
   317                              <1> 
   318 00006DFA C60425[7F0D0000]01  <1>     mov byte [bat_ec_ok], 1
   319 00006E02 E88BFEFFFF          <1>     call battery_do_read
   320                              <1> 
   321 00006E07 66BAF803            <1>     mov dx, 0x3F8
   322 00006E0B B062                <1>     mov al, 'b'
   323 00006E0D EE                  <1>     out dx, al
   324 00006E0E EB17                <1>     jmp .ret
   325                              <1> 
   326                              <1> .ec_fail:
   327                              <1>     ; EC didn't respond - assume AC power (safe for desktop use)
   328 00006E10 C60425[7D0D0000]01  <1>     mov byte [battery_state], BAT_STATE_AC
   329 00006E18 C60425[7E0D0000]64  <1>     mov byte [battery_percent], 100
   330 00006E20 66BAF803            <1>     mov dx, 0x3F8
   331 00006E24 B021                <1>     mov al, '!'
   332 00006E26 EE                  <1>     out dx, al
   333                              <1> 
   334                              <1> .ret:
   335 00006E27 5A                  <1>     pop rdx
   336 00006E28 58                  <1>     pop rax
   337 00006E29 C3                  <1>     ret
   338                              <1> 
   339                              <1> ; ============================================================================
   340                              <1> ; battery_poll - throttled poll, call every main loop iteration
   341                              <1> ; ============================================================================
   342                              <1> battery_poll:
   343 00006E2A 803C25[7F0D0000]00  <1>     cmp byte [bat_ec_ok], 0
   344 00006E32 7424                <1>     je .skip
   345                              <1> 
   346 00006E34 FF0425[830D0000]    <1>     inc dword [bat_poll_counter]
   347 00006E3B 813C25[830D0000]2C- <1>     cmp dword [bat_poll_counter], 300   ; ~3 seconds at ~100fps
   347 00006E43 010000              <1>
   348 00006E46 7C10                <1>     jl .skip
   349 00006E48 C70425[830D0000]00- <1>     mov dword [bat_poll_counter], 0
   349 00006E50 000000              <1>
   350 00006E53 E83AFEFFFF          <1>     call battery_do_read
   351                              <1> .skip:
   352 00006E58 C3                  <1>     ret
   353                              <1> 
   354                              <1> section .data
   355                              <1> 
   356                              <1> global battery_state
   357                              <1> global battery_percent
   358                              <1> 
   359 00000D7D 00                  <1> battery_state:    db BAT_STATE_UNKNOWN
   360 00000D7E 00                  <1> battery_percent:  db 0
   361 00000D7F 00                  <1> bat_ec_ok:        db 0
   362 00000D80 00                  <1> bat_layout:       db EC_LAYOUT_NONE
   363 00000D81 0000                <1> bat_design_cap:   dw 0           ; Layout C: design capacity (mWh/10)
   364 00000D83 00000000            <1> bat_poll_counter: dd 0
