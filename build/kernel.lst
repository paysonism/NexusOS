  1138 00004DB4 7517                <1>     jnz .done
  1139                              <1> 
  1140 00004DB6 FFC9                <1>     dec ecx
  1141 00004DB8 740D                <1>     jz .fail_timeout
  1142                              <1> 
  1143 00004DBA 488B0425[D0000000]  <1>     mov rax, [tick_count]
  1144 00004DC2 4839F0              <1>     cmp rax, rsi                 ; rsi = deadline (not corrupted by xhci_poll_event)
  1145 00004DC5 7CE6                <1>     jl .poll
  1146                              <1> 
  1147                              <1> .fail_timeout:
  1148 00004DC7 31C0                <1>     xor eax, eax
  1149 00004DC9 5E                  <1>     pop rsi
  1150 00004DCA 59                  <1>     pop rcx
  1151 00004DCB 5B                  <1>     pop rbx
  1152 00004DCC C3                  <1>     ret
  1153                              <1> 
  1154                              <1> .done:
  1155 00004DCD 5E                  <1>     pop rsi
  1156 00004DCE 59                  <1>     pop rcx
  1157 00004DCF 5B                  <1>     pop rbx
  1158                              <1>     ; Check if it was success
  1159 00004DD0 83F801              <1>     cmp eax, 1
  1160 00004DD3 7506                <1>     jne .fail
  1161 00004DD5 B801000000          <1>     mov eax, 1
  1162 00004DDA C3                  <1>     ret
  1163                              <1> .fail:
  1164 00004DDB 31C0                <1>     xor eax, eax
