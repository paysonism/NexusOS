   605 0000222C 660F6F5620          <1>     movdqa xmm2, [rsi + 32]
   606 00002231 660F6F5E30          <1>     movdqa xmm3, [rsi + 48]
   607 00002236 660F6F6640          <1>     movdqa xmm4, [rsi + 64]
   608 0000223B 660F6F6E50          <1>     movdqa xmm5, [rsi + 80]
   609 00002240 660F6F7660          <1>     movdqa xmm6, [rsi + 96]
   610 00002245 660F6F7E70          <1>     movdqa xmm7, [rsi + 112]
