   199                              <1> 
   200 0000441C 48BE-               <1>     mov rsi, szUsbAddress
   200 0000441E [DF4F000000000000]  <1>
   201 00004426 E8E6BCFFFF          <1>     call debug_print
   202                              <1> 
   203                              <1>     ; --- 3. Address Device ---
   204 0000442B E897F8FFFF          <1>     call xhci_address_device
   205 00004430 85C0                <1>     test eax, eax
   206 00004432 748C                <1>     jz .try_next_controller
   207                              <1> 
   208 00004434 48BE-               <1>     mov rsi, szUsbGetDesc
   208 00004436 [F94F000000000000]  <1>
   209 0000443E E8CEBCFFFF          <1>     call debug_print
   210                              <1> 
   211                              <1>     ; Serial: 'H' (HID Init)
