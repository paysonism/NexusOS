   625 0000866D 4881FEDC020000      <1>     cmp rsi, TASKBAR_Y
   626 00008674 7D47                <1>     jge .check_taskbar
   627                              <1> 
   628                              <1>     ; Click inside menu - determine which item
   629 00008676 4889F0              <1>     mov rax, rsi
   630 00008679 482D14020000        <1>     sub rax, START_MENU_Y
   631 0000867F 4883E808            <1>     sub rax, 8
   632 00008683 4883F800            <1>     cmp rax, 0
   633 00008687 7C22                <1>     jl .close_menu
   634 00008689 4831D2              <1>     xor rdx, rdx
   635 0000868C B91C000000          <1>     mov rcx, MENU_ITEM_H
   636 00008691 48F7F1              <1>     div rcx
   637                              <1> 
   638                              <1>     ; Validate range
   639 00008694 4883F806            <1>     cmp rax, MENU_ITEM_COUNT
   640 00008698 7D11                <1>     jge .close_menu
   641                              <1> 
   642                              <1>     ; Close menu and return item index + 2
   643 0000869A C60425[7B110000]00  <1>     mov byte [tb_start_menu_open], 0
   644 000086A2 4883C002            <1>     add rax, 2
   645 000086A6 E916010000          <1>     jmp .tb_click_ret
   646                              <1> 
