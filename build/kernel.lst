   837                              <1> ; --- Wait for VSync / Frame Pacing ---
   838                              <1> ; On real AMD/UEFI hardware port 0x3DA is unreliable for vsync.
   839                              <1> ; Strategy: first try 0x3DA (works on VGA/QEMU), fall back to PIT-tick pacing.
   840                              <1> ; vsync_target_ticks = PIT ticks per frame (100Hz PIT: 180fps -> ~0.55 ticks -> 1 tick min)
   841                              <1> ; We use a hybrid: try 0x3DA with a long timeout; if it times out too fast, use PIT.
   842                              <1> global wait_vsync
   843                              <1> wait_vsync:
   844 00000220 53                  <1>     push rbx
   845 00000221 51                  <1>     push rcx
   846 00000222 52                  <1>     push rdx
   847 00000223 50                  <1>     push rax
   848                              <1> 
   849                              <1>     ; Check if interrupts are enabled. If they are disabled (IF=0), we are likely 
   850                              <1>     ; in an ISR or Syscall. Since tick_count won't increment in this state, 
   851                              <1>     ; we must skip the PIT-based pacing to avoid deadlocking/stalling.
   852 00000224 9C                  <1>     pushf
   853 00000225 58                  <1>     pop rax
   854 00000226 A900020000          <1>     test eax, 0x200         ; Bit 9 = Interrupt Flag
   855 0000022B 7467                <1>     jz .vsync_done_pop      ; Masked? Skip vsync wait.
   856                              <1> 
   857                              <1>     ; Quick check: does 0x3DA work at all? (VGA retrace signal)
   858                              <1>     ; On AMD UEFI/GOP hardware 0x3DA returns 0 always - skip it entirely.
   859                              <1>     ; We detect this by checking if 0x3DA ever has bit 0x08 set.
   860                              <1>     ; Instead: use a very short probe (1000 iters) to check for any activity.
   861 0000022D 66BADA03            <1>     mov dx, 0x3DA
   862 00000231 B9D0070000          <1>     mov ecx, 2000          ; Short probe: ~0.2ms at 100ns/IO
   863                              <1> .probe_3da:
   864 00000236 EC                  <1>     in al, dx
   865 00000237 A808                <1>     test al, 0x08
   866 00000239 7506                <1>     jnz .vga_active        ; 0x3DA is live - use it
   867 0000023B FFC9                <1>     dec ecx
   868 0000023D 75F7                <1>     jnz .probe_3da
   869                              <1>     ; 0x3DA never went high - not a real VGA controller, use PIT
   870 0000023F EB1E                <1>     jmp .pit_fallback
   871                              <1> 
   872                              <1> .vga_active:
   873                              <1>     ; 0x3DA is working - do full VGA vsync wait
   874                              <1>     ; Wait for retrace to end first (if currently in retrace)
   875 00000241 B9A0860100          <1>     mov ecx, 100000
   876                              <1> .wait_retrace_end:
   877 00000246 EC                  <1>     in al, dx
   878 00000247 A808                <1>     test al, 0x08
   879 00000249 7406                <1>     jz .wait_retrace_start
   880 0000024B FFC9                <1>     dec ecx
   881 0000024D 75F7                <1>     jnz .wait_retrace_end
   882 0000024F EB0E                <1>     jmp .pit_fallback       ; Stuck in retrace - fall back
   883                              <1> 
   884                              <1> .wait_retrace_start:
   885 00000251 B9A0860100          <1>     mov ecx, 100000        ; ~10ms timeout
   886                              <1> .wait_loop:
   887 00000256 EC                  <1>     in al, dx
   888 00000257 A808                <1>     test al, 0x08
   889 00000259 7539                <1>     jnz .vsync_done        ; Got retrace pulse - success
   890 0000025B FFC9                <1>     dec ecx
   891 0000025D 75F7                <1>     jnz .wait_loop
   892                              <1>     ; Timed out waiting for retrace start - fall back to PIT pacing
   893                              <1> 
   894                              <1> .pit_fallback:
   895                              <1>     ; PIT-based frame pacing: wait until tick_count advances by at least 1
   896                              <1>     ; This gives ~100fps max (one frame per 10ms tick) when 0x3DA doesn't work.
   897                              <1>     ; At 180Hz monitor, frames will pace to ~100fps which is smooth enough.
   898                              <1>     ; last_vsync_tick holds the tick count when we last flipped.
   899 0000025F 488B0425[D0000000]  <1>     mov rax, [tick_count]
   900 00000267 488B1C25[18020000]  <1>     mov rbx, [last_vsync_tick]
   901                              <1>     ; If tick_count > last_vsync_tick, a new tick has occurred - proceed
   902 0000026F 4839D8              <1>     cmp rax, rbx
   903 00000272 7F18                <1>     jg .pit_new_tick
   904                              <1>     ; Same tick - spin briefly checking tick_count (don't busy-loop forever)
   905 00000274 B9404B4C00          <1>     mov ecx, 5000000       ; max spin ~1.7ms at 3GHz
   906                              <1> .pit_spin:
   907 00000279 488B0425[D0000000]  <1>     mov rax, [tick_count]
   908 00000281 4839D8              <1>     cmp rax, rbx
   909 00000284 7F06                <1>     jg .pit_new_tick
   910 00000286 FFC9                <1>     dec ecx
   911 00000288 75EF                <1>     jnz .pit_spin
   912                              <1>     ; Still no new tick - just proceed (avoid stalling)
   913 0000028A EB08                <1>     jmp .vsync_done
   914                              <1> .pit_new_tick:
   915 0000028C 48890425[18020000]  <1>     mov [last_vsync_tick], rax
   916                              <1> 
   917                              <1> .vsync_done:
   918                              <1> .vsync_done_pop:
   919 00000294 58                  <1>     pop rax
   920 00000295 5A                  <1>     pop rdx
   921 00000296 59                  <1>     pop rcx
   922 00000297 5B                  <1>     pop rbx
   923 00000298 C3                  <1>     ret
