  1896 00004264 66BAF803            <1>     mov dx, 0x3F8
  1897 00004268 EE                  <1>     out dx, al
  1898 00004269 5A                  <1>     pop rdx
  1899 0000426A 59                  <1>     pop rcx
  1900 0000426B 5B                  <1>     pop rbx
  1901 0000426C 58                  <1>     pop rax
  1902 0000426D C3                  <1>     ret
