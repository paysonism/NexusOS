  1049                              <1>     ; Setup TRB:
  1050                              <1>     ; DW0, DW1: Setup Data (R8, R9) -> TRB has IDT (Immediate Data)
  1051                              <1>     ; But XHCI spec says Setup TRB uses Immediate Data for the 8 setup bytes.
  1052                              <1>     ; DW0: RequestType | Request | Value
  1053                              <1>     ; DW1: Index | Length
  1054                              <1>     
  1055                              <1>     ; Note: R8/R9 passed by caller are the content of the 8 bytes.
  1056                              <1>     ; TRB fields:
  1057                              <1>     ; DW0 = R8
  1058                              <1>     ; DW1 = R9
  1059                              <1>     ; DW2 = 8 (Length of immediate data always 8)
  1060                              <1>     ; DW3 = TRB_SETUP | TRB_IDT | TRB_TRT_IN
  1061                              <1>     
  1062 00004D03 41BA08000000        <1>     mov r10d, 8
  1063 00004D09 41BB40080300        <1>     mov r11d, TRB_SETUP | TRB_IDT | TRB_TRT_IN
