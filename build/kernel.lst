  1337                              <1> ; ============================================================================
  1338                              <1> ; usb_parse_keyboard_report - Parse USB HID boot keyboard report, push to kb_buffer
  1339                              <1> ; RSI = 8-byte report: [modifier, reserved, key0..key5]
  1340                              <1> ; ============================================================================
  1341                              <1> usb_parse_keyboard_report:
  1342 00004E87 53                  <1>     push rbx
  1343 00004E88 51                  <1>     push rcx
  1344 00004E89 52                  <1>     push rdx
  1345 00004E8A 57                  <1>     push rdi
  1346 00004E8B 4150                <1>     push r8
  1347 00004E8D 4151                <1>     push r9
  1348 00004E8F 4152                <1>     push r10
