   197 000053C6 880C25[88870200]    <1>     mov [spi_tx_buf + 2], cl
   198 000053CD C1E908              <1>     shr ecx, 8
   199 000053D0 880C25[89870200]    <1>     mov [spi_tx_buf + 3], cl
