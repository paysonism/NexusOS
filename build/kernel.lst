    71                              <1> ; --- memcpy: Copy bytes ---
    72                              <1> ; RDI = dest, RSI = src, RDX = count
    73                              <1> ; Returns: RAX = dest
    74                              <1> global fn_memcpy
    75                              <1> fn_memcpy:
