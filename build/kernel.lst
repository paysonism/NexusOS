   901 00005C23 E872FCFFFF          <1>     call i2c_write_byte
   902 00005C28 0FB70425[36090000]  <1>     movzx eax, word [i2c_hid_input_reg]
   903 00005C30 C1E808              <1>     shr eax, 8
   904 00005C33 E862FCFFFF          <1>     call i2c_write_byte
   905                              <1> 
   906                              <1>     ; Queue reads for the 2-byte length header
   907 00005C38 B800050000          <1>     mov eax, IC_CMD_READ | IC_CMD_RESTART
   908 00005C3D 894610              <1>     mov [rsi + DW_IC_DATA_CMD], eax
   909 00005C40 B800030000          <1>     mov eax, IC_CMD_READ | IC_CMD_STOP
