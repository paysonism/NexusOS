    84                              <1> 
    85                              <1>     ; 1. Try XHCI controllers until one succeeds with a HID endpoint
    86                              <1>     ;    xhci_pci_find continues from where it left off each call
    87 0000429F C60425[D1070000]00  <1>     mov byte [usb_ctrl_attempts], 0
    88 000042A7 C60425[C3070000]00  <1>     mov byte [usb_no_xhci], 0   ; Assume XHCI might exist until proven otherwise
    89 000042AF E90C010000          <1>     jmp .try_next_controller
    90                              <1> 
    91                              <1> .try_next_port:
    92                              <1>     ; Not HID on current port. Scan remaining ports on same controller
    93                              <1>     ; before giving up and calling xhci_init for the next controller.
    94                              <1>     ; This handles the case where a boot USB drive is on port 0 and
    95                              <1>     ; the mouse is on a subsequent port of the same xHCI controller.
    96 000042B4 488B3425[22050000]  <1>     mov rsi, [xhci_op_base]
    97 000042BC 4881C600040000      <1>     add rsi, 0x400                      ; Port register base
    98 000042C3 0FB60C25[3D050000]  <1>     movzx ecx, byte [xhci_max_ports]
    99 000042CB 0FB61425[6C050000]  <1>     movzx edx, byte [xhci_port_num]     ; 1-based last tried → 0-based next to check
   100                              <1> .tport_scan:
   101 000042D3 39CA                <1>     cmp edx, ecx
   102 000042D5 0F8DE5000000        <1>     jge .try_next_controller            ; No more ports on this controller
   103 000042DB 89D0                <1>     mov eax, edx
   104 000042DD C1E004              <1>     shl eax, 4
   105 000042E0 8B1C06              <1>     mov ebx, [rsi + rax + XHCI_PORTSC]
   106 000042E3 F7C301000000        <1>     test ebx, XHCI_PORTSC_CCS
