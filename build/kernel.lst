    27 00001D25 8B04250C900000      <1>     mov eax, [0x900C]
    28 00001D2C 890425[0E020000]    <1>     mov [scr_height], eax
    29 00001D33 8B042510900000      <1>     mov eax, [0x9010]
    30 00001D3A 890425[12020000]    <1>     mov [scr_pitch], eax
    31                              <1> 
    32                              <1>     ; SAFETY: Check for zero dimensions/pitch (loader failure)
