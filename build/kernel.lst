   794                              <1> ; --- Helper: Restore just the FPS region from cached backbuffer ---
   795                              <1> ; Copies FPS_REGION_W * FPS_REGION_H pixels from save buffer to backbuffer
   796                              <1> .rf_restore_fps_region:
   797 000008EF 57                  <1>     push rdi
   798 000008F0 56                  <1>     push rsi
   799 000008F1 51                  <1>     push rcx
   800 000008F2 50                  <1>     push rax
   801                              <1> 
   802                              <1>     ; Calculate offset for FPS region: y*pitch + x*4
   803 000008F3 B808000000          <1>     mov eax, FPS_REGION_Y
   804 000008F8 0FAF0425[12020000]  <1>     imul eax, [scr_pitch]
   805 00000900 83C020              <1>     add eax, FPS_REGION_X * 4
   806                              <1> 
   807 00000903 488B3C25[02020000]  <1>     mov rdi, [bb_addr]
   808 0000090B 4801C7              <1>     add rdi, rax              ; dest = backbuffer + offset
   809 0000090E BE0000A000          <1>     mov rsi, BACK_BUFFER_SAVE_ADDR
   810 00000913 4801C6              <1>     add rsi, rax              ; src = save buffer + offset
   811                              <1> 
   812 00000916 48630C25[12020000]  <1>     movsxd rcx, dword [scr_pitch]
   813 0000091E B828000000          <1>     mov eax, FPS_REGION_H     ; row count
   814                              <1> 
   815                              <1> .rfr_row:
   816                              <1>     ; Copy one row of FPS region (FPS_REGION_W * 4 bytes)
   817 00000923 57                  <1>     push rdi
   818 00000924 56                  <1>     push rsi
   819 00000925 50                  <1>     push rax
   820 00000926 B922010000          <1>     mov ecx, FPS_REGION_W     ; pixels per row
   821 0000092B F3A5                <1>     rep movsd                  ; copy dwords (4 bytes per pixel)
   822 0000092D 58                  <1>     pop rax
   823 0000092E 5E                  <1>     pop rsi
   824 0000092F 5F                  <1>     pop rdi
   825                              <1> 
   826                              <1>     ; Advance to next row
   827 00000930 48630C25[12020000]  <1>     movsxd rcx, dword [scr_pitch]
   828 00000938 4801CF              <1>     add rdi, rcx
   829 0000093B 4801CE              <1>     add rsi, rcx
   830 0000093E FFC8                <1>     dec eax
   831 00000940 75E1                <1>     jnz .rfr_row
   832                              <1> 
   833 00000942 58                  <1>     pop rax
   834 00000943 59                  <1>     pop rcx
   835 00000944 5E                  <1>     pop rsi
   836 00000945 5F                  <1>     pop rdi
   837 00000946 C3                  <1>     ret
