   106 00001DED 4189CC              <1>     mov r12d, ecx            ; h
   107 00001DF0 4589C5              <1>     mov r13d, r8d            ; color
   108                              <1> 
   109                              <1>     ; Clip left
   110 00001DF3 4183F900            <1>     cmp r9d, 0
   111 00001DF7 7D06                <1>     jge .clip_right
   112 00001DF9 4501CB              <1>     add r11d, r9d            ; Reduce width
