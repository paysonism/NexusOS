  1065                              <1>     
  1066                              <1>     ; 2. Data Stage
  1067 00004D14 5F                  <1>     pop rdi
  1068 00004D15 59                  <1>     pop rcx
  1069                              <1>     
  1070 00004D16 4883F900            <1>     cmp rcx, 0
