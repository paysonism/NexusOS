    91                              <1> ; --- memset: Fill memory ---
    92                              <1> ; RDI = dest, ESI = byte value, RDX = count
    93                              <1> ; Returns: RAX = dest
    94                              <1> global fn_memset
    95                              <1> fn_memset:
    96 0000C8B8 57                  <1>     push rdi
    97 0000C8B9 51                  <1>     push rcx
    98 0000C8BA 4889F0              <1>     mov rax, rsi
    99 0000C8BD 4889D1              <1>     mov rcx, rdx
   100                              <1>     ; Fill qwords
   101 0000C8C0 88C4                <1>     mov ah, al
   102 0000C8C2 0FB7C0              <1>     movzx eax, ax
