    40 0000C878 48FFC6              <1>     inc rsi
    41 0000C87B EBEC                <1>     jmp .cmp_loop
    42                              <1> .cmp_diff:
    43 0000C87D 0FB6C0              <1>     movzx eax, al
    44 0000C880 0FB6DB              <1>     movzx ebx, bl
    45 0000C883 29D8                <1>     sub eax, ebx
    46 0000C885 5B                  <1>     pop rbx
