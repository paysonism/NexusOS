    95 00001DD9 56                  <1>     push rsi
    96 00001DDA 4151                <1>     push r9
    97 00001DDC 4152                <1>     push r10
    98 00001DDE 4153                <1>     push r11
    99 00001DE0 4154                <1>     push r12
