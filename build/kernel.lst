   114 000052D6 C60425[87870200]04  <1>     mov byte [spi_tx_buf + 1], SPI_CID_RESET
   115 000052DE C60425[88870200]04  <1>     mov byte [spi_tx_buf + 2], 0x04    ; length (4 bytes total including header)
   116 000052E6 C60425[89870200]00  <1>     mov byte [spi_tx_buf + 3], 0x00
   117 000052EE C60425[8A870200]01  <1>     mov byte [spi_tx_buf + 4], 0x01    ; RESET opcode
   118 000052F6 C60425[8B870200]00  <1>     mov byte [spi_tx_buf + 5], 0x00
   119                              <1> 
   120 000052FE 488D3C25[86870200]  <1>     lea rdi, [spi_tx_buf]
   121 00005306 BE06000000          <1>     mov rsi, 6
