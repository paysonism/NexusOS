   264                              <1> ; desktop_add_icon: EDI=app_id -> adds to first empty slot
   265                              <1> ; ============================================================================
   266                              <1> desktop_add_icon:
   267                              <1>     ; First check if already present
   268 00008D04 57                  <1>     push rdi
   269 00008D05 E8DDFFFFFF          <1>     call desktop_has_icon
   270 00008D0A 5F                  <1>     pop rdi
   271 00008D0B 85C0                <1>     test eax, eax
   272 00008D0D 751B                <1>     jnz .add_done             ; already there
   273                              <1> 
   274 00008D0F 31C9                <1>     xor ecx, ecx
   275                              <1> .add_loop:
   276 00008D11 83F908              <1>     cmp ecx, MAX_DESK_ICONS
   277 00008D14 7D14                <1>     jge .add_done             ; no room
   278 00008D16 80B9[96110000]00    <1>     cmp byte [desktop_icons + rcx], 0
   279 00008D1D 7404                <1>     je .add_found
   280 00008D1F FFC1                <1>     inc ecx
   281 00008D21 EBEE                <1>     jmp .add_loop
   282                              <1> .add_found:
   283 00008D23 4088B9[96110000]    <1>     mov byte [desktop_icons + rcx], dil
   284                              <1> .add_done:
   285 00008D2A C3                  <1>     ret
   286                              <1> 
