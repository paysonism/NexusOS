   588 000065D2 83F920              <1>     cmp ecx, 32
   589 000065D5 7D0B                <1>     jge .no_mask
   590 000065D7 BA01000000          <1>     mov edx, 1
   591 000065DC D3E2                <1>     shl edx, cl
   592 000065DE FFCA                <1>     dec edx                     ; mask = (1 << size) - 1
   593 000065E0 21D0                <1>     and eax, edx
   594                              <1> .no_mask:
   595                              <1> 
   596 000065E2 5E                  <1>     pop rsi
   597 000065E3 5A                  <1>     pop rdx
   598 000065E4 59                  <1>     pop rcx
   599 000065E5 5B                  <1>     pop rbx
