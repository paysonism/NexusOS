    21                              <1> ; --- Set one IDT entry ---
    22                              <1> ; RDI = entry index (0-255)
    23                              <1> ; RSI = handler address
    24                              <1> idt_set_entry:
    25 00000980 53                  <1>     push rbx
    26                              <1>     ; Calculate entry address: IDT_ADDR + index * 16
    27 00000981 4889F8              <1>     mov rax, rdi
    28 00000984 48C1E004            <1>     shl rax, 4              ; * 16
    29 00000988 488D9800002000      <1>     lea rbx, [IDT_ADDR + rax]
    30                              <1> 
    31                              <1>     ; Entry format (16 bytes):
    32                              <1>     ; [0-1]  Offset[15:0]
    33                              <1>     ; [2-3]  Segment selector (code segment = 0x08)
    34                              <1>     ; [4]    IST (0)
    35                              <1>     ; [5]    Type/Attr (0x8E = present, ring0, interrupt gate)
    36                              <1>     ; [6-7]  Offset[31:16]
    37                              <1>     ; [8-11] Offset[63:32]
    38                              <1>     ; [12-15] Reserved (0)
    39                              <1> 
    40 0000098F 4889F0              <1>     mov rax, rsi             ; Handler address
    41 00000992 668903              <1>     mov word [rbx], ax       ; Offset[15:0]
    42 00000995 66C743020800        <1>     mov word [rbx + 2], 0x08 ; Code segment selector
    43 0000099B C6430400            <1>     mov byte [rbx + 4], 0    ; IST = 0
    44 0000099F C643058E            <1>     mov byte [rbx + 5], 0x8E ; Type: present, DPL=0, interrupt gate
    45 000009A3 48C1E810            <1>     shr rax, 16
    46 000009A7 66894306            <1>     mov word [rbx + 6], ax   ; Offset[31:16]
    47 000009AB 48C1E810            <1>     shr rax, 16
    48 000009AF 894308              <1>     mov dword [rbx + 8], eax ; Offset[63:32]
    49 000009B2 C7430C00000000      <1>     mov dword [rbx + 12], 0  ; Reserved
    50                              <1> 
    51 000009B9 5B                  <1>     pop rbx
    52 000009BA C3                  <1>     ret
    53                              <1> 
    54                              <1> ; --- Initialize IDT ---
