   135 00001114 4881EB00003000      <1>     sub rbx, PAGE_BITMAP_ADDR  ; Byte offset
   136 0000111B 48C1E303            <1>     shl rbx, 3                 ; * 8 = base page number for this byte
   137                              <1> 
   138 0000111F 31C9                <1>     xor ecx, ecx
   139                              <1> .find_bit:
   140 00001121 0FA3C8              <1>     bt eax, ecx
   141 00001124 730C                <1>     jnc .got_bit
   142 00001126 FFC1                <1>     inc ecx
   143 00001128 83F908              <1>     cmp ecx, 8
   144 0000112B 7CF4                <1>     jl .find_bit
   145                              <1>     ; Shouldn't reach here
   146 0000112D 4831C0              <1>     xor rax, rax
   147 00001130 EB15                <1>     jmp .alloc_done
   148                              <1> 
   149                              <1> .got_bit:
