  1178                              <1>     
  1179                              <1> .parse:
  1180 00004DEB 39CA                <1>     cmp edx, ecx
  1181 00004DED 0F8D91000000        <1>     jge .not_found
  1182                              <1>     
  1183                              <1>     ; Read bLength (offset + 0)
  1184 00004DF3 0FB60416            <1>     movzx eax, byte [rsi + rdx]
