   128                              <1> 
   129                              <1> ; debug_print - Helper to print string to screen AND serial
   130                              <1> ; RSI = string pointer
   131                              <1> global debug_print
   132                              <1> debug_print:
   133 00000111 50                  <1>     push rax
   134 00000112 53                  <1>     push rbx
   135 00000113 51                  <1>     push rcx
   136 00000114 52                  <1>     push rdx
   137 00000115 57                  <1>     push rdi
   138 00000116 56                  <1>     push rsi
   139 00000117 4150                <1>     push r8
   140 00000119 4151                <1>     push r9
   141 0000011B 4152                <1>     push r10
   142 0000011D 4153                <1>     push r11
   143                              <1>     
   144                              <1>     ; --- Serial Output (0x3F8) ---
   145 0000011F 4889F2              <1>     mov rdx, rsi
   146                              <1> .serial_loop:
   147 00000122 0FB602              <1>     movzx eax, byte [rdx]
   148 00000125 84C0                <1>     test al, al
   149 00000127 740C                <1>     jz .serial_done
   150 00000129 52                  <1>     push rdx
   151 0000012A 66BAF803            <1>     mov dx, 0x3F8
   152 0000012E EE                  <1>     out dx, al
   153 0000012F 5A                  <1>     pop rdx
