     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - Task State Segment (64-bit)
     3                              <1> ; ============================================================================
     4                              <1> bits 64
     5                              <1> 
     6                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> 
    33                              <2> ; --- Stage 2 disk layout ---
    34                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    35                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    36                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    37                              <2> 
    38                              <2> ; --- Screen ---
    39                              <2> SCREEN_WIDTH        equ 1024
    40                              <2> SCREEN_HEIGHT       equ 768
    41                              <2> SCREEN_BPP          equ 32
    42                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    43                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    44                              <2> 
    45                              <2> 
    46                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    47                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    48                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    49                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    50                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    51                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    52                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    53                              <2> 
    54                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    55                              <2> COLOR_BLACK         equ 0x00000000
    56                              <2> COLOR_WHITE         equ 0x00FFFFFF
    57                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    58                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    59                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    60                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    61                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    62                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    63                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    64                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    65                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    66                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    67                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    68                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    69                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    70                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    71                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    72                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    73                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    74                              <2> COLOR_START_HOVER    equ 0x00338833
    75                              <2> 
    76                              <2> ; --- Window Manager ---
    77                              <2> MAX_WINDOWS         equ 8
    78                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    79                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    80                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    81                              <2> TITLEBAR_HEIGHT     equ 24
    82                              <2> BORDER_WIDTH        equ 2
    83                              <2> CLOSE_BTN_SIZE      equ 18
    84                              <2> MIN_BTN_SIZE        equ 18
    85                              <2> MIN_WINDOW_W        equ 200
    86                              <2> MIN_WINDOW_H        equ 100
    87                              <2> 
    88                              <2> ; --- Taskbar ---
    89                              <2> TASKBAR_HEIGHT      equ 36
    90                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    91                              <2> START_BTN_W         equ 70
    92                              <2> START_BTN_H         equ 28
    93                              <2> START_BTN_X         equ 4
    94                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    95                              <2> CLOCK_WIDTH         equ 64
    96                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    97                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    98                              <2> 
    99                              <2> ; --- Keyboard ---
   100                              <2> KB_BUFFER_SIZE      equ 64
   101                              <2> 
   102                              <2> ; --- Mouse ---
   103                              <2> MOUSE_BUFFER_SIZE   equ 64
   104                              <2> CURSOR_WIDTH        equ 12
   105                              <2> CURSOR_HEIGHT       equ 19
   106                              <2> 
   107                              <2> ; --- PIT ---
   108                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   109                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   110                              <2> 
   111                              <2> ; --- PIC vectors ---
   112                              <2> IRQ_BASE_MASTER     equ 32
   113                              <2> IRQ_BASE_SLAVE      equ 40
   114                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   115                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   116                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   117                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   118                              <2> 
   119                              <2> ; --- Font ---
   120                              <2> FONT_WIDTH          equ 8
   121                              <2> FONT_HEIGHT         equ 16
   122                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   123                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   124                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   125                              <2> 
   126                              <2> ; --- Window flags ---
   127                              <2> WF_VISIBLE          equ 0x01
   128                              <2> WF_FOCUSED          equ 0x02
   129                              <2> WF_DRAGGING         equ 0x04
   130                              <2> WF_MINIMIZED        equ 0x08
   131                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   132                              <2> 
   133                              <2> ; --- Mouse event types ---
   134                              <2> MEVT_MOVE           equ 1
   135                              <2> MEVT_LCLICK         equ 2
   136                              <2> MEVT_RCLICK         equ 3
   137                              <2> MEVT_LRELEASE       equ 4
   138                              <2> MEVT_RRELEASE       equ 5
   139                              <2> 
   140                              <2> ; --- Key modifier flags ---
   141                              <2> KMOD_SHIFT          equ 0x01
   142                              <2> KMOD_CTRL           equ 0x02
   143                              <2> KMOD_ALT            equ 0x04
   144                              <2> 
   145                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   146                              <2> KEY_F1              equ 0xF1
   147                              <2> KEY_F2              equ 0xF2
   148                              <2> KEY_F3              equ 0xF3
   149                              <2> KEY_F4              equ 0xF4
   150                              <2> KEY_F5              equ 0xF5
   151                              <2> KEY_F6              equ 0xF6
   152                              <2> KEY_F7              equ 0xF7
   153                              <2> KEY_F8              equ 0xF8
   154                              <2> KEY_F9              equ 0xF9
   155                              <2> KEY_F10             equ 0xFA
   156                              <2> KEY_F11             equ 0xFB
   157                              <2> KEY_F12             equ 0xFC
   158                              <2> 
   159                              <2> ; --- USB/XHCI Memory Layout ---
   160                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   161                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   162                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   163                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   164                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   165                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   166                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   167                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   168                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   169                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   170                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   171                              <2> ; Slot 2 device support
   172                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   173                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   174                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   175                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   176                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   177                              <2> 
   178                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   179                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   180                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   181                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   182                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   183                              <2> XHCI_CAP_DBOFF      equ 0x14
   184                              <2> XHCI_CAP_RTSOFF     equ 0x18
   185                              <2> 
   186                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   187                              <2> XHCI_OP_USBCMD      equ 0x00
   188                              <2> XHCI_OP_USBSTS      equ 0x04
   189                              <2> XHCI_OP_PAGESIZE     equ 0x08
   190                              <2> XHCI_OP_DNCTRL      equ 0x14
   191                              <2> XHCI_OP_CRCR_LO     equ 0x18
   192                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   193                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   194                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   195                              <2> XHCI_OP_CONFIG      equ 0x38
   196                              <2> 
   197                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   198                              <2> XHCI_PORTSC         equ 0x00
   199                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   200                              <2> 
   201                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   202                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   203                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   204                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   205                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   206                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   207                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   208                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   209                              <2> 
   210                              <2> ; --- USBCMD bits ---
   211                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   212                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   213                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   214                              <2> 
   215                              <2> ; --- USBSTS bits ---
   216                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   217                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   218                              <2> 
   219                              <2> ; --- PORTSC bits ---
   220                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   221                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   222                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   223                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   224                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   225                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   226                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   227                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   228                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   229                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   230                              <2> 
   231                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   232                              <2> TRB_NORMAL           equ (1 << 10)
   233                              <2> TRB_SETUP            equ (2 << 10)
   234                              <2> TRB_DATA             equ (3 << 10)
   235                              <2> TRB_STATUS           equ (4 << 10)
   236                              <2> TRB_LINK             equ (6 << 10)
   237                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   238                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   239                              <2> TRB_CONFIG_EP        equ (12 << 10)
   240                              <2> TRB_EVAL_CTX         equ (13 << 10)
   241                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   242                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   243                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   244                              <2> 
   245                              <2> ; --- TRB Flag Bits (dword 3) ---
   246                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   247                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   248                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   249                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   250                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   251                              <2> 
   252                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   253                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   254                              <2> TRB_TRT_OUT          equ (2 << 16)
   255                              <2> TRB_TRT_IN           equ (3 << 16)
   256                              <2> 
   257                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   258                              <2> TRB_DIR_OUT          equ (0 << 16)
   259                              <2> TRB_DIR_IN           equ (1 << 16)
   260                              <2> 
   261                              <2> ; --- Ring sizes ---
   262                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   263                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   264                              <2> 
   265                              <2> ; --- USB Standard Request Codes ---
   266                              <2> USB_REQ_GET_DESC     equ 0x06
   267                              <2> USB_REQ_SET_CONFIG   equ 0x09
   268                              <2> USB_REQ_SET_IFACE    equ 0x0B
   269                              <2> 
   270                              <2> ; --- USB HID Request Codes ---
   271                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   272                              <2> 
   273                              <2> ; --- USB Descriptor Types ---
   274                              <2> USB_DESC_DEVICE      equ 0x01
   275                              <2> USB_DESC_CONFIG      equ 0x02
   276                              <2> USB_DESC_INTERFACE   equ 0x04
   277                              <2> USB_DESC_ENDPOINT    equ 0x05
   278                              <2> USB_DESC_HID         equ 0x21
   279                              <2> 
   280                              <2> ; --- USB Endpoint Types ---
   281                              <2> USB_EP_CONTROL       equ 0
   282                              <2> USB_EP_ISOCH         equ 1
   283                              <2> USB_EP_BULK          equ 2
   284                              <2> USB_EP_INTERRUPT     equ 3
   285                              <2> 
   286                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   287                              <2> XHCI_EP_NOT_VALID    equ 0
   288                              <2> XHCI_EP_ISOCH_OUT    equ 1
   289                              <2> XHCI_EP_BULK_OUT     equ 2
   290                              <2> XHCI_EP_INT_OUT      equ 3
   291                              <2> XHCI_EP_CONTROL      equ 4
   292                              <2> XHCI_EP_ISOCH_IN     equ 5
   293                              <2> XHCI_EP_BULK_IN      equ 6
   294                              <2> XHCI_EP_INT_IN       equ 7
   295                              <2> 
   296                              <2> ; --- XHCI Port Speeds ---
   297                              <2> XHCI_SPEED_FULL      equ 1
   298                              <2> XHCI_SPEED_LOW       equ 2
   299                              <2> XHCI_SPEED_HIGH      equ 3
   300                              <2> XHCI_SPEED_SUPER     equ 4
     7                              <1> 
     8                              <1> section .data
     9                              <1> global tss64
    10 000000FC 90<rep 4h>          <1> align 16
    11                              <1> tss64:
    12 00000100 00000000            <1>     dd 0            ; Reserved
    13 00000104 0000200000000000    <1>     dq 0x200000     ; RSP0: Kernel stack top (must match stage2.asm)
    14 0000010C 0000000000000000    <1>     dq 0            ; RSP1
    15 00000114 0000000000000000    <1>     dq 0            ; RSP2
    16 0000011C 0000000000000000    <1>     dq 0            ; Reserved
    17 00000124 0000000000000000    <1>     dq 0            ; IST1
    18 0000012C 0000000000000000    <1>     dq 0            ; IST2
    19 00000134 0000000000000000    <1>     dq 0            ; IST3
    20 0000013C 0000000000000000    <1>     dq 0            ; IST4
    21 00000144 0000000000000000    <1>     dq 0            ; IST5
    22 0000014C 0000000000000000    <1>     dq 0            ; IST6
    23 00000154 0000000000000000    <1>     dq 0            ; IST7
    24 0000015C 0000000000000000    <1>     dq 0            ; Reserved
    25 00000164 0000                <1>     dw 0            ; Reserved
    26 00000166 6800                <1>     dw 104          ; I/O Map Base Address (points outside TSS = no I/O map)
    27                              <1> 
    28                              <1> section .text
    29                              <1> 
    30                              <1> ; --- Initialize TSS in GDT and load it ---
    31                              <1> global tss_init
    32                              <1> tss_init:
    33 00001345 50                  <1>     push rax
    34 00001346 53                  <1>     push rbx
    35 00001347 57                  <1>     push rdi
    36                              <1> 
    37                              <1>     ; Get TSS address
    38 00001348 488D0425[00010000]  <1>     lea rax, [tss64]
    39                              <1>     
    40                              <1>     ; Find the TSS descriptor in GDT - read actual GDT base from GDTR
    41 00001350 4883EC10            <1>     sub rsp, 16
    42 00001354 0F010424            <1>     sgdt [rsp]              ; store GDTR: [0-1]=limit, [2-9]=base
    43 00001358 488B7C2402          <1>     mov rdi, [rsp + 2]      ; RDI = actual GDT base address
    44 0000135D 4883C410            <1>     add rsp, 16
    45 00001361 4883C730            <1>     add rdi, 0x30           ; TSS descriptor at offset 0x30
    46                              <1> 
    47                              <1>     ; Fill TSS Descriptor (16 bytes)
    48                              <1>     ; [0-1] Limit[15:0] = 103 (already set in gdt.asm)
    49                              <1>     ; [2-3] Base[15:0]
    50 00001365 66894702            <1>     mov [rdi + 2], ax
    51 00001369 48C1E810            <1>     shr rax, 16
    52                              <1>     ; [4] Base[23:16]
    53 0000136D 884704              <1>     mov [rdi + 4], al
    54                              <1>     ; [5] Access: 0x89 (already set)
    55                              <1>     ; [6] Flags + Limit High (already set)
    56                              <1>     ; [7] Base[31:24]
    57 00001370 48C1E808            <1>     shr rax, 8
    58 00001374 884707              <1>     mov [rdi + 7], al
    59                              <1>     ; [8-11] Base[63:32]
    60 00001377 48C1E808            <1>     shr rax, 8
    61 0000137B 894708              <1>     mov [rdi + 8], eax
    62                              <1>     ; [12-15] Reserved (0)
    63                              <1> 
    64                              <1>     ; Load TR register
    65 0000137E 66B83000            <1>     mov ax, 0x30            ; TSS Selector (Index 6 * 8)
    66 00001382 0F00D8              <1>     ltr ax
    67                              <1> 
    68 00001385 5F                  <1>     pop rdi
    69 00001386 5B                  <1>     pop rbx
    70 00001387 58                  <1>     pop rax
    71 00001388 C3                  <1>     ret
    28                                  %include "src/boot/gdt.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - Global Descriptor Table
     3                              <1> ; Three stages: 16-bit temp, 32-bit PM, 64-bit LM
     4                              <1> ; ============================================================================
     5                              <1> 
     6                              <1> ; --- 32-bit Protected Mode GDT (temporary, for transition) ---
     7 00001389 90<rep 7h>          <1> align 16
     8                              <1> gdt32_start:
     9                              <1>     ; Null descriptor
    10 00001390 0000000000000000    <1>     dq 0
    11                              <1> 
    12                              <1> gdt32_code:
    13                              <1>     ; 32-bit code segment: base=0, limit=4GB, execute/read
    14 00001398 FFFF                <1>     dw 0xFFFF               ; Limit[15:0]
    15 0000139A 0000                <1>     dw 0x0000               ; Base[15:0]
    16 0000139C 00                  <1>     db 0x00                 ; Base[23:16]
    17 0000139D 9A                  <1>     db 10011010b            ; Access: present, ring0, code, exec/read
    18 0000139E CF                  <1>     db 11001111b            ; Flags: 4K granularity, 32-bit + Limit[19:16]
    19 0000139F 00                  <1>     db 0x00                 ; Base[31:24]
    20                              <1> 
    21                              <1> gdt32_data:
    22                              <1>     ; 32-bit data segment: base=0, limit=4GB, read/write
    23 000013A0 FFFF                <1>     dw 0xFFFF
    24 000013A2 0000                <1>     dw 0x0000
    25 000013A4 00                  <1>     db 0x00
    26 000013A5 92                  <1>     db 10010010b            ; Access: present, ring0, data, read/write
    27 000013A6 CF                  <1>     db 11001111b
    28 000013A7 00                  <1>     db 0x00
    29                              <1> gdt32_end:
    30                              <1> 
    31                              <1> gdt32_ptr:
    32 000013A8 1700                <1>     dw gdt32_end - gdt32_start - 1
    33 000013AA [90130000]          <1>     dd gdt32_start
    34                              <1> 
    35                              <1> GDT32_CODE_SEG equ gdt32_code - gdt32_start
    36                              <1> GDT32_DATA_SEG equ gdt32_data - gdt32_start
    37                              <1> 
    38                              <1> ; --- 64-bit Long Mode GDT ---
    39 000013AE 90<rep 2h>          <1> align 16
    40                              <1> gdt64_start:
    41                              <1>     ; Null descriptor (Selector 0x00)
    42 000013B0 0000000000000000    <1>     dq 0
    43                              <1> 
    44                              <1> gdt64_code:
    45                              <1>     ; 64-bit kernel code segment (Selector 0x08): L=1, D=0
    46 000013B8 0000                <1>     dw 0x0000               ; Limit[15:0] (ignored in 64-bit)
    47 000013BA 0000                <1>     dw 0x0000               ; Base[15:0]
    48 000013BC 00                  <1>     db 0x00                 ; Base[23:16]
    49 000013BD 9A                  <1>     db 10011010b            ; Access: present, ring0, code, exec/read
    50 000013BE 20                  <1>     db 00100000b            ; Flags: L=1 (64-bit), D=0
    51 000013BF 00                  <1>     db 0x00                 ; Base[31:24]
    52                              <1> 
    53                              <1> gdt64_data:
    54                              <1>     ; 64-bit kernel data segment (Selector 0x10)
    55 000013C0 0000                <1>     dw 0x0000
    56 000013C2 0000                <1>     dw 0x0000
    57 000013C4 00                  <1>     db 0x00
    58 000013C5 92                  <1>     db 10010010b            ; Access: present, ring0, data, read/write
    59 000013C6 00                  <1>     db 00000000b            ; Flags: none
    60 000013C7 00                  <1>     db 0x00
    61                              <1> 
    62                              <1> gdt64_user_code32:
    63                              <1>     ; User 32-bit code placeholder (Selector 0x18) - required for sysret layout
    64 000013C8 FFFF000000FACF00    <1>     dq 0x00CFFA000000FFFF   ; Present, DPL=3, Code, 32-bit
    65                              <1> 
    66                              <1> gdt64_user_data:
    67                              <1>     ; 64-bit user data segment (Selector 0x20): DPL=3, read/write
    68 000013D0 0000                <1>     dw 0x0000
    69 000013D2 0000                <1>     dw 0x0000
    70 000013D4 00                  <1>     db 0x00
    71 000013D5 F2                  <1>     db 11110010b            ; Access: present, ring3, data, read/write
    72 000013D6 00                  <1>     db 00000000b            ; Flags: none
    73 000013D7 00                  <1>     db 0x00
    74                              <1> 
    75                              <1> gdt64_user_code64:
    76                              <1>     ; 64-bit user code segment (Selector 0x28): DPL=3, L=1
    77 000013D8 0000                <1>     dw 0x0000
    78 000013DA 0000                <1>     dw 0x0000
    79 000013DC 00                  <1>     db 0x00
    80 000013DD FA                  <1>     db 11111010b            ; Access: present, ring3, code, exec/read
    81 000013DE 20                  <1>     db 00100000b            ; Flags: L=1, D=0
    82 000013DF 00                  <1>     db 0x00
    83                              <1> 
    84                              <1> gdt64_tss:
    85                              <1>     ; 64-bit TSS descriptor (16 bytes, Selector 0x30/0x38)
    86 000013E0 6700                <1>     dw 103                  ; Limit (104 bytes - 1)
    87 000013E2 0000                <1>     dw 0                    ; Base low (filled at runtime)
    88 000013E4 00                  <1>     db 0                    ; Base mid 1
    89 000013E5 89                  <1>     db 10001001b            ; Access: Present, TSS Available
    90 000013E6 00                  <1>     db 0                    ; Flags + Limit High
    91 000013E7 00                  <1>     db 0                    ; Base mid 2
    92 000013E8 0000000000000000    <1>     dq 0                    ; Base high (remaining 32 bits + reserved)
    93                              <1> 
    94                              <1> gdt64_end:
    95                              <1> 
    96                              <1> gdt64_ptr:
    97 000013F0 3F00                <1>     dw gdt64_end - gdt64_start - 1
    98 000013F2 [B013000000000000]  <1>     dq gdt64_start          ; dq instead of dd dd to avoid upper bits confusion
    99                              <1> 
   100                              <1> GDT64_CODE_SEG  equ gdt64_code - gdt64_start
   101                              <1> GDT64_DATA_SEG  equ gdt64_data - gdt64_start
   102                              <1> GDT64_USER_DATA equ (gdt64_user_data - gdt64_start) | 3
   103                              <1> GDT64_USER_CODE equ (gdt64_user_code64 - gdt64_start) | 3
   104                              <1> GDT64_TSS       equ gdt64_tss - gdt64_start
   105                              <1> 
   106                              <1> %ifndef STAGE2_BUILD
   107                              <1> section .text
   108                              <1> ; --- Re-load GDT from within kernel ---
   109                              <1> global gdt64_init
   110                              <1> bits 64
   111                              <1> gdt64_init:
   112 000013FA 50                  <1>     push rax
   113 000013FB 488D0425[F0130000]  <1>     lea rax, [gdt64_ptr]
   114 00001403 0F0110              <1>     lgdt [rax]
   115                              <1>     
   116                              <1>     ; Reload segments
   117 00001406 66B81000            <1>     mov ax, GDT64_DATA_SEG
   118 0000140A 8ED8                <1>     mov ds, ax
   119 0000140C 8EC0                <1>     mov es, ax
   120 0000140E 8EE0                <1>     mov fs, ax
   121 00001410 8EE8                <1>     mov gs, ax
   122 00001412 8ED0                <1>     mov ss, ax
   123                              <1>     
   124                              <1>     ; Far jump to reload CS
   125                              <1>     ; In 64-bit, we can use a direct push/retf
   126 00001414 488D0425[21140000]  <1>     lea rax, [.next]
   127 0000141C 6A08                <1>     push qword GDT64_CODE_SEG
   128 0000141E 50                  <1>     push rax
   129 0000141F 48CB                <1>     retfq
   130                              <1> .next:
   131 00001421 58                  <1>     pop rax
   132 00001422 C3                  <1>     ret
   133                              <1> %endif
    29                                  %include "src/kernel/usermode.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - Usermode Transition
     3                              <1> ; Clean L3 callback path for app draw/click/key handlers.
     4                              <1> ; ============================================================================
     5                              <1> bits 64
     6                              <1> 
     7                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> 
    33                              <2> ; --- Stage 2 disk layout ---
    34                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    35                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    36                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    37                              <2> 
    38                              <2> ; --- Screen ---
    39                              <2> SCREEN_WIDTH        equ 1024
    40                              <2> SCREEN_HEIGHT       equ 768
    41                              <2> SCREEN_BPP          equ 32
    42                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    43                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    44                              <2> 
    45                              <2> 
    46                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    47                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    48                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    49                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    50                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    51                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    52                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    53                              <2> 
    54                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    55                              <2> COLOR_BLACK         equ 0x00000000
    56                              <2> COLOR_WHITE         equ 0x00FFFFFF
    57                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    58                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    59                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    60                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    61                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    62                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    63                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    64                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    65                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    66                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    67                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    68                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    69                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    70                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    71                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    72                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    73                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    74                              <2> COLOR_START_HOVER    equ 0x00338833
    75                              <2> 
    76                              <2> ; --- Window Manager ---
    77                              <2> MAX_WINDOWS         equ 8
    78                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    79                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    80                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    81                              <2> TITLEBAR_HEIGHT     equ 24
    82                              <2> BORDER_WIDTH        equ 2
    83                              <2> CLOSE_BTN_SIZE      equ 18
    84                              <2> MIN_BTN_SIZE        equ 18
    85                              <2> MIN_WINDOW_W        equ 200
    86                              <2> MIN_WINDOW_H        equ 100
    87                              <2> 
    88                              <2> ; --- Taskbar ---
    89                              <2> TASKBAR_HEIGHT      equ 36
    90                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    91                              <2> START_BTN_W         equ 70
    92                              <2> START_BTN_H         equ 28
    93                              <2> START_BTN_X         equ 4
    94                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    95                              <2> CLOCK_WIDTH         equ 64
    96                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    97                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    98                              <2> 
    99                              <2> ; --- Keyboard ---
   100                              <2> KB_BUFFER_SIZE      equ 64
   101                              <2> 
   102                              <2> ; --- Mouse ---
   103                              <2> MOUSE_BUFFER_SIZE   equ 64
   104                              <2> CURSOR_WIDTH        equ 12
   105                              <2> CURSOR_HEIGHT       equ 19
   106                              <2> 
   107                              <2> ; --- PIT ---
   108                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   109                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   110                              <2> 
   111                              <2> ; --- PIC vectors ---
   112                              <2> IRQ_BASE_MASTER     equ 32
   113                              <2> IRQ_BASE_SLAVE      equ 40
   114                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   115                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   116                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   117                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   118                              <2> 
   119                              <2> ; --- Font ---
   120                              <2> FONT_WIDTH          equ 8
   121                              <2> FONT_HEIGHT         equ 16
   122                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   123                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   124                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   125                              <2> 
   126                              <2> ; --- Window flags ---
   127                              <2> WF_VISIBLE          equ 0x01
   128                              <2> WF_FOCUSED          equ 0x02
   129                              <2> WF_DRAGGING         equ 0x04
   130                              <2> WF_MINIMIZED        equ 0x08
   131                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   132                              <2> 
   133                              <2> ; --- Mouse event types ---
   134                              <2> MEVT_MOVE           equ 1
   135                              <2> MEVT_LCLICK         equ 2
   136                              <2> MEVT_RCLICK         equ 3
   137                              <2> MEVT_LRELEASE       equ 4
   138                              <2> MEVT_RRELEASE       equ 5
   139                              <2> 
   140                              <2> ; --- Key modifier flags ---
   141                              <2> KMOD_SHIFT          equ 0x01
   142                              <2> KMOD_CTRL           equ 0x02
   143                              <2> KMOD_ALT            equ 0x04
   144                              <2> 
   145                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   146                              <2> KEY_F1              equ 0xF1
   147                              <2> KEY_F2              equ 0xF2
   148                              <2> KEY_F3              equ 0xF3
   149                              <2> KEY_F4              equ 0xF4
   150                              <2> KEY_F5              equ 0xF5
   151                              <2> KEY_F6              equ 0xF6
   152                              <2> KEY_F7              equ 0xF7
   153                              <2> KEY_F8              equ 0xF8
   154                              <2> KEY_F9              equ 0xF9
   155                              <2> KEY_F10             equ 0xFA
   156                              <2> KEY_F11             equ 0xFB
   157                              <2> KEY_F12             equ 0xFC
   158                              <2> 
   159                              <2> ; --- USB/XHCI Memory Layout ---
   160                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   161                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   162                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   163                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   164                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   165                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   166                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   167                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   168                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   169                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   170                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   171                              <2> ; Slot 2 device support
   172                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   173                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   174                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   175                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   176                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   177                              <2> 
   178                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   179                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   180                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   181                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   182                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   183                              <2> XHCI_CAP_DBOFF      equ 0x14
   184                              <2> XHCI_CAP_RTSOFF     equ 0x18
   185                              <2> 
   186                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   187                              <2> XHCI_OP_USBCMD      equ 0x00
   188                              <2> XHCI_OP_USBSTS      equ 0x04
   189                              <2> XHCI_OP_PAGESIZE     equ 0x08
   190                              <2> XHCI_OP_DNCTRL      equ 0x14
   191                              <2> XHCI_OP_CRCR_LO     equ 0x18
   192                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   193                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   194                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   195                              <2> XHCI_OP_CONFIG      equ 0x38
   196                              <2> 
   197                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   198                              <2> XHCI_PORTSC         equ 0x00
   199                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   200                              <2> 
   201                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   202                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   203                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   204                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   205                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   206                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   207                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   208                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   209                              <2> 
   210                              <2> ; --- USBCMD bits ---
   211                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   212                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   213                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   214                              <2> 
   215                              <2> ; --- USBSTS bits ---
   216                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   217                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   218                              <2> 
   219                              <2> ; --- PORTSC bits ---
   220                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   221                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   222                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   223                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   224                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   225                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   226                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   227                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   228                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   229                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   230                              <2> 
   231                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   232                              <2> TRB_NORMAL           equ (1 << 10)
   233                              <2> TRB_SETUP            equ (2 << 10)
   234                              <2> TRB_DATA             equ (3 << 10)
   235                              <2> TRB_STATUS           equ (4 << 10)
   236                              <2> TRB_LINK             equ (6 << 10)
   237                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   238                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   239                              <2> TRB_CONFIG_EP        equ (12 << 10)
   240                              <2> TRB_EVAL_CTX         equ (13 << 10)
   241                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   242                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   243                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   244                              <2> 
   245                              <2> ; --- TRB Flag Bits (dword 3) ---
   246                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   247                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   248                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   249                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   250                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   251                              <2> 
   252                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   253                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   254                              <2> TRB_TRT_OUT          equ (2 << 16)
   255                              <2> TRB_TRT_IN           equ (3 << 16)
   256                              <2> 
   257                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   258                              <2> TRB_DIR_OUT          equ (0 << 16)
   259                              <2> TRB_DIR_IN           equ (1 << 16)
   260                              <2> 
   261                              <2> ; --- Ring sizes ---
   262                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   263                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   264                              <2> 
   265                              <2> ; --- USB Standard Request Codes ---
   266                              <2> USB_REQ_GET_DESC     equ 0x06
   267                              <2> USB_REQ_SET_CONFIG   equ 0x09
   268                              <2> USB_REQ_SET_IFACE    equ 0x0B
   269                              <2> 
   270                              <2> ; --- USB HID Request Codes ---
   271                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   272                              <2> 
   273                              <2> ; --- USB Descriptor Types ---
   274                              <2> USB_DESC_DEVICE      equ 0x01
   275                              <2> USB_DESC_CONFIG      equ 0x02
   276                              <2> USB_DESC_INTERFACE   equ 0x04
   277                              <2> USB_DESC_ENDPOINT    equ 0x05
   278                              <2> USB_DESC_HID         equ 0x21
   279                              <2> 
   280                              <2> ; --- USB Endpoint Types ---
   281                              <2> USB_EP_CONTROL       equ 0
   282                              <2> USB_EP_ISOCH         equ 1
   283                              <2> USB_EP_BULK          equ 2
   284                              <2> USB_EP_INTERRUPT     equ 3
   285                              <2> 
   286                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   287                              <2> XHCI_EP_NOT_VALID    equ 0
   288                              <2> XHCI_EP_ISOCH_OUT    equ 1
   289                              <2> XHCI_EP_BULK_OUT     equ 2
   290                              <2> XHCI_EP_INT_OUT      equ 3
   291                              <2> XHCI_EP_CONTROL      equ 4
   292                              <2> XHCI_EP_ISOCH_IN     equ 5
   293                              <2> XHCI_EP_BULK_IN      equ 6
   294                              <2> XHCI_EP_INT_IN       equ 7
   295                              <2> 
   296                              <2> ; --- XHCI Port Speeds ---
