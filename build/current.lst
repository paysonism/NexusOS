    13                              <1> section .text
    14                              <1> 
    15                              <1> ; --- Initialize keyboard ---
    16                              <1> global keyboard_init
    17                              <1> keyboard_init:
    18                              <1>     ; Flush keyboard buffer
    19                              <1> .flush:
    20 00002A5C E464                <1>     in al, 0x64
    21 00002A5E A801                <1>     test al, 0x01            ; Output buffer full?
    22 00002A60 7404                <1>     jz .flushed
    23 00002A62 E460                <1>     in al, 0x60              ; Read and discard
    24 00002A64 EBF6                <1>     jmp .flush
    25                              <1> .flushed:
    26                              <1>     ; Initialize buffer
    27 00002A66 C705(D4030000)0000- <1>     mov dword [kb_head], 0
    27 00002A6E 0000                <1>
    28 00002A70 C705(D8030000)0000- <1>     mov dword [kb_tail], 0
    28 00002A78 0000                <1>
    29 00002A7A C605(D1030000)00    <1>     mov byte [kb_modifiers], 0
    30 00002A81 C605(D2030000)00    <1>     mov byte [kb_extended], 0
    31 00002A88 C3                  <1>     ret
    32                              <1> 
    33                              <1> ; --- IRQ1 Keyboard Handler (called from ISR) ---
    34                              <1> global keyboard_handler
    35                              <1> keyboard_handler:
    36 00002A89 50                  <1>     push rax
    37 00002A8A 53                  <1>     push rbx
    38 00002A8B 51                  <1>     push rcx
    39 00002A8C 52                  <1>     push rdx
    40                              <1> 
    41                              <1>     ; Read scancode from data port
    42 00002A8D E460                <1>     in al, 0x60
    43 00002A8F 0FB6C0              <1>     movzx eax, al
    44 00002A92 50                  <1>     push rax
    45 00002A93 66BAF803            <1>     mov dx, 0x3F8
    46 00002A97 B04B                <1>     mov al, 'K'
    47 00002A99 EE                  <1>     out dx, al
