   122 00003891 488B1D(F0000000)    <1>     mov rbx, [tick_count]
   123 00003898 4883C332            <1>     add rbx, 50              ; 50 ticks = 500ms
   124 0000389C B980969800          <1>     mov ecx, 10000000        ; 10M spins fallback
   125                              <1> .wait_run:
   126 000038A1 8B4604              <1>     mov eax, [rsi + XHCI_OP_USBSTS]
   127 000038A4 A901000000          <1>     test eax, XHCI_STS_HCH
   128 000038A9 7414                <1>     jz .running
   129                              <1>     
   130 000038AB FFC9                <1>     dec ecx
   131 000038AD 7425                <1>     jz .fail
   132                              <1>     
   133 000038AF 488B05(F0000000)    <1>     mov rax, [tick_count]
   134 000038B6 4839D8              <1>     cmp rax, rbx
   135 000038B9 7D19                <1>     jge .fail
   136 000038BB F390                <1>     pause
   137 000038BD EBE2                <1>     jmp .wait_run
   138                              <1> .running:
   139                              <1> 
   140                              <1>     ; Serial: '4' (running)
   141 000038BF 66BAF803            <1>     mov dx, 0x3F8
   142 000038C3 B034                <1>     mov al, '4'
   143 000038C5 EE                  <1>     out dx, al
   144                              <1> 
