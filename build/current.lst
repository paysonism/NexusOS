   176                              <1> ; ============================================================================
   177                              <1> ; xhci_pci_find - Scan ALL PCI buses for XHCI controller
   178                              <1> ; Starts search from xhci_pci_search_start (so we can retry with next controller)
   179                              <1> ; Returns: EAX = 1 if found, 0 if not
   180                              <1> ; Sets xhci_pci_addr, xhci_mmio_base
   181                              <1> ; ============================================================================
   182                              <1> xhci_pci_find:
   183 00003902 53                  <1>     push rbx
   184 00003903 51                  <1>     push rcx
   185 00003904 52                  <1>     push rdx
   186                              <1> 
   187                              <1>     ; Load search start position to skip already-tried controllers
   188                              <1>     ; xhci_pci_search_start: bus<<16 | dev<<8 | func (packed)
   189 00003905 8B1D(4C050000)      <1>     mov ebx, [xhci_pci_search_start]
   190                              <1> 
   191                              <1>     ; Unpack: bus = bits 23:16, dev = bits 12:8, func = bits 2:0
   192 0000390B 89D8                <1>     mov eax, ebx
   193 0000390D C1E810              <1>     shr eax, 16
   194 00003910 25FF000000          <1>     and eax, 0xFF
   195 00003915 4189C4              <1>     mov r12d, eax                ; Starting bus
   196                              <1> 
   197 00003918 89D8                <1>     mov eax, ebx
   198 0000391A C1E808              <1>     shr eax, 8
   199 0000391D 25FF000000          <1>     and eax, 0xFF
   200 00003922 4189C6              <1>     mov r14d, eax                ; Starting dev
   201                              <1> 
   202 00003925 89D8                <1>     mov eax, ebx
   203 00003927 25FF000000          <1>     and eax, 0xFF
   204 0000392C 4189C5              <1>     mov r13d, eax                ; Starting func
   205                              <1> 
   206                              <1> .bus_loop:
   207 0000392F 4181FC00010000      <1>     cmp r12d, 256
   208 00003936 0F8D62010000        <1>     jge .not_found
   209                              <1> 
   210                              <1> .dev_loop:
   211 0000393C 4183FE20            <1>     cmp r14d, 32
   212 00003940 0F8D4A010000        <1>     jge .next_bus
   213                              <1> 
   214                              <1> .func_loop:
   215 00003946 4183FD08            <1>     cmp r13d, 8
   216 0000394A 0F8D35010000        <1>     jge .next_dev
   217                              <1> 
   218                              <1>     ; Build PCI config address: 1<<31 | bus<<16 | dev<<11 | func<<8 | reg
   219 00003950 B800000080          <1>     mov eax, 0x80000000
   220 00003955 4489E3              <1>     mov ebx, r12d
   221 00003958 C1E310              <1>     shl ebx, 16
   222 0000395B 09D8                <1>     or eax, ebx
   223 0000395D 4489F3              <1>     mov ebx, r14d
   224 00003960 C1E30B              <1>     shl ebx, 11
   225 00003963 09D8                <1>     or eax, ebx
   226 00003965 4489EB              <1>     mov ebx, r13d
   227 00003968 C1E308              <1>     shl ebx, 8
   228 0000396B 09D8                <1>     or eax, ebx
   229                              <1>     ; reg=0 for Vendor/Device
   230 0000396D 50                  <1>     push rax
   231 0000396E E828FEFFFF          <1>     call pci_read_conf_dword
   232 00003973 6683F8FF            <1>     cmp ax, 0xFFFF
   233 00003977 0F84FF000000        <1>     je .next_func_pop
   234                              <1> 
   235                              <1>     ; Read class at offset 0x08
   236 0000397D 58                  <1>     pop rax
   237 0000397E 50                  <1>     push rax
   238 0000397F 83C808              <1>     or eax, 0x08
   239 00003982 E814FEFFFF          <1>     call pci_read_conf_dword
   240 00003987 89C3                <1>     mov ebx, eax
   241 00003989 C1EB18              <1>     shr ebx, 24
   242 0000398C 80FB0C              <1>     cmp bl, 0x0C
   243 0000398F 0F85E7000000        <1>     jne .next_func_pop
   244 00003995 89C1                <1>     mov ecx, eax
   245 00003997 C1E910              <1>     shr ecx, 16
   246 0000399A 81E1FF000000        <1>     and ecx, 0xFF
   247 000039A0 83F903              <1>     cmp ecx, 0x03
   248 000039A3 0F85D3000000        <1>     jne .next_func_pop
   249 000039A9 89C2                <1>     mov edx, eax
   250 000039AB C1EA08              <1>     shr edx, 8
   251 000039AE 81E2FF000000        <1>     and edx, 0xFF
   252 000039B4 83FA30              <1>     cmp edx, 0x30
   253 000039B7 0F85BF000000        <1>     jne .next_func_pop
   254                              <1> 
   255                              <1>     ; Found XHCI!
