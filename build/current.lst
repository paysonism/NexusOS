    16                              <1> ; ============================================================================
    17                              <1> ; xhci_init - Find and initialize XHCI controller
    18                              <1> ; Returns: EAX = 1 on success, 0 on failure
    19                              <1> ; ============================================================================
    20                              <1> global xhci_init
    21                              <1> xhci_init:
    22 000037C1 53                  <1>     push rbx
    23 000037C2 51                  <1>     push rcx
    24 000037C3 52                  <1>     push rdx
    25 000037C4 56                  <1>     push rsi
    26 000037C5 57                  <1>     push rdi
    27 000037C6 55                  <1>     push rbp
    28 000037C7 4154                <1>     push r12
    29 000037C9 4155                <1>     push r13
    30 000037CB 4156                <1>     push r14
    31 000037CD 4157                <1>     push r15
    32                              <1>     
    33 000037CF 48BE-               <1>     mov rsi, szXhciStart
    33 000037D1 [A907000000000000]  <1>
    34 000037D9 E833C9FFFF          <1>     call debug_print
    35                              <1> 
    36                              <1>     ; Serial: 'U' start
    37 000037DE 66BAF803            <1>     mov dx, 0x3F8
    38 000037E2 B055                <1>     mov al, 'U'
    39 000037E4 EE                  <1>     out dx, al
    40                              <1> 
    41                              <1>     ; --- Zero XHCI memory region ---
    42 000037E5 BF00009000          <1>     mov rdi, XHCI_DCBAA_ADDR
    43 000037EA B900E00100          <1>     mov rcx, (XHCI_MEM_END - XHCI_DCBAA_ADDR) / 8
    44 000037EF 4831C0              <1>     xor rax, rax
    45 000037F2 F348AB              <1>     rep stosq
    46                              <1> 
    47                              <1>     ; --- PCI scan for next XHCI controller (resumes from last found position) ---
    48 000037F5 E808010000          <1>     call xhci_pci_find
    49 000037FA 85C0                <1>     test eax, eax
    50 000037FC 0F84D2000000        <1>     jz .fail
    51                              <1>     
    52 00003802 48BE-               <1>     mov rsi, szXhciFound
    52 00003804 [BB07000000000000]  <1>
    53 0000380C E800C9FFFF          <1>     call debug_print
    54                              <1> 
    55                              <1>     ; Serial: '1' (found)
    56 00003811 66BAF803            <1>     mov dx, 0x3F8
    57 00003815 B031                <1>     mov al, '1'
    58 00003817 EE                  <1>     out dx, al
    59                              <1> 
    60                              <1>     ; --- Read capability registers ---
    61 00003818 E8CF020000          <1>     call xhci_read_caps
    62                              <1> 
    63                              <1>     ; --- Take ownership from BIOS ---
    64 0000381D E873030000          <1>     call xhci_take_ownership
    65                              <1> 
    66                              <1>     ; Serial: '2' (ownership taken)
    67 00003822 66BAF803            <1>     mov dx, 0x3F8
    68 00003826 B032                <1>     mov al, '2'
    69 00003828 EE                  <1>     out dx, al
    70                              <1> 
    71                              <1>     ; --- Reset controller ---
    72 00003829 E8FA030000          <1>     call xhci_reset
    73 0000382E 85C0                <1>     test eax, eax
