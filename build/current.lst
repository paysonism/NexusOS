   251                              <1> ; Helper: Print 64-bit hex value to serial
   252                              <1> ser_print_hex64:
   253 00000FA0 51                  <1>     push rcx
   254 00000FA1 50                  <1>     push rax
   255 00000FA2 52                  <1>     push rdx
   256 00000FA3 B910000000          <1>     mov rcx, 16
   257                              <1> .hex_loop:
   258 00000FA8 48C1C704            <1>     rol rdi, 4
   259 00000FAC 4088F8              <1>     mov al, dil
   260 00000FAF 240F                <1>     and al, 0x0F
   261 00000FB1 3C0A                <1>     cmp al, 10
   262 00000FB3 7C02                <1>     jl .hex_digit
   263 00000FB5 0407                <1>     add al, 'A' - '0' - 10
   264                              <1> .hex_digit:
   265 00000FB7 0430                <1>     add al, '0'
   266 00000FB9 66BAF803            <1>     mov dx, 0x3F8
   267 00000FBD EE                  <1>     out dx, al
