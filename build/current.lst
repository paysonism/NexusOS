   122 00002B6F 7433                <1>     je .shift_release
   123 00002B71 80FB36              <1>     cmp bl, 0x36             ; Right Shift release
   124 00002B74 742E                <1>     je .shift_release
   125 00002B76 80FB1D              <1>     cmp bl, 0x1D             ; Left Ctrl release
   126 00002B79 743B                <1>     je .ctrl_release
   127 00002B7B 80FB38              <1>     cmp bl, 0x38             ; Left Alt release
