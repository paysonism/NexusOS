    83                                  section .text
    84                                  %include "src/drivers/hid_parser.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - HID Report Descriptor Parser & Gesture Engine
     3                              <1> ; Parses HID report descriptors to extract field layouts (X, Y, buttons,
     4                              <1> ; contact count, tip switch) and provides gesture detection (tap-to-click,
     5                              <1> ; two-finger scroll).
     6                              <1> ;
     7                              <1> ; Shared between USB HID, I2C HID, and SPI HID drivers.
     8                              <1> ; ============================================================================
     9                              <1> bits 64
    10                              <1> 
    11                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> L3_SYSCALL_STACK_ADDR equ 0xC00000   ; Kernel-only syscall stacks
    33                              <2> 
    34                              <2> ; --- Stage 2 disk layout ---
    35                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    36                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    37                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    38                              <2> 
    39                              <2> ; --- Screen ---
    40                              <2> SCREEN_WIDTH        equ 1024
    41                              <2> SCREEN_HEIGHT       equ 768
    42                              <2> SCREEN_BPP          equ 32
    43                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    44                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    45                              <2> 
    46                              <2> 
    47                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    48                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    49                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    50                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    51                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    52                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    53                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    54                              <2> 
    55                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    56                              <2> COLOR_BLACK         equ 0x00000000
    57                              <2> COLOR_WHITE         equ 0x00FFFFFF
    58                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    59                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    60                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    61                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    62                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    63                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    64                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    65                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    66                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    67                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    68                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    69                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    70                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    71                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    72                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    73                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    74                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    75                              <2> COLOR_START_HOVER    equ 0x00338833
    76                              <2> 
    77                              <2> ; --- Window Manager ---
    78                              <2> MAX_WINDOWS         equ 8
    79                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    80                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    81                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    82                              <2> TITLEBAR_HEIGHT     equ 24
    83                              <2> BORDER_WIDTH        equ 2
    84                              <2> CLOSE_BTN_SIZE      equ 18
    85                              <2> MIN_BTN_SIZE        equ 18
    86                              <2> MIN_WINDOW_W        equ 200
    87                              <2> MIN_WINDOW_H        equ 100
    88                              <2> 
    89                              <2> ; --- Taskbar ---
    90                              <2> TASKBAR_HEIGHT      equ 36
    91                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    92                              <2> START_BTN_W         equ 70
    93                              <2> START_BTN_H         equ 28
    94                              <2> START_BTN_X         equ 4
    95                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    96                              <2> CLOCK_WIDTH         equ 64
    97                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    98                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    99                              <2> 
   100                              <2> ; --- Keyboard ---
   101                              <2> KB_BUFFER_SIZE      equ 64
   102                              <2> 
   103                              <2> ; --- Mouse ---
   104                              <2> MOUSE_BUFFER_SIZE   equ 64
   105                              <2> CURSOR_WIDTH        equ 12
   106                              <2> CURSOR_HEIGHT       equ 19
   107                              <2> 
   108                              <2> ; --- PIT ---
   109                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   110                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   111                              <2> 
   112                              <2> ; --- PIC vectors ---
   113                              <2> IRQ_BASE_MASTER     equ 32
   114                              <2> IRQ_BASE_SLAVE      equ 40
   115                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   116                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   117                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   118                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   119                              <2> 
   120                              <2> ; --- Font ---
   121                              <2> FONT_WIDTH          equ 8
   122                              <2> FONT_HEIGHT         equ 16
   123                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   124                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   125                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   126                              <2> 
   127                              <2> ; --- Window flags ---
   128                              <2> WF_VISIBLE          equ 0x01
   129                              <2> WF_FOCUSED          equ 0x02
   130                              <2> WF_DRAGGING         equ 0x04
   131                              <2> WF_MINIMIZED        equ 0x08
