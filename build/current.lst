  1883 0000476B 3C0A                <1>     cmp al, 10
  1884 0000476D 7C04                <1>     jl .sh32_digit
  1885 0000476F 0437                <1>     add al, 'A' - 10
  1886 00004771 EB02                <1>     jmp .sh32_out
  1887                              <1> .sh32_digit:
  1888 00004773 0430                <1>     add al, '0'
  1889                              <1> .sh32_out:
