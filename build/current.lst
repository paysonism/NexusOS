   670 00008A14 C605(97110000)00    <1>     mov byte [tb_start_menu_open], 0
   671                              <1> 
   672                              <1>     ; Check if click is on one of the window buttons
   673                              <1>     ; Iterate active windows and check X ranges
   674 00008A1B BB00007100          <1>     mov rbx, WINDOW_POOL_ADDR
