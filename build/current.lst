   235                              <1> ; ============================================================================
   236                              <1> ; spi_hid_poll - Non-blocking SPI HID poll (called from main loop)
   237                              <1> ; ============================================================================
   238                              <1> spi_hid_poll:
   239 000058FE 803D(0B090000)01    <1>     cmp byte [spi_hid_active], 1
   240 00005905 0F8595010000        <1>     jne .poll_ret
   241                              <1> 
   242                              <1>     ; Request input report: SYNC + CID_OUTPUT + length=4 + register=0x0003
   243 0000590B C605(C6980200)FF    <1>     mov byte [spi_tx_buf + 0], SPI_SYNC_HOST
   244 00005912 C605(C7980200)0F    <1>     mov byte [spi_tx_buf + 1], SPI_CID_OUTPUT
   245 00005919 C605(C8980200)04    <1>     mov byte [spi_tx_buf + 2], 0x04
   246 00005920 C605(C9980200)00    <1>     mov byte [spi_tx_buf + 3], 0x00
   247 00005927 C605(CA980200)03    <1>     mov byte [spi_tx_buf + 4], 0x03    ; wInputRegister = 0x0003
   248 0000592E C605(CB980200)00    <1>     mov byte [spi_tx_buf + 5], 0x00
   249                              <1> 
   250                              <1>     ; Read response: header (4B) + up to 64B report
   251 00005935 488D3D(C6980200)    <1>     lea rdi, [spi_tx_buf]
   252 0000593C BE06000000          <1>     mov rsi, 6
   253 00005941 488D15(D6980200)    <1>     lea rdx, [spi_rx_buf]
   254 00005948 B944000000          <1>     mov rcx, 68
   255 0000594D E848FDFFFF          <1>     call spi_transfer
   256 00005952 85C0                <1>     test eax, eax
   257 00005954 0F8446010000        <1>     jz .poll_ret
   258                              <1> 
   259                              <1>     ; Check sync byte - if not 0x80, device has no data
   260 0000595A 803D(D6980200)80    <1>     cmp byte [spi_rx_buf + 0], SPI_SYNC_DEV
   261 00005961 0F8539010000        <1>     jne .poll_ret
   262                              <1> 
   263                              <1>     ; Get report length from header [2-3]
   264 00005967 0FB70D(D8980200)    <1>     movzx ecx, word [spi_rx_buf + 2]
   265 0000596E 85C9                <1>     test ecx, ecx
   266 00005970 0F842A010000        <1>     jz .poll_ret
   267 00005976 81F9FFFF0000        <1>     cmp ecx, 0xFFFF
   268 0000597C 0F841E010000        <1>     je .poll_ret
   269 00005982 83E904              <1>     sub ecx, 4                         ; subtract header
   270 00005985 0F8E15010000        <1>     jle .poll_ret
   271                              <1> 
   272                              <1>     ; Process data at spi_rx_buf + 4
   273 0000598B 488D35(DA980200)    <1>     lea rsi, [spi_rx_buf + 4]
   274                              <1> 
   275                              <1>     ; Check if we parsed the report descriptor
   276 00005992 803D(390D0000)00    <1>     cmp byte [hid_parsed_report_bytes], 0
   277 00005999 741F                <1>     je .fallback_parse
   278                              <1> 
   279                              <1>     ; Use hid_parser path
   280 0000599B 803D(360D0000)01    <1>     cmp byte [hid_parsed_has_report_id], 1
   281 000059A2 7505                <1>     jne .no_skip_id
   282 000059A4 48FFC6              <1>     inc rsi
   283 000059A7 FFC9                <1>     dec ecx
   284                              <1> .no_skip_id:
   285 000059A9 E82B100000          <1>     call hid_process_touchpad_report
   286 000059AE C605(2C050000)01    <1>     mov byte [mouse_moved], 1
   287 000059B5 E9E6000000          <1>     jmp .poll_ret
   288                              <1> 
   289                              <1> .fallback_parse:
   290                              <1>     ; Fallback: parse as 5-byte absolute or relative report
   291                              <1>     ; [0]=buttons [1-2]=X (LE) [3-4]=Y (LE)
   292 000059BA 83F905              <1>     cmp ecx, 5
   293 000059BD 7C64                <1>     jl .try_3byte
   294                              <1> 
   295 000059BF 0FB606              <1>     movzx eax, byte [rsi]
   296 000059C2 2407                <1>     and al, 0x07
   297 000059C4 8805(2B050000)      <1>     mov [mouse_buttons], al
   298                              <1> 
   299 000059CA 803D(370D0000)01    <1>     cmp byte [hid_parsed_is_absolute], 1
   300 000059D1 7416                <1>     je .fallback_abs
   301                              <1> 
   302                              <1>     ; Relative
   303 000059D3 0FBE4601            <1>     movsx eax, byte [rsi + 1]
   304 000059D7 0105(23050000)      <1>     add [mouse_x], eax
   305 000059DD 0FBE4602            <1>     movsx eax, byte [rsi + 2]
   306 000059E1 0105(27050000)      <1>     add [mouse_y], eax
   307 000059E7 EB5E                <1>     jmp .fallback_clamp
   308                              <1> 
   309                              <1> .fallback_abs:
   310 000059E9 0FB74601            <1>     movzx eax, word [rsi + 1]
   311 000059ED 8B0D(4E020000)      <1>     mov ecx, [scr_width]
   312 000059F3 0FAFC1              <1>     imul eax, ecx
   313 000059F6 B9FF7F0000          <1>     mov ecx, 0x7FFF
   314 000059FB 31D2                <1>     xor edx, edx
   315 000059FD F7F1                <1>     div ecx
   316 000059FF 8905(23050000)      <1>     mov [mouse_x], eax
   317                              <1> 
   318 00005A05 0FB74603            <1>     movzx eax, word [rsi + 3]
   319 00005A09 8B0D(52020000)      <1>     mov ecx, [scr_height]
   320 00005A0F 0FAFC1              <1>     imul eax, ecx
   321 00005A12 B9FF7F0000          <1>     mov ecx, 0x7FFF
   322 00005A17 31D2                <1>     xor edx, edx
   323 00005A19 F7F1                <1>     div ecx
   324 00005A1B 8905(27050000)      <1>     mov [mouse_y], eax
