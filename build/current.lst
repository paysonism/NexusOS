   559 00006964 89F9                <1>     mov ecx, edi
   560 00006966 83E107              <1>     and ecx, 7                  ; bit shift within byte = bit_offset % 8
   561                              <1> 
   562                              <1>     ; Read up to 4 bytes starting from this position
   563 00006969 31C0                <1>     xor eax, eax
   564 0000696B 0FB616              <1>     movzx edx, byte [rsi]
   565 0000696E 89D0                <1>     mov eax, edx
   566 00006970 4183F808            <1>     cmp r8d, 8
   567 00006974 7E27                <1>     jle .shift
   568 00006976 0FB65601            <1>     movzx edx, byte [rsi + 1]
   569 0000697A C1E208              <1>     shl edx, 8
   570 0000697D 09D0                <1>     or eax, edx
   571 0000697F 4183F810            <1>     cmp r8d, 16
   572 00006983 7E18                <1>     jle .shift
   573 00006985 0FB65602            <1>     movzx edx, byte [rsi + 2]
   574 00006989 C1E210              <1>     shl edx, 16
   575 0000698C 09D0                <1>     or eax, edx
   576 0000698E 4183F818            <1>     cmp r8d, 24
   577 00006992 7E09                <1>     jle .shift
   578 00006994 0FB65603            <1>     movzx edx, byte [rsi + 3]
   579 00006998 C1E218              <1>     shl edx, 24
   580 0000699B 09D0                <1>     or eax, edx
