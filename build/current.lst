   296 00000412 626E6D2C2E2F002A00- <1>     db  'b',  'n',  'm',  ',',  '.',  '/',    0,  '*',    0,  ' ',    0, KEY_F1, KEY_F2, KEY_F3, KEY_F4, KEY_F5  ; 0x30-0x3F
   296 0000041B 2000F1F2F3F4F5      <1>
   297 00000422 F6F7F8F9FA00003738- <1>     db KEY_F6, KEY_F7, KEY_F8, KEY_F9, KEY_F10,  0,    0,  '7',  '8',  '9',  '-',  '4',  '5',  '6',  '+',  '1'  ; 0x40-0x4F
   297 0000042B 392D3435362B31      <1>
   298 00000432 3233302E000000FBFC- <1>     db  '2',  '3',  '0',  '.',    0,    0,    0, KEY_F11, KEY_F12, 0,   0,    0,    0,    0,    0,    0   ; 0x50-0x5F
   298 0000043B 00000000000000      <1>
   299 00000442 00<rep 40h>         <1>     times 64 db 0  ; 0x60-0x7F
   300                              <1> 
