    64                              <1> 
    65                              <1>     ; --- Key press ---
    66                              <1>     ; Check for NumLock toggle
    67 00002AC3 3C45                <1>     cmp al, 0x45             ; NumLock press
    68 00002AC5 0F8406010000        <1>     je .numlock_toggle
    69                              <1> 
    70                              <1>     ; Check for modifier keys
    71 00002ACB 3C2A                <1>     cmp al, 0x2A             ; Left Shift press
    72 00002ACD 0F84C5000000        <1>     je .shift_press
    73 00002AD3 3C36                <1>     cmp al, 0x36             ; Right Shift press
    74 00002AD5 0F84BD000000        <1>     je .shift_press
    75 00002ADB 3C1D                <1>     cmp al, 0x1D             ; Left Ctrl press
    76 00002ADD 0F84CA000000        <1>     je .ctrl_press
    77 00002AE3 3C38                <1>     cmp al, 0x38             ; Left Alt press
    78 00002AE5 0F84D4000000        <1>     je .alt_press
