    58 000013C3 4989C0              <1>     mov r8, rax
    59 000013C6 488D356E030000      <1>     lea rsi, [rel l3_test_blob]
    60 000013CD B926000000          <1>     mov ecx, l3_test_blob_end - l3_test_blob
    61 000013D2 F3A4                <1>     rep movsb
    62 000013D4 4C89C0              <1>     mov rax, r8
    63 000013D7 C3                  <1>     ret
