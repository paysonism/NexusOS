   588 000069A2 83F920              <1>     cmp ecx, 32
   589 000069A5 7D0B                <1>     jge .no_mask
   590 000069A7 BA01000000          <1>     mov edx, 1
   591 000069AC D3E2                <1>     shl edx, cl
   592 000069AE FFCA                <1>     dec edx                     ; mask = (1 << size) - 1
   593 000069B0 21D0                <1>     and eax, edx
   594                              <1> .no_mask:
   595                              <1> 
   596 000069B2 5E                  <1>     pop rsi
   597 000069B3 5A                  <1>     pop rdx
   598 000069B4 59                  <1>     pop rcx
   599 000069B5 5B                  <1>     pop rbx
   600 000069B6 C3                  <1>     ret
