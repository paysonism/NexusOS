   270 0000376E 240F                <1>     and al, 0x0F
   271 00003770 0A05(46050000)      <1>     or al, [ata_drive_sel]
   272 00003776 66BAF601            <1>     mov dx, ATA_DRIVE
   273 0000377A EE                  <1>     out dx, al
   274                              <1>     
   275                              <1>     ; IO Wait (400ns)
   276 0000377B E80A000000          <1>     call ata_io_wait
   277                              <1>     
   278 00003780 6658                <1>     pop ax
   279 00003782 665A                <1>     pop dx
   280                              <1>     
   281                              <1>     ; Wait for BSY to clear
   282 00003784 E89BFFFFFF          <1>     call ata_wait_ready
   283 00003789 C3                  <1>     ret
   284                              <1> 
