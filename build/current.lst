   731 00008AA4 7410                <1>     je .tb_unfocus_done
   732 00008AA6 48836128FD          <1>     and qword [rcx + WIN_OFF_FLAGS], ~WF_FOCUSED
   733 00008AAB 4881C100010000      <1>     add rcx, WINDOW_STRUCT_SIZE
