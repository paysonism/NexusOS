  4201 0000C48A 48FFC7              <1>     inc rdi
  4202                              <1>     ; Copy extension (3 bytes), strip trailing spaces
  4203 0000C48D B903000000          <1>     mov ecx, 3
  4204                              <1> .ext_copy:
  4205 0000C492 AC                  <1>     lodsb
