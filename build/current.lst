   290 00003792 EC                  <1>     in al, dx
   291 00003793 EC                  <1>     in al, dx
   292 00003794 EC                  <1>     in al, dx
   293 00003795 EC                  <1>     in al, dx
   294 00003796 6658                <1>     pop ax
   295 00003798 665A                <1>     pop dx
   296 0000379A C3                  <1>     ret
