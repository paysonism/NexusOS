   948 00000309 663DC0B0            <1>     cmp ax, 0xB0C0
   949 0000030D 0F8CB3000000        <1>     jl .set_fail
   950 00000313 663DD0B0            <1>     cmp ax, 0xB0D0
   951 00000317 0F8FA9000000        <1>     jg .set_fail
   952                              <1> 
   953                              <1>     ; Set X res (Index 1)
