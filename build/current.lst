   275 000003D1 00                  <1> kb_modifiers:   db 0
   276 000003D2 00                  <1> kb_extended:    db 0
   277                              <1> global kb_numlock
   278 000003D3 00                  <1> kb_numlock:     db 0         ; 0 = cursor mode (arrows move mouse), 1 = typing mode
   279 000003D4 00000000            <1> kb_head:        dd 0
   280 000003D8 00000000            <1> kb_tail:        dd 0
   281 000003DC 00                  <1> kb_repeat_scancode: db 0
   282 000003DD 00                  <1> kb_repeat_ascii:    db 0
   283 000003DE 00000000            <1> kb_repeat_next_tick: dd 0
