   367                              <1> i2c_init_controller:
   368 00005CB2 51                  <1>     push rcx
   369                              <1> 
   370                              <1>     ; Disable controller first
   371 00005CB3 C7466C00000000      <1>     mov dword [rsi + DW_IC_ENABLE], 0
   372                              <1> 
   373                              <1>     ; Wait for disabled (activity bit clear)
   374 00005CBA B988130000          <1>     mov ecx, 5000
   375                              <1> .wait_dis:
   376 00005CBF 8B869C000000        <1>     mov eax, [rsi + DW_IC_ENABLE_STATUS]
