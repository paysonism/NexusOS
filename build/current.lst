    98 00003867 31C0                <1>     xor eax, eax
    99 00003869 894634              <1>     mov [rsi + XHCI_OP_DCBAAP_HI], eax
   100                              <1> 
   101                              <1>     ; Write CRCR (Command Ring Control Register)
   102 0000386C B800009100          <1>     mov eax, XHCI_CMD_RING_ADDR
   103 00003871 83C801              <1>     or eax, 1                     ; RCS = 1 (Ring Cycle State)
   104 00003874 894618              <1>     mov [rsi + XHCI_OP_CRCR_LO], eax
   105 00003877 31C0                <1>     xor eax, eax
   106 00003879 89461C              <1>     mov [rsi + XHCI_OP_CRCR_HI], eax
   107                              <1> 
   108                              <1>     ; Set MaxSlotsEn = 1
   109 0000387C C7463801000000      <1>     mov dword [rsi + XHCI_OP_CONFIG], 1
   110                              <1> 
   111                              <1>     ; Serial: '3' (regs programmed)
   112 00003883 66BAF803            <1>     mov dx, 0x3F8
   113 00003887 B033                <1>     mov al, '3'
   114 00003889 EE                  <1>     out dx, al
   115                              <1> 
   116                              <1>     ; --- Start controller ---
