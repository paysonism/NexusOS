    85                                  section .text
    86                                  %include "src/drivers/battery.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - ACPI EC Battery Driver
     3                              <1> ;
     4                              <1> ; EC I/O: 0x62 = data port, 0x66 = command/status port
     5                              <1> ; Protocol: wait IBF=0, write 0x80 to cmd port, wait IBF=0,
     6                              <1> ;           write reg addr to data port, wait OBF=1, read data from data port
     7                              <1> ;
     8                              <1> ; Acer Nitro ANV16-42 (ITE EC) register layout (probed at init):
     9                              <1> ;
    10                              <1> ;   Layout A (common Acer Nitro ITE, older):
    11                              <1> ;     0xA2 = battery remaining % (0-100)
    12                              <1> ;     0xA3 = battery status (bit1=charging, bit0=discharging)
    13                              <1> ;     0xA4 = AC adapter (bit0=1 = AC plugged)
    14                              <1> ;
    15                              <1> ;   Layout B (Acer Nitro 2023/2024 ITE8696/ITE8297):
    16                              <1> ;     0x42 = battery remaining % (0-100)
    17                              <1> ;     0x40 = battery status flags (bit0=discharging, bit1=charging)
    18                              <1> ;     0x41 = AC adapter (bit0=1 = AC plugged)
    19                              <1> ;
    20                              <1> ;   Layout C (some Acer with design/full/remaining in mWh):
    21                              <1> ;     0xB4 = design capacity low byte
    22                              <1> ;     0xB5 = design capacity high byte
    23                              <1> ;     0xB2 = remaining capacity low byte
    24                              <1> ;     0xB3 = remaining capacity high byte
    25                              <1> ;     0xA0 = status (bit0=discharging, bit1=charging)
    26                              <1> ;     0xA1 = AC present (bit0=1 = AC)
    27                              <1> ;
    28                              <1> ; We probe layout A first, then B, then C.
    29                              <1> ;
    30                              <1> ; Exported:
    31                              <1> ;   battery_state   (byte): 0=unknown, 1=AC, 2=discharging, 3=charging
    32                              <1> ;   battery_percent (byte): 0-100
    33                              <1> ;   battery_init    : call once at boot
    34                              <1> ;   battery_poll    : call from main loop (throttled internally)
    35                              <1> ; ============================================================================
    36                              <1> bits 64
    37                              <1> 
    38                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> L3_SYSCALL_STACK_ADDR equ 0xC00000   ; Kernel-only syscall stacks
    33                              <2> 
    34                              <2> ; --- Stage 2 disk layout ---
    35                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    36                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    37                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    38                              <2> 
    39                              <2> ; --- Screen ---
    40                              <2> SCREEN_WIDTH        equ 1024
    41                              <2> SCREEN_HEIGHT       equ 768
    42                              <2> SCREEN_BPP          equ 32
    43                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    44                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    45                              <2> 
    46                              <2> 
    47                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    48                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    49                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    50                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    51                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    52                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    53                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    54                              <2> 
    55                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    56                              <2> COLOR_BLACK         equ 0x00000000
    57                              <2> COLOR_WHITE         equ 0x00FFFFFF
    58                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    59                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    60                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    61                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    62                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    63                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    64                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    65                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    66                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    67                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    68                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    69                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    70                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    71                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    72                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    73                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    74                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    75                              <2> COLOR_START_HOVER    equ 0x00338833
    76                              <2> 
    77                              <2> ; --- Window Manager ---
    78                              <2> MAX_WINDOWS         equ 8
    79                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    80                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    81                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    82                              <2> TITLEBAR_HEIGHT     equ 24
    83                              <2> BORDER_WIDTH        equ 2
    84                              <2> CLOSE_BTN_SIZE      equ 18
    85                              <2> MIN_BTN_SIZE        equ 18
    86                              <2> MIN_WINDOW_W        equ 200
    87                              <2> MIN_WINDOW_H        equ 100
    88                              <2> 
    89                              <2> ; --- Taskbar ---
    90                              <2> TASKBAR_HEIGHT      equ 36
    91                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    92                              <2> START_BTN_W         equ 70
    93                              <2> START_BTN_H         equ 28
    94                              <2> START_BTN_X         equ 4
    95                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    96                              <2> CLOCK_WIDTH         equ 64
    97                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    98                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    99                              <2> 
   100                              <2> ; --- Keyboard ---
   101                              <2> KB_BUFFER_SIZE      equ 64
   102                              <2> 
   103                              <2> ; --- Mouse ---
   104                              <2> MOUSE_BUFFER_SIZE   equ 64
   105                              <2> CURSOR_WIDTH        equ 12
   106                              <2> CURSOR_HEIGHT       equ 19
   107                              <2> 
   108                              <2> ; --- PIT ---
   109                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   110                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   111                              <2> 
   112                              <2> ; --- PIC vectors ---
   113                              <2> IRQ_BASE_MASTER     equ 32
   114                              <2> IRQ_BASE_SLAVE      equ 40
   115                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   116                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   117                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   118                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   119                              <2> 
   120                              <2> ; --- Font ---
   121                              <2> FONT_WIDTH          equ 8
   122                              <2> FONT_HEIGHT         equ 16
   123                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   124                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   125                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   126                              <2> 
   127                              <2> ; --- Window flags ---
   128                              <2> WF_VISIBLE          equ 0x01
   129                              <2> WF_FOCUSED          equ 0x02
   130                              <2> WF_DRAGGING         equ 0x04
   131                              <2> WF_MINIMIZED        equ 0x08
   132                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   133                              <2> 
   134                              <2> ; --- Mouse event types ---
   135                              <2> MEVT_MOVE           equ 1
   136                              <2> MEVT_LCLICK         equ 2
   137                              <2> MEVT_RCLICK         equ 3
   138                              <2> MEVT_LRELEASE       equ 4
   139                              <2> MEVT_RRELEASE       equ 5
   140                              <2> 
   141                              <2> ; --- Key modifier flags ---
   142                              <2> KMOD_SHIFT          equ 0x01
   143                              <2> KMOD_CTRL           equ 0x02
   144                              <2> KMOD_ALT            equ 0x04
   145                              <2> 
   146                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   147                              <2> KEY_F1              equ 0xF1
   148                              <2> KEY_F2              equ 0xF2
   149                              <2> KEY_F3              equ 0xF3
   150                              <2> KEY_F4              equ 0xF4
   151                              <2> KEY_F5              equ 0xF5
   152                              <2> KEY_F6              equ 0xF6
   153                              <2> KEY_F7              equ 0xF7
   154                              <2> KEY_F8              equ 0xF8
   155                              <2> KEY_F9              equ 0xF9
   156                              <2> KEY_F10             equ 0xFA
   157                              <2> KEY_F11             equ 0xFB
   158                              <2> KEY_F12             equ 0xFC
   159                              <2> 
   160                              <2> ; --- USB/XHCI Memory Layout ---
   161                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   162                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   163                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   164                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   165                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   166                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   167                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   168                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   169                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   170                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   171                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   172                              <2> ; Slot 2 device support
   173                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   174                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   175                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   176                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   177                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   178                              <2> 
   179                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   180                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   181                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   182                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   183                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   184                              <2> XHCI_CAP_DBOFF      equ 0x14
   185                              <2> XHCI_CAP_RTSOFF     equ 0x18
   186                              <2> 
   187                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   188                              <2> XHCI_OP_USBCMD      equ 0x00
   189                              <2> XHCI_OP_USBSTS      equ 0x04
   190                              <2> XHCI_OP_PAGESIZE     equ 0x08
   191                              <2> XHCI_OP_DNCTRL      equ 0x14
   192                              <2> XHCI_OP_CRCR_LO     equ 0x18
   193                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   194                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   195                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   196                              <2> XHCI_OP_CONFIG      equ 0x38
   197                              <2> 
   198                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   199                              <2> XHCI_PORTSC         equ 0x00
   200                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   201                              <2> 
   202                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   203                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   204                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   205                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   206                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   207                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   208                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   209                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   210                              <2> 
   211                              <2> ; --- USBCMD bits ---
   212                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   213                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   214                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   215                              <2> 
   216                              <2> ; --- USBSTS bits ---
   217                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   218                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   219                              <2> 
   220                              <2> ; --- PORTSC bits ---
   221                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   222                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   223                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   224                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   225                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   226                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   227                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   228                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   229                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   230                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   231                              <2> 
   232                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   233                              <2> TRB_NORMAL           equ (1 << 10)
   234                              <2> TRB_SETUP            equ (2 << 10)
   235                              <2> TRB_DATA             equ (3 << 10)
   236                              <2> TRB_STATUS           equ (4 << 10)
   237                              <2> TRB_LINK             equ (6 << 10)
   238                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   239                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   240                              <2> TRB_CONFIG_EP        equ (12 << 10)
   241                              <2> TRB_EVAL_CTX         equ (13 << 10)
   242                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   243                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   244                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   245                              <2> 
   246                              <2> ; --- TRB Flag Bits (dword 3) ---
   247                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   248                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   249                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   250                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   251                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   252                              <2> 
   253                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   254                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   255                              <2> TRB_TRT_OUT          equ (2 << 16)
   256                              <2> TRB_TRT_IN           equ (3 << 16)
   257                              <2> 
   258                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   259                              <2> TRB_DIR_OUT          equ (0 << 16)
   260                              <2> TRB_DIR_IN           equ (1 << 16)
   261                              <2> 
   262                              <2> ; --- Ring sizes ---
   263                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   264                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   265                              <2> 
   266                              <2> ; --- USB Standard Request Codes ---
   267                              <2> USB_REQ_GET_DESC     equ 0x06
   268                              <2> USB_REQ_SET_CONFIG   equ 0x09
   269                              <2> USB_REQ_SET_IFACE    equ 0x0B
   270                              <2> 
   271                              <2> ; --- USB HID Request Codes ---
   272                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   273                              <2> 
   274                              <2> ; --- USB Descriptor Types ---
   275                              <2> USB_DESC_DEVICE      equ 0x01
   276                              <2> USB_DESC_CONFIG      equ 0x02
   277                              <2> USB_DESC_INTERFACE   equ 0x04
   278                              <2> USB_DESC_ENDPOINT    equ 0x05
   279                              <2> USB_DESC_HID         equ 0x21
   280                              <2> 
   281                              <2> ; --- USB Endpoint Types ---
   282                              <2> USB_EP_CONTROL       equ 0
   283                              <2> USB_EP_ISOCH         equ 1
   284                              <2> USB_EP_BULK          equ 2
   285                              <2> USB_EP_INTERRUPT     equ 3
   286                              <2> 
   287                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   288                              <2> XHCI_EP_NOT_VALID    equ 0
   289                              <2> XHCI_EP_ISOCH_OUT    equ 1
   290                              <2> XHCI_EP_BULK_OUT     equ 2
   291                              <2> XHCI_EP_INT_OUT      equ 3
   292                              <2> XHCI_EP_CONTROL      equ 4
   293                              <2> XHCI_EP_ISOCH_IN     equ 5
   294                              <2> XHCI_EP_BULK_IN      equ 6
   295                              <2> XHCI_EP_INT_IN       equ 7
   296                              <2> 
   297                              <2> ; --- XHCI Port Speeds ---
   298                              <2> XHCI_SPEED_FULL      equ 1
   299                              <2> XHCI_SPEED_LOW       equ 2
   300                              <2> XHCI_SPEED_HIGH      equ 3
   301                              <2> XHCI_SPEED_SUPER     equ 4
    39                              <1> 
    40                              <1> EC_DATA     equ 0x62
    41                              <1> EC_CMD      equ 0x66
    42                              <1> EC_IBF      equ (1 << 1)   ; Input buffer full  (busy, can't write)
    43                              <1> EC_OBF      equ (1 << 0)   ; Output buffer full (data ready to read)
    44                              <1> EC_READ_CMD equ 0x80       ; EC "read register" command
    45                              <1> 
    46                              <1> ; Layout A registers
    47                              <1> EC_REG_A_BAT_CAP    equ 0xA2
    48                              <1> EC_REG_A_BAT_FLAGS  equ 0xA3
    49                              <1> EC_REG_A_AC_STATUS  equ 0xA4
    50                              <1> 
    51                              <1> ; Layout B registers (Acer Nitro 2023/2024)
    52                              <1> EC_REG_B_BAT_CAP    equ 0x42
    53                              <1> EC_REG_B_BAT_FLAGS  equ 0x40
    54                              <1> EC_REG_B_AC_STATUS  equ 0x41
    55                              <1> 
    56                              <1> ; Layout C registers (mWh-based)
    57                              <1> EC_REG_C_REM_LO     equ 0xB2
    58                              <1> EC_REG_C_REM_HI     equ 0xB3
    59                              <1> EC_REG_C_DES_LO     equ 0xB4
    60                              <1> EC_REG_C_DES_HI     equ 0xB5
    61                              <1> EC_REG_C_STATUS     equ 0xA0
    62                              <1> EC_REG_C_AC         equ 0xA1
    63                              <1> 
    64                              <1> BAT_STATE_UNKNOWN  equ 0
    65                              <1> BAT_STATE_AC       equ 1
    66                              <1> BAT_STATE_DISCHARGE equ 2
    67                              <1> BAT_STATE_CHARGING equ 3
    68                              <1> 
    69                              <1> EC_LAYOUT_NONE  equ 0
    70                              <1> EC_LAYOUT_A     equ 1
    71                              <1> EC_LAYOUT_B     equ 2
    72                              <1> EC_LAYOUT_C     equ 3
    73                              <1> 
    74                              <1> section .text
    75                              <1> 
    76                              <1> global battery_init
    77                              <1> global battery_poll
    78                              <1> 
    79                              <1> extern acpi_ec_read
    80                              <1> 
    81                              <1> ; ============================================================================
    82                              <1> ; ec_read_reg - wrapper for the ACPI EC read function
    83                              <1> ; Input:  DL = register address
    84                              <1> ; Output: AL = register value, CF=0 on success; CF=1 on timeout
    85                              <1> ; ============================================================================
    86                              <1> ec_read_reg:
    87 00006F2E 88D1                <1>     mov cl, dl
    88 00006F30 E8E7B3FFFF          <1>     call acpi_ec_read
    89 00006F35 C3                  <1>     ret
    90                              <1> 
    91                              <1> ; ============================================================================
    92                              <1> ; battery_probe_layout - probe EC to find correct register layout
    93                              <1> ; Sets bat_layout and primes battery_state/battery_percent
    94                              <1> ; Returns: AL = layout found (0=none)
    95                              <1> ; ============================================================================
    96                              <1> battery_probe_layout:
    97 00006F36 53                  <1>     push rbx
    98 00006F37 52                  <1>     push rdx
    99                              <1> 
   100                              <1>     ; --- Try Layout A: reg 0xA2 should be 0-100 ---
   101 00006F38 B2A2                <1>     mov dl, EC_REG_A_BAT_CAP
   102 00006F3A E8EFFFFFFF          <1>     call ec_read_reg
   103 00006F3F 7225                <1>     jc .try_layout_b
   104 00006F41 0FB6D8              <1>     movzx ebx, al
   105 00006F44 80FB00              <1>     cmp bl, 0
   106 00006F47 7C1D                <1>     jl .try_layout_b
   107 00006F49 80FB64              <1>     cmp bl, 100
   108 00006F4C 7602                <1>     jbe .layout_a_cap_ok
   109                              <1>     ; Value > 100 - could be mWh or wrong register - not layout A
   110 00006F4E EB16                <1>     jmp .try_layout_b
   111                              <1> .layout_a_cap_ok:
   112                              <1>     ; Verify AC register too - bit0 should be 0 or 1
   113 00006F50 B2A4                <1>     mov dl, EC_REG_A_AC_STATUS
   114 00006F52 E8D7FFFFFF          <1>     call ec_read_reg
   115 00006F57 720D                <1>     jc .try_layout_b
   116 00006F59 24FE                <1>     and al, 0xFE             ; mask off bit0 - rest should be 0 or predictable
   117                              <1>     ; Accept layout A
   118 00006F5B C605(A50D0000)01    <1>     mov byte [bat_layout], EC_LAYOUT_A
   119 00006F62 B001                <1>     mov al, EC_LAYOUT_A
   120 00006F64 EB61                <1>     jmp .probe_done
   121                              <1> 
   122                              <1> .try_layout_b:
   123                              <1>     ; --- Try Layout B: reg 0x42 should be 0-100 ---
   124 00006F66 B242                <1>     mov dl, EC_REG_B_BAT_CAP
   125 00006F68 E8C1FFFFFF          <1>     call ec_read_reg
   126 00006F6D 7213                <1>     jc .try_layout_c
   127 00006F6F 0FB6D8              <1>     movzx ebx, al
   128 00006F72 80FB64              <1>     cmp bl, 100
   129 00006F75 770B                <1>     ja .try_layout_c
   130                              <1>     ; Looks like a valid percentage
   131 00006F77 C605(A50D0000)02    <1>     mov byte [bat_layout], EC_LAYOUT_B
   132 00006F7E B002                <1>     mov al, EC_LAYOUT_B
   133 00006F80 EB45                <1>     jmp .probe_done
   134                              <1> 
   135                              <1> .try_layout_c:
   136                              <1>     ; --- Try Layout C: read design cap (16-bit) and remaining cap ---
   137 00006F82 B2B4                <1>     mov dl, EC_REG_C_DES_LO
   138 00006F84 E8A5FFFFFF          <1>     call ec_read_reg
   139 00006F89 7233                <1>     jc .probe_fail
   140 00006F8B 0FB6D8              <1>     movzx ebx, al            ; design_lo
   141 00006F8E B2B5                <1>     mov dl, EC_REG_C_DES_HI
   142 00006F90 E899FFFFFF          <1>     call ec_read_reg
   143 00006F95 7227                <1>     jc .probe_fail
   144 00006F97 0FB6C0              <1>     movzx eax, al
   145 00006F9A C1E008              <1>     shl eax, 8
   146 00006F9D 09C3                <1>     or ebx, eax              ; ebx = design capacity (mWh/10 typically)
   147                              <1>     ; Must be non-zero and reasonable (e.g. 200-10000 range = 2Wh-100Wh)
   148 00006F9F 83FB0A              <1>     cmp ebx, 10
   149 00006FA2 7C1A                <1>     jl .probe_fail
   150 00006FA4 81FBE8FD0000        <1>     cmp ebx, 65000
   151 00006FAA 7F12                <1>     jg .probe_fail
   152                              <1>     ; Store design capacity for % calculation
   153 00006FAC 66891D(A60D0000)    <1>     mov [bat_design_cap], bx
   154 00006FB3 C605(A50D0000)03    <1>     mov byte [bat_layout], EC_LAYOUT_C
   155 00006FBA B003                <1>     mov al, EC_LAYOUT_C
   156 00006FBC EB09                <1>     jmp .probe_done
   157                              <1> 
   158                              <1> .probe_fail:
   159 00006FBE C605(A50D0000)00    <1>     mov byte [bat_layout], EC_LAYOUT_NONE
   160 00006FC5 30C0                <1>     xor al, al
   161                              <1> 
   162                              <1> .probe_done:
   163 00006FC7 5A                  <1>     pop rdx
   164 00006FC8 5B                  <1>     pop rbx
   165 00006FC9 C3                  <1>     ret
   166                              <1> 
   167                              <1> ; ============================================================================
   168                              <1> ; battery_do_read - read all EC registers and update state
   169                              <1> ; Uses layout stored in bat_layout
   170                              <1> ; ============================================================================
   171                              <1> battery_do_read:
   172 00006FCA 50                  <1>     push rax
   173 00006FCB 53                  <1>     push rbx
   174 00006FCC 52                  <1>     push rdx
   175                              <1> 
   176 00006FCD 0FB605(A50D0000)    <1>     movzx eax, byte [bat_layout]
   177 00006FD4 3C01                <1>     cmp al, EC_LAYOUT_A
   178 00006FD6 7411                <1>     je .read_layout_a
   179 00006FD8 3C02                <1>     cmp al, EC_LAYOUT_B
   180 00006FDA 744B                <1>     je .read_layout_b
   181 00006FDC 3C03                <1>     cmp al, EC_LAYOUT_C
   182 00006FDE 0F847E000000        <1>     je .read_layout_c
   183 00006FE4 E9FB000000          <1>     jmp .done              ; EC_LAYOUT_NONE
   184                              <1> 
   185                              <1> ; --- Layout A: 0xA2=cap%, 0xA3=flags, 0xA4=AC ---
   186                              <1> .read_layout_a:
   187 00006FE9 B2A4                <1>     mov dl, EC_REG_A_AC_STATUS
   188 00006FEB E83EFFFFFF          <1>     call ec_read_reg
   189 00006FF0 0F82EE000000        <1>     jc .done
   190 00006FF6 0FB6D8              <1>     movzx ebx, al               ; bit0=AC present
   191                              <1> 
   192 00006FF9 B2A2                <1>     mov dl, EC_REG_A_BAT_CAP
   193 00006FFB E82EFFFFFF          <1>     call ec_read_reg
   194 00007000 0F82DE000000        <1>     jc .done
   195 00007006 3C64                <1>     cmp al, 100
   196 00007008 7602                <1>     jbe .la_cap_ok
   197 0000700A B064                <1>     mov al, 100
   198                              <1> .la_cap_ok:
   199 0000700C 8805(A30D0000)      <1>     mov [battery_percent], al
   200                              <1> 
   201 00007012 B2A3                <1>     mov dl, EC_REG_A_BAT_FLAGS
   202 00007014 E815FFFFFF          <1>     call ec_read_reg
   203 00007019 0F82C5000000        <1>     jc .done
   204 0000701F 0FB6C0              <1>     movzx eax, al               ; bit1=charging
   205                              <1> 
   206 00007022 E99B000000          <1>     jmp .determine_state
   207                              <1> 
   208                              <1> ; --- Layout B: 0x40=flags, 0x41=AC, 0x42=cap% ---
   209                              <1> .read_layout_b:
   210 00007027 B241                <1>     mov dl, EC_REG_B_AC_STATUS
   211 00007029 E800FFFFFF          <1>     call ec_read_reg
   212 0000702E 0F82B0000000        <1>     jc .done
   213 00007034 0FB6D8              <1>     movzx ebx, al               ; bit0=AC present
   214                              <1> 
   215 00007037 B242                <1>     mov dl, EC_REG_B_BAT_CAP
   216 00007039 E8F0FEFFFF          <1>     call ec_read_reg
   217 0000703E 0F82A0000000        <1>     jc .done
   218 00007044 3C64                <1>     cmp al, 100
   219 00007046 7602                <1>     jbe .lb_cap_ok
   220 00007048 B064                <1>     mov al, 100
   221                              <1> .lb_cap_ok:
   222 0000704A 8805(A30D0000)      <1>     mov [battery_percent], al
   223                              <1> 
   224 00007050 B240                <1>     mov dl, EC_REG_B_BAT_FLAGS
   225 00007052 E8D7FEFFFF          <1>     call ec_read_reg
   226 00007057 0F8287000000        <1>     jc .done
   227 0000705D 0FB6C0              <1>     movzx eax, al               ; bit1=charging
   228                              <1> 
   229 00007060 EB60                <1>     jmp .determine_state
   230                              <1> 
   231                              <1> ; --- Layout C: mWh-based, compute % from remaining/design ---
   232                              <1> .read_layout_c:
   233 00007062 B2A1                <1>     mov dl, EC_REG_C_AC
   234 00007064 E8C5FEFFFF          <1>     call ec_read_reg
   235 00007069 7279                <1>     jc .done
   236 0000706B 0FB6D8              <1>     movzx ebx, al               ; bit0=AC present
   237                              <1> 
   238 0000706E B2B2                <1>     mov dl, EC_REG_C_REM_LO
   239 00007070 E8B9FEFFFF          <1>     call ec_read_reg
   240 00007075 726D                <1>     jc .done
   241 00007077 0FB6C8              <1>     movzx ecx, al
   242 0000707A B2B3                <1>     mov dl, EC_REG_C_REM_HI
   243 0000707C E8ADFEFFFF          <1>     call ec_read_reg
   244 00007081 7261                <1>     jc .done
   245 00007083 0FB6C0              <1>     movzx eax, al
   246 00007086 C1E008              <1>     shl eax, 8
   247 00007089 09C1                <1>     or ecx, eax                 ; ecx = remaining mWh/10
   248                              <1> 
   249                              <1>     ; Compute percent: remaining * 100 / design
   250 0000708B 0FB705(A60D0000)    <1>     movzx eax, word [bat_design_cap]
   251 00007092 85C0                <1>     test eax, eax
   252 00007094 744E                <1>     jz .done
   253 00007096 89C8                <1>     mov eax, ecx
   254 00007098 6BC064              <1>     imul eax, 100
   255 0000709B 31D2                <1>     xor edx, edx
   256 0000709D 0FB70D(A60D0000)    <1>     movzx ecx, word [bat_design_cap]
   257 000070A4 F7F1                <1>     div ecx                     ; eax = percent
   258 000070A6 83F864              <1>     cmp eax, 100
   259 000070A9 7605                <1>     jbe .lc_cap_ok
   260 000070AB B864000000          <1>     mov eax, 100
   261                              <1> .lc_cap_ok:
   262 000070B0 8805(A30D0000)      <1>     mov [battery_percent], al
   263                              <1> 
   264 000070B6 B2A0                <1>     mov dl, EC_REG_C_STATUS
   265 000070B8 E871FEFFFF          <1>     call ec_read_reg
   266 000070BD 7225                <1>     jc .done
   267 000070BF 0FB6C0              <1>     movzx eax, al               ; bit1=charging
   268                              <1> 
   269                              <1>     ; Fall through to determine_state
   270                              <1> 
   271                              <1> ; --- Determine state from EBX (AC bit0) and EAX (charging bit1) ---
   272                              <1> .determine_state:
   273 000070C2 F6C301              <1>     test bl, 0x01               ; AC present?
   274 000070C5 7416                <1>     jz .on_battery
   275                              <1> 
   276 000070C7 A802                <1>     test al, 0x02               ; Charging?
   277 000070C9 7509                <1>     jnz .state_charging
   278                              <1> 
   279 000070CB C605(A20D0000)01    <1>     mov byte [battery_state], BAT_STATE_AC
   280 000070D2 EB10                <1>     jmp .done
   281                              <1> 
   282                              <1> .state_charging:
   283 000070D4 C605(A20D0000)03    <1>     mov byte [battery_state], BAT_STATE_CHARGING
   284 000070DB EB07                <1>     jmp .done
   285                              <1> 
   286                              <1> .on_battery:
   287 000070DD C605(A20D0000)02    <1>     mov byte [battery_state], BAT_STATE_DISCHARGE
   288                              <1> 
   289                              <1> .done:
   290 000070E4 5A                  <1>     pop rdx
   291 000070E5 5B                  <1>     pop rbx
   292 000070E6 58                  <1>     pop rax
   293 000070E7 C3                  <1>     ret
   294                              <1> 
   295                              <1> ; ============================================================================
   296                              <1> ; battery_init
   297                              <1> ; ============================================================================
   298                              <1> battery_init:
   299 000070E8 50                  <1>     push rax
   300 000070E9 52                  <1>     push rdx
   301                              <1> 
   302 000070EA C605(A20D0000)00    <1>     mov byte [battery_state], BAT_STATE_UNKNOWN
   303 000070F1 C605(A30D0000)00    <1>     mov byte [battery_percent], 0
   304 000070F8 C605(A40D0000)00    <1>     mov byte [bat_ec_ok], 0
   305 000070FF C605(A50D0000)00    <1>     mov byte [bat_layout], EC_LAYOUT_NONE
   306 00007106 C705(A80D0000)0000- <1>     mov dword [bat_poll_counter], 0
   306 0000710E 0000                <1>
   307                              <1> 
   308                              <1>     ; Serial: 'B'
   309 00007110 66BAF803            <1>     mov dx, 0x3F8
   310 00007114 B042                <1>     mov al, 'B'
   311 00007116 EE                  <1>     out dx, al
   312                              <1> 
   313                              <1>     ; Probe EC to find working register layout
   314 00007117 E81AFEFFFF          <1>     call battery_probe_layout
   315 0000711C 84C0                <1>     test al, al
   316 0000711E 7415                <1>     jz .ec_fail
   317                              <1> 
   318 00007120 C605(A40D0000)01    <1>     mov byte [bat_ec_ok], 1
   319 00007127 E89EFEFFFF          <1>     call battery_do_read
   320                              <1> 
   321 0000712C 66BAF803            <1>     mov dx, 0x3F8
   322 00007130 B062                <1>     mov al, 'b'
   323 00007132 EE                  <1>     out dx, al
   324 00007133 EB15                <1>     jmp .ret
   325                              <1> 
   326                              <1> .ec_fail:
   327                              <1>     ; EC didn't respond - assume AC power (safe for desktop use)
   328 00007135 C605(A20D0000)01    <1>     mov byte [battery_state], BAT_STATE_AC
   329 0000713C C605(A30D0000)64    <1>     mov byte [battery_percent], 100
   330 00007143 66BAF803            <1>     mov dx, 0x3F8
   331 00007147 B021                <1>     mov al, '!'
   332 00007149 EE                  <1>     out dx, al
   333                              <1> 
   334                              <1> .ret:
   335 0000714A 5A                  <1>     pop rdx
   336 0000714B 58                  <1>     pop rax
   337 0000714C C3                  <1>     ret
   338                              <1> 
   339                              <1> ; ============================================================================
   340                              <1> ; battery_poll - throttled poll, call every main loop iteration
   341                              <1> ; ============================================================================
   342                              <1> battery_poll:
   343 0000714D 803D(A40D0000)00    <1>     cmp byte [bat_ec_ok], 0
   344 00007154 7421                <1>     je .skip
   345                              <1> 
   346 00007156 FF05(A80D0000)      <1>     inc dword [bat_poll_counter]
   347 0000715C 813D(A80D0000)2C01- <1>     cmp dword [bat_poll_counter], 300   ; ~3 seconds at ~100fps
   347 00007164 0000                <1>
   348 00007166 7C0F                <1>     jl .skip
   349 00007168 C705(A80D0000)0000- <1>     mov dword [bat_poll_counter], 0
   349 00007170 0000                <1>
   350 00007172 E853FEFFFF          <1>     call battery_do_read
   351                              <1> .skip:
   352 00007177 C3                  <1>     ret
   353                              <1> 
   354                              <1> section .data
   355                              <1> 
   356                              <1> global battery_state
   357                              <1> global battery_percent
   358                              <1> 
   359 00000DA2 00                  <1> battery_state:    db BAT_STATE_UNKNOWN
   360 00000DA3 00                  <1> battery_percent:  db 0
   361 00000DA4 00                  <1> bat_ec_ok:        db 0
   362 00000DA5 00                  <1> bat_layout:       db EC_LAYOUT_NONE
   363 00000DA6 0000                <1> bat_design_cap:   dw 0           ; Layout C: design capacity (mWh/10)
   364 00000DA8 00000000            <1> bat_poll_counter: dd 0
    87                                  
    88                                  ; --- Filesystem ---
    89                                  section .text
    90                                  %include "src/kernel/fat16.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - FAT16 Filesystem Driver
     3                              <1> ; Reads/writes files from a FAT16 partition starting at a fixed sector offset
     4                              <1> ; ============================================================================
     5                              <1> bits 64
     6                              <1> 
     7                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> L3_SYSCALL_STACK_ADDR equ 0xC00000   ; Kernel-only syscall stacks
    33                              <2> 
    34                              <2> ; --- Stage 2 disk layout ---
    35                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    36                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    37                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    38                              <2> 
    39                              <2> ; --- Screen ---
    40                              <2> SCREEN_WIDTH        equ 1024
    41                              <2> SCREEN_HEIGHT       equ 768
    42                              <2> SCREEN_BPP          equ 32
    43                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    44                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    45                              <2> 
    46                              <2> 
    47                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    48                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    49                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    50                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    51                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    52                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    53                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    54                              <2> 
    55                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    56                              <2> COLOR_BLACK         equ 0x00000000
    57                              <2> COLOR_WHITE         equ 0x00FFFFFF
    58                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    59                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    60                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    61                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    62                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    63                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    64                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    65                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    66                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    67                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    68                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    69                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    70                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    71                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    72                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    73                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    74                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    75                              <2> COLOR_START_HOVER    equ 0x00338833
    76                              <2> 
    77                              <2> ; --- Window Manager ---
    78                              <2> MAX_WINDOWS         equ 8
    79                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    80                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    81                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    82                              <2> TITLEBAR_HEIGHT     equ 24
    83                              <2> BORDER_WIDTH        equ 2
    84                              <2> CLOSE_BTN_SIZE      equ 18
    85                              <2> MIN_BTN_SIZE        equ 18
    86                              <2> MIN_WINDOW_W        equ 200
    87                              <2> MIN_WINDOW_H        equ 100
    88                              <2> 
    89                              <2> ; --- Taskbar ---
    90                              <2> TASKBAR_HEIGHT      equ 36
    91                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    92                              <2> START_BTN_W         equ 70
    93                              <2> START_BTN_H         equ 28
    94                              <2> START_BTN_X         equ 4
    95                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    96                              <2> CLOCK_WIDTH         equ 64
    97                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    98                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    99                              <2> 
   100                              <2> ; --- Keyboard ---
   101                              <2> KB_BUFFER_SIZE      equ 64
   102                              <2> 
   103                              <2> ; --- Mouse ---
   104                              <2> MOUSE_BUFFER_SIZE   equ 64
   105                              <2> CURSOR_WIDTH        equ 12
   106                              <2> CURSOR_HEIGHT       equ 19
   107                              <2> 
   108                              <2> ; --- PIT ---
   109                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   110                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   111                              <2> 
   112                              <2> ; --- PIC vectors ---
   113                              <2> IRQ_BASE_MASTER     equ 32
   114                              <2> IRQ_BASE_SLAVE      equ 40
   115                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   116                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   117                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   118                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   119                              <2> 
   120                              <2> ; --- Font ---
   121                              <2> FONT_WIDTH          equ 8
   122                              <2> FONT_HEIGHT         equ 16
   123                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   124                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   125                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   126                              <2> 
   127                              <2> ; --- Window flags ---
   128                              <2> WF_VISIBLE          equ 0x01
   129                              <2> WF_FOCUSED          equ 0x02
   130                              <2> WF_DRAGGING         equ 0x04
   131                              <2> WF_MINIMIZED        equ 0x08
   132                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   133                              <2> 
   134                              <2> ; --- Mouse event types ---
   135                              <2> MEVT_MOVE           equ 1
   136                              <2> MEVT_LCLICK         equ 2
   137                              <2> MEVT_RCLICK         equ 3
   138                              <2> MEVT_LRELEASE       equ 4
   139                              <2> MEVT_RRELEASE       equ 5
   140                              <2> 
   141                              <2> ; --- Key modifier flags ---
   142                              <2> KMOD_SHIFT          equ 0x01
   143                              <2> KMOD_CTRL           equ 0x02
   144                              <2> KMOD_ALT            equ 0x04
   145                              <2> 
   146                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   147                              <2> KEY_F1              equ 0xF1
   148                              <2> KEY_F2              equ 0xF2
   149                              <2> KEY_F3              equ 0xF3
   150                              <2> KEY_F4              equ 0xF4
   151                              <2> KEY_F5              equ 0xF5
   152                              <2> KEY_F6              equ 0xF6
   153                              <2> KEY_F7              equ 0xF7
   154                              <2> KEY_F8              equ 0xF8
   155                              <2> KEY_F9              equ 0xF9
   156                              <2> KEY_F10             equ 0xFA
   157                              <2> KEY_F11             equ 0xFB
   158                              <2> KEY_F12             equ 0xFC
   159                              <2> 
   160                              <2> ; --- USB/XHCI Memory Layout ---
   161                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   162                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   163                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   164                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   165                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   166                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   167                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   168                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   169                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   170                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   171                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   172                              <2> ; Slot 2 device support
   173                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   174                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   175                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   176                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   177                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   178                              <2> 
   179                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   180                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   181                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   182                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   183                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   184                              <2> XHCI_CAP_DBOFF      equ 0x14
   185                              <2> XHCI_CAP_RTSOFF     equ 0x18
   186                              <2> 
   187                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   188                              <2> XHCI_OP_USBCMD      equ 0x00
   189                              <2> XHCI_OP_USBSTS      equ 0x04
   190                              <2> XHCI_OP_PAGESIZE     equ 0x08
   191                              <2> XHCI_OP_DNCTRL      equ 0x14
   192                              <2> XHCI_OP_CRCR_LO     equ 0x18
   193                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   194                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   195                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   196                              <2> XHCI_OP_CONFIG      equ 0x38
   197                              <2> 
   198                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   199                              <2> XHCI_PORTSC         equ 0x00
   200                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   201                              <2> 
   202                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   203                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   204                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   205                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   206                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   207                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   208                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   209                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   210                              <2> 
   211                              <2> ; --- USBCMD bits ---
   212                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   213                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   214                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   215                              <2> 
   216                              <2> ; --- USBSTS bits ---
   217                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   218                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   219                              <2> 
   220                              <2> ; --- PORTSC bits ---
   221                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   222                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   223                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   224                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   225                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   226                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   227                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   228                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   229                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   230                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   231                              <2> 
   232                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   233                              <2> TRB_NORMAL           equ (1 << 10)
   234                              <2> TRB_SETUP            equ (2 << 10)
   235                              <2> TRB_DATA             equ (3 << 10)
   236                              <2> TRB_STATUS           equ (4 << 10)
   237                              <2> TRB_LINK             equ (6 << 10)
   238                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   239                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   240                              <2> TRB_CONFIG_EP        equ (12 << 10)
   241                              <2> TRB_EVAL_CTX         equ (13 << 10)
   242                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   243                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   244                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   245                              <2> 
   246                              <2> ; --- TRB Flag Bits (dword 3) ---
   247                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   248                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   249                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   250                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   251                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   252                              <2> 
   253                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   254                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   255                              <2> TRB_TRT_OUT          equ (2 << 16)
   256                              <2> TRB_TRT_IN           equ (3 << 16)
   257                              <2> 
   258                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   259                              <2> TRB_DIR_OUT          equ (0 << 16)
   260                              <2> TRB_DIR_IN           equ (1 << 16)
   261                              <2> 
   262                              <2> ; --- Ring sizes ---
   263                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   264                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   265                              <2> 
   266                              <2> ; --- USB Standard Request Codes ---
   267                              <2> USB_REQ_GET_DESC     equ 0x06
   268                              <2> USB_REQ_SET_CONFIG   equ 0x09
   269                              <2> USB_REQ_SET_IFACE    equ 0x0B
   270                              <2> 
   271                              <2> ; --- USB HID Request Codes ---
   272                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   273                              <2> 
   274                              <2> ; --- USB Descriptor Types ---
   275                              <2> USB_DESC_DEVICE      equ 0x01
   276                              <2> USB_DESC_CONFIG      equ 0x02
   277                              <2> USB_DESC_INTERFACE   equ 0x04
   278                              <2> USB_DESC_ENDPOINT    equ 0x05
   279                              <2> USB_DESC_HID         equ 0x21
   280                              <2> 
   281                              <2> ; --- USB Endpoint Types ---
   282                              <2> USB_EP_CONTROL       equ 0
   283                              <2> USB_EP_ISOCH         equ 1
   284                              <2> USB_EP_BULK          equ 2
   285                              <2> USB_EP_INTERRUPT     equ 3
   286                              <2> 
   287                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   288                              <2> XHCI_EP_NOT_VALID    equ 0
   289                              <2> XHCI_EP_ISOCH_OUT    equ 1
   290                              <2> XHCI_EP_BULK_OUT     equ 2
   291                              <2> XHCI_EP_INT_OUT      equ 3
   292                              <2> XHCI_EP_CONTROL      equ 4
   293                              <2> XHCI_EP_ISOCH_IN     equ 5
   294                              <2> XHCI_EP_BULK_IN      equ 6
   295                              <2> XHCI_EP_INT_IN       equ 7
   296                              <2> 
   297                              <2> ; --- XHCI Port Speeds ---
   298                              <2> XHCI_SPEED_FULL      equ 1
   299                              <2> XHCI_SPEED_LOW       equ 2
   300                              <2> XHCI_SPEED_HIGH      equ 3
   301                              <2> XHCI_SPEED_SUPER     equ 4
     8                              <1> 
     9                              <1> section .text
    10                              <1> 
    11                              <1> global fat16_init
    12                              <1> global fat16_list_dir
    13                              <1> global fat16_read_file
    14                              <1> global fat16_write_file
    15                              <1> global fat16_get_file_size
    16                              <1> global fat16_file_count
    17                              <1> global fat16_get_entry
    18                              <1> 
    19                              <1> extern ata_read_sectors
    20                              <1> extern ata_write_sectors
    21                              <1> extern ata_drive_sel
    22                              <1> 
    23                              <1> ; The FAT16 partition starts at this LBA sector on the disk image
    24                              <1> FAT16_PART_LBA  equ 320           ; After MBR + Stage2 + Kernel (sector 320 = byte 163840)
    25                              <1> 
    26                              <1> ; FAT16 BPB offsets (from start of boot sector)
    27                              <1> BPB_BYTES_PER_SECT  equ 11        ; word
    28                              <1> BPB_SECT_PER_CLUS   equ 13        ; byte
    29                              <1> BPB_RESERVED_SECTS  equ 14        ; word
    30                              <1> BPB_NUM_FATS        equ 16        ; byte
    31                              <1> BPB_ROOT_ENTRIES    equ 17        ; word
    32                              <1> BPB_TOTAL_SECTS16   equ 19        ; word
    33                              <1> BPB_FAT_SIZE16      equ 22        ; word
    34                              <1> 
    35                              <1> ; FAT16 directory entry offsets
    36                              <1> DIR_NAME            equ 0          ; 8 bytes filename
    37                              <1> DIR_EXT             equ 8          ; 3 bytes extension
    38                              <1> DIR_ATTR            equ 11         ; 1 byte attributes
    39                              <1> DIR_FIRST_CLUS_HI   equ 20        ; 2 bytes (FAT32 only, 0 for FAT16)
    40                              <1> DIR_FIRST_CLUS_LO   equ 26        ; 2 bytes
    41                              <1> DIR_FILE_SIZE       equ 28         ; 4 bytes
    42                              <1> DIR_ENTRY_SIZE      equ 32
    43                              <1> 
    44                              <1> ; Attributes
    45                              <1> ATTR_READ_ONLY      equ 0x01
    46                              <1> ATTR_HIDDEN         equ 0x02
    47                              <1> ATTR_SYSTEM         equ 0x04
    48                              <1> ATTR_VOLUME_ID      equ 0x08
    49                              <1> ATTR_DIRECTORY      equ 0x10
    50                              <1> ATTR_ARCHIVE        equ 0x20
    51                              <1> ATTR_LFN            equ 0x0F
    52                              <1> 
    53                              <1> ; Temp buffers - moved to 13MB region to avoid XHCI conflict (0x900000-0x9F0000)
    54                              <1> FAT16_SECTOR_BUF    equ 0xD00000   ; 512 byte sector buffer
    55                              <1> FAT16_FAT_CACHE     equ 0xD01000   ; FAT table cache (up to 64KB)
    56                              <1> FAT16_ROOT_CACHE    equ 0xD11000   ; Root directory cache (up to 32 sectors = 16KB)
    57                              <1> FAT16_FILE_BUF      equ 0xD21000   ; File read buffer (up to 64KB)
    58                              <1> FAT16_DIR_CACHE     equ 0xD31000   ; Current directory listing cache
    59                              <1> 
    60                              <1> ; ============================================================================
    61                              <1> ; fat16_init - Initialize FAT16 driver, read BPB and cache FAT + root dir
    62                              <1> ; Returns: eax = 0 on success
    63                              <1> ; ============================================================================
    64                              <1> fat16_init:
    65 00007178 53                  <1>     push rbx
    66 00007179 51                  <1>     push rcx
    67 0000717A 52                  <1>     push rdx
    68 0000717B 57                  <1>     push rdi
    69 0000717C 56                  <1>     push rsi
    70                              <1> 
    71                              <1>     ; Read boot sector of FAT16 partition
    72                              <1>     ; First attempt with default drive (0xE0)
    73 0000717D BF40010000          <1>     mov rdi, FAT16_PART_LBA
    74 00007182 BE0000D000          <1>     mov rsi, FAT16_SECTOR_BUF
    75 00007187 BA01000000          <1>     mov edx, 1
    76 0000718C E881C4FFFF          <1>     call ata_read_sectors
    77 00007191 85C0                <1>     test eax, eax
    78 00007193 750C                <1>     jnz .try_next_drive
    79                              <1> 
    80                              <1>     ; Check partition signature
    81 00007195 66813C25FE01D00055- <1>     cmp word [FAT16_SECTOR_BUF + 510], 0xAA55
    81          ******************  <1>  warning: absolute address can not be RIP-relative [-w+ea-absolute]
    81 0000719E AA                  <1>
    82 0000719F 743A                <1>     je .bpb_found
    83                              <1> 
    84                              <1> .try_next_drive:
    85                              <1>     ; Toggle drive (0xE0 -> 0xF0 or vice versa)
    86 000071A1 8A05(46050000)      <1>     mov al, [ata_drive_sel]
    87 000071A7 3410                <1>     xor al, 0x10
    88 000071A9 8805(46050000)      <1>     mov [ata_drive_sel], al
    89                              <1> 
    90                              <1>     ; Try reading again
    91 000071AF BF40010000          <1>     mov rdi, FAT16_PART_LBA
    92 000071B4 BE0000D000          <1>     mov rsi, FAT16_SECTOR_BUF
    93 000071B9 BA01000000          <1>     mov edx, 1
    94 000071BE E84FC4FFFF          <1>     call ata_read_sectors
    95 000071C3 85C0                <1>     test eax, eax
    96 000071C5 0F85EB000000        <1>     jnz .init_fail
    97                              <1> 
    98                              <1>     ; Check signature again
    99 000071CB 66813C25FE01D00055- <1>     cmp word [FAT16_SECTOR_BUF + 510], 0xAA55
    99          ******************  <1>  warning: absolute address can not be RIP-relative [-w+ea-absolute]
    99 000071D4 AA                  <1>
   100 000071D5 0F85DB000000        <1>     jne .init_fail
   101                              <1> 
   102                              <1> .bpb_found:
   103                              <1>     ; Parse BPB
   104 000071DB BB0000D000          <1>     mov rbx, FAT16_SECTOR_BUF
   105 000071E0 0FB7430B            <1>     movzx eax, word [rbx + BPB_BYTES_PER_SECT]
   106 000071E4 668905(AC0D0000)    <1>     mov [fat16_bytes_per_sect], ax
   107 000071EB 0FB6430D            <1>     movzx eax, byte [rbx + BPB_SECT_PER_CLUS]
   108 000071EF 8805(AE0D0000)      <1>     mov [fat16_sect_per_clus], al
   109 000071F5 0FB7430E            <1>     movzx eax, word [rbx + BPB_RESERVED_SECTS]
   110 000071F9 668905(AF0D0000)    <1>     mov [fat16_reserved_sects], ax
   111 00007200 0FB64310            <1>     movzx eax, byte [rbx + BPB_NUM_FATS]
   112 00007204 8805(B10D0000)      <1>     mov [fat16_num_fats], al
   113 0000720A 0FB74311            <1>     movzx eax, word [rbx + BPB_ROOT_ENTRIES]
   114 0000720E 668905(B20D0000)    <1>     mov [fat16_root_entries], ax
   115 00007215 0FB74316            <1>     movzx eax, word [rbx + BPB_FAT_SIZE16]
   116 00007219 668905(B40D0000)    <1>     mov [fat16_fat_size], ax
   117                              <1> 
   118                              <1>     ; Calculate key offsets (all relative to partition start)
   119                              <1>     ; FAT start = reserved sectors
