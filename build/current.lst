     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - Math Utility Functions
     3                              <1> ; ============================================================================
     4                              <1> bits 64
     5                              <1> 
     6                              <1> section .text
     7                              <1> 
     8                              <1> ; --- clamp: Clamp value to range ---
     9                              <1> ; EDI = value, ESI = min, EDX = max
    10                              <1> ; Returns: EAX = clamped value
    11                              <1> global fn_clamp
    12                              <1> fn_clamp:
    13 0000CD5F 89F8                <1>     mov eax, edi
    14 0000CD61 39F0                <1>     cmp eax, esi
    15 0000CD63 0F4CC6              <1>     cmovl eax, esi           ; If value < min, use min
    16 0000CD66 39D0                <1>     cmp eax, edx
    17 0000CD68 0F4FC2              <1>     cmovg eax, edx           ; If value > max, use max
    18 0000CD6B C3                  <1>     ret
    19                              <1> 
    20                              <1> ; --- min: Integer minimum ---
    21                              <1> ; EDI = a, ESI = b
    22                              <1> ; Returns: EAX = min(a, b)
    23                              <1> global fn_min
    24                              <1> fn_min:
    25 0000CD6C 89F8                <1>     mov eax, edi
    26 0000CD6E 39F0                <1>     cmp eax, esi
    27 0000CD70 0F4FC6              <1>     cmovg eax, esi
    28 0000CD73 C3                  <1>     ret
    29                              <1> 
    30                              <1> ; --- max: Integer maximum ---
    31                              <1> ; EDI = a, ESI = b
    32                              <1> ; Returns: EAX = max(a, b)
    33                              <1> global fn_max
    34                              <1> fn_max:
    35 0000CD74 89F8                <1>     mov eax, edi
    36 0000CD76 39F0                <1>     cmp eax, esi
    37 0000CD78 0F4CC6              <1>     cmovl eax, esi
    38 0000CD7B C3                  <1>     ret
    39                              <1> 
    40                              <1> ; --- abs: Absolute value ---
    41                              <1> ; EDI = value
    42                              <1> ; Returns: EAX = |value|
    43                              <1> global fn_abs
    44                              <1> fn_abs:
    45 0000CD7C 89F8                <1>     mov eax, edi
    46 0000CD7E 99                  <1>     cdq
    47 0000CD7F 31D0                <1>     xor eax, edx
    48 0000CD81 29D0                <1>     sub eax, edx
    49 0000CD83 C3                  <1>     ret
    50                              <1> 
    51                              <1> ; --- rect_intersect: Test if two rectangles overlap ---
    52                              <1> ; RDI = rect1 pointer, RSI = rect2 pointer
    53                              <1> ; Returns: EAX = 1 if overlapping, 0 if not
    54                              <1> global fn_rect_intersect
    55                              <1> fn_rect_intersect:
    56                              <1>     ; rect1.x + rect1.w <= rect2.x?
    57 0000CD84 8B07                <1>     mov eax, [rdi]           ; rect1.x
    58 0000CD86 034708              <1>     add eax, [rdi + 8]      ; + rect1.w
    59 0000CD89 3B06                <1>     cmp eax, [rsi]           ; vs rect2.x
    60 0000CD8B 7E25                <1>     jle .no_intersect
    61                              <1> 
    62                              <1>     ; rect2.x + rect2.w <= rect1.x?
    63 0000CD8D 8B06                <1>     mov eax, [rsi]
    64 0000CD8F 034608              <1>     add eax, [rsi + 8]
    65 0000CD92 3B07                <1>     cmp eax, [rdi]
    66 0000CD94 7E1C                <1>     jle .no_intersect
    67                              <1> 
    68                              <1>     ; rect1.y + rect1.h <= rect2.y?
    69 0000CD96 8B4704              <1>     mov eax, [rdi + 4]
    70 0000CD99 03470C              <1>     add eax, [rdi + 12]
    71 0000CD9C 3B4604              <1>     cmp eax, [rsi + 4]
    72 0000CD9F 7E11                <1>     jle .no_intersect
    73                              <1> 
    74                              <1>     ; rect2.y + rect2.h <= rect1.y?
    75 0000CDA1 8B4604              <1>     mov eax, [rsi + 4]
    76 0000CDA4 03460C              <1>     add eax, [rsi + 12]
    77 0000CDA7 3B4704              <1>     cmp eax, [rdi + 4]
    78 0000CDAA 7E06                <1>     jle .no_intersect
    79                              <1> 
    80 0000CDAC B801000000          <1>     mov eax, 1
    81 0000CDB1 C3                  <1>     ret
    82                              <1> 
    83                              <1> .no_intersect:
    84 0000CDB2 31C0                <1>     xor eax, eax
    85 0000CDB4 C3                  <1>     ret
   111                                  
   112                                  ; --- Helper Wrappers ---
   113                                  fn_memcpy_wrapper:
   114 0000CDB5 E9B8FEFFFF                  jmp fn_memcpy
   115                                  fn_memset_wrapper:
   116 0000CDBA E9CEFEFFFF                  jmp fn_memset
   117                                  fn_strlen_wrapper:
   118 0000CDBF E961FEFFFF                  jmp fn_strlen
   119                                  
   120                                  ; Resolve symbols used by other modules
   121                                  memcpy equ fn_memcpy
   122                                  memset equ fn_memset
   123                                  strlen equ fn_strlen
