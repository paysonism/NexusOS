   962 00000330 66BACE01            <1>     mov dx, 0x1CE
   963 00000334 66B80200            <1>     mov ax, 0x02
   964 00000338 66EF                <1>     out dx, ax
   965 0000033A 66BACF01            <1>     mov dx, 0x1CF
   966 0000033E 6689F0              <1>     mov ax, si
