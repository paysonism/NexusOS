   156                              <1> 
   157 000038DB 48BE-               <1>     mov rsi, szXhciFail
   157 000038DD [D307000000000000]  <1>
   158 000038E5 E827C8FFFF          <1>     call debug_print
   159                              <1> 
   160 000038EA C605(47050000)00    <1>     mov byte [xhci_active], 0
   161 000038F1 31C0                <1>     xor eax, eax
   162                              <1> 
   163                              <1> .ret:
   164 000038F3 415F                <1>     pop r15
   165 000038F5 415E                <1>     pop r14
   166 000038F7 415D                <1>     pop r13
   167 000038F9 415C                <1>     pop r12
   168 000038FB 5D                  <1>     pop rbp
   169 000038FC 5F                  <1>     pop rdi
   170 000038FD 5E                  <1>     pop rsi
   171 000038FE 5A                  <1>     pop rdx
   172 000038FF 59                  <1>     pop rcx
