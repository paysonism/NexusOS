    21                              <1> WIN_OFF_FLAGS   equ 40
    22                              <1> WIN_OFF_TITLE   equ 48
    23                              <1> WIN_OFF_DRAWFN  equ 112
    24                              <1> WIN_OFF_KEYFN   equ 120
    25                              <1> WIN_OFF_CLICKFN equ 128
    26                              <1> WIN_OFF_APPDATA equ 136
