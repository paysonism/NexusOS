     9                              <1> section .data
    10 00000224 0000E0FE00000000    <1> lapic_base dq 0xFEE00000
    11                              <1> 
    12                              <1> section .text
    13                              <1> global apic_init
    14                              <1> global apic_eoi
    15                              <1> 
    16                              <1> ; --- Initialize Local APIC ---
    17                              <1> apic_init:
    18                              <1>     ; Read APIC base from MSR 0x1B
    19 0000218E B91B000000          <1>     mov ecx, 0x1B
    20 00002193 0F32                <1>     rdmsr                   ; EAX = low 32 bits of APIC_BASE
    21                              <1>     
    22                              <1>     ; Debug: Print the MSR value bits 11:8 (bit 10 is x2apic)
    23 00002195 50                  <1>     push rax
    24 00002196 52                  <1>     push rdx
    25                              <1>     SER 'M'
    10 00002197 50                  <2>  push rax
    11 00002198 52                  <2>  push rdx
    12 00002199 66BAF803            <2>  mov dx, 0x3F8
    13 0000219D B04D                <2>  mov al, %1
    14 0000219F EE                  <2>  out dx, al
    15 000021A0 5A                  <2>  pop rdx
    16 000021A1 58                  <2>  pop rax
    26                              <1>     SER 'S'
    10 000021A2 50                  <2>  push rax
    11 000021A3 52                  <2>  push rdx
    12 000021A4 66BAF803            <2>  mov dx, 0x3F8
    13 000021A8 B053                <2>  mov al, %1
    14 000021AA EE                  <2>  out dx, al
    15 000021AB 5A                  <2>  pop rdx
    16 000021AC 58                  <2>  pop rax
    27                              <1>     SER 'R'
    10 000021AD 50                  <2>  push rax
    11 000021AE 52                  <2>  push rdx
    12 000021AF 66BAF803            <2>  mov dx, 0x3F8
    13 000021B3 B052                <2>  mov al, %1
    14 000021B5 EE                  <2>  out dx, al
    15 000021B6 5A                  <2>  pop rdx
    16 000021B7 58                  <2>  pop rax
    28 000021B8 89C2                <1>     mov edx, eax
    29 000021BA C1EA08              <1>     shr edx, 8
    30 000021BD 80E20F              <1>     and dl, 0x0F            ; Bits 11:8
    31 000021C0 80C230              <1>     add dl, '0'
    32 000021C3 88D0                <1>     mov al, dl
    33 000021C5 BAF8030000          <1>     mov edx, 0x3F8
    34 000021CA EE                  <1>     out dx, al           ; Output bit pattern (e.g. '8'=xAPIC, 'L'=x2APIC?)
    35 000021CB 5A                  <1>     pop rdx
    36 000021CC 58                  <1>     pop rax
    37                              <1> 
    38                              <1>     ; Ensure APIC is enabled (bit 11) and x2APIC is disabled (bit 10) for now
    39                              <1>     ; to keep the MMIO-based driver working.
    40 000021CD 80E4FB              <1>     and ah, 11111011b       ; Clear bit 10 (x2APIC)
    41 000021D0 0FBAE80B            <1>     bts eax, 11
    42 000021D4 0F30                <1>     wrmsr
    43                              <1> 
    44                              <1>     ; Map the APIC base (mask out lower 12 bits)
    45 000021D6 2500F0FFFF          <1>     and eax, 0xFFFFF000
    46 000021DB 488905(24020000)    <1>     mov [lapic_base], rax
    47                              <1> 
    48                              <1>     ; Spurious Interrupt Vector Register (SIVR)
    49                              <1>     ; Enable APIC (bit 8) and set vector to 255
    50 000021E2 488B3D(24020000)    <1>     mov rdi, [lapic_base]
    51 000021E9 C787F0000000FF0100- <1>     mov dword [rdi + 0x0F0], 0x1FF
    51 000021F2 00                  <1>
    52                              <1> 
    53                              <1>     ; Set Task Priority Register (TPR) to 0 to enable all interrupts
    54                              <1>     ; On many UEFI systems this is 0xFF by default, which blocks all IRQs.
    55 000021F3 488B3D(24020000)    <1>     mov rdi, [lapic_base]
    56 000021FA C78780000000000000- <1>     mov dword [rdi + 0x080], 0
    56 00002203 00                  <1>
    57                              <1>     
    58 00002204 C3                  <1>     ret
    59                              <1> 
