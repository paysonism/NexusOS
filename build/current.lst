    51                              <1> ; l3_prepare_test_callback - copy demo user code into slot app arena
    52                              <1> ; EDI = slot, RAX = entry pointer in APP_DATA space
    53                              <1> l3_prepare_test_callback:
    54 000013B1 89F8                <1>     mov eax, edi
    55 000013B3 4869C000000100      <1>     imul rax, APP_SLOT_SIZE
    56 000013BA 480500008000        <1>     add rax, APP_DATA_ADDR
