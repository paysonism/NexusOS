   372                              <1> ; tb_draw_battery - Draw battery/power indicator in taskbar right area
   373                              <1> ;
   374                              <1> ; Layout (BAT_IND_X, TASKBAR_Y+4):
   375                              <1> ;   State 1 (AC only):      [plug icon] "AC"
   376                              <1> ;   State 2 (discharging):  [battery icon] "75%"
   377                              <1> ;   State 3 (charging):     [battery icon][plug icon] "75%"
   378                              <1> ;   State 0 (unknown):      nothing drawn
   379                              <1> ; ============================================================================
   380                              <1> tb_draw_battery:
   381 00008720 50                  <1>     push rax
