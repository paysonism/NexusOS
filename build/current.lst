    10                              <1> section .text
    11                              <1> global acpi_ec_init
    12                              <1> global acpi_ec_read
    13                              <1> global acpi_ec_write
    14                              <1> 
    15                              <1> ; ACPI EC Command/Status port normally 0x66
    16                              <1> ; ACPI EC Data port normally 0x62
    17                              <1> EC_DATA_PORT equ 0x62
    18                              <1> EC_CMD_PORT  equ 0x66
    19                              <1> 
    20                              <1> acpi_ec_init:
    21                              <1>     ; Provide pointer to EC node from DSDT/ECDT
    22 000022E9 C3                  <1>     ret
    23                              <1> 
    24                              <1> ; ec_wait_ibf
    25                              <1> ; Waits until IBF=0
    26                              <1> ec_wait_ibf:
    27 000022EA 50                  <1>     push rax
    28 000022EB 51                  <1>     push rcx
    29 000022EC B920A10700          <1>     mov ecx, 500000
    30                              <1> .loop:
    31 000022F1 E466                <1>     in al, EC_CMD_PORT
    32 000022F3 A802                <1>     test al, 0x02
    33 000022F5 7408                <1>     jz .ok
    34 000022F7 FFC9                <1>     dec ecx
    35 000022F9 75F6                <1>     jnz .loop
    36 000022FB 59                  <1>     pop rcx
    37 000022FC 58                  <1>     pop rax
    38 000022FD F9                  <1>     stc
    39 000022FE C3                  <1>     ret
    40                              <1> .ok:
    41 000022FF 59                  <1>     pop rcx
    42 00002300 58                  <1>     pop rax
    43 00002301 F8                  <1>     clc
    44 00002302 C3                  <1>     ret
    45                              <1> 
    46                              <1> ; ec_wait_obf
    47                              <1> ; Waits until OBF=1
    48                              <1> ec_wait_obf:
    49 00002303 50                  <1>     push rax
    50 00002304 51                  <1>     push rcx
    51 00002305 B920A10700          <1>     mov ecx, 500000
    52                              <1> .loop:
    53 0000230A E466                <1>     in al, EC_CMD_PORT
    54 0000230C A801                <1>     test al, 0x01
    55 0000230E 7508                <1>     jnz .ok
    56 00002310 FFC9                <1>     dec ecx
    57 00002312 75F6                <1>     jnz .loop
    58 00002314 59                  <1>     pop rcx
    59 00002315 58                  <1>     pop rax
    60 00002316 F9                  <1>     stc
    61 00002317 C3                  <1>     ret
    62                              <1> .ok:
    63 00002318 59                  <1>     pop rcx
    64 00002319 58                  <1>     pop rax
    65 0000231A F8                  <1>     clc
    66 0000231B C3                  <1>     ret
