  4050                              <1> ; BMP viewer draw callback
  4051                              <1> app_bmp_draw:
  4052 0000C36E 53                  <1>     push rbx
  4053 0000C36F 4154                <1>     push r12
  4054 0000C371 4155                <1>     push r13
  4055 0000C373 4156                <1>     push r14
  4056 0000C375 4157                <1>     push r15
  4057                              <1> 
  4058 0000C377 4889FB              <1>     mov rbx, rdi
  4059 0000C37A 4C8B6308            <1>     mov r12, [rbx + WIN_OFF_X]    ; window X
  4060 0000C37E 4C8B6B10            <1>     mov r13, [rbx + WIN_OFF_Y]    ; window Y
  4061                              <1> 
  4062                              <1>     ; Get BMP parameters
  4063 0000C382 8B0D(751E0000)      <1>     mov ecx, [bmp_width]
  4064 0000C388 8B15(791E0000)      <1>     mov edx, [bmp_height]
  4065 0000C38E 85C9                <1>     test ecx, ecx
  4066 0000C390 0F84C0000000        <1>     jz .bmp_draw_done
  4067 0000C396 85D2                <1>     test edx, edx
  4068 0000C398 0F84B8000000        <1>     jz .bmp_draw_done
  4069                              <1> 
  4070                              <1>     ; Calculate BMP row size (padded to 4 bytes)
  4071 0000C39E 8B05(811E0000)      <1>     mov eax, [bmp_bpp]
  4072 0000C3A4 83F818              <1>     cmp eax, 24
  4073 0000C3A7 0F85A9000000        <1>     jne .bmp_draw_done        ; only support 24bpp for now
  4074                              <1> 
  4075 0000C3AD 89C8                <1>     mov eax, ecx
  4076 0000C3AF 6BC003              <1>     imul eax, 3               ; bytes per row (24bpp)
  4077 0000C3B2 83C003              <1>     add eax, 3
  4078 0000C3B5 83E0FC              <1>     and eax, ~3               ; pad to 4 bytes
  4079 0000C3B8 4189C6              <1>     mov r14d, eax             ; row stride
  4080                              <1> 
  4081                              <1>     ; BMP is bottom-up, so row 0 is at bottom
  4082 0000C3BB 4189D7              <1>     mov r15d, edx             ; height
  4083 0000C3BE 41FFCF              <1>     dec r15d                  ; start from last row
  4084                              <1> 
  4085                              <1>     ; Source = BMP_FILE_BUF + data_offset
  4086 0000C3C1 8B05(7D1E0000)      <1>     mov eax, [bmp_data_offset]
  4087 0000C3C7 4C8D8000009500      <1>     lea r8, [BMP_FILE_BUF + rax]
  4088                              <1> 
  4089                              <1>     ; Get framebuffer address
  4090 0000C3CE 488B05(46020000)    <1>     mov rax, [bb_addr]         ; backbuffer logic
  4091                              <1> 
  4092                              <1>     ; Draw pixel by pixel
  4093 0000C3D5 31D2                <1>     xor edx, edx              ; dest Y counter (0 = top)
  4094                              <1> .bmp_row_loop:
  4095 0000C3D7 3B15(791E0000)      <1>     cmp edx, [bmp_height]
  4096 0000C3DD 7D77                <1>     jge .bmp_draw_done
  4097                              <1> 
  4098                              <1>     ; Source row = r15d (counts down from height-1)
  4099 0000C3DF 4489F8              <1>     mov eax, r15d
  4100 0000C3E2 410FAFC6            <1>     imul eax, r14d            ; row * stride
  4101 0000C3E6 498D3400            <1>     lea rsi, [r8 + rax]      ; source pixel row
  4102                              <1> 
  4103                              <1>     ; Dest pixel Y = window_Y + titlebar + edx
  4104 0000C3EA 4489EF              <1>     mov edi, r13d
  4105 0000C3ED 83C718              <1>     add edi, TITLEBAR_HEIGHT
  4106 0000C3F0 01D7                <1>     add edi, edx
  4107                              <1>     ; Check Y bounds
  4108 0000C3F2 81FF00030000        <1>     cmp edi, SCREEN_HEIGHT
