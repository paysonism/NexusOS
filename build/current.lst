   925                              <1> ; --- Set Video Mode (Bochs VBE) ---
   926                              <1> ; EDI = width, ESI = height, EDX = bpp
   927                              <1> ; Returns 0 on success, -1 on failure
   928                              <1> global display_set_mode
   929                              <1> display_set_mode:
   930 000002D9 53                  <1>     push rbx
