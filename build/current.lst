    91                              <1> 
    92                              <1>     ; --- Program registers ---
    93 00003858 488B35(5C050000)    <1>     mov rsi, [xhci_op_base]
    94                              <1> 
    95                              <1>     ; Write DCBAAP
    96 0000385F B800009000          <1>     mov eax, XHCI_DCBAA_ADDR
