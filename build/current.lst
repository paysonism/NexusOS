   715 00003D5E 48C70000009100      <1>     mov qword [rax], XHCI_CMD_RING_ADDR
   716                              <1>     ; DWord 2: 0 (Interrupter Target)
   717 00003D65 C7400800000000      <1>     mov dword [rax + 8], 0
   718                              <1>     ; DWord 3: Type=Link (6), TC=1 (Toggle Cycle), Cycle=1
   719 00003D6C C7400C03180000      <1>     mov dword [rax + 12], TRB_LINK | TRB_TC | TRB_CYCLE
   720                              <1> 
   721                              <1>     ; Initialize cmd ring state
   722 00003D73 C705(8A050000)0000- <1>     mov dword [xhci_cmd_enqueue], 0
   722 00003D7B 0000                <1>
