   529 00007546 0FB615(AE0D0000)    <1>     movzx edx, byte [fat16_sect_per_clus]
   530 0000754D E843C1FFFF          <1>     call ata_write_sectors
   531 00007552 59                  <1>     pop rcx
   532                              <1> 
   533                              <1>     ; Advance source pointer
   534 00007553 0FB605(AE0D0000)    <1>     movzx eax, byte [fat16_sect_per_clus]
   535 0000755A C1E009              <1>     shl eax, 9
