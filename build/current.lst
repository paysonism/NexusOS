    69                              <1> acpi_ec_read:
    70                              <1>     ; CL = register address
    71                              <1>     ; Returns AL = data, CF=0 ok, CF=1 error
    72 0000231C 51                  <1>     push rcx
    73 0000231D 52                  <1>     push rdx
    74                              <1> 
    75                              <1>     ; Drain any stale OBF data first (avoids reading leftover bytes)
    76 0000231E BA08000000          <1>     mov edx, 8
    77                              <1> .drain_obf:
    78 00002323 E466                <1>     in al, EC_CMD_PORT
    79 00002325 A801                <1>     test al, 0x01
    80 00002327 7406                <1>     jz .drained
    81 00002329 E462                <1>     in al, EC_DATA_PORT
    82 0000232B FFCA                <1>     dec edx
    83 0000232D 75F4                <1>     jnz .drain_obf
    84                              <1> .drained:
    85                              <1> 
    86 0000232F 5A                  <1>     pop rdx
    87                              <1>     
    88 00002330 E8B5FFFFFF          <1>     call ec_wait_ibf
    89 00002335 721B                <1>     jc .fail
    90                              <1> 
    91                              <1>     ; Send EC READ command (0x80)
    92 00002337 B080                <1>     mov al, 0x80
    93 00002339 E666                <1>     out EC_CMD_PORT, al
    94                              <1>     
    95 0000233B E8AAFFFFFF          <1>     call ec_wait_ibf
    96 00002340 7210                <1>     jc .fail
    97                              <1>     
    98                              <1>     ; Send address
    99 00002342 88C8                <1>     mov al, cl
   100 00002344 E662                <1>     out EC_DATA_PORT, al
   101                              <1>     
   102 00002346 E8B8FFFFFF          <1>     call ec_wait_obf
   103 0000234B 7205                <1>     jc .fail
   104                              <1>     
   105                              <1>     ; Read data
   106 0000234D E462                <1>     in al, EC_DATA_PORT
   107 0000234F 59                  <1>     pop rcx
   108 00002350 F8                  <1>     clc
   109 00002351 C3                  <1>     ret
   110                              <1> .fail:
   111 00002352 59                  <1>     pop rcx
   112 00002353 F9                  <1>     stc
   113 00002354 C3                  <1>     ret
