   707 00008A72 56                  <1>     push rsi
   708 00008A73 4C89E7              <1>     mov rdi, r12               ; window ID
   709 00008A76 E811F0FFFF          <1>     call wm_close_window
   710 00008A7B 5E                  <1>     pop rsi
   711 00008A7C 5F                  <1>     pop rdi
   712 00008A7D B801000000          <1>     mov rax, 1
   713 00008A82 EB67                <1>     jmp .tb_click_ret
   714                              <1> 
   715                              <1> .tb_btn_activate:
   716                              <1>     ; Click on window name area - restore and focus
   717                              <1>     ; If minimized, un-minimize
   718 00008A84 48F7432808000000    <1>     test qword [rbx + WIN_OFF_FLAGS], WF_MINIMIZED
   719 00008A8C 740A                <1>     jz .tb_btn_focus
   720 00008A8E 48836328F7          <1>     and qword [rbx + WIN_OFF_FLAGS], ~WF_MINIMIZED
   721 00008A93 48834B2801          <1>     or qword [rbx + WIN_OFF_FLAGS], WF_VISIBLE
   722                              <1> 
   723                              <1> .tb_btn_focus:
   724                              <1>     ; Unfocus all windows, then focus this one
   725 00008A98 51                  <1>     push rcx
   726 00008A99 52                  <1>     push rdx
   727 00008A9A B900007100          <1>     mov rcx, WINDOW_POOL_ADDR
   728 00008A9F 31D2                <1>     xor edx, edx
   729                              <1> .tb_unfocus_loop:
