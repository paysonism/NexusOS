   585                              <1>     ; [4:5]  wReportDescLength
   586                              <1>     ; [6:7]  wReportDescRegister
   587                              <1>     ; [8:9]  wInputRegister
   588                              <1>     ; [10:11] wMaxInputLength
   589                              <1>     ; [12:13] wOutputRegister
