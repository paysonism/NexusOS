  1272 0000090F 0050DCFE00000000    <1>     dq I2C_BASE_2               ; 0xFEDC5000 - most likely I2CD on Strix Point
  1273 00000917 0060DCFE00000000    <1>     dq I2C_BASE_3               ; 0xFEDC6000 - fallback I2CD candidate
  1274 0000091F 0030DCFE00000000    <1>     dq I2C_BASE_1               ; 0xFEDC3000 - I2CB
  1275 00000927 0020DCFE00000000    <1>     dq I2C_BASE_0               ; 0xFEDC2000 - I2CA
  1276 0000092F 0000DCFE00000000    <1>     dq I2C_BASE_4               ; 0xFEDC0000 - additional FCH block
  1277                              <1> 
