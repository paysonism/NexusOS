   112                              <1> 
   113                              <1>     ; Advance tail
   114 00002B59 FFC1                <1>     inc ecx
   115 00002B5B 83E13F              <1>     and ecx, (KB_BUFFER_SIZE - 1)
   116 00002B5E 890D(D8030000)      <1>     mov [kb_tail], ecx
