  1281 00000938 17                  <1>     db 0x17             ; ELAN variant (Nitro V16 AI / Strix Point)
  1282 00000939 2C                  <1>     db 0x2C             ; Synaptics / ALPS
  1283 0000093A 38                  <1>     db 0x38             ; ELAN variant
  1284 0000093B 10                  <1>     db 0x10             ; ELAN alt
  1285 0000093C 14                  <1>     db 0x14             ; Goodix
  1286 0000093D 5D                  <1>     db 0x5D             ; Goodix alternate
  1287 0000093E 2A                  <1>     db 0x2A             ; Synaptics secondary
  1288 0000093F 3C                  <1>     db 0x3C             ; ALPS I2C-HID
  1289 00000940 20                  <1>     db 0x20             ; Pixart
  1290 00000941 34                  <1>     db 0x34             ; FocalTech
  1291 00000942 16                  <1>     db 0x16             ; ELAN variant 2
  1292 00000943 2D                  <1>     db 0x2D             ; Synaptics variant
  1293                              <1> I2C_TP_ADDR_COUNT   equ ($ - i2c_tp_addrs)
