    89 00002B0B EB08                <1>     jmp .push_key
    90                              <1> .shifted:
    91 00002B0D 670FB691[82040000]  <1>     movzx edx, byte [scancode_shifted + ecx]
    92                              <1> 
    93                              <1> .push_key:
    94                              <1>     ; Push key event to circular buffer
    95                              <1>     ; Format: scancode (byte), ascii (byte), modifiers (byte), pressed (byte)
    96 00002B15 8B0D(D8030000)      <1>     mov ecx, [kb_tail]
    97 00002B1B 4189C8              <1>     mov r8d, ecx
