   208                              <1> 
   209                              <1> .empty:
   210 00002C53 31C0                <1>     xor eax, eax
   211 00002C55 C3                  <1>     ret
   212                              <1> 
   213                              <1> ; --- Check if buffer has data ---
   214                              <1> ; Returns: EAX = 1 if data available, 0 if empty
   215                              <1> global keyboard_available
   216                              <1> keyboard_available:
   217 00002C56 8B05(D4030000)      <1>     mov eax, [kb_head]
   218 00002C5C 3B05(D8030000)      <1>     cmp eax, [kb_tail]
   219 00002C62 7406                <1>     je .no
   220 00002C64 B801000000          <1>     mov eax, 1
   221 00002C69 C3                  <1>     ret
   222                              <1> .no:
   223 00002C6A 31C0                <1>     xor eax, eax
   224 00002C6C C3                  <1>     ret
   225                              <1> 
   226                              <1> ; --- Fire repeat event if a key is held and timer expired ---
   227                              <1> ; Call once per frame from main loop
   228                              <1> global keyboard_repeat_tick
   229                              <1> keyboard_repeat_tick:
   230 00002C6D 50                  <1>     push rax
   231 00002C6E 53                  <1>     push rbx
   232 00002C6F 51                  <1>     push rcx
   233 00002C70 52                  <1>     push rdx
   234 00002C71 4150                <1>     push r8
   235                              <1> 
   236 00002C73 0FB605(DC030000)    <1>     movzx eax, byte [kb_repeat_scancode]
   237 00002C7A 85C0                <1>     test eax, eax
   238 00002C7C 7455                <1>     jz .rep_done
   239                              <1> 
   240 00002C7E 8B0D(F0000000)      <1>     mov ecx, [tick_count]
   241 00002C84 8B1D(DE030000)      <1>     mov ebx, [kb_repeat_next_tick]
   242 00002C8A 85DB                <1>     test ebx, ebx
   243 00002C8C 7445                <1>     jz .rep_done             ; Don't repeat if next_tick is 0
   244 00002C8E 39D9                <1>     cmp ecx, ebx
   245 00002C90 7C41                <1>     jl .rep_done
   246                              <1> 
   247                              <1>     ; Advance next repeat tick
   248 00002C92 83C105              <1>     add ecx, KB_REPEAT_RATE
   249 00002C95 890D(DE030000)      <1>     mov [kb_repeat_next_tick], ecx
   250                              <1> 
   251                              <1>     ; Push repeat key event to buffer
   252 00002C9B 8B0D(D8030000)      <1>     mov ecx, [kb_tail]
   253 00002CA1 4189C8              <1>     mov r8d, ecx
   254 00002CA4 41C1E002            <1>     shl r8d, 2
   255 00002CA8 498D98[C0930200]    <1>     lea rbx, [kb_buffer + r8]
   256 00002CAF 8803                <1>     mov [rbx], al                 ; scancode
   257 00002CB1 0FB615(DD030000)    <1>     movzx edx, byte [kb_repeat_ascii]
   258 00002CB8 885301              <1>     mov [rbx + 1], dl             ; ASCII
   259 00002CBB 8A15(D1030000)      <1>     mov dl, [kb_modifiers]
   260 00002CC1 885302              <1>     mov [rbx + 2], dl             ; modifiers
   261 00002CC4 C6430301            <1>     mov byte [rbx + 3], 1         ; pressed
   262 00002CC8 FFC1                <1>     inc ecx
   263 00002CCA 83E13F              <1>     and ecx, (KB_BUFFER_SIZE - 1)
   264 00002CCD 890D(D8030000)      <1>     mov [kb_tail], ecx
   265                              <1> 
   266                              <1> .rep_done:
   267 00002CD3 4158                <1>     pop r8
   268 00002CD5 5A                  <1>     pop rdx
   269 00002CD6 59                  <1>     pop rcx
   270 00002CD7 5B                  <1>     pop rbx
   271 00002CD8 58                  <1>     pop rax
   272 00002CD9 C3                  <1>     ret
   273                              <1> 
