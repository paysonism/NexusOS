   956 00000325 66EF                <1>     out dx, ax
   957 00000327 66BACF01            <1>     mov dx, 0x1CF
   958 0000032B 6689F8              <1>     mov ax, di
   959 0000032E 66EF                <1>     out dx, ax
   960                              <1> 
