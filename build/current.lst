  4140 0000C443 4801C7              <1>     add rdi, rax
  4141 0000C446 44891C9F            <1>     mov [rdi + rbx * 4], r11d
  4142 0000C44A 5F                  <1>     pop rdi
  4143                              <1> 
  4144 0000C44B FFC1                <1>     inc ecx
  4145 0000C44D EBB4                <1>     jmp .bmp_col_loop
