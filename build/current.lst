    49                              <1> 
    50                              <1>     ; Check for extended scancode prefix
    51 00002A9B 3CE0                <1>     cmp al, 0xE0
    52 00002A9D 0F8478010000        <1>     je .extended
    53 00002AA3 3CE1                <1>     cmp al, 0xE1
    54 00002AA5 0F8479010000        <1>     je .done                 ; Ignore E1 prefix (pause key)
    55                              <1> 
    56                              <1>     ; Check if this is an extended scancode follow-up
    57 00002AAB 803D(D2030000)01    <1>     cmp byte [kb_extended], 1
    58 00002AB2 0F8422010000        <1>     je .ext_key
    59                              <1> 
    60                              <1>     ; Check if this is a release (break) code (bit 7 set)
