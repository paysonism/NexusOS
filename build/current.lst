    80                              <1> 
    81                              <1>     ; --- Setup data structures ---
    82 0000383D E8C9040000          <1>     call xhci_setup_scratchpad
    83 00003842 E809050000          <1>     call xhci_setup_dcbaa
    84 00003847 E805050000          <1>     call xhci_setup_cmd_ring
    85 0000384C E835050000          <1>     call xhci_setup_event_ring
    86                              <1> 
    87                              <1>     ; Serial: 'R' (rings set up)
