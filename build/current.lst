     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - Desktop Environment
     3                              <1> ; Data-driven icons with add/remove support
     4                              <1> ; ============================================================================
     5                              <1> bits 64
     6                              <1> 
     7                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> L3_SYSCALL_STACK_ADDR equ 0xC00000   ; Kernel-only syscall stacks
    33                              <2> 
    34                              <2> ; --- Stage 2 disk layout ---
    35                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    36                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    37                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    38                              <2> 
    39                              <2> ; --- Screen ---
    40                              <2> SCREEN_WIDTH        equ 1024
    41                              <2> SCREEN_HEIGHT       equ 768
    42                              <2> SCREEN_BPP          equ 32
    43                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    44                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    45                              <2> 
    46                              <2> 
    47                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    48                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    49                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    50                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    51                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    52                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    53                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    54                              <2> 
    55                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    56                              <2> COLOR_BLACK         equ 0x00000000
    57                              <2> COLOR_WHITE         equ 0x00FFFFFF
    58                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    59                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    60                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    61                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    62                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    63                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    64                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    65                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    66                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    67                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    68                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    69                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    70                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    71                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    72                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    73                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    74                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    75                              <2> COLOR_START_HOVER    equ 0x00338833
    76                              <2> 
    77                              <2> ; --- Window Manager ---
    78                              <2> MAX_WINDOWS         equ 8
    79                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    80                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    81                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    82                              <2> TITLEBAR_HEIGHT     equ 24
    83                              <2> BORDER_WIDTH        equ 2
    84                              <2> CLOSE_BTN_SIZE      equ 18
    85                              <2> MIN_BTN_SIZE        equ 18
    86                              <2> MIN_WINDOW_W        equ 200
    87                              <2> MIN_WINDOW_H        equ 100
    88                              <2> 
    89                              <2> ; --- Taskbar ---
    90                              <2> TASKBAR_HEIGHT      equ 36
    91                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    92                              <2> START_BTN_W         equ 70
    93                              <2> START_BTN_H         equ 28
    94                              <2> START_BTN_X         equ 4
    95                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    96                              <2> CLOCK_WIDTH         equ 64
    97                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    98                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    99                              <2> 
   100                              <2> ; --- Keyboard ---
   101                              <2> KB_BUFFER_SIZE      equ 64
   102                              <2> 
   103                              <2> ; --- Mouse ---
   104                              <2> MOUSE_BUFFER_SIZE   equ 64
   105                              <2> CURSOR_WIDTH        equ 12
   106                              <2> CURSOR_HEIGHT       equ 19
   107                              <2> 
   108                              <2> ; --- PIT ---
   109                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   110                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   111                              <2> 
   112                              <2> ; --- PIC vectors ---
   113                              <2> IRQ_BASE_MASTER     equ 32
   114                              <2> IRQ_BASE_SLAVE      equ 40
   115                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   116                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   117                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   118                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   119                              <2> 
   120                              <2> ; --- Font ---
   121                              <2> FONT_WIDTH          equ 8
   122                              <2> FONT_HEIGHT         equ 16
   123                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   124                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   125                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   126                              <2> 
   127                              <2> ; --- Window flags ---
   128                              <2> WF_VISIBLE          equ 0x01
   129                              <2> WF_FOCUSED          equ 0x02
   130                              <2> WF_DRAGGING         equ 0x04
   131                              <2> WF_MINIMIZED        equ 0x08
   132                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   133                              <2> 
   134                              <2> ; --- Mouse event types ---
   135                              <2> MEVT_MOVE           equ 1
   136                              <2> MEVT_LCLICK         equ 2
   137                              <2> MEVT_RCLICK         equ 3
   138                              <2> MEVT_LRELEASE       equ 4
   139                              <2> MEVT_RRELEASE       equ 5
   140                              <2> 
   141                              <2> ; --- Key modifier flags ---
   142                              <2> KMOD_SHIFT          equ 0x01
   143                              <2> KMOD_CTRL           equ 0x02
   144                              <2> KMOD_ALT            equ 0x04
   145                              <2> 
   146                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   147                              <2> KEY_F1              equ 0xF1
   148                              <2> KEY_F2              equ 0xF2
   149                              <2> KEY_F3              equ 0xF3
   150                              <2> KEY_F4              equ 0xF4
   151                              <2> KEY_F5              equ 0xF5
   152                              <2> KEY_F6              equ 0xF6
   153                              <2> KEY_F7              equ 0xF7
   154                              <2> KEY_F8              equ 0xF8
   155                              <2> KEY_F9              equ 0xF9
   156                              <2> KEY_F10             equ 0xFA
   157                              <2> KEY_F11             equ 0xFB
   158                              <2> KEY_F12             equ 0xFC
   159                              <2> 
   160                              <2> ; --- USB/XHCI Memory Layout ---
   161                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   162                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   163                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   164                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   165                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   166                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   167                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   168                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   169                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   170                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   171                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   172                              <2> ; Slot 2 device support
   173                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   174                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   175                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   176                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   177                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   178                              <2> 
   179                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   180                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   181                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   182                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   183                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   184                              <2> XHCI_CAP_DBOFF      equ 0x14
   185                              <2> XHCI_CAP_RTSOFF     equ 0x18
   186                              <2> 
   187                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   188                              <2> XHCI_OP_USBCMD      equ 0x00
   189                              <2> XHCI_OP_USBSTS      equ 0x04
   190                              <2> XHCI_OP_PAGESIZE     equ 0x08
   191                              <2> XHCI_OP_DNCTRL      equ 0x14
   192                              <2> XHCI_OP_CRCR_LO     equ 0x18
   193                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   194                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   195                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   196                              <2> XHCI_OP_CONFIG      equ 0x38
   197                              <2> 
   198                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   199                              <2> XHCI_PORTSC         equ 0x00
   200                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   201                              <2> 
   202                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   203                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   204                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   205                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   206                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   207                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   208                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   209                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   210                              <2> 
   211                              <2> ; --- USBCMD bits ---
   212                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   213                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   214                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   215                              <2> 
   216                              <2> ; --- USBSTS bits ---
   217                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   218                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   219                              <2> 
   220                              <2> ; --- PORTSC bits ---
   221                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   222                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   223                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   224                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   225                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   226                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   227                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   228                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   229                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   230                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   231                              <2> 
   232                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   233                              <2> TRB_NORMAL           equ (1 << 10)
   234                              <2> TRB_SETUP            equ (2 << 10)
   235                              <2> TRB_DATA             equ (3 << 10)
   236                              <2> TRB_STATUS           equ (4 << 10)
   237                              <2> TRB_LINK             equ (6 << 10)
   238                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   239                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   240                              <2> TRB_CONFIG_EP        equ (12 << 10)
   241                              <2> TRB_EVAL_CTX         equ (13 << 10)
   242                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   243                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   244                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   245                              <2> 
   246                              <2> ; --- TRB Flag Bits (dword 3) ---
   247                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   248                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   249                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   250                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   251                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   252                              <2> 
   253                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   254                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   255                              <2> TRB_TRT_OUT          equ (2 << 16)
   256                              <2> TRB_TRT_IN           equ (3 << 16)
   257                              <2> 
   258                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   259                              <2> TRB_DIR_OUT          equ (0 << 16)
   260                              <2> TRB_DIR_IN           equ (1 << 16)
   261                              <2> 
   262                              <2> ; --- Ring sizes ---
   263                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   264                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   265                              <2> 
   266                              <2> ; --- USB Standard Request Codes ---
   267                              <2> USB_REQ_GET_DESC     equ 0x06
   268                              <2> USB_REQ_SET_CONFIG   equ 0x09
   269                              <2> USB_REQ_SET_IFACE    equ 0x0B
   270                              <2> 
   271                              <2> ; --- USB HID Request Codes ---
   272                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   273                              <2> 
   274                              <2> ; --- USB Descriptor Types ---
   275                              <2> USB_DESC_DEVICE      equ 0x01
   276                              <2> USB_DESC_CONFIG      equ 0x02
   277                              <2> USB_DESC_INTERFACE   equ 0x04
   278                              <2> USB_DESC_ENDPOINT    equ 0x05
   279                              <2> USB_DESC_HID         equ 0x21
   280                              <2> 
   281                              <2> ; --- USB Endpoint Types ---
   282                              <2> USB_EP_CONTROL       equ 0
   283                              <2> USB_EP_ISOCH         equ 1
   284                              <2> USB_EP_BULK          equ 2
   285                              <2> USB_EP_INTERRUPT     equ 3
   286                              <2> 
   287                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   288                              <2> XHCI_EP_NOT_VALID    equ 0
   289                              <2> XHCI_EP_ISOCH_OUT    equ 1
   290                              <2> XHCI_EP_BULK_OUT     equ 2
   291                              <2> XHCI_EP_INT_OUT      equ 3
   292                              <2> XHCI_EP_CONTROL      equ 4
   293                              <2> XHCI_EP_ISOCH_IN     equ 5
   294                              <2> XHCI_EP_BULK_IN      equ 6
   295                              <2> XHCI_EP_INT_IN       equ 7
   296                              <2> 
   297                              <2> ; --- XHCI Port Speeds ---
   298                              <2> XHCI_SPEED_FULL      equ 1
   299                              <2> XHCI_SPEED_LOW       equ 2
   300                              <2> XHCI_SPEED_HIGH      equ 3
   301                              <2> XHCI_SPEED_SUPER     equ 4
     8                              <1> 
     9                              <1> ; Icon layout
    10                              <1> ICON_SIZE       equ 48
    11                              <1> ICON_STRIDE     equ 84         ; vertical spacing per icon (48 + 20 gap + 16 label)
    12                              <1> ICON_X          equ 24
    13                              <1> ICON_BASE_Y     equ 24
    14                              <1> MAX_DESK_ICONS  equ 8
    15                              <1> 
    16                              <1> section .text
    17                              <1> global desktop_draw_icons
    18                              <1> global desktop_handle_click
    19                              <1> global desktop_has_icon
    20                              <1> global desktop_add_icon
    21                              <1> global desktop_remove_icon
    22                              <1> global desktop_icons
    23                              <1> 
    24                              <1> extern render_rect
    25                              <1> extern render_text
    26                              <1> extern app_launch
    27                              <1> extern tb_start_menu_open
    28                              <1> 
    29                              <1> ; ============================================================================
    30                              <1> ; Draw all desktop icons from the icon table
    31                              <1> ; ============================================================================
    32                              <1> desktop_draw_icons:
    33 00008D55 53                  <1>     push rbx
    34 00008D56 4154                <1>     push r12
    35 00008D58 4155                <1>     push r13
    36 00008D5A 4156                <1>     push r14
    37                              <1> 
    38 00008D5C 4531E4              <1>     xor r12d, r12d           ; slot index
    39 00008D5F 41BE18000000        <1>     mov r14d, ICON_BASE_Y    ; current Y position
    40                              <1> 
    41                              <1> .draw_loop:
    42 00008D65 4183FC08            <1>     cmp r12d, MAX_DESK_ICONS
    43 00008D69 0F8D10020000        <1>     jge .draw_done
    44                              <1> 
    45 00008D6F 410FB68424-         <1>     movzx eax, byte [desktop_icons + r12]
    45 00008D74 [B2110000]          <1>
    46 00008D78 84C0                <1>     test al, al
    47 00008D7A 0F84F3010000        <1>     jz .draw_next             ; empty slot
    48                              <1> 
    49                              <1>     ; al = app ID. Look up icon info.
    50 00008D80 4189C5              <1>     mov r13d, eax             ; save app ID
    51 00008D83 488D1D(BA110000)    <1>     lea rbx, [icon_table]
    52                              <1>     ; index = app_id - 2 (apps start at ID 2)
    53 00008D8A 83E802              <1>     sub eax, 2
    54 00008D8D 0F88E0010000        <1>     js .draw_next
    55 00008D93 83F806              <1>     cmp eax, 6
    56 00008D96 0F8DD7010000        <1>     jge .draw_next
    57 00008D9C 6BC014              <1>     imul eax, eax, 20        ; 20 bytes per entry: 4 color + 8 label_ptr + 4 detail_color + 4 pad
    58 00008D9F 4801C3              <1>     add rbx, rax
    59                              <1> 
    60                              <1>     ; Draw icon background
    61 00008DA2 BF18000000          <1>     mov rdi, ICON_X
    62 00008DA7 4C89F6              <1>     mov rsi, r14
    63 00008DAA BA30000000          <1>     mov rdx, ICON_SIZE
    64 00008DAF B930000000          <1>     mov rcx, ICON_SIZE
    65 00008DB4 448B03              <1>     mov r8d, [rbx]            ; icon color
    66 00008DB7 E89DE9FFFF          <1>     call render_rect
    67                              <1> 
    68                              <1>     ; Draw icon detail based on app type
    69 00008DBC 4183FD02            <1>     cmp r13d, 2
    70 00008DC0 7425                <1>     je .detail_explorer
    71 00008DC2 4183FD03            <1>     cmp r13d, 3
    72 00008DC6 7441                <1>     je .detail_terminal
    73 00008DC8 4183FD04            <1>     cmp r13d, 4
    74 00008DCC 7464                <1>     je .detail_notepad
    75 00008DCE 4183FD05            <1>     cmp r13d, 5
    76 00008DD2 0F84BC000000        <1>     je .detail_settings
    77 00008DD8 4183FD06            <1>     cmp r13d, 6
    78 00008DDC 0F84F5000000        <1>     je .detail_paint
    79 00008DE2 E96E010000          <1>     jmp .draw_label
    80                              <1> 
    81                              <1> .detail_explorer:
    82                              <1>     ; Folder tab
    83 00008DE7 BF18000000          <1>     mov rdi, ICON_X
    84 00008DEC 4C89F6              <1>     mov rsi, r14
    85 00008DEF BA14000000          <1>     mov rdx, 20
    86 00008DF4 B908000000          <1>     mov rcx, 8
    87 00008DF9 41B82288AA00        <1>     mov r8d, 0x00AA8822
    88 00008DFF E855E9FFFF          <1>     call render_rect
    89 00008E04 E94C010000          <1>     jmp .draw_label
    90                              <1> 
    91                              <1> .detail_terminal:
    92                              <1>     ; Green prompt ">_"
    93 00008E09 BF20000000          <1>     mov rdi, ICON_X + 8
    94 00008E0E 67418D7610          <1>     lea esi, [r14d + 16]
    95 00008E13 48BA-               <1>     mov rdx, szPromptIcon
    95 00008E15 [5E12000000000000]  <1>
    96 00008E1D B900FF0000          <1>     mov ecx, 0x0000FF00
    97 00008E22 41B822222200        <1>     mov r8d, 0x00222222
    98 00008E28 E831E9FFFF          <1>     call render_text
    99 00008E2D E923010000          <1>     jmp .draw_label
   100                              <1> 
   101                              <1> .detail_notepad:
   102                              <1>     ; Lines on notepad
   103 00008E32 BF20000000          <1>     mov rdi, ICON_X + 8
   104 00008E37 67418D760C          <1>     lea esi, [r14d + 12]
   105 00008E3C BA20000000          <1>     mov rdx, 32
   106 00008E41 B902000000          <1>     mov rcx, 2
   107 00008E46 41B8CCCCCC00        <1>     mov r8d, 0x00CCCCCC
   108 00008E4C E808E9FFFF          <1>     call render_rect
   109 00008E51 BF20000000          <1>     mov rdi, ICON_X + 8
   110 00008E56 67418D7614          <1>     lea esi, [r14d + 20]
   111 00008E5B BA1C000000          <1>     mov rdx, 28
   112 00008E60 B902000000          <1>     mov rcx, 2
   113 00008E65 41B8CCCCCC00        <1>     mov r8d, 0x00CCCCCC
   114 00008E6B E8E9E8FFFF          <1>     call render_rect
   115 00008E70 BF20000000          <1>     mov rdi, ICON_X + 8
   116 00008E75 67418D761C          <1>     lea esi, [r14d + 28]
   117 00008E7A BA20000000          <1>     mov rdx, 32
   118 00008E7F B902000000          <1>     mov rcx, 2
   119 00008E84 41B8CCCCCC00        <1>     mov r8d, 0x00CCCCCC
   120 00008E8A E8CAE8FFFF          <1>     call render_rect
   121 00008E8F E9C1000000          <1>     jmp .draw_label
   122                              <1> 
   123                              <1> .detail_settings:
   124                              <1>     ; Gear-like crosshair
   125 00008E94 BF2C000000          <1>     mov rdi, ICON_X + 20
   126 00008E99 67418D7608          <1>     lea esi, [r14d + 8]
   127 00008E9E BA08000000          <1>     mov rdx, 8
   128 00008EA3 B920000000          <1>     mov rcx, 32
   129 00008EA8 41B8AAAAAA00        <1>     mov r8d, 0x00AAAAAA
   130 00008EAE E8A6E8FFFF          <1>     call render_rect
   131 00008EB3 BF20000000          <1>     mov rdi, ICON_X + 8
   132 00008EB8 67418D7614          <1>     lea esi, [r14d + 20]
   133 00008EBD BA20000000          <1>     mov rdx, 32
   134 00008EC2 B908000000          <1>     mov rcx, 8
   135 00008EC7 41B8AAAAAA00        <1>     mov r8d, 0x00AAAAAA
   136 00008ECD E887E8FFFF          <1>     call render_rect
   137 00008ED2 E97E000000          <1>     jmp .draw_label
   138                              <1> 
   139                              <1> .detail_paint:
   140                              <1>     ; Color swatch
   141 00008ED7 BF20000000          <1>     mov rdi, ICON_X + 8
   142 00008EDC 67418D7608          <1>     lea esi, [r14d + 8]
   143 00008EE1 BA0E000000          <1>     mov rdx, 14
   144 00008EE6 B90E000000          <1>     mov rcx, 14
   145 00008EEB 41B80000FF00        <1>     mov r8d, 0x00FF0000
   146 00008EF1 E863E8FFFF          <1>     call render_rect
   147 00008EF6 BF32000000          <1>     mov rdi, ICON_X + 26
   148 00008EFB 67418D7608          <1>     lea esi, [r14d + 8]
   149 00008F00 BA0E000000          <1>     mov rdx, 14
   150 00008F05 B90E000000          <1>     mov rcx, 14
   151 00008F0A 41B8FF000000        <1>     mov r8d, 0x000000FF
   152 00008F10 E844E8FFFF          <1>     call render_rect
   153 00008F15 BF20000000          <1>     mov rdi, ICON_X + 8
   154 00008F1A 67418D761A          <1>     lea esi, [r14d + 26]
   155 00008F1F BA0E000000          <1>     mov rdx, 14
   156 00008F24 B90E000000          <1>     mov rcx, 14
   157 00008F29 41B800FF0000        <1>     mov r8d, 0x0000FF00
   158 00008F2F E825E8FFFF          <1>     call render_rect
   159 00008F34 BF32000000          <1>     mov rdi, ICON_X + 26
   160 00008F39 67418D761A          <1>     lea esi, [r14d + 26]
   161 00008F3E BA0E000000          <1>     mov rdx, 14
   162 00008F43 B90E000000          <1>     mov rcx, 14
   163 00008F48 41B800FFFF00        <1>     mov r8d, 0x00FFFF00
   164 00008F4E E806E8FFFF          <1>     call render_rect
   165 00008F53 EB00                <1>     jmp .draw_label
   166                              <1> 
   167                              <1> .draw_label:
   168                              <1>     ; Draw label below icon
   169 00008F55 BF18000000          <1>     mov rdi, ICON_X
   170 00008F5A 67418D7634          <1>     lea esi, [r14d + ICON_SIZE + 4]
   171 00008F5F 488B5304            <1>     mov rdx, [rbx + 4]       ; label string pointer
   172 00008F63 B9FFFFFF00          <1>     mov ecx, COLOR_TEXT_WHITE
   173 00008F68 41B8FFFFFFFF        <1>     mov r8d, -1               ; transparent bg
   174 00008F6E E8EBE7FFFF          <1>     call render_text
   175                              <1> 
   176                              <1> .draw_next:
   177 00008F73 41FFC4              <1>     inc r12d
   178 00008F76 4183C654            <1>     add r14d, ICON_STRIDE
   179 00008F7A E9E6FDFFFF          <1>     jmp .draw_loop
   180                              <1> 
   181                              <1> .draw_done:
   182 00008F7F 415E                <1>     pop r14
   183 00008F81 415D                <1>     pop r13
   184 00008F83 415C                <1>     pop r12
   185 00008F85 5B                  <1>     pop rbx
   186 00008F86 C3                  <1>     ret
   187                              <1> 
   188                              <1> ; ============================================================================
   189                              <1> ; Handle desktop clicks: RDI=mouseX, RSI=mouseY
   190                              <1> ; Returns RAX: 0=not handled, 1=handled
   191                              <1> ; ============================================================================
   192                              <1> desktop_handle_click:
   193 00008F87 53                  <1>     push rbx
   194 00008F88 4154                <1>     push r12
   195 00008F8A 4155                <1>     push r13
   196                              <1> 
   197                              <1>     ; Close start menu
   198 00008F8C C605(97110000)00    <1>     mov byte [tb_start_menu_open], 0
   199                              <1> 
   200                              <1>     ; Check if click is in icon column
   201 00008F93 83FF18              <1>     cmp edi, ICON_X
   202 00008F96 7C4D                <1>     jl .click_none
   203 00008F98 83FF48              <1>     cmp edi, ICON_X + ICON_SIZE
   204 00008F9B 7F48                <1>     jg .click_none
   205                              <1> 
   206                              <1>     ; Find which icon slot
   207 00008F9D 4531E4              <1>     xor r12d, r12d
   208 00008FA0 41BD18000000        <1>     mov r13d, ICON_BASE_Y
   209                              <1> 
   210                              <1> .click_loop:
   211 00008FA6 4183FC08            <1>     cmp r12d, MAX_DESK_ICONS
   212 00008FAA 7D39                <1>     jge .click_none
   213                              <1> 
   214 00008FAC 410FB68424-         <1>     movzx eax, byte [desktop_icons + r12]
   214 00008FB1 [B2110000]          <1>
   215 00008FB5 84C0                <1>     test al, al
   216 00008FB7 7423                <1>     jz .click_next
   217                              <1> 
   218                              <1>     ; Check Y range (icon + label area)
   219 00008FB9 4439EE              <1>     cmp esi, r13d
   220 00008FBC 7C1E                <1>     jl .click_next
   221 00008FBE 67418D4D44          <1>     lea ecx, [r13d + ICON_SIZE + 20]
   222 00008FC3 39CE                <1>     cmp esi, ecx
   223 00008FC5 7F15                <1>     jg .click_next
   224                              <1> 
   225                              <1>     ; Hit! Launch this app
   226 00008FC7 410FB6BC24-         <1>     movzx edi, byte [desktop_icons + r12]
   226 00008FCC [B2110000]          <1>
   227 00008FD0 E803060000          <1>     call app_launch
   228 00008FD5 B801000000          <1>     mov rax, 1
   229 00008FDA EB0B                <1>     jmp .click_ret
   230                              <1> 
   231                              <1> .click_next:
   232 00008FDC 41FFC4              <1>     inc r12d
   233 00008FDF 4183C554            <1>     add r13d, ICON_STRIDE
   234 00008FE3 EBC1                <1>     jmp .click_loop
   235                              <1> 
   236                              <1> .click_none:
   237 00008FE5 31C0                <1>     xor eax, eax
   238                              <1> .click_ret:
   239 00008FE7 415D                <1>     pop r13
   240 00008FE9 415C                <1>     pop r12
   241 00008FEB 5B                  <1>     pop rbx
   242 00008FEC C3                  <1>     ret
   243                              <1> 
   244                              <1> ; ============================================================================
   245                              <1> ; desktop_has_icon: EDI=app_id -> EAX=1 if on desktop, 0 if not
   246                              <1> ; ============================================================================
   247                              <1> desktop_has_icon:
   248 00008FED 31C9                <1>     xor ecx, ecx
   249                              <1> .has_loop:
   250 00008FEF 83F908              <1>     cmp ecx, MAX_DESK_ICONS
   251 00008FF2 7D13                <1>     jge .has_no
   252 00008FF4 4038B9[B2110000]    <1>     cmp byte [desktop_icons + rcx], dil
   253 00008FFB 7404                <1>     je .has_yes
   254 00008FFD FFC1                <1>     inc ecx
   255 00008FFF EBEE                <1>     jmp .has_loop
   256                              <1> .has_yes:
   257 00009001 B801000000          <1>     mov eax, 1
   258 00009006 C3                  <1>     ret
   259                              <1> .has_no:
   260 00009007 31C0                <1>     xor eax, eax
   261 00009009 C3                  <1>     ret
   262                              <1> 
   263                              <1> ; ============================================================================
   264                              <1> ; desktop_add_icon: EDI=app_id -> adds to first empty slot
   265                              <1> ; ============================================================================
   266                              <1> desktop_add_icon:
   267                              <1>     ; First check if already present
   268 0000900A 57                  <1>     push rdi
   269 0000900B E8DDFFFFFF          <1>     call desktop_has_icon
   270 00009010 5F                  <1>     pop rdi
   271 00009011 85C0                <1>     test eax, eax
   272 00009013 751B                <1>     jnz .add_done             ; already there
   273                              <1> 
   274 00009015 31C9                <1>     xor ecx, ecx
   275                              <1> .add_loop:
   276 00009017 83F908              <1>     cmp ecx, MAX_DESK_ICONS
   277 0000901A 7D14                <1>     jge .add_done             ; no room
   278 0000901C 80B9[B2110000]00    <1>     cmp byte [desktop_icons + rcx], 0
   279 00009023 7404                <1>     je .add_found
   280 00009025 FFC1                <1>     inc ecx
   281 00009027 EBEE                <1>     jmp .add_loop
   282                              <1> .add_found:
   283 00009029 4088B9[B2110000]    <1>     mov byte [desktop_icons + rcx], dil
   284                              <1> .add_done:
   285 00009030 C3                  <1>     ret
   286                              <1> 
   287                              <1> ; ============================================================================
   288                              <1> ; desktop_remove_icon: EDI=app_id -> removes from desktop
   289                              <1> ; ============================================================================
   290                              <1> desktop_remove_icon:
   291 00009031 31C9                <1>     xor ecx, ecx
   292                              <1> .rem_loop:
   293 00009033 83F908              <1>     cmp ecx, MAX_DESK_ICONS
   294 00009036 7D3E                <1>     jge .rem_done
   295 00009038 4038B9[B2110000]    <1>     cmp byte [desktop_icons + rcx], dil
   296 0000903F 7404                <1>     je .rem_found
   297 00009041 FFC1                <1>     inc ecx
   298 00009043 EBEE                <1>     jmp .rem_loop
   299                              <1> .rem_found:
   300 00009045 C681[B2110000]00    <1>     mov byte [desktop_icons + rcx], 0
   301                              <1>     ; Compact: shift remaining entries down
   302 0000904C 678D5101            <1>     lea edx, [ecx + 1]
   303                              <1> .compact:
   304 00009050 83FA08              <1>     cmp edx, MAX_DESK_ICONS
   305 00009053 7D1A                <1>     jge .compact_zero
   306 00009055 0FB682[B2110000]    <1>     movzx eax, byte [desktop_icons + rdx]
   307 0000905C 8881[B2110000]      <1>     mov byte [desktop_icons + rcx], al
   308 00009062 C682[B2110000]00    <1>     mov byte [desktop_icons + rdx], 0
   309 00009069 FFC1                <1>     inc ecx
   310 0000906B FFC2                <1>     inc edx
   311 0000906D EBE1                <1>     jmp .compact
   312                              <1> .compact_zero:
   313 0000906F C681[B2110000]00    <1>     mov byte [desktop_icons + rcx], 0
   314                              <1> .rem_done:
   315 00009076 C3                  <1>     ret
