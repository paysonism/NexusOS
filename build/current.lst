    49                              <1> section .text
    50                              <1> global usb_hid_init
    51                              <1> global usb_hid_init_same_ctrl
    52                              <1> global usb_hid_init_slot2
    53                              <1> global usb_poll_mouse
    54                              <1> 
    55                              <1> ; ============================================================================
    56                              <1> ; usb_hid_init_same_ctrl - Re-enumerate on the currently active XHCI controller
    57                              <1> ; Used for hot-plug: device was unplugged and re-plugged on the same port/controller
    58                              <1> ; ============================================================================
    59                              <1> usb_hid_init_same_ctrl:
    60                              <1>     ; Restore xhci_pci_search_start to the position of the current controller
    61                              <1>     ; so xhci_pci_find will re-find the same one
    62 0000478A 8B05(50050000)      <1>     mov eax, [xhci_pci_this_start]
    63 00004790 8905(4C050000)      <1>     mov [xhci_pci_search_start], eax
    64 00004796 EB0A                <1>     jmp usb_hid_init_body
    65                              <1> 
    66                              <1> ; ============================================================================
    67                              <1> ; usb_hid_init - Initialize USB HID Mouse (full scan from controller 0)
    68                              <1> ; ============================================================================
    69                              <1> usb_hid_init:
    70                              <1>     ; Reset PCI search to beginning so we scan all controllers fresh
    71 00004798 C705(4C050000)0000- <1>     mov dword [xhci_pci_search_start], 0
    71 000047A0 0000                <1>
    72                              <1> 
    73                              <1> usb_hid_init_body:
    74 000047A2 53                  <1>     push rbx
    75 000047A3 51                  <1>     push rcx
    76 000047A4 52                  <1>     push rdx
    77 000047A5 56                  <1>     push rsi
    78 000047A6 57                  <1>     push rdi
    79 000047A7 55                  <1>     push rbp
    80                              <1> 
    81                              <1>     ; Reset active flag
    82 000047A8 C605(E6070000)00    <1>     mov byte [usb_mouse_active], 0
    83 000047AF C605(F8070000)00    <1>     mov byte [usb_use_parsed], 0
    84 000047B6 C605(F9070000)00    <1>     mov byte [usb_accept_keyboard], 0
    85                              <1> 
    86                              <1>     ; 1. Try XHCI controllers until one succeeds with a HID endpoint
    87                              <1>     ;    xhci_pci_find continues from where it left off each call
