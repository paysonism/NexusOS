   627                              <1> ; fat16_change_dir - Change current directory (load into ROOT_CACHE)
   628                              <1> ; ax = cluster number (0 = root)
   629                              <1> ; Returns: eax = 0 on success
   630                              <1> ; ============================================================================
   631                              <1> global fat16_change_dir
   632                              <1> fat16_change_dir:
   633 00007645 53                  <1>     push rbx
   634 00007646 51                  <1>     push rcx
   635 00007647 52                  <1>     push rdx
   636 00007648 57                  <1>     push rdi
   637 00007649 56                  <1>     push rsi
   638 0000764A 4150                <1>     push r8
   639 0000764C 4151                <1>     push r9
   640 0000764E 4152                <1>     push r10
   641                              <1> 
   642 00007650 0FB7D8              <1>     movzx ebx, ax          ; cluster
   643 00007653 66891D(CA0D0000)    <1>     mov [fat16_cur_dir_cluster], bx
   644                              <1>     
   645                              <1>     ; Cluster 0 -> Load Root Directory
   646 0000765A 85DB                <1>     test ebx, ebx
   647 0000765C 7528                <1>     jnz .cd_subdir
   648                              <1>     
   649                              <1>     ; Load Root (contiguous)
   650 0000765E 8B3D(BA0D0000)      <1>     mov edi, [fat16_root_start_sect]
   651 00007664 81C740010000        <1>     add edi, FAT16_PART_LBA
   652 0000766A BE0010D100          <1>     mov rsi, FAT16_ROOT_CACHE
   653 0000766F 8B15(BE0D0000)      <1>     mov edx, [fat16_root_sectors]
   654 00007675 E898BFFFFF          <1>     call ata_read_sectors
   655                              <1>     
   656                              <1>     ; Reset file count
   657 0000767A E842FCFFFF          <1>     call fat16_count_root_files
   658 0000767F 31C0                <1>     xor eax, eax
   659 00007681 E982000000          <1>     jmp .cd_done
   660                              <1> 
   661                              <1> .cd_subdir:
   662                              <1>     ; Subdirectory: Read cluster chain into FAT16_ROOT_CACHE
   663                              <1>     ; Max entries restricted by ROOT_CACHE size (16KB = 512 entries)
   664                              <1>     ; Clear cache first
   665 00007686 BF0010D100          <1>     mov rdi, FAT16_ROOT_CACHE
   666 0000768B B900100000          <1>     mov ecx, 16384 / 4
   667 00007690 31C0                <1>     xor eax, eax
   668 00007692 F3AB                <1>     rep stosd
   669                              <1>     
   670 00007694 BE0010D100          <1>     mov rsi, FAT16_ROOT_CACHE ; Dest
   671 00007699 4531D2              <1>     xor r10d, r10d            ; Total bytes read
   672                              <1>     
   673                              <1> .cd_loop:
   674 0000769C 83FB02              <1>     cmp ebx, 2
   675 0000769F 7C60                <1>     jl .cd_finish
   676 000076A1 81FBF8FF0000        <1>     cmp ebx, 0xFFF8
   677 000076A7 7D58                <1>     jge .cd_finish
   678                              <1>     
   679                              <1>     ; Read cluster
   680 000076A9 89D8                <1>     mov eax, ebx
   681 000076AB 83E802              <1>     sub eax, 2
   682 000076AE 0FB615(AE0D0000)    <1>     movzx edx, byte [fat16_sect_per_clus]
   683 000076B5 0FAFC2              <1>     imul eax, edx
   684 000076B8 0305(C20D0000)      <1>     add eax, [fat16_data_start_sect]
   685 000076BE 0540010000          <1>     add eax, FAT16_PART_LBA
   686                              <1>     
   687 000076C3 89C7                <1>     mov edi, eax
   688 000076C5 0FB615(AE0D0000)    <1>     movzx edx, byte [fat16_sect_per_clus]
   689                              <1>     
   690                              <1>     ; Safety check for cache overflow
   691 000076CC 89D0                <1>     mov eax, edx
   692 000076CE C1E009              <1>     shl eax, 9 ; bytes to read
   693 000076D1 67458D0C02          <1>     lea r9d, [r10d + eax]
   694 000076D6 4181F900400000      <1>     cmp r9d, 16384
   695 000076DD 7F22                <1>     jg .cd_finish ; Truncate if too big
   696                              <1>     
   697 000076DF E82EBFFFFF          <1>     call ata_read_sectors
   698                              <1>     
   699                              <1>     ; Advance ptr
   700 000076E4 0FB605(AE0D0000)    <1>     movzx eax, byte [fat16_sect_per_clus]
   701 000076EB C1E009              <1>     shl eax, 9
   702 000076EE 4801C6              <1>     add rsi, rax
   703 000076F1 4101C2              <1>     add r10d, eax
   704                              <1>     
   705                              <1>     ; Next cluster
   706 000076F4 89D8                <1>     mov eax, ebx
   707 000076F6 D1E0                <1>     shl eax, 1
   708 000076F8 0FB7980010D000      <1>     movzx ebx, word [FAT16_FAT_CACHE + rax]
   709 000076FF EB9B                <1>     jmp .cd_loop
   710                              <1> 
   711                              <1> .cd_finish:
   712                              <1>     ; Recount files in new view
   713 00007701 E8BBFBFFFF          <1>     call fat16_count_root_files
   714 00007706 31C0                <1>     xor eax, eax
   715                              <1> 
   716                              <1> .cd_done:
   717 00007708 415A                <1>     pop r10
   718                              <1> 
   719 0000770A 4159                <1>     pop r9
   720 0000770C 4158                <1>     pop r8
   721 0000770E 5E                  <1>     pop rsi
   722 0000770F 5F                  <1>     pop rdi
   723 00007710 5A                  <1>     pop rdx
   724 00007711 59                  <1>     pop rcx
   725 00007712 5B                  <1>     pop rbx
   726 00007713 C3                  <1>     ret
   727                              <1> 
