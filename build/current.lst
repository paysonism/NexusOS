  4110                              <1> 
  4111 0000C3FA 0FAF3D(56020000)    <1>     imul edi, [scr_pitch]    ; Y * pitch (use variable pitch)
  4112                              <1> 
  4113 0000C401 31C9                <1>     xor ecx, ecx              ; X counter
  4114                              <1> .bmp_col_loop:
  4115 0000C403 3B0D(751E0000)      <1>     cmp ecx, [bmp_width]
  4116 0000C409 7D44                <1>     jge .bmp_row_done
  4117                              <1> 
  4118                              <1>     ; Dest pixel X = window_X + border + ecx
  4119 0000C40B 4489E3              <1>     mov ebx, r12d
  4120 0000C40E 83C302              <1>     add ebx, BORDER_WIDTH
  4121 0000C411 01CB                <1>     add ebx, ecx
  4122 0000C413 81FB00040000        <1>     cmp ebx, SCREEN_WIDTH
  4123 0000C419 7D34                <1>     jge .bmp_row_done
  4124                              <1> 
  4125                              <1>     ; Read BGR from source
  4126 0000C41B 440FB60E            <1>     movzx r9d, byte [rsi]      ; B
  4127 0000C41F 440FB65601          <1>     movzx r10d, byte [rsi + 1] ; G
