   275 000039E1 B800000080          <1>     mov eax, 0x80000000
   276 000039E6 4489E3              <1>     mov ebx, r12d
   277 000039E9 C1E310              <1>     shl ebx, 16
   278 000039EC 09D8                <1>     or eax, ebx
   279 000039EE 4489F3              <1>     mov ebx, r14d
   280 000039F1 C1E30B              <1>     shl ebx, 11
   281 000039F4 09D8                <1>     or eax, ebx
   282 000039F6 4489EB              <1>     mov ebx, r13d
   283 000039F9 C1E308              <1>     shl ebx, 8
   284 000039FC 09D8                <1>     or eax, ebx
   285 000039FE 8905(48050000)      <1>     mov [xhci_pci_addr], eax
   286                              <1> 
   287                              <1>     ; Read BAR0 (offset 0x10)
   288 00003A04 8B05(48050000)      <1>     mov eax, [xhci_pci_addr]
   289 00003A0A 83C810              <1>     or eax, 0x10
   290 00003A0D E889FDFFFF          <1>     call pci_read_conf_dword
   291 00003A12 89C3                <1>     mov ebx, eax
   292 00003A14 83E306              <1>     and ebx, 0x06
   293 00003A17 89C1                <1>     mov ecx, eax
   294 00003A19 83E1F0              <1>     and ecx, 0xFFFFFFF0
   295 00003A1C 48890D(54050000)    <1>     mov [xhci_mmio_base], rcx
   296                              <1> 
   297 00003A23 80FB04              <1>     cmp bl, 0x04
   298 00003A26 7519                <1>     jne .bar_done
   299 00003A28 8B05(48050000)      <1>     mov eax, [xhci_pci_addr]
   300 00003A2E 83C814              <1>     or eax, 0x14
   301 00003A31 E865FDFFFF          <1>     call pci_read_conf_dword
   302 00003A36 48C1E020            <1>     shl rax, 32
   303 00003A3A 480905(54050000)    <1>     or [xhci_mmio_base], rax
   304                              <1> 
   305                              <1> .bar_done:
   306                              <1>     ; Enable bus mastering + memory space
   307 00003A41 8B05(48050000)      <1>     mov eax, [xhci_pci_addr]
   308 00003A47 83C804              <1>     or eax, 0x04
   309 00003A4A E84CFDFFFF          <1>     call pci_read_conf_dword
   310 00003A4F 83C806              <1>     or eax, 0x06
   311 00003A52 89C1                <1>     mov ecx, eax
   312 00003A54 8B05(48050000)      <1>     mov eax, [xhci_pci_addr]
   313 00003A5A 83C804              <1>     or eax, 0x04
   314 00003A5D E84BFDFFFF          <1>     call pci_write_conf_dword
   315                              <1> 
   316                              <1>     ; Print MMIO base low 32 bits to serial for debug
   317 00003A62 50                  <1>     push rax
   318 00003A63 52                  <1>     push rdx
   319 00003A64 8B05(54050000)      <1>     mov eax, [xhci_mmio_base]
   320 00003A6A 66BAF803            <1>     mov dx, 0x3F8
   321 00003A6E E8E60C0000          <1>     call serial_hex32
   322 00003A73 5A                  <1>     pop rdx
   323 00003A74 58                  <1>     pop rax
   324                              <1> 
   325 00003A75 B801000000          <1>     mov eax, 1
   326 00003A7A EB2E                <1>     jmp .pci_ret
   327                              <1> 
   328                              <1> .next_func_pop:
   329 00003A7C 58                  <1>     pop rax
   330 00003A7D 41FFC5              <1>     inc r13d
   331 00003A80 E9C1FEFFFF          <1>     jmp .func_loop
   332                              <1> 
   333                              <1> .next_dev:
   334 00003A85 41FFC6              <1>     inc r14d
   335 00003A88 4531ED              <1>     xor r13d, r13d
   336 00003A8B E9ACFEFFFF          <1>     jmp .dev_loop
   337                              <1> 
   338                              <1> .next_bus:
   339 00003A90 41FFC4              <1>     inc r12d
   340 00003A93 4531F6              <1>     xor r14d, r14d
   341 00003A96 4531ED              <1>     xor r13d, r13d
   342 00003A99 E991FEFFFF          <1>     jmp .bus_loop
   343                              <1> 
   344                              <1> .not_found:
   345                              <1>     ; Reset search start for next full scan
   346 00003A9E C705(4C050000)0000- <1>     mov dword [xhci_pci_search_start], 0
   346 00003AA6 0000                <1>
   347 00003AA8 31C0                <1>     xor eax, eax
   348                              <1> .pci_ret:
   349 00003AAA 5A                  <1>     pop rdx
   350 00003AAB 59                  <1>     pop rcx
   351 00003AAC 5B                  <1>     pop rbx
   352 00003AAD C3                  <1>     ret
   353                              <1> 
   354                              <1> ; ============================================================================
   355                              <1> ; xhci_probe - Find XHCI controller via PCI and read capabilities.
   356                              <1> ; Does NOT reset or initialise the controller.
   357                              <1> ; Sets xhci_op_base and xhci_max_ports so port registers can be polled.
   358                              <1> ; Returns: EAX = 1 found, 0 not found.
   359                              <1> ; ============================================================================
   360                              <1> global xhci_probe
   361                              <1> xhci_probe:
   362 00003AAE 53                  <1>     push rbx
   363 00003AAF 51                  <1>     push rcx
   364 00003AB0 52                  <1>     push rdx
   365 00003AB1 56                  <1>     push rsi
   366 00003AB2 57                  <1>     push rdi
   367 00003AB3 55                  <1>     push rbp
   368 00003AB4 4154                <1>     push r12
   369 00003AB6 4155                <1>     push r13
   370 00003AB8 4156                <1>     push r14
   371 00003ABA 4157                <1>     push r15
   372 00003ABC C705(4C050000)0000- <1>     mov dword [xhci_pci_search_start], 0
   372 00003AC4 0000                <1>
   373 00003AC6 E837FEFFFF          <1>     call xhci_pci_find
   374 00003ACB 85C0                <1>     test eax, eax
   375 00003ACD 740C                <1>     jz .not_found
   376 00003ACF E818000000          <1>     call xhci_read_caps
   377 00003AD4 B801000000          <1>     mov eax, 1
   378 00003AD9 EB02                <1>     jmp .done
   379                              <1> .not_found:
   380 00003ADB 31C0                <1>     xor eax, eax
   381                              <1> .done:
   382 00003ADD 415F                <1>     pop r15
   383 00003ADF 415E                <1>     pop r14
   384 00003AE1 415D                <1>     pop r13
   385 00003AE3 415C                <1>     pop r12
   386 00003AE5 5D                  <1>     pop rbp
   387 00003AE6 5F                  <1>     pop rdi
   388 00003AE7 5E                  <1>     pop rsi
   389 00003AE8 5A                  <1>     pop rdx
   390 00003AE9 59                  <1>     pop rcx
   391 00003AEA 5B                  <1>     pop rbx
   392 00003AEB C3                  <1>     ret
   393                              <1> 
   394                              <1> ; ============================================================================
   395                              <1> ; xhci_read_caps - Read capability registers
   396                              <1> ; ============================================================================
   397                              <1> xhci_read_caps:
   398 00003AEC 56                  <1>     push rsi
   399                              <1> 
   400 00003AED 488B35(54050000)    <1>     mov rsi, [xhci_mmio_base]
   401                              <1> 
   402                              <1>     ; CAPLENGTH (byte at offset 0)
   403 00003AF4 0FB606              <1>     movzx eax, byte [rsi + XHCI_CAP_CAPLENGTH]
   404 00003AF7 8805(75050000)      <1>     mov [xhci_cap_length], al
   405                              <1> 
   406                              <1>     ; OpBase = MMIO + CAPLENGTH
   407 00003AFD 480FB605(75050000)  <1>     movzx rax, byte [xhci_cap_length]
   408 00003B05 4801F0              <1>     add rax, rsi
   409 00003B08 488905(5C050000)    <1>     mov [xhci_op_base], rax
   410                              <1> 
   411                              <1>     ; HCSPARAMS1
   412 00003B0F 8B4604              <1>     mov eax, [rsi + XHCI_CAP_HCSPARAMS1]
   413 00003B12 8905(7E050000)      <1>     mov [xhci_hcsparams1], eax
   414 00003B18 25FF000000          <1>     and eax, 0xFF                 ; MaxSlots (bits 0-7)
   415 00003B1D 8805(76050000)      <1>     mov [xhci_max_slots], al
   416 00003B23 8B05(7E050000)      <1>     mov eax, [xhci_hcsparams1]
   417 00003B29 C1E818              <1>     shr eax, 24                   ; MaxPorts (bits 24-31)
   418 00003B2C 8805(77050000)      <1>     mov [xhci_max_ports], al
   419                              <1> 
   420                              <1>     ; HCSPARAMS2
   421 00003B32 8B4608              <1>     mov eax, [rsi + XHCI_CAP_HCSPARAMS2]
   422 00003B35 8905(82050000)      <1>     mov [xhci_hcsparams2], eax
   423                              <1>     ; Scratchpad count = (bits 25-31) << 5 | (bits 21-25)
   424 00003B3B 89C3                <1>     mov ebx, eax
   425 00003B3D C1EB1B              <1>     shr ebx, 27                   ; High 5 bits (bits 31-27)
   426 00003B40 89C1                <1>     mov ecx, eax
   427 00003B42 C1E915              <1>     shr ecx, 21
   428 00003B45 83E11F              <1>     and ecx, 0x1F                 ; Low 5 bits (bits 25-21)
   429 00003B48 C1E305              <1>     shl ebx, 5
   430 00003B4B 09CB                <1>     or ebx, ecx
   431 00003B4D 881D(78050000)      <1>     mov [xhci_scratchpad_count], bl
   432                              <1> 
   433                              <1>     ; HCCPARAMS1
   434 00003B53 8B4610              <1>     mov eax, [rsi + XHCI_CAP_HCCPARAMS1]
   435 00003B56 8905(86050000)      <1>     mov [xhci_hccparams1], eax
   436                              <1>     ; Context size: bit 2 = CSZ (0=32 bytes, 1=64 bytes)
   437 00003B5C A904000000          <1>     test eax, 0x04
   438 00003B61 7409                <1>     jz .ctx_32
   439 00003B63 C605(79050000)40    <1>     mov byte [xhci_ctx_size], 64
   440 00003B6A EB07                <1>     jmp .ctx_done
   441                              <1> .ctx_32:
   442 00003B6C C605(79050000)20    <1>     mov byte [xhci_ctx_size], 32
   443                              <1> .ctx_done:
   444                              <1> 
   445                              <1>     ; DBOFF
   446 00003B73 8B4614              <1>     mov eax, [rsi + XHCI_CAP_DBOFF]
   447 00003B76 83E0FC              <1>     and eax, ~0x03                ; Clear low 2 bits
   448 00003B79 4801F0              <1>     add rax, rsi
   449 00003B7C 488905(64050000)    <1>     mov [xhci_db_base], rax
   450                              <1> 
   451                              <1>     ; RTSOFF
   452 00003B83 8B4618              <1>     mov eax, [rsi + XHCI_CAP_RTSOFF]
   453 00003B86 83E0E0              <1>     and eax, ~0x1F                ; Clear low 5 bits
   454 00003B89 4801F0              <1>     add rax, rsi
   455 00003B8C 488905(6C050000)    <1>     mov [xhci_rt_base], rax
   456                              <1> 
   457 00003B93 5E                  <1>     pop rsi
   458 00003B94 C3                  <1>     ret
   459                              <1> 
   460                              <1> ; ============================================================================
   461                              <1> ; xhci_take_ownership - Take XHCI from BIOS via Legacy Support capability
   462                              <1> ; ============================================================================
   463                              <1> xhci_take_ownership:
   464 00003B95 56                  <1>     push rsi
   465 00003B96 51                  <1>     push rcx
   466 00003B97 50                  <1>     push rax
   467                              <1> 
   468 00003B98 488B35(54050000)    <1>     mov rsi, [xhci_mmio_base]
   469 00003B9F 8B05(86050000)      <1>     mov eax, [xhci_hccparams1]
   470 00003BA5 C1E810              <1>     shr eax, 16                   ; xECP offset in dwords
   471 00003BA8 C1E002              <1>     shl eax, 2                    ; Convert to bytes
   472 00003BAB 85C0                <1>     test eax, eax
   473 00003BAD 7475                <1>     jz .own_done                  ; No extended capabilities
   474                              <1> 
   475 00003BAF 4801C6              <1>     add rsi, rax                  ; RSI = first extended cap
   476                              <1> 
   477                              <1> .cap_loop:
   478 00003BB2 8B06                <1>     mov eax, [rsi]
   479 00003BB4 89C1                <1>     mov ecx, eax
   480 00003BB6 81E1FF000000        <1>     and ecx, 0xFF                 ; Capability ID
   481 00003BBC 83F901              <1>     cmp ecx, 1                    ; USB Legacy Support
   482 00003BBF 7414                <1>     je .found_legacy
   483                              <1> 
   484                              <1>     ; Next capability
   485 00003BC1 C1E808              <1>     shr eax, 8
   486 00003BC4 25FF000000          <1>     and eax, 0xFF                 ; Next offset (in dwords)
   487 00003BC9 85C0                <1>     test eax, eax
   488 00003BCB 7457                <1>     jz .own_done                  ; End of list
   489 00003BCD C1E002              <1>     shl eax, 2
   490 00003BD0 4801C6              <1>     add rsi, rax
   491 00003BD3 EBDD                <1>     jmp .cap_loop
   492                              <1> 
   493                              <1> .found_legacy:
   494                              <1>     ; Check if BIOS owns it
   495 00003BD5 8B06                <1>     mov eax, [rsi]
   496 00003BD7 A900000100          <1>     test eax, (1 << 16)          ; BIOS Owned Semaphore
   497 00003BDC 7446                <1>     jz .own_done                  ; BIOS doesn't own it
   498                              <1> 
   499                              <1>     ; Set OS Owned Semaphore (bit 24)
   500 00003BDE 0D00000001          <1>     or eax, (1 << 24)
   501 00003BE3 8906                <1>     mov [rsi], eax
   502                              <1> 
   503                              <1>     ; Wait for BIOS to release (bit 16 = 0) - up to 100ms
   504 00003BE5 52                  <1>     push rdx
   505 00003BE6 51                  <1>     push rcx
   506 00003BE7 488B15(F0000000)    <1>     mov rdx, [tick_count]
   507 00003BEE 4883C20A            <1>     add rdx, 10              ; 10 ticks = 100ms
   508 00003BF2 B980841E00          <1>     mov ecx, 2000000
   509                              <1> .wait_bios:
   510 00003BF7 8B06                <1>     mov eax, [rsi]
   511 00003BF9 A900000100          <1>     test eax, (1 << 16)
   512 00003BFE 7422                <1>     jz .own_done_pop
   513 00003C00 FFC9                <1>     dec ecx
   514 00003C02 7410                <1>     jz .bios_timeout
   515 00003C04 488B05(F0000000)    <1>     mov rax, [tick_count]
   516 00003C0B 4839D0              <1>     cmp rax, rdx
   517 00003C0E 7D04                <1>     jge .bios_timeout
   518 00003C10 F390                <1>     pause
   519 00003C12 EBE3                <1>     jmp .wait_bios
   520                              <1> .bios_timeout:
   521                              <1>     ; Timeout - force release
   522 00003C14 8B06                <1>     mov eax, [rsi]
   523 00003C16 25FFFFFEFF          <1>     and eax, ~(1 << 16)
   524 00003C1B 0D00000001          <1>     or eax, (1 << 24)
   525 00003C20 8906                <1>     mov [rsi], eax
   526                              <1> .own_done_pop:
   527 00003C22 59                  <1>     pop rcx
   528 00003C23 5A                  <1>     pop rdx
   529                              <1> 
   530                              <1> .own_done:
   531 00003C24 58                  <1>     pop rax
   532 00003C25 59                  <1>     pop rcx
   533 00003C26 5E                  <1>     pop rsi
   534 00003C27 C3                  <1>     ret
   535                              <1> 
   536                              <1> ; ============================================================================
   537                              <1> ; xhci_reset - Reset the XHCI controller
   538                              <1> ; Returns: EAX = 1 on success, 0 on timeout
   539                              <1> ; Uses PIT-based timeouts so they work on any CPU speed.
   540                              <1> ; ============================================================================
   541                              <1> xhci_reset:
   542 00003C28 56                  <1>     push rsi
   543 00003C29 51                  <1>     push rcx
   544 00003C2A 53                  <1>     push rbx
   545                              <1> 
   546 00003C2B 488B35(5C050000)    <1>     mov rsi, [xhci_op_base]
   547                              <1> 
   548                              <1>     ; Stop controller: clear Run/Stop
   549 00003C32 8B06                <1>     mov eax, [rsi + XHCI_OP_USBCMD]
   550 00003C34 83E0FE              <1>     and eax, ~XHCI_CMD_RS
   551 00003C37 8906                <1>     mov [rsi + XHCI_OP_USBCMD], eax
   552                              <1> 
   553                              <1>     ; Serial: 'a' (wait halt start)
   554 00003C39 52                  <1>     push rdx
   555 00003C3A 66BAF803            <1>     mov dx, 0x3F8
   556 00003C3E B061                <1>     mov al, 'a'
   557 00003C40 EE                  <1>     out dx, al
   558 00003C41 5A                  <1>     pop rdx
   559                              <1> 
   560                              <1>     ; Wait for HCH = 1 (halted) - up to 100ms
   561 00003C42 488B1D(F0000000)    <1>     mov rbx, [tick_count]
   562 00003C49 4883C30A            <1>     add rbx, 10              ; 10 PIT ticks = 100ms
   563 00003C4D B980841E00          <1>     mov ecx, 2000000
   564                              <1> .wait_halt:
   565 00003C52 8B4604              <1>     mov eax, [rsi + XHCI_OP_USBSTS]
   566 00003C55 A901000000          <1>     test eax, XHCI_STS_HCH
   567 00003C5A 751C                <1>     jnz .halted
   568 00003C5C FFC9                <1>     dec ecx
   569 00003C5E 0F8498000000        <1>     jz .reset_fail
   570 00003C64 488B05(F0000000)    <1>     mov rax, [tick_count]
   571 00003C6B 4839D8              <1>     cmp rax, rbx
   572 00003C6E 0F8D88000000        <1>     jge .reset_fail          ; Timeout
   573 00003C74 F390                <1>     pause
   574 00003C76 EBDA                <1>     jmp .wait_halt
   575                              <1> .halted:
   576                              <1> 
   577                              <1>     ; Serial: 'b' (halted)
   578 00003C78 52                  <1>     push rdx
   579 00003C79 66BAF803            <1>     mov dx, 0x3F8
   580 00003C7D B062                <1>     mov al, 'b'
   581 00003C7F EE                  <1>     out dx, al
   582 00003C80 5A                  <1>     pop rdx
   583                              <1> 
   584                              <1>     ; Set HCRST
   585 00003C81 8B06                <1>     mov eax, [rsi + XHCI_OP_USBCMD]
   586 00003C83 83C802              <1>     or eax, XHCI_CMD_HCRST
   587 00003C86 8906                <1>     mov [rsi + XHCI_OP_USBCMD], eax
   588                              <1> 
   589                              <1>     ; Wait for HCRST to clear - up to 1 second
   590 00003C88 488B1D(F0000000)    <1>     mov rbx, [tick_count]
   591 00003C8F 4883C364            <1>     add rbx, 100             ; 100 PIT ticks = 1 second
   592 00003C93 B9002D3101          <1>     mov ecx, 20000000
   593                              <1> .wait_rst:
   594 00003C98 8B06                <1>     mov eax, [rsi + XHCI_OP_USBCMD]
   595 00003C9A A902000000          <1>     test eax, XHCI_CMD_HCRST
   596 00003C9F 7414                <1>     jz .rst_done
   597 00003CA1 FFC9                <1>     dec ecx
   598 00003CA3 7457                <1>     jz .reset_fail
   599 00003CA5 488B05(F0000000)    <1>     mov rax, [tick_count]
   600 00003CAC 4839D8              <1>     cmp rax, rbx
   601 00003CAF 7D4B                <1>     jge .reset_fail          ; Timeout
   602 00003CB1 F390                <1>     pause
   603 00003CB3 EBE3                <1>     jmp .wait_rst
   604                              <1> .rst_done:
   605                              <1> 
   606                              <1>     ; Serial: 'c' (reset done)
   607 00003CB5 52                  <1>     push rdx
   608 00003CB6 66BAF803            <1>     mov dx, 0x3F8
   609 00003CBA B063                <1>     mov al, 'c'
   610 00003CBC EE                  <1>     out dx, al
   611 00003CBD 5A                  <1>     pop rdx
   612                              <1> 
   613                              <1>     ; Wait for CNR = 0 - up to 1 second
   614 00003CBE 488B1D(F0000000)    <1>     mov rbx, [tick_count]
   615 00003CC5 4883C364            <1>     add rbx, 100
   616 00003CC9 B9002D3101          <1>     mov ecx, 20000000
   617                              <1> .wait_cnr:
   618 00003CCE 8B4604              <1>     mov eax, [rsi + XHCI_OP_USBSTS]
   619 00003CD1 A900080000          <1>     test eax, XHCI_STS_CNR
   620 00003CD6 7414                <1>     jz .reset_ok
   621 00003CD8 FFC9                <1>     dec ecx
   622 00003CDA 7420                <1>     jz .reset_fail
   623 00003CDC 488B05(F0000000)    <1>     mov rax, [tick_count]
   624 00003CE3 4839D8              <1>     cmp rax, rbx
   625 00003CE6 7D14                <1>     jge .reset_fail
   626 00003CE8 F390                <1>     pause
   627 00003CEA EBE2                <1>     jmp .wait_cnr
   628                              <1> 
   629                              <1> .reset_ok:
   630                              <1>     ; Serial: 'd' (CNR clear)
   631 00003CEC 52                  <1>     push rdx
   632 00003CED 66BAF803            <1>     mov dx, 0x3F8
   633 00003CF1 B064                <1>     mov al, 'd'
   634 00003CF3 EE                  <1>     out dx, al
   635 00003CF4 5A                  <1>     pop rdx
   636 00003CF5 B801000000          <1>     mov eax, 1
   637 00003CFA EB0B                <1>     jmp .reset_ret
   638                              <1> .reset_fail:
   639                              <1>     ; Serial: 'e' (reset fail)
   640 00003CFC 52                  <1>     push rdx
   641 00003CFD 66BAF803            <1>     mov dx, 0x3F8
   642 00003D01 B065                <1>     mov al, 'e'
   643 00003D03 EE                  <1>     out dx, al
   644 00003D04 5A                  <1>     pop rdx
   645 00003D05 31C0                <1>     xor eax, eax
   646                              <1> .reset_ret:
   647 00003D07 5B                  <1>     pop rbx
   648 00003D08 59                  <1>     pop rcx
   649 00003D09 5E                  <1>     pop rsi
   650 00003D0A C3                  <1>     ret
   651                              <1> 
   652                              <1> ; ============================================================================
   653                              <1> ; xhci_setup_scratchpad - Allocate scratchpad buffers if needed
   654                              <1> ; ============================================================================
   655                              <1> xhci_setup_scratchpad:
   656 00003D0B 51                  <1>     push rcx
   657 00003D0C 57                  <1>     push rdi
   658                              <1> 
   659 00003D0D 0FB60D(78050000)    <1>     movzx ecx, byte [xhci_scratchpad_count]
   660 00003D14 85C9                <1>     test ecx, ecx
   661 00003D16 7435                <1>     jz .scratch_done              ; No scratchpads needed
   662                              <1> 
   663                              <1>     ; Cap at 4 (we have space for 4 buffer pages)
   664 00003D18 83F904              <1>     cmp ecx, 4
   665 00003D1B 7E05                <1>     jle .scratch_ok
   666 00003D1D B904000000          <1>     mov ecx, 4
   667                              <1> .scratch_ok:
   668                              <1> 
   669                              <1>     ; Scratchpad array at XHCI_SCRATCH_ADDR
   670                              <1>     ; Buffers at XHCI_SCRATCH_ADDR + 0x1000, +0x2000, etc.
   671 00003D22 BF00009400          <1>     mov rdi, XHCI_SCRATCH_ADDR
   672 00003D27 31D2                <1>     xor edx, edx
   673                              <1> .scratch_loop:
   674 00003D29 39CA                <1>     cmp edx, ecx
   675 00003D2B 7D14                <1>     jge .scratch_set_dcbaa
   676                              <1>     ; Buffer address = XHCI_SCRATCH_ADDR + 0x1000 * (edx + 1)
   677 00003D2D 89D0                <1>     mov eax, edx
   678 00003D2F FFC0                <1>     inc eax
   679 00003D31 C1E00C              <1>     shl eax, 12                   ; * 4096
   680 00003D34 0500009400          <1>     add eax, XHCI_SCRATCH_ADDR
   681 00003D39 488904D7            <1>     mov [rdi + rdx * 8], rax      ; Write 64-bit pointer to array
   682 00003D3D FFC2                <1>     inc edx
   683 00003D3F EBE8                <1>     jmp .scratch_loop
   684                              <1> 
   685                              <1> .scratch_set_dcbaa:
   686                              <1>     ; DCBAA[0] = scratchpad array pointer
   687 00003D41 BF00009000          <1>     mov rdi, XHCI_DCBAA_ADDR
   688 00003D46 48C70700009400      <1>     mov qword [rdi], XHCI_SCRATCH_ADDR
   689                              <1> 
   690                              <1> .scratch_done:
   691 00003D4D 5F                  <1>     pop rdi
   692 00003D4E 59                  <1>     pop rcx
   693 00003D4F C3                  <1>     ret
   694                              <1> 
   695                              <1> ; ============================================================================
   696                              <1> ; xhci_setup_dcbaa - Setup Device Context Base Address Array
   697                              <1> ; ============================================================================
   698                              <1> xhci_setup_dcbaa:
   699                              <1>     ; DCBAA already zeroed. Scratchpad pointer set if needed.
   700                              <1>     ; Slot 1 device context will be set during address_device.
   701 00003D50 C3                  <1>     ret
   702                              <1> 
   703                              <1> ; ============================================================================
   704                              <1> ; xhci_setup_cmd_ring - Initialize Command Ring
   705                              <1> ; ============================================================================
   706                              <1> xhci_setup_cmd_ring:
   707 00003D51 57                  <1>     push rdi
   708                              <1> 
   709                              <1>     ; Command Ring at XHCI_CMD_RING_ADDR, already zeroed
   710                              <1>     ; Set last TRB as Link TRB pointing back to start
   711 00003D52 BF00009100          <1>     mov rdi, XHCI_CMD_RING_ADDR
   712                              <1>     ; Link TRB at entry 255 (offset 255 * 16)
   713 00003D57 488D87F0FF0000      <1>     lea rax, [rdi + (XHCI_RING_SIZE - 1) * XHCI_TRB_SIZE]
