   257                              <1> 
   258                              <1>     ; Pack bus/dev/func into a dword: bus<<16 | dev<<8 | func
   259 000039BE 4489E1              <1>     mov ecx, r12d
   260 000039C1 C1E110              <1>     shl ecx, 16
   261 000039C4 4489F0              <1>     mov eax, r14d
   262 000039C7 C1E008              <1>     shl eax, 8
   263 000039CA 09C1                <1>     or ecx, eax
   264 000039CC 4489E8              <1>     mov eax, r13d
   265 000039CF 09C1                <1>     or ecx, eax
