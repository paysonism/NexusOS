   143 00002BB4 EB6E                <1>     jmp .done
   144                              <1> .ctrl_release:
   145 00002BB6 8025(D1030000)FD    <1>     and byte [kb_modifiers], ~KMOD_CTRL
   146 00002BBD EB65                <1>     jmp .done
   147                              <1> .alt_press:
   148 00002BBF 800D(D1030000)04    <1>     or byte [kb_modifiers], KMOD_ALT
   149 00002BC6 EB5C                <1>     jmp .done
   150                              <1> .alt_release:
   151 00002BC8 8025(D1030000)FB    <1>     and byte [kb_modifiers], ~KMOD_ALT
   152 00002BCF EB53                <1>     jmp .done
   153                              <1> 
   154                              <1> .numlock_toggle:
   155 00002BD1 8035(D3030000)01    <1>     xor byte [kb_numlock], 1    ; Toggle NumLock state
