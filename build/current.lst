   830 0000025A 00                  <1> vsync_enabled: db 0        ; Disabled by default (uses PIT fallback on AMD/UEFI)
   831 0000025B 01                  <1> fps_show:      db 1
   832 0000025C 0000000000000000    <1> last_vsync_tick: dq 0      ; PIT tick count at last vsync
   833                              <1> global last_vsync_tick
   834                              <1> global vsync_enabled, fps_show
   835                              <1> extern fps_count, last_fps, frame_count, start_tick
   836                              <1> 
   837                              <1> ; --- Wait for VSync / Frame Pacing ---
   838                              <1> ; On real AMD/UEFI hardware port 0x3DA is unreliable for vsync.
   839                              <1> ; Strategy: first try 0x3DA (works on VGA/QEMU), fall back to PIT-tick pacing.
   840                              <1> ; vsync_target_ticks = PIT ticks per frame (100Hz PIT: 180fps -> ~0.55 ticks -> 1 tick min)
   841                              <1> ; We use a hybrid: try 0x3DA with a long timeout; if it times out too fast, use PIT.
   842                              <1> global wait_vsync
   843                              <1> wait_vsync:
   844 00000264 53                  <1>     push rbx
   845 00000265 51                  <1>     push rcx
   846 00000266 52                  <1>     push rdx
   847 00000267 50                  <1>     push rax
   848                              <1> 
   849                              <1>     ; Check if interrupts are enabled. If they are disabled (IF=0), we are likely 
   850                              <1>     ; in an ISR or Syscall. Since tick_count won't increment in this state, 
   851                              <1>     ; we must skip the PIT-based pacing to avoid deadlocking/stalling.
   852 00000268 9C                  <1>     pushf
   853 00000269 58                  <1>     pop rax
   854 0000026A A900020000          <1>     test eax, 0x200         ; Bit 9 = Interrupt Flag
   855 0000026F 7463                <1>     jz .vsync_done_pop      ; Masked? Skip vsync wait.
   856                              <1> 
   857                              <1>     ; Quick check: does 0x3DA work at all? (VGA retrace signal)
   858                              <1>     ; On AMD UEFI/GOP hardware 0x3DA returns 0 always - skip it entirely.
   859                              <1>     ; We detect this by checking if 0x3DA ever has bit 0x08 set.
   860                              <1>     ; Instead: use a very short probe (1000 iters) to check for any activity.
   861 00000271 66BADA03            <1>     mov dx, 0x3DA
   862 00000275 B9D0070000          <1>     mov ecx, 2000          ; Short probe: ~0.2ms at 100ns/IO
   863                              <1> .probe_3da:
   864 0000027A EC                  <1>     in al, dx
   865 0000027B A808                <1>     test al, 0x08
   866 0000027D 7506                <1>     jnz .vga_active        ; 0x3DA is live - use it
   867 0000027F FFC9                <1>     dec ecx
   868 00000281 75F7                <1>     jnz .probe_3da
   869                              <1>     ; 0x3DA never went high - not a real VGA controller, use PIT
   870 00000283 EB1E                <1>     jmp .pit_fallback
   871                              <1> 
   872                              <1> .vga_active:
   873                              <1>     ; 0x3DA is working - do full VGA vsync wait
   874                              <1>     ; Wait for retrace to end first (if currently in retrace)
   875 00000285 B9A0860100          <1>     mov ecx, 100000
   876                              <1> .wait_retrace_end:
   877 0000028A EC                  <1>     in al, dx
   878 0000028B A808                <1>     test al, 0x08
   879 0000028D 7406                <1>     jz .wait_retrace_start
   880 0000028F FFC9                <1>     dec ecx
   881 00000291 75F7                <1>     jnz .wait_retrace_end
   882 00000293 EB0E                <1>     jmp .pit_fallback       ; Stuck in retrace - fall back
   883                              <1> 
   884                              <1> .wait_retrace_start:
   885 00000295 B9A0860100          <1>     mov ecx, 100000        ; ~10ms timeout
   886                              <1> .wait_loop:
   887 0000029A EC                  <1>     in al, dx
   888 0000029B A808                <1>     test al, 0x08
   889 0000029D 7535                <1>     jnz .vsync_done        ; Got retrace pulse - success
   890 0000029F FFC9                <1>     dec ecx
   891 000002A1 75F7                <1>     jnz .wait_loop
   892                              <1>     ; Timed out waiting for retrace start - fall back to PIT pacing
   893                              <1> 
   894                              <1> .pit_fallback:
   895                              <1>     ; PIT-based frame pacing: wait until tick_count advances by at least 1
   896                              <1>     ; This gives ~100fps max (one frame per 10ms tick) when 0x3DA doesn't work.
   897                              <1>     ; At 180Hz monitor, frames will pace to ~100fps which is smooth enough.
   898                              <1>     ; last_vsync_tick holds the tick count when we last flipped.
   899 000002A3 488B0546FEFFFF      <1>     mov rax, [tick_count]
   900 000002AA 488B1DABFFFFFF      <1>     mov rbx, [last_vsync_tick]
   901                              <1>     ; If tick_count > last_vsync_tick, a new tick has occurred - proceed
   902 000002B1 4839D8              <1>     cmp rax, rbx
   903 000002B4 7F17                <1>     jg .pit_new_tick
   904                              <1>     ; Same tick - spin briefly checking tick_count (don't busy-loop forever)
   905 000002B6 B9404B4C00          <1>     mov ecx, 5000000       ; max spin ~1.7ms at 3GHz
   906                              <1> .pit_spin:
   907 000002BB 488B052EFEFFFF      <1>     mov rax, [tick_count]
   908 000002C2 4839D8              <1>     cmp rax, rbx
   909 000002C5 7F06                <1>     jg .pit_new_tick
   910 000002C7 FFC9                <1>     dec ecx
   911 000002C9 75F0                <1>     jnz .pit_spin
   912                              <1>     ; Still no new tick - just proceed (avoid stalling)
   913 000002CB EB07                <1>     jmp .vsync_done
   914                              <1> .pit_new_tick:
   915 000002CD 48890588FFFFFF      <1>     mov [last_vsync_tick], rax
   916                              <1> 
   917                              <1> .vsync_done:
   918                              <1> .vsync_done_pop:
   919 000002D4 58                  <1>     pop rax
   920 000002D5 5A                  <1>     pop rdx
   921 000002D6 59                  <1>     pop rcx
   922 000002D7 5B                  <1>     pop rbx
   923 000002D8 C3                  <1>     ret
