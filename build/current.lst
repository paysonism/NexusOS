  1891 00004779 EE                  <1>     out dx, al
  1892 0000477A FFC9                <1>     dec ecx
  1893 0000477C 75E6                <1>     jnz .sh32_loop
  1894                              <1>     ; print space separator
  1895 0000477E B020                <1>     mov al, ' '
  1896 00004780 66BAF803            <1>     mov dx, 0x3F8
  1897 00004784 EE                  <1>     out dx, al
  1898 00004785 5A                  <1>     pop rdx
  1899 00004786 59                  <1>     pop rcx
  1900 00004787 5B                  <1>     pop rbx
  1901 00004788 58                  <1>     pop rax
  1902 00004789 C3                  <1>     ret
