   630 000089A8 482D14020000        <1>     sub rax, START_MENU_Y
   631 000089AE 4883E808            <1>     sub rax, 8
   632 000089B2 4883F800            <1>     cmp rax, 0
   633 000089B6 7C21                <1>     jl .close_menu
   634 000089B8 4831D2              <1>     xor rdx, rdx
   635 000089BB B91C000000          <1>     mov rcx, MENU_ITEM_H
   636 000089C0 48F7F1              <1>     div rcx
   637                              <1> 
   638                              <1>     ; Validate range
   639 000089C3 4883F806            <1>     cmp rax, MENU_ITEM_COUNT
   640 000089C7 7D10                <1>     jge .close_menu
   641                              <1> 
   642                              <1>     ; Close menu and return item index + 2
   643 000089C9 C605(97110000)00    <1>     mov byte [tb_start_menu_open], 0
   644 000089D0 4883C002            <1>     add rax, 2
   645 000089D4 E912010000          <1>     jmp .tb_click_ret
   646                              <1> 
