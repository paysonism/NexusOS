   735 00008AB4 EBEB                <1>     jmp .tb_unfocus_loop
   736                              <1> .tb_unfocus_done:
   737 00008AB6 5A                  <1>     pop rdx
   738 00008AB7 59                  <1>     pop rcx
   739 00008AB8 48834B2802          <1>     or qword [rbx + WIN_OFF_FLAGS], WF_FOCUSED
   740 00008ABD 4C8925(01110000)    <1>     mov [wm_focused_window], r12
   741 00008AC4 B801000000          <1>     mov rax, 1
   742 00008AC9 EB20                <1>     jmp .tb_click_ret
   743                              <1> 
   744                              <1> .tb_click_next_active:
