  1726                                  ; SETUP_PAGING - Build identity-mapped page tables at 0x70000
  1727                                  ; Maps first 512GB with 1GB pages for UEFI compatibility.
  1728                                  ; AMD GPUs (Radeon 780M etc.) may place framebuffers above 4GB,
  1729                                  ; so we need more than just the first 4GB mapped.
  1730                                  ; 1GB pages (PDPE.PS=1) are supported on all 64-bit AMD CPUs.
  1731                                  ; Layout: PML4 at 0x70000, PDPT at 0x71000 (just 2 pages needed)
  1732                                  ; ============================================================================
  1733                                  setup_paging:
  1734 000043A5 53                          push rbx
  1735 000043A6 4154                        push r12
  1736                                  
  1737                                      ; Clear page table area (8KB: PML4 + PDPT)
  1738 000043A8 BF00000700                  mov rdi, PAGE_TBL_ADDR
  1739 000043AD 31C0                        xor eax, eax
  1740 000043AF B900080000                  mov ecx, (2 * 4096) / 4         ; 2 pages, clear as dwords
  1741 000043B4 F3AB                        rep stosd
  1742                                  
  1743                                      ; PML4[0] -> PDPT at 0x71000
  1744 000043B6 BF00000700                  mov rdi, PAGE_TBL_ADDR           ; 0x70000
  1745 000043BB 48C70703100700              mov qword [rdi], 0x71000 | 3     ; Present + Writable
  1746                                  
  1747                                      ; PDPT[0..511] -> 1GB identity-mapped pages
  1748                                      ; Entry format: physical_addr | 0x83 (Present + Writable + PageSize=1GB)
  1749 000043C2 BF00100700                  mov rdi, PAGE_TBL_ADDR + 0x1000  ; 0x71000 = PDPT
  1750 000043C7 4831DB                      xor rbx, rbx                     ; Starting physical address = 0
  1751 000043CA 41BC00020000                mov r12d, 512                    ; 512 entries * 1GB = 512GB
  1752                                  
  1753                                  .pt_loop:
  1754 000043D0 4889D8                      mov rax, rbx
  1755 000043D3 480D83000000                or rax, 0x83                     ; Present | Writable | PS (1GB page)
  1756 000043D9 488907                      mov [rdi], rax
  1757 000043DC 4883C708                    add rdi, 8
  1758 000043E0 4881C300000040              add rbx, 0x40000000             ; Next 1GB (0x40000000)
  1759 000043E7 41FFCC                      dec r12d
  1760 000043EA 75E4                        jnz .pt_loop
  1761                                  
  1762 000043EC 415C                        pop r12
  1763 000043EE 5B                          pop rbx
  1764 000043EF C3                          ret
