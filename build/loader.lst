  1078                                      ; OpenProtocol(Handle, &PrevGuid, &Interface, ImageHandle, NULL, EFI_OPEN_PROTOCOL_GET_PROTOCOL=2)
  1079                                      ; OpenProtocol is at offset 280 (0x118) in BootServices
  1080                                      
  1081 000037D8 488B742438                  mov rsi, [rsp+56]                ; HandleBuffer ptr
  1082 000037DD 488B0E                      mov rcx, [rsi]                   ; First handle (Handle)
  1083                                      
  1084 000037E0 488B1541150000              mov rdx, [v_bs]
  1085 000037E7 488B8218010000              mov rax, [rdx + 280]             ; OpenProtocol
  1086                                      
  1087 000037EE 488D158F110000              lea rdx, [gop_guid]              ; Protocol GUID
  1088 000037F5 4C8D442428                  lea r8, [rsp+40]                 ; &Interface (Output)
  1089 000037FA 4C8B0D17150000              mov r9, [v_handle]               ; ImageHandle (AgentHandle)
  1090 00003801 48C744242000000000          mov qword [rsp+32], 0            ; ControllerHandle (NULL)
  1091 0000380A 48C744242802000000          mov qword [rsp+40], 2            ; Attributes (GET_PROTOCOL). Wait! [rsp+40] is output ptr location?
  1092                                                                       ; NO!
  1093                                                                       ; Output ptr is 3rd arg (R8).
  1094                                                                       ; R8 points to [rsp+40] (our local variable).
  1095                                                                       ; The 6th arg is on stack at [rsp+40] (in the called function frame).
  1096                                                                       ; BUT our stack frame is `sub rsp, 64`.
  1097                                                                       ; We are at `gop_init`.
  1098                                                                       ; Arguments > 4 go to shadow space + N.
  1099                                                                       ; Shadow space is [rsp+0..31].
  1100                                                                       ; 5th arg at [rsp+32].
  1101                                                                       ; 6th arg at [rsp+40].
  1102                                                                       
  1103                                                                       ; Wait, `mov qword [r9], 0` earlier used `[rsp+40]` for `&gop_interface`.
  1104                                                                       ; This is dangerously close.
  1105                                                                       ; gop_interface is at `[rsp+40]`.
  1106                                                                       ; 6th argument to OpenProtocol goes to `[rsp+40]`.
  1107                                                                       ; THIS IS A COLLISION.
  1108                                                                       ; The `call` will push return address, shifting RSP by 8.
  1109                                                                       ; The callee reads `[rsp+8+40]`? No.
  1110                                                                       ; The caller puts arguments at `[rsp+32]`, `[rsp+40]`.
  1111                                                                       ; My local variable `gop_interface` is at `[rsp+40]`.
  1112                                                                       ; I am overwriting my local variable with the 6th argument!
  1113                                                                       
  1114                                                                       ; Solution: Move local variables higher up or allocate more stack space.
  1115                                                                       ; I allocated 64 bytes.
  1116                                                                       ; [rsp+0..31] Shadow
  1117                                                                       ; [rsp+32] 5th arg
  1118                                                                       ; [rsp+40] 6th arg OR local var?
  1119                                                                       
  1120                                                                       ; I need to allocate MORE stack space.
  1121                                                                       ; 4 arguments in registers.
  1122                                                                       ; OpenProtocol has 6 arguments.
  1123                                                                       ; 5th at [rsp+32]. 6th at [rsp+40].
  1124                                                                       ; So [rsp+0..47] is reserved for outbound calls.
  1125                                                                       ; Locals must start at [rsp+48].
  1126                                                                       
  1127                                                                       ; Currently:
  1128                                                                       ; [rsp+40] = gop_interface_ptr
  1129                                                                       ; [rsp+48] = num_handles
  1130                                                                       ; [rsp+56] = handle_buffer_ptr
  1131                                                                       
  1132                                                                       ; This layout is WRONG for 6-argument calls.
  1133                                                                       ; I need to shift locals.
  1134                                                                       
  1135                                                                       ; Let's re-allocate stack to 96 bytes (aligned 16n).
  1136                                                                       ; 16n-8 (entry) - 40 (pushes) = 16n-48.
  1137                                                                       ; sub 96 = 16n-144. Aligned.
  1138                                                                       
  1139                                                                       ; New layout:
  1140                                                                       ; [rsp+0..31] Shadow
  1141                                                                       ; [rsp+32] Arg5
  1142                                                                       ; [rsp+40] Arg6
  1143                                                                       ; [rsp+48] Arg7 ...
  1144                                                                       ; Let's put locals at [rsp+64] and up.
  1145                                                                       ; [rsp+64] = gop_interface_ptr
  1146                                                                       ; [rsp+72] = num_handles
  1147                                                                       ; [rsp+80] = handle_buffer_ptr
  1148                                      
  1149                                      ; Since I can't easily change the `sub rsp` at the top without touching the whole function,
  1150                                      ; I will perform a smaller edit to fix the call site by pushing/popping or just moving the local usage.
  1151                                      ; OR... I can just use a global variable/temp space for the output pointer?
  1152                                      ; I have `v_gop` global. I can point R8 to `v_gop` directly!
  1153                                      ; No need for stack local for `gop_interface` if I have `v_gop`.
  1154                                      
