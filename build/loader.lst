  1156 0000381A 4C8B0DF7140000              mov r9, [v_handle]               ; ImageHandle
  1157 00003821 48C744242000000000          mov qword [rsp+32], 0            ; ControllerHandle (NULL)
  1158 0000382A 48C744242802000000          mov qword [rsp+40], 2            ; Attributes (GET_PROTOCOL)
  1159                                      
  1160 00003833 FFD0                        call rax
  1161                                      
  1162                                      ; Save RAX to R12
  1163 00003835 4989C4                      mov r12, rax
  1164                                      SERIAL_REG 'OPENPROT-RET', r12
