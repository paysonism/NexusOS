     1                                  ; ============================================================================
     2                                  ; NexusOS v3.0 - UEFI Bootloader
     3                                  ; Loads the full kernel via UEFI, calls ExitBootServices, jumps to kernel
     4                                  ; Output: BOOTX64.EFI (PE32+ UEFI application)
     5                                  ; ============================================================================
     6                                  bits 64
     7                                  default rel
     8                                  
     9                                  ; --- PE layout constants ---
    10                                  %define HEADER_SIZE   0x200
    11                                  %define TEXT_RAWSIZE  0x10000
    12                                  %define TEXT_VADDR    0x1000
    13                                  %define TEXT_VSIZE    0x10000
    14                                  %define RELOC_FOFF    (HEADER_SIZE + TEXT_RAWSIZE)
    15                                  %define RELOC_FSIZE   0x200
    16                                  %define RELOC_VADDR   0x11000
    17                                  %define RELOC_VSIZE   0x0C
    18                                  %define IMAGE_SIZE    0x12000
    19                                  
    20                                  ; --- UEFI System Table offsets ---
    21                                  %define ST_CONOUT     64
    22                                  %define ST_BOOTSERV   96
    23                                  %define CO_STR        8
    24                                  %define CO_CLR        48
    25                                  
    26                                  ; --- Boot Services offsets ---
    27                                  %define BS_ALLOCPOOL  64
    28                                  %define BS_FREEPOOL   72
    29                                  %define BS_GETMEMMAP  56
    30                                  %define BS_ALLOCPAGES 40
    31                                  %define BS_STALL      248
    32                                  %define BS_WATCHDOG   256
    33                                  %define BS_LOCATE     320
    34                                  %define BS_EXITBOOT   232
    35                                  %define BS_HANDLEPROTO 152
    36                                  %define BS_LOCATEHANDLE 312
    37                                  
    38                                  ; --- GOP offsets ---
    39                                  %define GOP_QUERY     0
    40                                  %define GOP_SET       8
    41                                  %define GOP_MODE      24
    42                                  %define GOPM_MAX      0
    43                                  %define GOPM_CUR      4
    44                                  %define GOPM_INFO     8
    45                                  %define GOPM_FBBASE   24
    46                                  %define GOPM_FBSIZE   32
    47                                  %define GOPI_HRES     4
    48                                  %define GOPI_VRES     8
    49                                  %define GOPI_PPSL     32
    50                                  
    51                                  ; --- File Protocol offsets ---
    52                                  %define SFS_OPENVOL   8
    53                                  %define FP_OPEN       8
    54                                  %define FP_CLOSE      16
    55                                  %define FP_READ       32
    56                                  
    57                                  ; --- Kernel expectations ---
    58                                  %define VBE_INFO_ADDR  0x9000
    59                                  %define PAGE_TBL_ADDR  0x70000
    60                                  %define KERNEL_ADDR    0x100000
    61                                  %define KERNEL_TEMP    0x400000          ; Temp buffer (4MB) - above our PE image
    62                                  
    63                                  ; UCS-2 string macro
    64                                  %macro u 1+
    65                                    %assign %%i 1
    66                                    %strlen %%len %1
    67                                    %rep %%len
    68                                      %substr %%c %1 %%i
    69                                      dw %%c
    70                                      %assign %%i %%i+1
    71                                    %endrep
    72                                    dw 0
    73                                  %endmacro
    74                                  
    75                                  ; Busy-wait delay macro - ~500ms on a ~3GHz CPU
    76                                  ; Uses a simple dec loop. 500M iterations ≈ 500ms at 1 cycle/iter on modern CPUs.
    77                                  ; Actual time varies but will be clearly visible even at 180Hz.
    78                                  %macro DELAY_500MS 0
    79                                    push rcx
    80                                    mov rcx, 500000000               ; ~500M iterations
    81                                  %%delay:
    82                                    dec rcx
    83                                    jnz %%delay
    84                                    pop rcx
    85                                  %endmacro
    86                                  
    87                                  ; Visual debug macro - paints a colored horizontal bar on the framebuffer
    88                                  ; Uses v_fb for FB address, paints at y-row based on step number
    89                                  ; Each bar is 1024 pixels wide x 8 pixels tall, with 500ms delay after
    90                                  ; Usage: VDEBUG step_number, color  (step 0-95, color is 0xRRGGBB)
    91                                  %macro VDEBUG 2
    92                                    push rax
    93                                    push rcx
    94                                    push rdx
    95                                    push rdi
    96                                    mov rdi, [v_fb]
    97                                    ; Calculate Y offset: step * 8 rows * bytes_per_row
    98                                    mov eax, [v_pitch]
    99                                    test eax, eax
   100                                    jnz %%has_pitch
   101                                    mov eax, 1024                    ; Fallback if pitch is 0
   102                                  %%has_pitch:
   103                                    shl eax, 2                       ; pixels * 4 bytes = bytes per row
   104                                    mov edx, (%1) * 8                ; step * 8 rows
   105                                    mul edx                           ; eax = eax * edx (result in edx:eax)
   106                                    ; eax now has byte offset to target row
   107                                    add rdi, rax
   108                                    mov eax, %2                      ; Color
   109                                    mov ecx, 1024 * 8                ; 1024 pixels * 8 rows
   110                                    rep stosd
   111                                    pop rdi
   112                                    pop rdx
   113                                    pop rcx
   114                                    pop rax
   115                                    DELAY_500MS
   116                                  %endmacro
   117                                  
   118                                  ; Serial debug macro - outputs a string to COM1 (0x3F8)
   119                                  ; Usage: SERIAL_DBG 'XX' where XX is a 2-char code
   120                                  ; After ExitBootServices, this is our ONLY debug output
   121                                  %macro SERIAL_DBG 1
   122                                    push rax
   123                                    push rdx
   124                                    mov dx, 0x3F8
   125                                    %strlen %%slen %1
   126                                    %assign %%si 1
   127                                    %rep %%slen
   128                                      %substr %%ch %1 %%si
   129                                      mov al, %%ch
   130                                      out dx, al
   131                                      %assign %%si %%si+1
   132                                    %endrep
   133                                    mov al, 13
   134                                    out dx, al
   135                                    mov al, 10
   136                                    out dx, al
   137                                    pop rdx
   138                                    pop rax
   139                                  
   140                                    ; File log
   141                                    jmp %%over
   142                                  %%msg: db %1, 13, 10, 0
   143                                  %%over:
   144                                    push rsi
   145                                    lea rsi, [%%msg]
   146                                    call log_string
   147                                    pop rsi
   148                                  %endmacro
   149                                  
   150                                  ; Serial debug that also outputs a 64-bit register value as hex
   151                                  ; Usage: SERIAL_REG 'XX', rax  (prints XX=<hex value>\n)
   152                                  %macro SERIAL_REG 2
   153                                    push rbx
   154                                    mov rbx, %2            ; Capture value FIRST before clobbering any regs
   155                                    push rax
   156                                    push rcx
   157                                    push rdx
   158                                  
   159                                    ; Print tag
   160                                    mov dx, 0x3F8
   161                                    %strlen %%slen %1
   162                                    %assign %%si 1
   163                                    %rep %%slen
   164                                      %substr %%ch %1 %%si
   165                                      mov al, %%ch
   166                                      out dx, al
   167                                      %assign %%si %%si+1
   168                                    %endrep
   169                                    mov al, '='
   170                                    out dx, al
   171                                  
   172                                    ; Print 64-bit hex value (already in rbx)
   173                                    mov ecx, 16           ; 16 hex digits
   174                                  %%hex_loop:
   175                                    rol rbx, 4
   176                                    mov al, bl
   177                                    and al, 0x0F
   178                                    add al, '0'
   179                                    cmp al, '9'
   180                                    jle %%hex_ok
   181                                    add al, 7             ; 'A'-'9'-1
   182                                  %%hex_ok:
   183                                    out dx, al
   184                                    dec ecx
   185                                    jnz %%hex_loop
   186                                  
   187                                    ; newline
   188                                    mov al, 13
   189                                    out dx, al
   190                                    mov al, 10
   191                                    out dx, al
   192                                  
   193                                    pop rdx
   194                                    pop rcx
   195                                    pop rax
   196                                    pop rbx
   197                                  
   198                                    ; File Log
   199                                    jmp %%over
   200                                  %%lbl: db %1, '=', 0
   201                                  %%crlf: db 13, 10, 0
   202                                  %%over:
   203                                    push rsi
   204                                    lea rsi, [%%lbl]
   205                                    call log_string
   206                                    pop rsi
   207                                  
   208                                    push rdi
   209                                    mov rdi, %2
   210                                    call log_hex
   211                                    pop rdi
   212                                  
   213                                    push rsi
   214                                    lea rsi, [%%crlf]
   215                                    call log_string
   216                                    pop rsi
   217                                  %endmacro
