    16                              <1> section .text
    17                              <1> global madt_init
    18                              <1> global madt_lapic_count
    19                              <1> global madt_enabled_cpu_count
    20                              <1> global madt_lapic_ids
    21                              <1> 
    22                              <1> ; RSI = pointer to MADT table (starts with signature "APIC", length, revision...)
    23                              <1> madt_init:
    24 000029D6 53                  <1>     push rbx
    25 000029D7 51                  <1>     push rcx
    26 000029D8 52                  <1>     push rdx
    27 000029D9 56                  <1>     push rsi
    28 000029DA 57                  <1>     push rdi
    29 000029DB 4150                <1>     push r8
    30                              <1>     SER 'M'
    20                              <2> %ifdef ENABLE_DEBUG_SERIAL
    21                              <2>  push rax
    22                              <2>  push rdx
    23                              <2>  mov dx, 0x3F8
    24                              <2>  mov al, %1
    25                              <2>  out dx, al
    26                              <2>  pop rdx
    27                              <2>  pop rax
    28                              <2> %endif
    31 000029DD C705(AC010000)0000- <1>     mov dword [madt_lapic_count], 0
    31 000029E5 0000                <1>
    32 000029E7 C705(B0010000)0000- <1>     mov dword [madt_enabled_cpu_count], 0
    32 000029EF 0000                <1>
    33                              <1>     
    34                              <1>     ; MADT Header size is 44 bytes
    35                              <1>     ; +0: Signature (4)
    36                              <1>     ; +4: Length (4)
    37                              <1>     ; ...
    38                              <1>     ; +36: Local APIC Address (4)
    39                              <1>     ; +40: Flags (4)
    40                              <1>     
    41 000029F1 8B4E04              <1>     mov ecx, [rsi + 4]      ; Total table length
    42                              <1>     
    43 000029F4 488D5E2C            <1>     lea rbx, [rsi + 44]     ; First entry
    44 000029F8 4801F1              <1>     add rcx, rsi            ; End of table
    45                              <1>     
    46                              <1> .scan_loop:
    47 000029FB 4839CB              <1>     cmp rbx, rcx
    48 000029FE 0F8383000000        <1>     jae .done
    49                              <1>     
    50 00002A04 0FB603              <1>     movzx eax, byte [rbx]   ; Type
    51 00002A07 0FB65301            <1>     movzx edx, byte [rbx + 1] ; Length
    52                              <1>     
    53 00002A0B 83F800              <1>     cmp eax, 0              ; Type 0: Local APIC
    54 00002A0E 7411                <1>     je .found_lapic
    55 00002A10 83F809              <1>     cmp eax, 9              ; Type 9: x2APIC
    56 00002A13 742C                <1>     je .found_x2apic
    57 00002A15 83F801              <1>     cmp eax, 1              ; Type 1: I/O APIC
    58 00002A18 7446                <1>     je .found_ioapic
    59 00002A1A 83F802              <1>     cmp eax, 2              ; Type 2: Interrupt Source Override
    60 00002A1D 744D                <1>     je .found_iso
    61                              <1>     
    62 00002A1F EB5E                <1>     jmp .next
    63                              <1> 
    64                              <1> .found_lapic:
    65 00002A21 FF05(AC010000)      <1>     inc dword [madt_lapic_count]
    66 00002A27 0FB64304            <1>     movzx eax, byte [rbx + 4] ; Flags
    67 00002A2B A901000000          <1>     test eax, 1             ; Processor enabled
    68 00002A30 7507                <1>     jnz .lapic_enabled
    69 00002A32 A908000000          <1>     test eax, 8             ; Online-capable
    70 00002A37 7446                <1>     jz .next
    71                              <1> .lapic_enabled:
    72                              <1> %ifdef NEXUS_CACHE32_MAX
    73                              <1>     ; rcx holds the table-end pointer; use rdi for the count to avoid clobber.
    74                              <1>     mov edi, [madt_enabled_cpu_count]
    75                              <1>     cmp edi, SMP_MAX_CORES
    76                              <1>     jae .skip_store_lapic
    77                              <1>     mov al, [rbx + 3]
    78                              <1>     mov [madt_lapic_ids + rdi], al
    79                              <1> .skip_store_lapic:
    80                              <1> %endif
    81 00002A39 FF05(B0010000)      <1>     inc dword [madt_enabled_cpu_count]
    82 00002A3F EB3E                <1>     jmp .next
    83                              <1> 
    84                              <1> .found_x2apic:
    85 00002A41 FF05(AC010000)      <1>     inc dword [madt_lapic_count]
    86 00002A47 8B430C              <1>     mov eax, [rbx + 12]
    87 00002A4A A901000000          <1>     test eax, 1
    88 00002A4F 7507                <1>     jnz .x2_enabled
    89 00002A51 A908000000          <1>     test eax, 8
    90 00002A56 7427                <1>     jz .next
    91                              <1> .x2_enabled:
    92                              <1> %ifdef NEXUS_CACHE32_MAX
    93                              <1>     mov edi, [madt_enabled_cpu_count]
    94                              <1>     cmp edi, SMP_MAX_CORES
    95                              <1>     jae .skip_store_x2
    96                              <1>     mov eax, [rbx + 4]
    97                              <1>     mov [madt_lapic_ids + rdi], al
    98                              <1> .skip_store_x2:
    99                              <1> %endif
   100 00002A58 FF05(B0010000)      <1>     inc dword [madt_enabled_cpu_count]
   101 00002A5E EB1F                <1>     jmp .next
   102                              <1> 
   103                              <1> .found_ioapic:
   104                              <1>     ; +2: I/O APIC ID
   105                              <1>     ; +3: Reserved
   106                              <1>     ; +4: I/O APIC Address (4 bytes)
   107                              <1>     ; +8: Global System Interrupt Base (4 bytes)
   108 00002A60 8B4304              <1>     mov eax, [rbx + 4]
   109 00002A63 488905(10020000)    <1>     mov [ioapic_base], rax
   110 00002A6A EB13                <1>     jmp .next
   111                              <1> 
   112                              <1> .found_iso:
   113                              <1>     ; +2: Bus Source (usually 0 = ISA)
   114                              <1>     ; +3: IRQ Source
   115                              <1>     ; +4: Global System Interrupt (4 bytes)
   116                              <1>     ; +8: Flags (2 bytes)
   117                              <1>     ; If IRQ Source is 0 (Timer), log the Global System Interrupt
   118 00002A6C 807B0300            <1>     cmp byte [rbx + 3], 0
   119 00002A70 750D                <1>     jne .next
   120                              <1>     
   121                              <1>     ; Found Timer ISO
   122                              <1>     SER 'I'
