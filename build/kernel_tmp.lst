  1273                              <1> section .data
  1274                              <1> 
  1275                              <1> ; AMD FCH I2C base addresses - all blocks seen on Strix Point real hardware
  1276                              <1> ; Order: higher indices first (I2CD = instance 3 likely at 0xFEDC5000 or 0xFEDC6000)
  1277                              <1> i2c_amd_bases:
  1278 00000945 0050DCFE00000000    <1>     dq I2C_BASE_2               ; 0xFEDC5000 - most likely I2CD on Strix Point
  1279 0000094D 0060DCFE00000000    <1>     dq I2C_BASE_3               ; 0xFEDC6000 - fallback I2CD candidate
  1280 00000955 0030DCFE00000000    <1>     dq I2C_BASE_1               ; 0xFEDC3000 - I2CB
  1281 0000095D 0020DCFE00000000    <1>     dq I2C_BASE_0               ; 0xFEDC2000 - I2CA
  1282 00000965 0000DCFE00000000    <1>     dq I2C_BASE_4               ; 0xFEDC0000 - additional FCH block
  1283                              <1> 
  1284                              <1> ; Touchpad I2C addresses to probe (most-common first)
  1285                              <1> i2c_tp_addrs:
  1286 0000096D 15                  <1>     db 0x15             ; ELAN primary (Acer Nitro / AMD Ryzen)
  1287 0000096E 17                  <1>     db 0x17             ; ELAN variant (Nitro V16 AI / Strix Point)
  1288 0000096F 2C                  <1>     db 0x2C             ; Synaptics / ALPS
  1289 00000970 38                  <1>     db 0x38             ; ELAN variant
  1290 00000971 10                  <1>     db 0x10             ; ELAN alt
  1291 00000972 14                  <1>     db 0x14             ; Goodix
  1292 00000973 5D                  <1>     db 0x5D             ; Goodix alternate
  1293 00000974 2A                  <1>     db 0x2A             ; Synaptics secondary
  1294 00000975 3C                  <1>     db 0x3C             ; ALPS I2C-HID
  1295 00000976 20                  <1>     db 0x20             ; Pixart
  1296 00000977 34                  <1>     db 0x34             ; FocalTech
  1297 00000978 16                  <1>     db 0x16             ; ELAN variant 2
  1298 00000979 2D                  <1>     db 0x2D             ; Synaptics variant
  1299                              <1> I2C_TP_ADDR_COUNT   equ ($ - i2c_tp_addrs)
  1300                              <1> 
  1301                              <1> ; I2C-HID state
  1302                              <1> global i2c_hid_active
  1303 0000097A 00                  <1> i2c_hid_active:     db 0
  1304 0000097B 00                  <1> i2c_dev_addr:       db 0
  1305 0000097C 00                  <1> i2c_poll_state:     db 0        ; 0=issue, 1=read header, 2=read data
  1306 0000097D 00                  <1> i2c_is_intel:       db 0        ; 1 if controller found via PCI (Intel LPSS)
  1307 0000097E 00                  <1> i2c_use_parsed:     db 0        ; 1 if HID report descriptor was parsed successfully
  1308 0000097F 0000000000000000    <1> i2c_base_addr:      dq 0
  1309 00000987 0000                <1> i2c_hid_desc_len:   dw 0
  1310 00000989 00000000            <1> i2c_error_count:    dd 0        ; consecutive error counter for bus reset
  1311 0000098D 0000                <1> i2c_pending_len:    dw 0        ; bytes pending in state 2
  1312                              <1> 
  1313                              <1> ; I2C-HID register addresses (from HID descriptor, with defaults)
  1314 0000098F 0500                <1> i2c_hid_cmd_reg:    dw 0x0005
  1315 00000991 0300                <1> i2c_hid_input_reg:  dw 0x0003
  1316 00000993 0700                <1> i2c_hid_data_reg:   dw 0x0007
  1317 00000995 4000                <1> i2c_max_input_len:  dw 64       ; wMaxInputLength from descriptor
  1318                              <1> 
  1319                              <1> ; Report descriptor info
  1320 00000997 0000                <1> i2c_report_desc_len:    dw 0    ; wReportDescLength
  1321 00000999 0000                <1> i2c_report_desc_reg:    dw 0    ; wReportDescRegister
  1322 0000099B 0000                <1> i2c_rdesc_read_len:     dw 0    ; actual bytes to read
  1323                              <1> 
  1324                              <1> ; Buffers
  1325 0000099D 00<rep 20h>         <1> i2c_desc_buf:       times 32 db 0   ; Raw HID descriptor (30 bytes)
  1326 000009BD 00<rep 100h>        <1> i2c_report_buf:     times 256 db 0  ; Input report buffer (variable length)
  1327                              <1> 
  1328                              <1> I2C_RDESC_BUF_SIZE  equ 512
  1329 00000ABD 00<rep 200h>        <1> i2c_rdesc_buf:      times I2C_RDESC_BUF_SIZE db 0  ; Report descriptor buffer
  1330                              <1> 
  1331                              <1> ; Strings
