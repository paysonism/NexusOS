   134                              <1> ; --- itoa: Convert integer to ASCII string ---
   135                              <1> ; RDI = value (unsigned 64-bit), RSI = buffer, EDX = radix (10 or 16)
   136                              <1> ; Returns: RAX = pointer to buffer
   137                              <1> global fn_itoa
   138                              <1> fn_itoa:
   139 00011189 53                  <1>     push rbx
   140 0001118A 51                  <1>     push rcx
   141 0001118B 57                  <1>     push rdi
   142 0001118C 56                  <1>     push rsi
   143 0001118D 4150                <1>     push r8
   144                              <1> 
   145 0001118F 4889F8              <1>     mov rax, rdi             ; Value
   146 00011192 4989F0              <1>     mov r8, rsi              ; Buffer start
   147 00011195 4889F3              <1>     mov rbx, rsi             ; Working pointer
   148 00011198 89D1                <1>     mov ecx, edx             ; Radix
   149                              <1> 
   150                              <1>     ; Special case: 0
   151 0001119A 4885C0              <1>     test rax, rax
   152 0001119D 7508                <1>     jnz .itoa_loop
   153 0001119F C60330              <1>     mov byte [rbx], '0'
   154 000111A2 48FFC3              <1>     inc rbx
   155 000111A5 EB3C                <1>     jmp .itoa_terminate
   156                              <1> 
   157                              <1> .itoa_loop:
   158 000111A7 4885C0              <1>     test rax, rax
   159 000111AA 7419                <1>     jz .itoa_reverse
   160 000111AC 31D2                <1>     xor edx, edx
   161 000111AE 48F7F1              <1>     div rcx                  ; RAX = quotient, RDX = remainder
   162 000111B1 80FA0A              <1>     cmp dl, 10
   163 000111B4 7C05                <1>     jl .digit
   164 000111B6 80C237              <1>     add dl, 'A' - 10
   165 000111B9 EB03                <1>     jmp .store
   166                              <1> .digit:
   167 000111BB 80C230              <1>     add dl, '0'
   168                              <1> .store:
   169 000111BE 8813                <1>     mov [rbx], dl
   170 000111C0 48FFC3              <1>     inc rbx
   171 000111C3 EBE2                <1>     jmp .itoa_loop
   172                              <1> 
   173                              <1> .itoa_reverse:
   174                              <1>     ; Null-terminate
   175 000111C5 C60300              <1>     mov byte [rbx], 0
   176 000111C8 48FFCB              <1>     dec rbx                  ; Point to last digit
   177                              <1> 
   178                              <1>     ; Reverse the string
   179 000111CB 4C89C7              <1>     mov rdi, r8              ; Start
   180                              <1> .rev_loop:
   181 000111CE 4839DF              <1>     cmp rdi, rbx
   182 000111D1 7313                <1>     jae .itoa_done           ; unsigned compare: pointers are unsigned
   183 000111D3 8A07                <1>     mov al, [rdi]
   184 000111D5 8A0B                <1>     mov cl, [rbx]
   185 000111D7 880F                <1>     mov [rdi], cl
   186 000111D9 8803                <1>     mov [rbx], al
   187 000111DB 48FFC7              <1>     inc rdi
   188 000111DE 48FFCB              <1>     dec rbx
   189 000111E1 EBEB                <1>     jmp .rev_loop
   190                              <1> 
   191                              <1> .itoa_terminate:
   192 000111E3 C60300              <1>     mov byte [rbx], 0
   193                              <1> 
   194                              <1> .itoa_done:
   195 000111E6 4C89C0              <1>     mov rax, r8              ; Return buffer pointer
   196                              <1> 
   197 000111E9 4158                <1>     pop r8
   198 000111EB 5E                  <1>     pop rsi
   199 000111EC 5F                  <1>     pop rdi
   200 000111ED 59                  <1>     pop rcx
   201 000111EE 5B                  <1>     pop rbx
   202 000111EF C3                  <1>     ret
   203                              <1> 
   204                              <1> ; --- itoa_dec2: Format a number as 2-digit decimal with leading zero ---
   205                              <1> ; EDI = value (0-99), RSI = buffer (at least 3 bytes)
   206                              <1> global fn_itoa_dec2
   207                              <1> fn_itoa_dec2:
   208 000111F0 50                  <1>     push rax
   209 000111F1 52                  <1>     push rdx
   210                              <1> 
   211 000111F2 89F8                <1>     mov eax, edi
   212 000111F4 31D2                <1>     xor edx, edx
   213 000111F6 B90A000000          <1>     mov ecx, 10
   214 000111FB F7F1                <1>     div ecx                  ; EAX = tens, EDX = ones
   215                              <1> 
   216 000111FD 0430                <1>     add al, '0'
   217 000111FF 8806                <1>     mov [rsi], al
   218 00011201 80C230              <1>     add dl, '0'
   219 00011204 885601              <1>     mov [rsi + 1], dl
   220 00011207 C6460200            <1>     mov byte [rsi + 2], 0
   221                              <1> 
   222 0001120B 5A                  <1>     pop rdx
   223 0001120C 58                  <1>     pop rax
   224 0001120D C3                  <1>     ret
   225                              <1> 
