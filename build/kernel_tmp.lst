   349 00006748 59                  <1>     pop rcx
   350 00006749 FFC1                <1>     inc ecx
   351 0000674B EBC0                <1>     jmp .try_addr
   352                              <1> 
   353                              <1> .addr_fail:
   354 0000674D 31C0                <1>     xor eax, eax
   355                              <1> 
   356                              <1> .addr_ret:
