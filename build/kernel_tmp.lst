   413 000044CA 8905(B4050000)      <1>     mov [xhci_hcsparams1], eax
   414 000044D0 25FF000000          <1>     and eax, 0xFF                 ; MaxSlots (bits 0-7)
   415 000044D5 8805(AC050000)      <1>     mov [xhci_max_slots], al
   416 000044DB 8B05(B4050000)      <1>     mov eax, [xhci_hcsparams1]
   417 000044E1 C1E818              <1>     shr eax, 24                   ; MaxPorts (bits 24-31)
   418 000044E4 8805(AD050000)      <1>     mov [xhci_max_ports], al
   419                              <1> 
   420                              <1>     ; HCSPARAMS2
   421 000044EA 8B4608              <1>     mov eax, [rsi + XHCI_CAP_HCSPARAMS2]
   422 000044ED 8905(B8050000)      <1>     mov [xhci_hcsparams2], eax
