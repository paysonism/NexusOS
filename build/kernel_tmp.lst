    83                                  section .text
    84                                  %include "src/kernel/drivers/pci.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - PCI Driver
     3                              <1> ; Basic mechanism to read/write PCI configuration space
     4                              <1> ; ============================================================================
     5                              <1> bits 64
     6                              <1> 
     7                              <1> section .text
     8                              <1> 
     9                              <1> ; --- Read 32-bit word from PCI Config Space ---
    10                              <1> ; Arguments:
    11                              <1> ;   RBX = Bus (8 bits) | Device (5 bits) | Function (3 bits) | Register (8 bits, must be dword aligned)
    12                              <1> ;         Format: 0000:bbbb:bbbb:dddd:dfff:rrrr:rr00
    13                              <1> ;         Actually standard format is:
    14                              <1> ;         Bit 31: Enable (1)
    15                              <1> ;         Bit 30-24: Reserved
    16                              <1> ;         Bit 23-16: Bus
    17                              <1> ;         Bit 15-11: Device
    18                              <1> ;         Bit 10-8: Function
    19                              <1> ;         Bit 7-2: Register (00- FC)
    20                              <1> ;
    21                              <1> ;   We'll take a packed address in EAX or separate args?
    22                              <1> ;   Let's use a simpler signature:
    23                              <1> ;   EAX = Packed Address (Bus << 16 | Dev << 11 | Func << 8 | Reg)
    24                              <1> ; Returns:
    25                              <1> ;   EAX = Value
    26                              <1> global pci_read_conf_dword
    27                              <1> pci_read_conf_dword:
    28 00004153 52                  <1>     push rdx
    29                              <1>     
    30 00004154 0D00000080          <1>     or eax, 0x80000000       ; Set Enable bit
    31 00004159 66BAF80C            <1>     mov dx, 0xCF8
    32 0000415D EF                  <1>     out dx, eax
    33                              <1>     
    34 0000415E 66BAFC0C            <1>     mov dx, 0xCFC
    35 00004162 ED                  <1>     in eax, dx
    36                              <1>     
    37 00004163 5A                  <1>     pop rdx
    38 00004164 C3                  <1>     ret
    39                              <1> 
    40                              <1> ; --- Write 32-bit word to PCI Config Space ---
    41                              <1> ; Arguments:
    42                              <1> ;   EAX = Packed Address
    43                              <1> ;   ECX = Value
    44                              <1> global pci_write_conf_dword
    45                              <1> pci_write_conf_dword:
    46 00004165 52                  <1>     push rdx
    47                              <1>     
    48 00004166 0D00000080          <1>     or eax, 0x80000000
    49 0000416B 66BAF80C            <1>     mov dx, 0xCF8
    50 0000416F EF                  <1>     out dx, eax
    51                              <1>     
    52 00004170 66BAFC0C            <1>     mov dx, 0xCFC
    53 00004174 89C8                <1>     mov eax, ecx
    54 00004176 EF                  <1>     out dx, eax
    55                              <1>     
    56 00004177 5A                  <1>     pop rdx
    57 00004178 C3                  <1>     ret
    85                                  section .text
    86                                  %include "src/kernel/drivers/xhci.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - USB XHCI Host Controller Driver
