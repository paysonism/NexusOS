   181 000065FF E84FDBFFFF          <1>     call pci_read_conf_dword
   182 00006604 83F8FF              <1>     cmp eax, 0xFFFFFFFF
   183 00006607 7503                <1>     jne .pci_check_vendor
   184 00006609 58                  <1>     pop rax                     ; balance push before jumping
