   522 0000F1DE C6470142            <2>     mov byte [rdi + 1], 'B'
   523 0000F1E2 C6470200            <2>     mov byte [rdi + 2], 0
   524                              <2> 
   525                              <2> .skip_u2s:
   526                              <2> .u2s_done:
