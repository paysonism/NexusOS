   435 0000450E 8905(BC050000)      <1>     mov [xhci_hccparams1], eax
   436                              <1>     ; Context size: bit 2 = CSZ (0=32 bytes, 1=64 bytes)
   437 00004514 A904000000          <1>     test eax, 0x04
   438 00004519 7409                <1>     jz .ctx_32
   439 0000451B C605(AF050000)40    <1>     mov byte [xhci_ctx_size], 64
   440 00004522 EB07                <1>     jmp .ctx_done
   441                              <1> .ctx_32:
   442 00004524 C605(AF050000)20    <1>     mov byte [xhci_ctx_size], 32
   443                              <1> .ctx_done:
   444                              <1> 
   445                              <1>     ; DBOFF
   446 0000452B 8B4614              <1>     mov eax, [rsi + XHCI_CAP_DBOFF]
