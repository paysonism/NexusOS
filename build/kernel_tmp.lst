   241 0000667B 85C0                <1>     test eax, eax
   242 0000667D 7533                <1>     jnz .found_pop
   243                              <1> 
   244                              <1> .pci_next_pop:
   245 0000667F 58                  <1>     pop rax
   246                              <1> .pci_next:
   247                              <1>     ; Advance PCI scan
   248 00006680 41FFC7              <1>     inc r15d
   249 00006683 4183FF08            <1>     cmp r15d, 8
