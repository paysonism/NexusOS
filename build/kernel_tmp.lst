   674 000046E1 39CA                <1>     cmp edx, ecx
   675 000046E3 7D14                <1>     jge .scratch_set_dcbaa
   676                              <1>     ; Buffer address = XHCI_SCRATCH_ADDR + 0x1000 * (edx + 1)
   677 000046E5 89D0                <1>     mov eax, edx
   678 000046E7 FFC0                <1>     inc eax
   679 000046E9 C1E00C              <1>     shl eax, 12                   ; * 4096
   680 000046EC 0500009400          <1>     add eax, XHCI_SCRATCH_ADDR
   681 000046F1 488904D7            <1>     mov [rdi + rdx * 8], rax      ; Write 64-bit pointer to array
   682 000046F5 FFC2                <1>     inc edx
   683 000046F7 EBE8                <1>     jmp .scratch_loop
   684                              <1> 
   685                              <1> .scratch_set_dcbaa:
   686                              <1>     ; DCBAA[0] = scratchpad array pointer
   687 000046F9 BF00009000          <1>     mov rdi, XHCI_DCBAA_ADDR
   688 000046FE 48C70700009400      <1>     mov qword [rdi], XHCI_SCRATCH_ADDR
   689                              <1> 
   690                              <1> .scratch_done:
   691 00004705 5F                  <1>     pop rdi
   692 00004706 59                  <1>     pop rcx
   693 00004707 C3                  <1>     ret
