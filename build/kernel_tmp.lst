   378 0000F11B AA                  <2>     stosb
   379 0000F11C FFC9                <2>     dec ecx
   380 0000F11E 75F6                <2>     jnz .ext_copy
   381                              <2> .ext_done:
   382                              <2> .fn_noext:
   383 0000F120 C60700              <2>     mov byte [rdi], 0     ; null terminate
   384                              <2> 
   385 0000F123 5E                  <2>     pop rsi
   386 0000F124 5F                  <2>     pop rdi
   387 0000F125 5A                  <2>     pop rdx
   388 0000F126 59                  <2>     pop rcx
   389 0000F127 58                  <2>     pop rax
   390 0000F128 C3                  <2>     ret
