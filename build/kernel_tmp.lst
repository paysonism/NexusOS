   196                              <1> .pci_check_class:
   197                              <1>     ; Read class code (reg 0x08)
   198 0000661A 58                  <1>     pop rax
   199 0000661B 50                  <1>     push rax
   200 0000661C 83C808              <1>     or eax, 0x08                ; Register 0x08
   201 0000661F E82FDBFFFF          <1>     call pci_read_conf_dword
   202                              <1>     ; Class code is in bits 31:8
   203 00006624 C1E808              <1>     shr eax, 8
   204                              <1>     ; Check class=0x0C (Serial Bus), subclass=0x80 (Other)
   205                              <1>     ; EAX high 16 bits = class:subclass
   206 00006627 C1E808              <1>     shr eax, 8
   207 0000662A 663D800C            <1>     cmp ax, 0x0C80
