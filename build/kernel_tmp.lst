    23                              <2> 
    24                              <2> ; FN_BEGIN emits a normal function label plus machine-readable metadata.
    25                              <2> ; Slot is read from the global trace_active_slot (set by syscall entry).
    26                              <2> ; All caller-saved registers are preserved so this is safe to drop into
    27                              <2> ; ISR/IRQ landing pads as well as ordinary kernel functions.
    28                              <2> %macro FN_BEGIN 4
    29                              <2> %define __fn_prev_section __?SECT?__
    30                              <2>     global %1
    31                              <2> %1:
    32                              <2> %assign %{1}__argc %2
    33                              <2> %assign %{1}__kindmask %3
    34                              <2> %assign %{1}__retkind %4
    35                              <2> %ifdef ENABLE_SIG_SECTION
    36                              <2>     [section .signature]
    37                              <2> %{1}__sigmeta:
    38                              <2> %ifdef %{1}__hash
    39                              <2>     dq %{1}__hash
    40                              <2> %else
    41                              <2>     dq 0
    42                              <2> %endif
    43                              <2>     db %2
    44                              <2>     dd %3
    45                              <2>     db %4
    46                              <2>     dd __LINE__
    47                              <2>     dq %{1}__name
    48                              <2> %{1}__name:
    49                              <2>     db %str(%1), 0
    50                              <2>     __fn_prev_section
    51                              <2> %endif
    52                              <2> %ifdef ENABLE_TRACE
    53                              <2> %ifndef DISABLE_FN_RUNTIME_TRACE
    54                              <2>     push rax
    55                              <2>     push rcx
    56                              <2>     push rdx
    57                              <2>     push rsi
    58                              <2>     push rdi
    59                              <2>     push r8
    60                              <2>     push r9
    61                              <2>     push r10
    62                              <2>     push r11
    63                              <2> %ifdef %{1}__hash32
    64                              <2>     mov edi, %{1}__hash32
    65                              <2> %else
    66                              <2>     mov edi, %1
    67                              <2> %endif
    68                              <2>     movzx esi, byte [rel trace_active_slot]
    69                              <2>     call trace_fn_enter
    70                              <2>     pop r11
    71                              <2>     pop r10
    72                              <2>     pop r9
    73                              <2>     pop r8
    74                              <2>     pop rdi
    75                              <2>     pop rsi
    76                              <2>     pop rdx
    77                              <2>     pop rcx
    78                              <2>     pop rax
    79                              <2> %endif
    80                              <2> %endif
    81                              <2> %endmacro
    82                              <2> 
    83                              <2> ; FN_ARG is intentionally doc-only for now. The registry builder reads source
    84                              <2> ; FN_ARG lines and attaches arg names/kinds to the JSON sidecar.
    85                              <2> %macro FN_ARG 3
    86                              <2> %endmacro
