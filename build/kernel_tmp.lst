   163                              <1>     ; Scan PCI for Intel LPSS I2C controllers
   164                              <1>     ; Look for: vendor=0x8086, class code byte 0x0C (Serial Bus), subclass 0x80
   165 000065DF 4531ED              <1>     xor r13d, r13d              ; PCI bus
   166 000065E2 4531F6              <1>     xor r14d, r14d              ; PCI device
   167 000065E5 4531FF              <1>     xor r15d, r15d              ; PCI function
   168                              <1> 
   169                              <1> .pci_scan:
   170                              <1>     ; Build PCI address: bus<<16 | dev<<11 | func<<8 | reg
   171 000065E8 4489E8              <1>     mov eax, r13d
   172 000065EB C1E010              <1>     shl eax, 16
   173 000065EE 4489F1              <1>     mov ecx, r14d
   174 000065F1 C1E10B              <1>     shl ecx, 11
   175 000065F4 09C8                <1>     or eax, ecx
   176 000065F6 4489F9              <1>     mov ecx, r15d
   177 000065F9 C1E108              <1>     shl ecx, 8
   178 000065FC 09C8                <1>     or eax, ecx
