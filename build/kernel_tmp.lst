   460                              <1> ; ============================================================================
   461                              <1> ; xhci_take_ownership - Take XHCI from BIOS via Legacy Support capability
   462                              <1> ; ============================================================================
   463                              <1> xhci_take_ownership:
   464 0000454D 56                  <1>     push rsi
   465 0000454E 51                  <1>     push rcx
   466 0000454F 50                  <1>     push rax
   467                              <1> 
   468 00004550 488B35(8A050000)    <1>     mov rsi, [xhci_mmio_base]
   469 00004557 8B05(BC050000)      <1>     mov eax, [xhci_hccparams1]
   470 0000455D C1E810              <1>     shr eax, 16                   ; xECP offset in dwords
   471 00004560 C1E002              <1>     shl eax, 2                    ; Convert to bytes
   472 00004563 85C0                <1>     test eax, eax
   473 00004565 7475                <1>     jz .own_done                  ; No extended capabilities
   474                              <1> 
   475 00004567 4801C6              <1>     add rsi, rax                  ; RSI = first extended cap
   476                              <1> 
   477                              <1> .cap_loop:
   478 0000456A 8B06                <1>     mov eax, [rsi]
   479 0000456C 89C1                <1>     mov ecx, eax
   480 0000456E 81E1FF000000        <1>     and ecx, 0xFF                 ; Capability ID
   481 00004574 83F901              <1>     cmp ecx, 1                    ; USB Legacy Support
   482 00004577 7414                <1>     je .found_legacy
   483                              <1> 
   484                              <1>     ; Next capability
   485 00004579 C1E808              <1>     shr eax, 8
   486 0000457C 25FF000000          <1>     and eax, 0xFF                 ; Next offset (in dwords)
   487 00004581 85C0                <1>     test eax, eax
   488 00004583 7457                <1>     jz .own_done                  ; End of list
   489 00004585 C1E002              <1>     shl eax, 2
   490 00004588 4801C6              <1>     add rsi, rax
   491 0000458B EBDD                <1>     jmp .cap_loop
   492                              <1> 
   493                              <1> .found_legacy:
   494                              <1>     ; Check if BIOS owns it
   495 0000458D 8B06                <1>     mov eax, [rsi]
   496 0000458F A900000100          <1>     test eax, (1 << 16)          ; BIOS Owned Semaphore
   497 00004594 7446                <1>     jz .own_done                  ; BIOS doesn't own it
   498                              <1> 
   499                              <1>     ; Set OS Owned Semaphore (bit 24)
   500 00004596 0D00000001          <1>     or eax, (1 << 24)
   501 0000459B 8906                <1>     mov [rsi], eax
   502                              <1> 
   503                              <1>     ; Wait for BIOS to release (bit 16 = 0) - up to 100ms
   504 0000459D 52                  <1>     push rdx
   505 0000459E 51                  <1>     push rcx
   506 0000459F 488B15(40000000)    <1>     mov rdx, [tick_count]
   507 000045A6 4883C20A            <1>     add rdx, 10              ; 10 ticks = 100ms
   508 000045AA B980841E00          <1>     mov ecx, 2000000
   509                              <1> .wait_bios:
   510 000045AF 8B06                <1>     mov eax, [rsi]
   511 000045B1 A900000100          <1>     test eax, (1 << 16)
   512 000045B6 7422                <1>     jz .own_done_pop
   513 000045B8 FFC9                <1>     dec ecx
   514 000045BA 7410                <1>     jz .bios_timeout
   515 000045BC 488B05(40000000)    <1>     mov rax, [tick_count]
   516 000045C3 4839D0              <1>     cmp rax, rdx
   517 000045C6 7D04                <1>     jge .bios_timeout
   518 000045C8 F390                <1>     pause
   519 000045CA EBE3                <1>     jmp .wait_bios
   520                              <1> .bios_timeout:
   521                              <1>     ; Timeout - force release
   522 000045CC 8B06                <1>     mov eax, [rsi]
   523 000045CE 25FFFFFEFF          <1>     and eax, ~(1 << 16)
   524 000045D3 0D00000001          <1>     or eax, (1 << 24)
   525 000045D8 8906                <1>     mov [rsi], eax
   526                              <1> .own_done_pop:
   527 000045DA 59                  <1>     pop rcx
   528 000045DB 5A                  <1>     pop rdx
   529                              <1> 
   530                              <1> .own_done:
   531 000045DC 58                  <1>     pop rax
   532 000045DD 59                  <1>     pop rcx
   533 000045DE 5E                  <1>     pop rsi
   534 000045DF C3                  <1>     ret
