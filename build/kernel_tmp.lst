     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - Math Utility Functions
     3                              <1> ; ============================================================================
     4                              <1> bits 64
     5                              <1> 
     6                              <1> section .text
     7                              <1> 
     8                              <1> ; --- clamp: Clamp value to range ---
     9                              <1> ; EDI = value, ESI = min, EDX = max
    10                              <1> ; Returns: EAX = clamped value
    11                              <1> global fn_clamp
    12                              <1> fn_clamp:
    13 00011218 89F8                <1>     mov eax, edi
    14 0001121A 39F0                <1>     cmp eax, esi
    15 0001121C 0F4CC6              <1>     cmovl eax, esi           ; If value < min, use min
    16 0001121F 39D0                <1>     cmp eax, edx
    17 00011221 0F4FC2              <1>     cmovg eax, edx           ; If value > max, use max
    18 00011224 C3                  <1>     ret
    19                              <1> 
    20                              <1> ; --- min: Integer minimum ---
    21                              <1> ; EDI = a, ESI = b
    22                              <1> ; Returns: EAX = min(a, b)
    23                              <1> global fn_min
    24                              <1> fn_min:
    25 00011225 89F8                <1>     mov eax, edi
    26 00011227 39F0                <1>     cmp eax, esi
    27 00011229 0F4FC6              <1>     cmovg eax, esi
    28 0001122C C3                  <1>     ret
    29                              <1> 
    30                              <1> ; --- max: Integer maximum ---
    31                              <1> ; EDI = a, ESI = b
    32                              <1> ; Returns: EAX = max(a, b)
    33                              <1> global fn_max
    34                              <1> fn_max:
    35 0001122D 89F8                <1>     mov eax, edi
    36 0001122F 39F0                <1>     cmp eax, esi
    37 00011231 0F4CC6              <1>     cmovl eax, esi
    38 00011234 C3                  <1>     ret
    39                              <1> 
    40                              <1> ; --- abs: Absolute value ---
    41                              <1> ; EDI = value
    42                              <1> ; Returns: EAX = |value|
    43                              <1> global fn_abs
    44                              <1> fn_abs:
    45 00011235 89F8                <1>     mov eax, edi
    46 00011237 99                  <1>     cdq
    47 00011238 31D0                <1>     xor eax, edx
    48 0001123A 29D0                <1>     sub eax, edx
    49 0001123C C3                  <1>     ret
    50                              <1> 
    51                              <1> ; --- rect_intersect: Test if two rectangles overlap ---
    52                              <1> ; RDI = rect1 pointer, RSI = rect2 pointer
    53                              <1> ; Returns: EAX = 1 if overlapping, 0 if not
    54                              <1> global fn_rect_intersect
    55                              <1> fn_rect_intersect:
    56                              <1>     ; rect1.x + rect1.w <= rect2.x?
    57 0001123D 8B07                <1>     mov eax, [rdi]           ; rect1.x
    58 0001123F 034708              <1>     add eax, [rdi + 8]      ; + rect1.w
    59 00011242 3B06                <1>     cmp eax, [rsi]           ; vs rect2.x
    60 00011244 7E25                <1>     jle .no_intersect
    61                              <1> 
    62                              <1>     ; rect2.x + rect2.w <= rect1.x?
    63 00011246 8B06                <1>     mov eax, [rsi]
    64 00011248 034608              <1>     add eax, [rsi + 8]
    65 0001124B 3B07                <1>     cmp eax, [rdi]
    66 0001124D 7E1C                <1>     jle .no_intersect
    67                              <1> 
    68                              <1>     ; rect1.y + rect1.h <= rect2.y?
    69 0001124F 8B4704              <1>     mov eax, [rdi + 4]
    70 00011252 03470C              <1>     add eax, [rdi + 12]
    71 00011255 3B4604              <1>     cmp eax, [rsi + 4]
    72 00011258 7E11                <1>     jle .no_intersect
    73                              <1> 
    74                              <1>     ; rect2.y + rect2.h <= rect1.y?
    75 0001125A 8B4604              <1>     mov eax, [rsi + 4]
    76 0001125D 03460C              <1>     add eax, [rsi + 12]
    77 00011260 3B4704              <1>     cmp eax, [rdi + 4]
    78 00011263 7E06                <1>     jle .no_intersect
    79                              <1> 
    80 00011265 B801000000          <1>     mov eax, 1
    81 0001126A C3                  <1>     ret
    82                              <1> 
    83                              <1> .no_intersect:
    84 0001126B 31C0                <1>     xor eax, eax
    85 0001126D C3                  <1>     ret
