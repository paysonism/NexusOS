   104                              <2> %endif
   105                              <2>     movzx esi, byte [rel trace_active_slot]
   106                              <2>     mov rdx, [rsp + 8*8]            ; saved RAX (retval) sits 8 qwords below top
   107                              <2>     call trace_fn_exit
   108                              <2>     pop r11
   109                              <2>     pop r10
   110                              <2>     pop r9
   111                              <2>     pop r8
   112                              <2>     pop rdi
   113                              <2>     pop rsi
   114                              <2>     pop rdx
   115                              <2>     pop rcx
   116                              <2>     pop rax
   117                              <2> %endif
   118                              <2> %endif
   119                              <2> %endmacro
