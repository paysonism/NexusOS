   186                              <1> .pci_check_vendor:
   187                              <1>     ; Check vendor = 0x8086 (Intel) or 0x1022 (AMD)
   188 0000660C 663D8680            <1>     cmp ax, 0x8086
   189 00006610 7408                <1>     je .pci_check_class
   190 00006612 663D2210            <1>     cmp ax, 0x1022
