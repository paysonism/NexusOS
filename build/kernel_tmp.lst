   152 000062AC C605(0BD90000)00    <1>     mov byte [spi_tx_buf + 5], 0x00    ; wDescriptorAddress high
   153                              <1> 
   154 000062B3 488D3D(06D90000)    <1>     lea rdi, [spi_tx_buf]
   155 000062BA BE06000000          <1>     mov rsi, 6
   156 000062BF 488D15(16D90000)    <1>     lea rdx, [spi_rx_buf]
   157 000062C6 B91E000000          <1>     mov rcx, 30
