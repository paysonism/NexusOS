   191                              <2> %else
   192                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   193                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   194                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   195                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   196                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   197                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   198                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   199                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   200                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   201                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   202                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   203                              <2> ; Slot 2 device support
   204                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   205                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   206                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   207                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   208                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   209                              <2> %endif
   210                              <2> 
   211                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   212                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   213                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   214                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   215                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   216                              <2> XHCI_CAP_DBOFF      equ 0x14
   217                              <2> XHCI_CAP_RTSOFF     equ 0x18
   218                              <2> 
   219                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   220                              <2> XHCI_OP_USBCMD      equ 0x00
   221                              <2> XHCI_OP_USBSTS      equ 0x04
   222                              <2> XHCI_OP_PAGESIZE     equ 0x08
   223                              <2> XHCI_OP_DNCTRL      equ 0x14
   224                              <2> XHCI_OP_CRCR_LO     equ 0x18
   225                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   226                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   227                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   228                              <2> XHCI_OP_CONFIG      equ 0x38
   229                              <2> 
   230                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   231                              <2> XHCI_PORTSC         equ 0x00
   232                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   233                              <2> 
   234                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   235                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   236                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   237                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   238                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   239                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   240                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   241                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   242                              <2> 
   243                              <2> ; --- USBCMD bits ---
   244                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   245                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   246                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   247                              <2> 
   248                              <2> ; --- USBSTS bits ---
   249                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   250                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   251                              <2> 
   252                              <2> ; --- PORTSC bits ---
   253                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   254                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   255                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   256                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   257                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   258                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   259                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   260                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   261                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   262                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   263                              <2> 
   264                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   265                              <2> TRB_NORMAL           equ (1 << 10)
   266                              <2> TRB_SETUP            equ (2 << 10)
   267                              <2> TRB_DATA             equ (3 << 10)
   268                              <2> TRB_STATUS           equ (4 << 10)
   269                              <2> TRB_LINK             equ (6 << 10)
   270                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   271                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   272                              <2> TRB_CONFIG_EP        equ (12 << 10)
   273                              <2> TRB_EVAL_CTX         equ (13 << 10)
   274                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   275                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   276                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   277                              <2> 
   278                              <2> ; --- TRB Flag Bits (dword 3) ---
   279                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   280                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   281                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   282                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   283                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   284                              <2> 
   285                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   286                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   287                              <2> TRB_TRT_OUT          equ (2 << 16)
   288                              <2> TRB_TRT_IN           equ (3 << 16)
   289                              <2> 
   290                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   291                              <2> TRB_DIR_OUT          equ (0 << 16)
   292                              <2> TRB_DIR_IN           equ (1 << 16)
   293                              <2> 
   294                              <2> ; --- Ring sizes ---
   295                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   296                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   297                              <2> 
   298                              <2> ; --- USB Standard Request Codes ---
   299                              <2> USB_REQ_GET_DESC     equ 0x06
   300                              <2> USB_REQ_SET_CONFIG   equ 0x09
   301                              <2> USB_REQ_SET_IFACE    equ 0x0B
   302                              <2> 
   303                              <2> ; --- USB HID Request Codes ---
   304                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   305                              <2> 
   306                              <2> ; --- USB Descriptor Types ---
   307                              <2> USB_DESC_DEVICE      equ 0x01
   308                              <2> USB_DESC_CONFIG      equ 0x02
   309                              <2> USB_DESC_INTERFACE   equ 0x04
   310                              <2> USB_DESC_ENDPOINT    equ 0x05
   311                              <2> USB_DESC_HID         equ 0x21
   312                              <2> 
   313                              <2> ; --- USB Endpoint Types ---
   314                              <2> USB_EP_CONTROL       equ 0
   315                              <2> USB_EP_ISOCH         equ 1
   316                              <2> USB_EP_BULK          equ 2
   317                              <2> USB_EP_INTERRUPT     equ 3
   318                              <2> 
   319                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   320                              <2> XHCI_EP_NOT_VALID    equ 0
   321                              <2> XHCI_EP_ISOCH_OUT    equ 1
   322                              <2> XHCI_EP_BULK_OUT     equ 2
   323                              <2> XHCI_EP_INT_OUT      equ 3
   324                              <2> XHCI_EP_CONTROL      equ 4
   325                              <2> XHCI_EP_ISOCH_IN     equ 5
   326                              <2> XHCI_EP_BULK_IN      equ 6
   327                              <2> XHCI_EP_INT_IN       equ 7
   328                              <2> 
   329                              <2> ; --- XHCI Port Speeds ---
   330                              <2> XHCI_SPEED_FULL      equ 1
   331                              <2> XHCI_SPEED_LOW       equ 2
   332                              <2> XHCI_SPEED_HIGH      equ 3
   333                              <2> XHCI_SPEED_SUPER     equ 4
     8                              <1> 
     9                              <1> extern tick_count
    10                              <1> 
    11                              <1> section .text
    12                              <1> 
    13                              <1> global ata_read_sectors
    14                              <1> global ata_write_sectors
    15                              <1> global ata_drive_select_byte
    16                              <1> global ata_drive_sel
    17                              <1> 
    18                              <1> ; ATA PIO ports (primary controller)
    19                              <1> ATA_DATA        equ 0x1F0
    20                              <1> ATA_ERROR       equ 0x1F1
    21                              <1> ATA_SECT_COUNT  equ 0x1F2
    22                              <1> ATA_LBA_LO     equ 0x1F3
    23                              <1> ATA_LBA_MID     equ 0x1F4
    24                              <1> ATA_LBA_HI      equ 0x1F5
    25                              <1> ATA_DRIVE       equ 0x1F6
    26                              <1> ATA_CMD         equ 0x1F7
    27                              <1> ATA_STATUS      equ 0x1F7
    28                              <1> 
    29                              <1> ATA_CMD_READ    equ 0x20
    30                              <1> ATA_CMD_WRITE   equ 0x30
    31                              <1> 
    32                              <1> ATA_SR_BSY      equ 0x80
    33                              <1> ATA_SR_DRQ      equ 0x08
    34                              <1> ATA_SR_ERR      equ 0x01
    35                              <1> 
    36                              <1> ; ============================================================================
    37                              <1> ; ata_read_sectors - Read sectors from disk using LBA28 PIO
    38                              <1> ; rdi = LBA (sector number)
    39                              <1> ; rsi = pointer to destination buffer
    40                              <1> ; edx = number of sectors to read
    41                              <1> ; Returns: eax = 0 on success, -1 on error
    42                              <1> ; ============================================================================
    43                              <1> ata_read_sectors:
    44 00003FA6 53                  <1>     push rbx
    45 00003FA7 51                  <1>     push rcx
    46 00003FA8 52                  <1>     push rdx
    47 00003FA9 57                  <1>     push rdi
    48 00003FAA 56                  <1>     push rsi
    49 00003FAB 4154                <1>     push r12
    50 00003FAD 4155                <1>     push r13
    51                              <1> 
    52 00003FAF 4989FC              <1>     mov r12, rdi         ; LBA
    53 00003FB2 4989F5              <1>     mov r13, rsi         ; buffer
    54 00003FB5 89D3                <1>     mov ebx, edx         ; sector count
    55                              <1> 
    56                              <1> .read_loop:
    57 00003FB7 85DB                <1>     test ebx, ebx
    58 00003FB9 745B                <1>     jz .read_done
    59                              <1> 
    60                              <1>     ; Select drive and wait for it to be ready
    61 00003FBB E85C010000          <1>     call ata_select_drive
    62 00003FC0 85C0                <1>     test eax, eax
    63 00003FC2 7556                <1>     jnz .read_error
    64                              <1> 
    65                              <1>     ; Sector count = 1
    66 00003FC4 66BAF201            <1>     mov dx, ATA_SECT_COUNT
    67 00003FC8 B001                <1>     mov al, 1
    68 00003FCA EE                  <1>     out dx, al
    69                              <1> 
    70                              <1>     ; LBA low byte
    71 00003FCB 4489E0              <1>     mov eax, r12d
    72 00003FCE 66BAF301            <1>     mov dx, ATA_LBA_LO
    73 00003FD2 EE                  <1>     out dx, al
    74                              <1> 
    75                              <1>     ; LBA mid byte
    76 00003FD3 4489E0              <1>     mov eax, r12d
    77 00003FD6 C1E808              <1>     shr eax, 8
    78 00003FD9 66BAF401            <1>     mov dx, ATA_LBA_MID
    79 00003FDD EE                  <1>     out dx, al
    80                              <1> 
    81                              <1>     ; LBA high byte
    82 00003FDE 4489E0              <1>     mov eax, r12d
    83 00003FE1 C1E810              <1>     shr eax, 16
    84 00003FE4 66BAF501            <1>     mov dx, ATA_LBA_HI
    85 00003FE8 EE                  <1>     out dx, al
    86                              <1> 
    87                              <1>     ; Send READ command
    88 00003FE9 66BAF701            <1>     mov dx, ATA_CMD
    89 00003FED B020                <1>     mov al, ATA_CMD_READ
    90 00003FEF EE                  <1>     out dx, al
    91                              <1> 
    92                              <1>     ; Wait for data ready
    93 00003FF0 E8F3000000          <1>     call ata_wait_drq
    94 00003FF5 85C0                <1>     test eax, eax
    95 00003FF7 7521                <1>     jnz .read_error
    96                              <1> 
    97                              <1>     ; Read 256 words (512 bytes) from data port
    98 00003FF9 4C89EF              <1>     mov rdi, r13
    99 00003FFC 66BAF001            <1>     mov dx, ATA_DATA
   100 00004000 B900010000          <1>     mov ecx, 256
   101 00004005 F3666D              <1>     rep insw
   102                              <1> 
   103                              <1>     ; Advance to next sector
   104 00004008 4981C500020000      <1>     add r13, 512
   105 0000400F 49FFC4              <1>     inc r12
   106 00004012 FFCB                <1>     dec ebx
   107 00004014 EBA1                <1>     jmp .read_loop
   108                              <1> 
   109                              <1> .read_done:
   110 00004016 31C0                <1>     xor eax, eax         ; success
   111 00004018 EB05                <1>     jmp .read_ret
   112                              <1> 
   113                              <1> .read_error:
   114 0000401A B8FFFFFFFF          <1>     mov eax, -1
   115                              <1> 
   116                              <1> .read_ret:
   117 0000401F 415D                <1>     pop r13
   118 00004021 415C                <1>     pop r12
   119 00004023 5E                  <1>     pop rsi
   120 00004024 5F                  <1>     pop rdi
   121 00004025 5A                  <1>     pop rdx
   122 00004026 59                  <1>     pop rcx
   123 00004027 5B                  <1>     pop rbx
   124 00004028 C3                  <1>     ret
   125                              <1> 
   126                              <1> ; ============================================================================
   127                              <1> ; ata_write_sectors - Write sectors to disk using LBA28 PIO
   128                              <1> ; rdi = LBA (sector number)
   129                              <1> ; rsi = pointer to source buffer
   130                              <1> ; edx = number of sectors to write
   131                              <1> ; Returns: eax = 0 on success, -1 on error
   132                              <1> ; ============================================================================
   133                              <1> ata_write_sectors:
   134 00004029 53                  <1>     push rbx
   135 0000402A 51                  <1>     push rcx
   136 0000402B 52                  <1>     push rdx
   137 0000402C 57                  <1>     push rdi
   138 0000402D 56                  <1>     push rsi
   139 0000402E 4154                <1>     push r12
   140 00004030 4155                <1>     push r13
   141                              <1> 
   142 00004032 4989FC              <1>     mov r12, rdi         ; LBA
   143 00004035 4989F5              <1>     mov r13, rsi         ; buffer
   144 00004038 89D3                <1>     mov ebx, edx         ; sector count
   145                              <1> 
   146                              <1> .write_loop:
   147 0000403A 85DB                <1>     test ebx, ebx
   148 0000403C 7467                <1>     jz .write_done
   149                              <1> 
   150                              <1>     ; Select drive and wait for it to be ready
   151 0000403E E8D9000000          <1>     call ata_select_drive
   152 00004043 85C0                <1>     test eax, eax
   153 00004045 7562                <1>     jnz .write_error
   154                              <1> 
   155                              <1>     ; Sector count = 1
   156 00004047 66BAF201            <1>     mov dx, ATA_SECT_COUNT
   157 0000404B B001                <1>     mov al, 1
   158 0000404D EE                  <1>     out dx, al
   159                              <1> 
   160                              <1>     ; LBA bytes
   161 0000404E 4489E0              <1>     mov eax, r12d
   162 00004051 66BAF301            <1>     mov dx, ATA_LBA_LO
   163 00004055 EE                  <1>     out dx, al
   164 00004056 4489E0              <1>     mov eax, r12d
   165 00004059 C1E808              <1>     shr eax, 8
   166 0000405C 66BAF401            <1>     mov dx, ATA_LBA_MID
   167 00004060 EE                  <1>     out dx, al
   168 00004061 4489E0              <1>     mov eax, r12d
   169 00004064 C1E810              <1>     shr eax, 16
   170 00004067 66BAF501            <1>     mov dx, ATA_LBA_HI
   171 0000406B EE                  <1>     out dx, al
   172                              <1> 
   173                              <1>     ; Send WRITE command
   174 0000406C 66BAF701            <1>     mov dx, ATA_CMD
   175 00004070 B030                <1>     mov al, ATA_CMD_WRITE
   176 00004072 EE                  <1>     out dx, al
   177                              <1> 
   178                              <1>     ; Wait for DRQ
   179 00004073 E870000000          <1>     call ata_wait_drq
   180 00004078 85C0                <1>     test eax, eax
   181 0000407A 752D                <1>     jnz .write_error
   182                              <1> 
   183                              <1>     ; Write 256 words (512 bytes) to data port
   184 0000407C 4C89EE              <1>     mov rsi, r13
   185 0000407F 66BAF001            <1>     mov dx, ATA_DATA
   186 00004083 B900010000          <1>     mov ecx, 256
   187 00004088 F3666F              <1>     rep outsw
   188                              <1> 
   189                              <1>     ; Flush cache
   190 0000408B 66BAF701            <1>     mov dx, ATA_CMD
   191 0000408F B0E7                <1>     mov al, 0xE7          ; CACHE FLUSH
   192 00004091 EE                  <1>     out dx, al
   193 00004092 E821000000          <1>     call ata_wait_ready
   194                              <1> 
   195                              <1>     ; Advance
   196 00004097 4981C500020000      <1>     add r13, 512
   197 0000409E 49FFC4              <1>     inc r12
   198 000040A1 FFCB                <1>     dec ebx
   199 000040A3 EB95                <1>     jmp .write_loop
   200                              <1> 
   201                              <1> .write_done:
   202 000040A5 31C0                <1>     xor eax, eax
   203 000040A7 EB05                <1>     jmp .write_ret
   204                              <1> 
   205                              <1> .write_error:
   206 000040A9 B8FFFFFFFF          <1>     mov eax, -1
   207                              <1> 
   208                              <1> .write_ret:
   209 000040AE 415D                <1>     pop r13
   210 000040B0 415C                <1>     pop r12
   211 000040B2 5E                  <1>     pop rsi
   212 000040B3 5F                  <1>     pop rdi
   213 000040B4 5A                  <1>     pop rdx
   214 000040B5 59                  <1>     pop rcx
   215 000040B6 5B                  <1>     pop rbx
   216 000040B7 C3                  <1>     ret
   217                              <1> 
   218                              <1> ; --- Internal helpers ---
   219                              <1> 
   220                              <1> ; PIT-based deadline waits. CPU-spin loops are unreliable across CPU clocks
   221                              <1> ; (too short on fast real HW, too long on slow QEMU). 100 ticks = 1 second.
   222                              <1> ata_wait_ready:
   223 000040B8 53                  <1>     push rbx
   224 000040B9 488B1D(40000000)    <1>     mov rbx, [tick_count]
   225 000040C0 4883C364            <1>     add rbx, 100
   226                              <1> .wr_loop:
   227 000040C4 66BAF701            <1>     mov dx, ATA_STATUS
   228 000040C8 EC                  <1>     in al, dx
   229 000040C9 A880                <1>     test al, ATA_SR_BSY
   230 000040CB 7417                <1>     jz .wr_ok
   231 000040CD 488B05(40000000)    <1>     mov rax, [tick_count]
   232 000040D4 4839D8              <1>     cmp rax, rbx
   233 000040D7 7304                <1>     jae .wr_timeout
   234 000040D9 F390                <1>     pause
   235 000040DB EBE7                <1>     jmp .wr_loop
   236                              <1> .wr_timeout:
   237 000040DD 5B                  <1>     pop rbx
   238 000040DE B8FFFFFFFF          <1>     mov eax, -1
   239 000040E3 C3                  <1>     ret
   240                              <1> .wr_ok:
   241 000040E4 5B                  <1>     pop rbx
   242 000040E5 31C0                <1>     xor eax, eax
   243 000040E7 C3                  <1>     ret
   244                              <1> 
   245                              <1> ata_wait_drq:
   246 000040E8 53                  <1>     push rbx
   247 000040E9 488B1D(40000000)    <1>     mov rbx, [tick_count]
   248 000040F0 4883C364            <1>     add rbx, 100
   249                              <1> .wdrq_loop:
   250 000040F4 66BAF701            <1>     mov dx, ATA_STATUS
   251 000040F8 EC                  <1>     in al, dx
   252 000040F9 A801                <1>     test al, ATA_SR_ERR
   253 000040FB 7514                <1>     jnz .wdrq_err
   254 000040FD A808                <1>     test al, ATA_SR_DRQ
   255 000040FF 7517                <1>     jnz .wdrq_ok
   256 00004101 488B05(40000000)    <1>     mov rax, [tick_count]
   257 00004108 4839D8              <1>     cmp rax, rbx
   258 0000410B 7304                <1>     jae .wdrq_err
   259 0000410D F390                <1>     pause
   260 0000410F EBE3                <1>     jmp .wdrq_loop
   261                              <1> .wdrq_err:
   262 00004111 5B                  <1>     pop rbx
   263 00004112 B8FFFFFFFF          <1>     mov eax, -1
   264 00004117 C3                  <1>     ret
   265                              <1> .wdrq_ok:
   266 00004118 5B                  <1>     pop rbx
   267 00004119 31C0                <1>     xor eax, eax
   268 0000411B C3                  <1>     ret
   269                              <1> 
   270                              <1> 
   271                              <1> ; Helper: Select drive and wait for ready
   272                              <1> ; Uses r12d (LBA) for top bits, [ata_drive_sel] for drive
   273                              <1> ; Returns eax=0 success, -1 error
   274                              <1> ata_select_drive:
   275 0000411C 6652                <1>     push dx
   276 0000411E 6650                <1>     push ax
   277                              <1>     
   278                              <1>     ; Select drive
   279 00004120 4489E0              <1>     mov eax, r12d
   280 00004123 C1E818              <1>     shr eax, 24
   281 00004126 240F                <1>     and al, 0x0F
