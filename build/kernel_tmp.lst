    88                              <2> %macro FN_END 1
    89                              <2> %ifdef ENABLE_TRACE
    90                              <2> %ifndef DISABLE_FN_RUNTIME_TRACE
    91                              <2>     push rax                        ; preserve retval at top of save area
    92                              <2>     push rcx
