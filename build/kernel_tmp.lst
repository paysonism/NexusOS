  1010 00000EB5 50                  <1>     push rax
  1011 00000EB6 240F                <1>     and al, 0x0F
  1012 00000EB8 E827000000          <1>     call .nib
  1013 00000EBD 58                  <1>     pop rax
  1014 00000EBE C3                  <1>     ret
  1015                              <1> 
  1016                              <1> .writehex16:
  1017 00000EBF 50                  <1>     push rax
  1018 00000EC0 66C1E808            <1>     shr ax, 8
  1019 00000EC4 E8E2FFFFFF          <1>     call .writehex8
  1020 00000EC9 58                  <1>     pop rax
  1021 00000ECA 50                  <1>     push rax
  1022 00000ECB E8DBFFFFFF          <1>     call .writehex8
