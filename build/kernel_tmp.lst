    40                              <3> VBE_SPP_OFF         equ 0x18
    41                              <3> VBE_APPS_BASE_OFF   equ 0x20
    42                              <3> VBE_APPS_SIZE_OFF   equ 0x28
    43                              <3> VBE_BACKBUF_OFF     equ 0x30
    44                              <3> VBE_BACKBUF_SIZE_OFF equ 0x38
    45                              <3> VBE_APP_ARENA_BASE_OFF equ 0x40
    46                              <3> VBE_APP_ARENA_SIZE_OFF equ 0x48
    47                              <3> 
    48                              <3> %endif
     6                              <2> 
     7                              <2> ; --- Memory Layout ---
     8                              <2> ; Cache32Max speed tiers:
     9                              <2> ; - L1-hot: IRQ/syscall/scheduler/input flags/per-core state.
    10                              <2> ; - L2-warm: HID parser, window metadata, font/text primitives, FAT metadata.
    11                              <2> ; - L3/LLC GUI: framebuffer composition buffers in 4MB..16MB.
    12                              <2> ; - RAM-cold: app arenas, device DMA rings, filesystem staging, debug data.
    13                              <2> ; Core physical addresses live in boot_memory.inc.
    14                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    15                              <2> ; IDT structure is fixed size.
    16                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    17                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    18                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    19                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    20                              <2> ; So they don't overlap. This is safe.
    21                              <2> 
    22                              <2> %ifdef NEXUS_CACHE32_MAX
    23                              <2> CACHE32_RAM_LIMIT   equ 0x2000000    ; 32MB strict profile cap
    24                              <2> SYSTEM_RESERVED_END equ 0x1B00000    ; Keep allocator above fixed cold buffers
    25                              <2> SMP_CORE_STATE_ADDR equ 0x220000     ; Cacheline-aligned per-core records
    26                              <2> SMP_CORE_STACK_BASE equ 0x240000     ; AP stacks grow down from here
    27                              <2> SMP_MAX_CORES       equ 8
    28                              <2> SMP_CORE_STATE_SIZE equ 64
    29                              <2> SMP_CORE_STACK_SIZE equ 0x4000
    30                              <2> %else
    31                              <2> SMP_CORE_STATE_ADDR equ 0x220000
    32                              <2> SMP_MAX_CORES       equ 1
    33                              <2> SMP_CORE_STATE_SIZE equ 64
    34                              <2> SYSTEM_RESERVED_END equ 0xD00000
    35                              <2> %endif
    36                              <2> 
    37                              <2> ; --- Stage 2 disk layout ---
    38                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    39                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    40                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    41                              <2> 
    42                              <2> ; --- Screen ---
    43                              <2> SCREEN_WIDTH        equ 1024
    44                              <2> SCREEN_HEIGHT       equ 768
    45                              <2> SCREEN_BPP          equ 32
    46                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    47                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    48                              <2> 
    49                              <2> 
    50                              <2> ; VBE info offsets live in boot_memory.inc.
    51                              <2> 
    52                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    53                              <2> ; VGA 16-color palette (NexusOS Design System, format 0x00RRGGBB)
    54                              <2> COLOR_VGA_BLACK     equ 0x00000000   ; #000000
    55                              <2> COLOR_VGA_BLUE      equ 0x000000A8   ; #0000A8
    56                              <2> COLOR_VGA_LGRAY     equ 0x00A8A8A8   ; #A8A8A8
    57                              <2> COLOR_VGA_DGRAY     equ 0x00545454   ; #545454
    58                              <2> COLOR_VGA_WHITE     equ 0x00FCFCFC   ; #FCFCFC
    59                              <2> COLOR_VGA_TEAL      equ 0x00008080   ; #008080
    60                              <2> COLOR_VGA_RED       equ 0x00A80000   ; #A80000
    61                              <2> COLOR_VGA_GREEN     equ 0x0000A800   ; #00A800
    62                              <2> 
    63                              <2> COLOR_BLACK         equ 0x00000000
    64                              <2> COLOR_WHITE         equ 0x00FCFCFC
    65                              <2> COLOR_DESKTOP_BG    equ 0x00008080   ; Teal #008080
    66                              <2> COLOR_TASKBAR_BG    equ 0x00A8A8A8   ; VGA lightgray #A8A8A8
    67                              <2> COLOR_TASKBAR_TOP   equ 0x00FCFCFC   ; Bevel highlight
    68                              <2> COLOR_CHROME_FACE   equ 0x00A8A8A8   ; #A8A8A8 3D face
    69                              <2> COLOR_SURFACE       equ 0x00C0C0C0   ; #C0C0C0 window surface
    70                              <2> COLOR_SUNKEN        equ 0x00FCFCFC   ; #FCFCFC sunken bg
    71                              <2> COLOR_BEVEL_LT      equ 0x00FCFCFC   ; top/left highlight #FCFCFC
    72                              <2> COLOR_BEVEL_DK      equ 0x00545454   ; bottom/right shadow #545454
    73                              <2> COLOR_BEVEL_XDK     equ 0x00000000   ; outer 1px black
    74                              <2> COLOR_TITLEBAR      equ 0x000000A8   ; focused titlebar #0000A8
    75                              <2> COLOR_TITLEBAR_UNF  equ 0x00545454   ; unfocused #545454
    76                              <2> COLOR_WINDOW_BG     equ 0x00C0C0C0   ; #C0C0C0
    77                              <2> COLOR_WINDOW_BORDER equ 0x00000000   ; outer border black
    78                              <2> COLOR_CLOSE_BTN     equ 0x00A8A8A8   ; face (no red)
    79                              <2> COLOR_CLOSE_HOVER   equ 0x00C0C0C0
    80                              <2> COLOR_MIN_BTN       equ 0x00A8A8A8   ; face
    81                              <2> COLOR_TEXT_WHITE     equ 0x00FCFCFC
    82                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    83                              <2> COLOR_TEXT_GRAY      equ 0x00545454
    84                              <2> COLOR_TEXT_TITLE     equ 0x00FCFCFC   ; title bar text
    85                              <2> COLOR_HIGHLIGHT      equ 0x000000A8   ; selection = accent blue
    86                              <2> COLOR_CURSOR         equ 0x00FCFCFC
    87                              <2> COLOR_START_BTN      equ 0x00A8A8A8   ; face
    88                              <2> COLOR_START_HOVER    equ 0x00C0C0C0
    89                              <2> 
    90                              <2> ; --- Window Manager ---
    91                              <2> MAX_WINDOWS         equ 8
    92                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    93                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    94                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    95                              <2> TITLEBAR_HEIGHT     equ 24
    96                              <2> BORDER_WIDTH        equ 2
    97                              <2> CLOSE_BTN_SIZE      equ 18
    98                              <2> MIN_BTN_SIZE        equ 18
    99                              <2> MIN_WINDOW_W        equ 200
   100                              <2> MIN_WINDOW_H        equ 100
   101                              <2> 
   102                              <2> ; --- Taskbar ---
   103                              <2> TASKBAR_HEIGHT      equ 36
   104                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
   105                              <2> START_BTN_W         equ 70
   106                              <2> START_BTN_H         equ 28
   107                              <2> START_BTN_X         equ 4
   108                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
   109                              <2> CLOCK_WIDTH         equ 64
   110                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
   111                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
   112                              <2> 
   113                              <2> ; --- Keyboard ---
   114                              <2> KB_BUFFER_SIZE      equ 64
   115                              <2> 
   116                              <2> ; --- Mouse ---
   117                              <2> MOUSE_BUFFER_SIZE   equ 64
   118                              <2> CURSOR_WIDTH        equ 12
   119                              <2> CURSOR_HEIGHT       equ 19
   120                              <2> 
   121                              <2> ; --- PIT ---
   122                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   123                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   124                              <2> 
   125                              <2> ; --- PIC vectors ---
   126                              <2> IRQ_BASE_MASTER     equ 32
   127                              <2> IRQ_BASE_SLAVE      equ 40
   128                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   129                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   130                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   131                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   132                              <2> 
   133                              <2> ; --- Font ---
   134                              <2> FONT_WIDTH          equ 8
   135                              <2> FONT_HEIGHT         equ 16
   136                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   137                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   138                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   139                              <2> 
   140                              <2> ; --- Window flags ---
   141                              <2> WF_VISIBLE          equ 0x01
   142                              <2> WF_FOCUSED          equ 0x02
   143                              <2> WF_DRAGGING         equ 0x04
   144                              <2> WF_MINIMIZED        equ 0x08
   145                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   146                              <2> 
   147                              <2> ; --- Mouse event types ---
   148                              <2> MEVT_MOVE           equ 1
   149                              <2> MEVT_LCLICK         equ 2
   150                              <2> MEVT_RCLICK         equ 3
   151                              <2> MEVT_LRELEASE       equ 4
   152                              <2> MEVT_RRELEASE       equ 5
   153                              <2> 
   154                              <2> ; --- Key modifier flags ---
   155                              <2> KMOD_SHIFT          equ 0x01
   156                              <2> KMOD_CTRL           equ 0x02
   157                              <2> KMOD_ALT            equ 0x04
   158                              <2> 
   159                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   160                              <2> KEY_F1              equ 0xF1
   161                              <2> KEY_F2              equ 0xF2
   162                              <2> KEY_F3              equ 0xF3
   163                              <2> KEY_F4              equ 0xF4
   164                              <2> KEY_F5              equ 0xF5
   165                              <2> KEY_F6              equ 0xF6
   166                              <2> KEY_F7              equ 0xF7
   167                              <2> KEY_F8              equ 0xF8
   168                              <2> KEY_F9              equ 0xF9
   169                              <2> KEY_F10             equ 0xFA
   170                              <2> KEY_F11             equ 0xFB
   171                              <2> KEY_F12             equ 0xFC
   172                              <2> 
   173                              <2> ; --- USB/XHCI Memory Layout ---
   174                              <2> %ifdef NEXUS_CACHE32_MAX
   175                              <2> XHCI_DCBAA_ADDR     equ 0x1900000    ; Cold DMA region outside GUI LLC arena
   176                              <2> XHCI_CMD_RING_ADDR  equ 0x1910000
   177                              <2> XHCI_ERST_ADDR      equ 0x1920000
   178                              <2> XHCI_EVT_RING_ADDR  equ 0x1930000
   179                              <2> XHCI_SCRATCH_ADDR   equ 0x1940000
   180                              <2> XHCI_DEV_CTX_ADDR   equ 0x1950000
   181                              <2> XHCI_INPUT_CTX_ADDR equ 0x1960000
   182                              <2> XHCI_CTRL_RING_ADDR equ 0x1970000
   183                              <2> XHCI_INT_RING_ADDR  equ 0x1980000
   184                              <2> XHCI_CTRL_BUF_ADDR  equ 0x1990000
   185                              <2> XHCI_MOUSE_BUF_ADDR equ 0x19A0000
   186                              <2> XHCI_DEV_CTX2_ADDR  equ 0x19B0000
   187                              <2> XHCI_INT_RING2_ADDR equ 0x19C0000
   188                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x19D0000
   189                              <2> XHCI_CTRL_RING2_ADDR equ 0x19E0000
   190                              <2> XHCI_MEM_END        equ 0x19F0000
   191                              <2> %else
   192                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   193                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   194                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   195                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   196                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   197                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   198                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   199                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   200                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   201                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   202                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   203                              <2> ; Slot 2 device support
   204                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   205                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   206                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   207                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   208                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   209                              <2> %endif
   210                              <2> 
   211                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   212                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   213                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   214                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   215                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   216                              <2> XHCI_CAP_DBOFF      equ 0x14
   217                              <2> XHCI_CAP_RTSOFF     equ 0x18
   218                              <2> 
   219                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   220                              <2> XHCI_OP_USBCMD      equ 0x00
   221                              <2> XHCI_OP_USBSTS      equ 0x04
   222                              <2> XHCI_OP_PAGESIZE     equ 0x08
   223                              <2> XHCI_OP_DNCTRL      equ 0x14
   224                              <2> XHCI_OP_CRCR_LO     equ 0x18
   225                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   226                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   227                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   228                              <2> XHCI_OP_CONFIG      equ 0x38
   229                              <2> 
   230                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   231                              <2> XHCI_PORTSC         equ 0x00
   232                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   233                              <2> 
   234                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   235                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   236                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   237                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   238                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   239                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   240                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   241                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   242                              <2> 
   243                              <2> ; --- USBCMD bits ---
   244                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   245                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   246                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   247                              <2> 
   248                              <2> ; --- USBSTS bits ---
   249                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   250                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   251                              <2> 
   252                              <2> ; --- PORTSC bits ---
   253                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   254                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   255                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   256                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   257                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   258                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   259                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   260                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   261                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   262                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   263                              <2> 
   264                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   265                              <2> TRB_NORMAL           equ (1 << 10)
   266                              <2> TRB_SETUP            equ (2 << 10)
   267                              <2> TRB_DATA             equ (3 << 10)
   268                              <2> TRB_STATUS           equ (4 << 10)
   269                              <2> TRB_LINK             equ (6 << 10)
   270                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   271                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   272                              <2> TRB_CONFIG_EP        equ (12 << 10)
   273                              <2> TRB_EVAL_CTX         equ (13 << 10)
   274                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   275                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   276                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   277                              <2> 
   278                              <2> ; --- TRB Flag Bits (dword 3) ---
   279                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   280                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   281                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   282                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   283                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   284                              <2> 
   285                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   286                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   287                              <2> TRB_TRT_OUT          equ (2 << 16)
   288                              <2> TRB_TRT_IN           equ (3 << 16)
   289                              <2> 
   290                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   291                              <2> TRB_DIR_OUT          equ (0 << 16)
   292                              <2> TRB_DIR_IN           equ (1 << 16)
   293                              <2> 
   294                              <2> ; --- Ring sizes ---
   295                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   296                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   297                              <2> 
   298                              <2> ; --- USB Standard Request Codes ---
   299                              <2> USB_REQ_GET_DESC     equ 0x06
   300                              <2> USB_REQ_SET_CONFIG   equ 0x09
   301                              <2> USB_REQ_SET_IFACE    equ 0x0B
   302                              <2> 
   303                              <2> ; --- USB HID Request Codes ---
   304                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   305                              <2> 
   306                              <2> ; --- USB Descriptor Types ---
   307                              <2> USB_DESC_DEVICE      equ 0x01
   308                              <2> USB_DESC_CONFIG      equ 0x02
   309                              <2> USB_DESC_INTERFACE   equ 0x04
   310                              <2> USB_DESC_ENDPOINT    equ 0x05
   311                              <2> USB_DESC_HID         equ 0x21
   312                              <2> 
   313                              <2> ; --- USB Endpoint Types ---
   314                              <2> USB_EP_CONTROL       equ 0
   315                              <2> USB_EP_ISOCH         equ 1
   316                              <2> USB_EP_BULK          equ 2
   317                              <2> USB_EP_INTERRUPT     equ 3
   318                              <2> 
   319                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   320                              <2> XHCI_EP_NOT_VALID    equ 0
   321                              <2> XHCI_EP_ISOCH_OUT    equ 1
   322                              <2> XHCI_EP_BULK_OUT     equ 2
   323                              <2> XHCI_EP_INT_OUT      equ 3
   324                              <2> XHCI_EP_CONTROL      equ 4
   325                              <2> XHCI_EP_ISOCH_IN     equ 5
   326                              <2> XHCI_EP_BULK_IN      equ 6
   327                              <2> XHCI_EP_INT_IN       equ 7
   328                              <2> 
   329                              <2> ; --- XHCI Port Speeds ---
   330                              <2> XHCI_SPEED_FULL      equ 1
   331                              <2> XHCI_SPEED_LOW       equ 2
   332                              <2> XHCI_SPEED_HIGH      equ 3
   333                              <2> XHCI_SPEED_SUPER     equ 4
     8                              <1> 
     9                              <1> extern tick_count
    10                              <1> KB_REPEAT_DELAY     equ 40      ; ticks before first repeat (~400ms at 100Hz)
    11                              <1> KB_REPEAT_RATE      equ 5       ; ticks between repeats (~50ms)
    12                              <1> 
    13                              <1> section .text
    14                              <1> 
    15                              <1> ; --- Initialize keyboard ---
    16                              <1> global keyboard_init
    17                              <1> keyboard_init:
    18                              <1>     ; Flush keyboard buffer
    19                              <1> .flush:
    20 000033EE E464                <1>     in al, 0x64
    21 000033F0 A801                <1>     test al, 0x01            ; Output buffer full?
    22 000033F2 7404                <1>     jz .flushed
    23 000033F4 E460                <1>     in al, 0x60              ; Read and discard
    24 000033F6 EBF6                <1>     jmp .flush
    25                              <1> .flushed:
    26                              <1>     ; Initialize buffer
    27 000033F8 C705(0A040000)0000- <1>     mov dword [kb_head], 0
    27 00003400 0000                <1>
    28 00003402 C705(0E040000)0000- <1>     mov dword [kb_tail], 0
    28 0000340A 0000                <1>
    29 0000340C C605(07040000)00    <1>     mov byte [kb_modifiers], 0
    30 00003413 C605(08040000)00    <1>     mov byte [kb_extended], 0
    31 0000341A C3                  <1>     ret
    32                              <1> 
    33                              <1> ; --- IRQ1 Keyboard Handler (called from ISR) ---
    34                              <1> global keyboard_handler
    35                              <1> keyboard_handler:
    36 0000341B 50                  <1>     push rax
    37 0000341C 53                  <1>     push rbx
    38 0000341D 51                  <1>     push rcx
    39 0000341E 52                  <1>     push rdx
    40                              <1> 
    41                              <1>     ; Read scancode from data port
    42 0000341F E460                <1>     in al, 0x60
    43 00003421 0FB6C0              <1>     movzx eax, al
