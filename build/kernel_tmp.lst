   284                              <1> 
   285 000066E1 48BE-               <1>     mov rsi, szI2cFail
   285 000066E3 [3F0D000000000000]  <1>
   286 000066EB E8219AFFFF          <1>     call debug_print
   287                              <1> 
   288 000066F0 31C0                <1>     xor eax, eax
   289                              <1> 
   290                              <1> .ret:
   291 000066F2 415F                <1>     pop r15
   292 000066F4 415E                <1>     pop r14
   293 000066F6 415D                <1>     pop r13
   294 000066F8 415C                <1>     pop r12
   295 000066FA 5F                  <1>     pop rdi
   296 000066FB 5E                  <1>     pop rsi
   297 000066FC 5A                  <1>     pop rdx
