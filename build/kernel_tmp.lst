   448 00004531 4801F0              <1>     add rax, rsi
   449 00004534 488905(9A050000)    <1>     mov [xhci_db_base], rax
   450                              <1> 
   451                              <1>     ; RTSOFF
   452 0000453B 8B4618              <1>     mov eax, [rsi + XHCI_CAP_RTSOFF]
   453 0000453E 83E0E0              <1>     and eax, ~0x1F                ; Clear low 5 bits
   454 00004541 4801F0              <1>     add rax, rsi
   455 00004544 488905(A2050000)    <1>     mov [xhci_rt_base], rax
   456                              <1> 
   457 0000454B 5E                  <1>     pop rsi
   458 0000454C C3                  <1>     ret
