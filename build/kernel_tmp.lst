   301                              <1>     mov rcx, 16
   302                              <1> .hex_loop:
   303                              <1>     rol rdi, 4
   304                              <1>     mov al, dil
   305                              <1>     and al, 0x0F
   306                              <1>     cmp al, 10
   307                              <1>     jl .hex_digit
   308                              <1>     add al, 'A' - '0' - 10
   309                              <1> .hex_digit:
   310                              <1>     add al, '0'
   311                              <1>     mov dx, 0x3F8
   312                              <1>     out dx, al
