    22                              <1> 
    23                              <1> ; The FAT16 partition starts at this LBA sector on the disk image
    24                              <1> FAT16_PART_LBA  equ 320           ; After MBR + Stage2 + Kernel (sector 320 = byte 163840)
    25                              <1> FAT16_FAT_CACHE_SECTORS equ 128
    26                              <1> FAT16_ROOT_CACHE_SECTORS equ 32
    27                              <1> FAT16_MAX_FAT_ENTRIES equ (FAT16_FAT_CACHE_SECTORS * 256)
    28                              <1> 
    29                              <1> ; FAT16 BPB offsets (from start of boot sector)
    30                              <1> BPB_BYTES_PER_SECT  equ 11        ; word
    31                              <1> BPB_SECT_PER_CLUS   equ 13        ; byte
    32                              <1> BPB_RESERVED_SECTS  equ 14        ; word
    33                              <1> BPB_NUM_FATS        equ 16        ; byte
    34                              <1> BPB_ROOT_ENTRIES    equ 17        ; word
    35                              <1> BPB_TOTAL_SECTS16   equ 19        ; word
    36                              <1> BPB_FAT_SIZE16      equ 22        ; word
    37                              <1> 
    38                              <1> ; FAT16 directory entry offsets
    39                              <1> DIR_NAME            equ 0          ; 8 bytes filename
    40                              <1> DIR_EXT             equ 8          ; 3 bytes extension
    41                              <1> DIR_ATTR            equ 11         ; 1 byte attributes
    42                              <1> DIR_FIRST_CLUS_HI   equ 20        ; 2 bytes (FAT32 only, 0 for FAT16)
    43                              <1> DIR_FIRST_CLUS_LO   equ 26        ; 2 bytes
    44                              <1> DIR_FILE_SIZE       equ 28         ; 4 bytes
    45                              <1> DIR_ENTRY_SIZE      equ 32
    46                              <1> 
    47                              <1> ; Attributes
    48                              <1> ATTR_READ_ONLY      equ 0x01
    49                              <1> ATTR_HIDDEN         equ 0x02
    50                              <1> ATTR_SYSTEM         equ 0x04
    51                              <1> ATTR_VOLUME_ID      equ 0x08
    52                              <1> ATTR_DIRECTORY      equ 0x10
    53                              <1> ATTR_ARCHIVE        equ 0x20
    54                              <1> ATTR_LFN            equ 0x0F
    55                              <1> 
    56                              <1> ; Temp buffers. Cache32Max keeps these cold buffers outside the 4MB..16MB GUI
    57                              <1> ; LLC arena and outside the 16MB..24MB app arena.
    58                              <1> %ifdef NEXUS_CACHE32_MAX
    59                              <1> FAT16_SECTOR_BUF    equ 0x1A00000   ; 512 byte sector buffer
    60                              <1> FAT16_FAT_CACHE     equ 0x1A01000   ; FAT table cache (up to 64KB)
    61                              <1> FAT16_ROOT_CACHE    equ 0x1A11000   ; Root directory cache (up to 32 sectors = 16KB)
    62                              <1> FAT16_FILE_BUF      equ 0x1A21000   ; File read buffer (up to 64KB)
    63                              <1> FAT16_DIR_CACHE     equ 0x1A31000   ; Current directory listing cache
    64                              <1> %else
    65                              <1> ; Moved to 13MB region to avoid XHCI conflict (0x900000-0x9F0000)
    66                              <1> FAT16_SECTOR_BUF    equ 0xD00000   ; 512 byte sector buffer
    67                              <1> FAT16_FAT_CACHE     equ 0xD01000   ; FAT table cache (up to 64KB)
    68                              <1> FAT16_ROOT_CACHE    equ 0xD11000   ; Root directory cache (up to 32 sectors = 16KB)
    69                              <1> FAT16_FILE_BUF      equ 0xD21000   ; File read buffer (up to 64KB)
    70                              <1> FAT16_DIR_CACHE     equ 0xD31000   ; Current directory listing cache
    71                              <1> %endif
