    40                              <2> %else
    41                              <2>  dq 0
    42                              <2> %endif
    43                              <2>  db %2
    44                              <2>  dd %3
    45                              <2>  db %4
    46                              <2>  dd __LINE__
    47                              <2>  dq %1__name
    48                              <2> %1__name:
    49                              <2>  db %str(%1), 0
