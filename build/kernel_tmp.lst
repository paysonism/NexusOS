   334                              <2> ; fat16_format_name - Format FAT16 8.3 name to readable string
   335                              <2> ; rdi = output buffer (at least 13 bytes)
   336                              <2> ; rsi = pointer to FAT16 dir entry (32 bytes)
   337                              <2> fat16_format_name:
   338 0000F0E4 50                  <2>     push rax
   339 0000F0E5 51                  <2>     push rcx
   340 0000F0E6 52                  <2>     push rdx
   341 0000F0E7 57                  <2>     push rdi
   342 0000F0E8 56                  <2>     push rsi
   343                              <2> 
   344                              <2>     ; Copy filename part (8 bytes), strip trailing spaces
   345 0000F0E9 B908000000          <2>     mov ecx, 8
   346                              <2> .fn_copy:
   347 0000F0EE AC                  <2>     lodsb
   348 0000F0EF 3C20                <2>     cmp al, ' '
   349 0000F0F1 7407                <2>     je .fn_space
   350 0000F0F3 AA                  <2>     stosb
   351 0000F0F4 FFC9                <2>     dec ecx
   352 0000F0F6 75F6                <2>     jnz .fn_copy
   353 0000F0F8 EB0B                <2>     jmp .fn_dot
   354                              <2> .fn_space:
   355 0000F0FA FFC9                <2>     dec ecx
   356                              <2>     ; Skip remaining filename chars
   357                              <2> .fn_skip:
   358 0000F0FC 85C9                <2>     test ecx, ecx
   359 0000F0FE 7405                <2>     jz .fn_dot
   360 0000F100 AC                  <2>     lodsb
   361 0000F101 FFC9                <2>     dec ecx
   362 0000F103 EBF7                <2>     jmp .fn_skip
   363                              <2> 
   364                              <2> .fn_dot:
   365                              <2>     ; Check if extension is blank
   366 0000F105 8A06                <2>     mov al, [rsi]
   367 0000F107 3C20                <2>     cmp al, ' '
   368 0000F109 7415                <2>     je .fn_noext
   369                              <2>     ; Add dot
   370 0000F10B C6072E              <2>     mov byte [rdi], '.'
   371 0000F10E 48FFC7              <2>     inc rdi
   372                              <2>     ; Copy extension (3 bytes), strip trailing spaces
   373 0000F111 B903000000          <2>     mov ecx, 3
   374                              <2> .ext_copy:
   375 0000F116 AC                  <2>     lodsb
   376 0000F117 3C20                <2>     cmp al, ' '
