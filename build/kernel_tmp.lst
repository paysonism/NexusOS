   653                              <1> ; xhci_setup_scratchpad - Allocate scratchpad buffers if needed
   654                              <1> ; ============================================================================
   655                              <1> xhci_setup_scratchpad:
   656 000046C3 51                  <1>     push rcx
   657 000046C4 57                  <1>     push rdi
   658                              <1> 
   659 000046C5 0FB60D(AE050000)    <1>     movzx ecx, byte [xhci_scratchpad_count]
   660 000046CC 85C9                <1>     test ecx, ecx
   661 000046CE 7435                <1>     jz .scratch_done              ; No scratchpads needed
   662                              <1> 
   663                              <1>     ; Cap at 4 (we have space for 4 buffer pages)
   664 000046D0 83F904              <1>     cmp ecx, 4
   665 000046D3 7E05                <1>     jle .scratch_ok
   666 000046D5 B904000000          <1>     mov ecx, 4
   667                              <1> .scratch_ok:
   668                              <1> 
   669                              <1>     ; Scratchpad array at XHCI_SCRATCH_ADDR
   670                              <1>     ; Buffers at XHCI_SCRATCH_ADDR + 0x1000, +0x2000, etc.
   671 000046DA BF00009400          <1>     mov rdi, XHCI_SCRATCH_ADDR
   672 000046DF 31D2                <1>     xor edx, edx
