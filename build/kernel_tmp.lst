   552                              <1> 
   553                              <1>     ; Serial: 'a' (wait halt start)
   554 000045F1 52                  <1>     push rdx
   555 000045F2 66BAF803            <1>     mov dx, 0x3F8
   556 000045F6 B061                <1>     mov al, 'a'
   557 000045F8 EE                  <1>     out dx, al
   558 000045F9 5A                  <1>     pop rdx
   559                              <1> 
   560                              <1>     ; Wait for HCH = 1 (halted) - up to 100ms
   561 000045FA 488B1D(40000000)    <1>     mov rbx, [tick_count]
   562 00004601 4883C30A            <1>     add rbx, 10              ; 10 PIT ticks = 100ms
   563 00004605 B980841E00          <1>     mov ecx, 2000000
   564                              <1> .wait_halt:
   565 0000460A 8B4604              <1>     mov eax, [rsi + XHCI_OP_USBSTS]
   566 0000460D A901000000          <1>     test eax, XHCI_STS_HCH
   567 00004612 751C                <1>     jnz .halted
   568 00004614 FFC9                <1>     dec ecx
   569 00004616 0F8498000000        <1>     jz .reset_fail
   570 0000461C 488B05(40000000)    <1>     mov rax, [tick_count]
   571 00004623 4839D8              <1>     cmp rax, rbx
   572 00004626 0F8D88000000        <1>     jge .reset_fail          ; Timeout
   573 0000462C F390                <1>     pause
   574 0000462E EBDA                <1>     jmp .wait_halt
   575                              <1> .halted:
   576                              <1> 
   577                              <1>     ; Serial: 'b' (halted)
   578 00004630 52                  <1>     push rdx
   579 00004631 66BAF803            <1>     mov dx, 0x3F8
   580 00004635 B062                <1>     mov al, 'b'
   581 00004637 EE                  <1>     out dx, al
   582 00004638 5A                  <1>     pop rdx
