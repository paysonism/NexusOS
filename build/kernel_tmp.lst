   217                              <1>     ; BAR0 is memory-mapped, mask off type bits
   218 0000663A 2500F0FFFF          <1>     and eax, 0xFFFFF000
   219 0000663F 85C0                <1>     test eax, eax
   220 00006641 743C                <1>     jz .pci_next_pop
