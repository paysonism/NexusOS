     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - Application Framework + Built-in Apps
     3                              <1> ; Split into per-app/source includes to keep userland code maintainable while
     4                              <1> ; preserving the monolithic kernel build.
     5                              <1> ; ============================================================================
     6                              <1> 
     7                              <1> %include "trace.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - Function signature and trace macros
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> %ifndef TRACE_INC
     6                              <2> %define TRACE_INC
     7                              <2> 
     8                              <2> FN_KIND_SCALAR  equ 0
     9                              <2> FN_KIND_PTR     equ 1
    10                              <2> FN_KIND_CSTRING equ 2
    11                              <2> FN_KIND_HANDLE  equ 3
    12                              <2> 
    13                              <2> FN_RET_VOID     equ 0
    14                              <2> FN_RET_SCALAR   equ 1
    15                              <2> FN_RET_PTR      equ 2
    16                              <2> FN_RET_HANDLE   equ 3
    17                              <2> 
    18                              <2> TRACE_FLAG_ENTER         equ 1
    19                              <2> TRACE_FLAG_EXIT          equ 2
    20                              <2> TRACE_FLAG_SYSCALL_ENTER equ 4
    21                              <2> TRACE_FLAG_SYSCALL_EXIT  equ 8
    22                              <2> TRACE_FLAG_VALIDATE_FAIL equ 16
    23                              <2> 
    24                              <2> ; FN_BEGIN emits a normal function label plus machine-readable metadata.
    25                              <2> ; Slot is read from the global trace_active_slot (set by syscall entry).
    26                              <2> ; All caller-saved registers are preserved so this is safe to drop into
    27                              <2> ; ISR/IRQ landing pads as well as ordinary kernel functions.
    28                              <2> %macro FN_BEGIN 4
    29                              <2> %define __fn_prev_section __?SECT?__
    30                              <2>     global %1
    31                              <2> %1:
    32                              <2> %assign %{1}__argc %2
    33                              <2> %assign %{1}__kindmask %3
    34                              <2> %assign %{1}__retkind %4
    35                              <2> %ifdef ENABLE_SIG_SECTION
    36                              <2>     [section .signature]
    37                              <2> %{1}__sigmeta:
    38                              <2> %ifdef %{1}__hash
    39                              <2>     dq %{1}__hash
    40                              <2> %else
    41                              <2>     dq 0
    42                              <2> %endif
    43                              <2>     db %2
    44                              <2>     dd %3
    45                              <2>     db %4
    46                              <2>     dd __LINE__
    47                              <2>     dq %{1}__name
    48                              <2> %{1}__name:
    49                              <2>     db %str(%1), 0
    50                              <2>     __fn_prev_section
    51                              <2> %endif
    52                              <2> %ifdef ENABLE_TRACE
    53                              <2> %ifndef DISABLE_FN_RUNTIME_TRACE
    54                              <2>     push rax
    55                              <2>     push rcx
    56                              <2>     push rdx
    57                              <2>     push rsi
    58                              <2>     push rdi
    59                              <2>     push r8
    60                              <2>     push r9
    61                              <2>     push r10
    62                              <2>     push r11
    63                              <2> %ifdef %{1}__hash32
    64                              <2>     mov edi, %{1}__hash32
    65                              <2> %else
    66                              <2>     mov edi, %1
    67                              <2> %endif
    68                              <2>     movzx esi, byte [rel trace_active_slot]
    69                              <2>     call trace_fn_enter
    70                              <2>     pop r11
    71                              <2>     pop r10
    72                              <2>     pop r9
    73                              <2>     pop r8
    74                              <2>     pop rdi
    75                              <2>     pop rsi
    76                              <2>     pop rdx
    77                              <2>     pop rcx
    78                              <2>     pop rax
    79                              <2> %endif
    80                              <2> %endif
    81                              <2> %endmacro
    82                              <2> 
    83                              <2> ; FN_ARG is intentionally doc-only for now. The registry builder reads source
    84                              <2> ; FN_ARG lines and attaches arg names/kinds to the JSON sidecar.
    85                              <2> %macro FN_ARG 3
    86                              <2> %endmacro
    87                              <2> 
    88                              <2> %macro FN_END 1
    89                              <2> %ifdef ENABLE_TRACE
    90                              <2> %ifndef DISABLE_FN_RUNTIME_TRACE
    91                              <2>     push rax                        ; preserve retval at top of save area
    92                              <2>     push rcx
    93                              <2>     push rdx
    94                              <2>     push rsi
    95                              <2>     push rdi
    96                              <2>     push r8
    97                              <2>     push r9
    98                              <2>     push r10
    99                              <2>     push r11
   100                              <2> %ifdef %{1}__hash32
   101                              <2>     mov edi, %{1}__hash32
   102                              <2> %else
   103                              <2>     mov edi, %1
   104                              <2> %endif
   105                              <2>     movzx esi, byte [rel trace_active_slot]
   106                              <2>     mov rdx, [rsp + 8*8]            ; saved RAX (retval) sits 8 qwords below top
   107                              <2>     call trace_fn_exit
   108                              <2>     pop r11
   109                              <2>     pop r10
   110                              <2>     pop r9
   111                              <2>     pop r8
   112                              <2>     pop rdi
   113                              <2>     pop rsi
   114                              <2>     pop rdx
   115                              <2>     pop rcx
   116                              <2>     pop rax
   117                              <2> %endif
   118                              <2> %endif
   119                              <2> %endmacro
   120                              <2> 
   121                              <2> %macro FN_CALL 2
   122                              <2> %ifdef %{1}__argc
   123                              <2>     %if %{1}__argc != %2
   124                              <2>         %error "FN_CALL argc mismatch"
   125                              <2>     %endif
   126                              <2> %endif
   127                              <2>     call %1
   128                              <2> %endmacro
   129                              <2> 
   130                              <2> %macro FN_BEGIN_FULL 4
   131                              <2>     FN_BEGIN %1, %2, %3, %4
   132                              <2> %endmacro
   133                              <2> 
   134                              <2> ; Lightweight: declares signature only, no runtime trace (use in ISR/IRQ
   135                              <2> ; landing pads where calling helpers before the iretq frame is unsafe).
   136                              <2> %macro FN_DECL 4
   137                              <2>     global %1
   138                              <2> %1:
   139                              <2> %assign %{1}__argc %2
   140                              <2> %assign %{1}__kindmask %3
   141                              <2> %assign %{1}__retkind %4
   142                              <2> %ifdef ENABLE_SIG_SECTION
   143                              <2>     [section .signature]
   144                              <2> %{1}__sigmeta_decl:
   145                              <2> %ifdef %{1}__hash
   146                              <2>     dq %{1}__hash
   147                              <2> %else
   148                              <2>     dq 0
   149                              <2> %endif
   150                              <2>     db %2
   151                              <2>     dd %3
   152                              <2>     db %4
   153                              <2>     dd __LINE__
   154                              <2>     dq %{1}__name_decl
   155                              <2> %{1}__name_decl:
   156                              <2>     db %str(%1), 0
   157                              <2>     __SECT__
   158                              <2> %endif
   159                              <2> %endmacro
   160                              <2> 
   161                              <2> %endif
     8                              <1> 
     9                              <1> ; Neutralize extern/global so this file assembles both inside the monolithic
    10                              <1> ; kernel build AND as a standalone flat binary (APPS.BIN).
    11                              <1> %ifmacro extern 1-*
    12                              <1> %unmacro extern 1-*
    13                              <1> %endif
    14                              <1> %macro extern 1-*
    15                              <1> %endmacro
    16                              <1> %ifmacro global 1-*
    17                              <1> %unmacro global 1-*
    18                              <1> %endif
    19                              <1> %macro global 1-*
    20                              <1> %endmacro
    21                              <1> 
    22                              <1> ; Redirect direct kernel render calls to local syscall wrappers so that
    23                              <1> ; when the blob is copied to a user slot and runs in Ring 3, all relative
    24                              <1> ; calls stay within the blob (correct rel32) and use the syscall ABI.
    25                              <1> %define render_rect  app_sys_render_rect
    26                              <1> %define render_text  app_sys_render_text
    27                              <1> 
    28                              <1> global app_blob_start
    29                              <1> app_blob_start:
    30                              <1> ; 16-byte sentinel so a post-build extraction can locate this blob inside
    31                              <1> ; kernel.bin without needing NASM symbol maps.
    32 0000A0D1 4E58415050424C4F    <1> db 0x4E, 0x58, 0x41, 0x50, 0x50, 0x42, 0x4C, 0x4F    ; "NXAPPBLO"
    33 0000A0D9 4253545254DEADBE    <1> db 0x42, 0x53, 0x54, 0x52, 0x54, 0xDE, 0xAD, 0xBE    ; "BSTRT" + 0xDEADBE
    34                              <1> global app_l3_done_trampoline
    35                              <1> app_l3_done_trampoline:
    36 0000A0E1 B80A000000          <1>     mov eax, 10
    37 0000A0E6 0F05                <1>     syscall
    38 0000A0E8 0F0B                <1>     ud2
    39                              <1> %include "src/user/apps/common.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - Application Framework + Built-in Apps
     3                              <2> ; Each app provides: draw_fn(rdi=window_ptr), click_fn(rdi=window_ptr,
     4                              <2> ;   rsi=client_x, rdx=client_y), key_fn(rdi=window_ptr, esi=key_event)
     5                              <2> ; Window struct offsets (from window.asm):
     6                              <2> ;   8:X 16:Y 24:W 32:H 40:Flags 48:Title 112:draw_fn 120:key_fn 128:click_fn 136:app_data
     7                              <2> ; ============================================================================
     8                              <2> bits 64
     9                              <2> default rel
    10                              <2> 
    11                              <2> section .text
    12                              <2> 
    13                              <2> %include "nexus_app.inc"
     1                              <3> %ifndef NEXUS_APP_INC
     2                              <3> %define NEXUS_APP_INC
     3                              <3> 
     4                              <3> ; ============================================================================
     5                              <3> ; NexusOS v3.0 - User App Kit
     6                              <3> ; Shared include for ring-3 apps. Pulls in the syscall wrappers and the shared
     7                              <3> ; window/constants definitions that callback code usually needs.
     8                              <3> ; ============================================================================
     9                              <3> 
    10                              <3> %include "constants.inc"
     1                              <4> ; ============================================================================
     2                              <4> ; NexusOS v3.0 - System Constants
     3                              <4> ; ============================================================================
     4                              <4> 
     5                              <4> %include "boot_memory.inc"
     1                              <5> %ifndef BOOT_MEMORY_INC
     2                              <5> %define BOOT_MEMORY_INC
     3                              <5> 
     4                              <5> ; NexusOS boot memory contract.
     5                              <5> ; Keep loader, paging, and kernel users on one map while relocation work lands.
     6                              <5> 
     7                              <5> STAGE2_LOAD_ADDR    equ 0x7E00
     8                              <5> E820_COUNT_ADDR     equ 0x1FF0
     9                              <5> E820_MAP_ADDR       equ 0x2000
    10                              <5> VBE_INFO_ADDR       equ 0x9000
    11                              <5> BOOT_DRIVE_ADDR     equ 0x9100
    12                              <5> PAGE_TABLE_ADDR     equ 0x70000
    13                              <5> SMP_TRAMPOLINE_ADDR equ 0x8000
    14                              <5> KERNEL_LOAD_ADDR    equ 0x100000
    15                              <5> KERNEL_STACK_TOP    equ 0x200000
    16                              <5> IDT_ADDR            equ 0x200000
    17                              <5> KERNEL_DATA_ADDR    equ 0x210000
    18                              <5> PAGE_BITMAP_ADDR    equ 0x300000
    19                              <5> PAGE_BITMAP_SIZE    equ 0x100000
    20                              <5> BACK_BUFFER_ADDR    equ 0x400000
    21                              <5> BOOT_BACK_BUFFER_SIZE equ (1024 * 768 * 4)
    22                              <5> BACK_BUFFER_SAVE_ADDR equ 0xA00000
    23                              <5> CURSOR_BG_ADDR      equ 0x700000
    24                              <5> WINDOW_POOL_ADDR    equ 0x710000
    25                              <5> EVENT_BUFFER_ADDR   equ 0x720000
    26                              <5> APP_DATA_ADDR       equ 0x1000000
    27                              <5> APP_SLOT_SIZE       equ 0x100000
    28                              <5> L3_SYSCALL_STACK_ADDR equ 0x1800000
    29                              <5> APPS_BLOB_ADDR      equ 0x2000000
    30                              <5> APPS_BLOB_MAX_SIZE  equ 0x100000
    31                              <5> 
    32                              <5> GUI_LLC_ARENA_START equ BACK_BUFFER_ADDR
    33                              <5> GUI_LLC_ARENA_END   equ APP_DATA_ADDR
    34                              <5> 
    35                              <5> VBE_FB_ADDR_OFF     equ 0x00
    36                              <5> VBE_WIDTH_OFF       equ 0x08
    37                              <5> VBE_HEIGHT_OFF      equ 0x0C
    38                              <5> VBE_PITCH_OFF       equ 0x10
    39                              <5> VBE_BPP_OFF         equ 0x14
    40                              <5> VBE_SPP_OFF         equ 0x18
    41                              <5> VBE_APPS_BASE_OFF   equ 0x20
    42                              <5> VBE_APPS_SIZE_OFF   equ 0x28
    43                              <5> VBE_BACKBUF_OFF     equ 0x30
    44                              <5> VBE_BACKBUF_SIZE_OFF equ 0x38
    45                              <5> VBE_APP_ARENA_BASE_OFF equ 0x40
    46                              <5> VBE_APP_ARENA_SIZE_OFF equ 0x48
    47                              <5> 
    48                              <5> %endif
     6                              <4> 
     7                              <4> ; --- Memory Layout ---
     8                              <4> ; Cache32Max speed tiers:
     9                              <4> ; - L1-hot: IRQ/syscall/scheduler/input flags/per-core state.
    10                              <4> ; - L2-warm: HID parser, window metadata, font/text primitives, FAT metadata.
    11                              <4> ; - L3/LLC GUI: framebuffer composition buffers in 4MB..16MB.
    12                              <4> ; - RAM-cold: app arenas, device DMA rings, filesystem staging, debug data.
    13                              <4> ; Core physical addresses live in boot_memory.inc.
    14                              <4> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    15                              <4> ; IDT structure is fixed size.
    16                              <4> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    17                              <4> ; Stack grows DOWN. IDT grows UP (fixed size).
    18                              <4> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    19                              <4> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    20                              <4> ; So they don't overlap. This is safe.
    21                              <4> 
    22                              <4> %ifdef NEXUS_CACHE32_MAX
    23                              <4> CACHE32_RAM_LIMIT   equ 0x2000000    ; 32MB strict profile cap
    24                              <4> SYSTEM_RESERVED_END equ 0x1B00000    ; Keep allocator above fixed cold buffers
    25                              <4> SMP_CORE_STATE_ADDR equ 0x220000     ; Cacheline-aligned per-core records
    26                              <4> SMP_CORE_STACK_BASE equ 0x240000     ; AP stacks grow down from here
    27                              <4> SMP_MAX_CORES       equ 8
    28                              <4> SMP_CORE_STATE_SIZE equ 64
    29                              <4> SMP_CORE_STACK_SIZE equ 0x4000
    30                              <4> %else
    31                              <4> SMP_CORE_STATE_ADDR equ 0x220000
    32                              <4> SMP_MAX_CORES       equ 1
    33                              <4> SMP_CORE_STATE_SIZE equ 64
    34                              <4> SYSTEM_RESERVED_END equ 0xD00000
    35                              <4> %endif
    36                              <4> 
    37                              <4> ; --- Stage 2 disk layout ---
    38                              <4> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    39                              <4> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    40                              <4> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    41                              <4> 
    42                              <4> ; --- Screen ---
    43                              <4> SCREEN_WIDTH        equ 1024
    44                              <4> SCREEN_HEIGHT       equ 768
    45                              <4> SCREEN_BPP          equ 32
    46                              <4> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    47                              <4> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    48                              <4> 
    49                              <4> 
    50                              <4> ; VBE info offsets live in boot_memory.inc.
    51                              <4> 
    52                              <4> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    53                              <4> ; VGA 16-color palette (NexusOS Design System, format 0x00RRGGBB)
    54                              <4> COLOR_VGA_BLACK     equ 0x00000000   ; #000000
    55                              <4> COLOR_VGA_BLUE      equ 0x000000A8   ; #0000A8
    56                              <4> COLOR_VGA_LGRAY     equ 0x00A8A8A8   ; #A8A8A8
    57                              <4> COLOR_VGA_DGRAY     equ 0x00545454   ; #545454
    58                              <4> COLOR_VGA_WHITE     equ 0x00FCFCFC   ; #FCFCFC
    59                              <4> COLOR_VGA_TEAL      equ 0x00008080   ; #008080
    60                              <4> COLOR_VGA_RED       equ 0x00A80000   ; #A80000
    61                              <4> COLOR_VGA_GREEN     equ 0x0000A800   ; #00A800
    62                              <4> 
    63                              <4> COLOR_BLACK         equ 0x00000000
    64                              <4> COLOR_WHITE         equ 0x00FCFCFC
    65                              <4> COLOR_DESKTOP_BG    equ 0x00008080   ; Teal #008080
    66                              <4> COLOR_TASKBAR_BG    equ 0x00A8A8A8   ; VGA lightgray #A8A8A8
    67                              <4> COLOR_TASKBAR_TOP   equ 0x00FCFCFC   ; Bevel highlight
    68                              <4> COLOR_CHROME_FACE   equ 0x00A8A8A8   ; #A8A8A8 3D face
    69                              <4> COLOR_SURFACE       equ 0x00C0C0C0   ; #C0C0C0 window surface
    70                              <4> COLOR_SUNKEN        equ 0x00FCFCFC   ; #FCFCFC sunken bg
    71                              <4> COLOR_BEVEL_LT      equ 0x00FCFCFC   ; top/left highlight #FCFCFC
    72                              <4> COLOR_BEVEL_DK      equ 0x00545454   ; bottom/right shadow #545454
    73                              <4> COLOR_BEVEL_XDK     equ 0x00000000   ; outer 1px black
    74                              <4> COLOR_TITLEBAR      equ 0x000000A8   ; focused titlebar #0000A8
    75                              <4> COLOR_TITLEBAR_UNF  equ 0x00545454   ; unfocused #545454
    76                              <4> COLOR_WINDOW_BG     equ 0x00C0C0C0   ; #C0C0C0
    77                              <4> COLOR_WINDOW_BORDER equ 0x00000000   ; outer border black
    78                              <4> COLOR_CLOSE_BTN     equ 0x00A8A8A8   ; face (no red)
    79                              <4> COLOR_CLOSE_HOVER   equ 0x00C0C0C0
    80                              <4> COLOR_MIN_BTN       equ 0x00A8A8A8   ; face
    81                              <4> COLOR_TEXT_WHITE     equ 0x00FCFCFC
    82                              <4> COLOR_TEXT_BLACK     equ 0x00000000
    83                              <4> COLOR_TEXT_GRAY      equ 0x00545454
    84                              <4> COLOR_TEXT_TITLE     equ 0x00FCFCFC   ; title bar text
    85                              <4> COLOR_HIGHLIGHT      equ 0x000000A8   ; selection = accent blue
    86                              <4> COLOR_CURSOR         equ 0x00FCFCFC
    87                              <4> COLOR_START_BTN      equ 0x00A8A8A8   ; face
    88                              <4> COLOR_START_HOVER    equ 0x00C0C0C0
    89                              <4> 
    90                              <4> ; --- Window Manager ---
    91                              <4> MAX_WINDOWS         equ 8
    92                              <4> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    93                              <4> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    94                              <4> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    95                              <4> TITLEBAR_HEIGHT     equ 24
    96                              <4> BORDER_WIDTH        equ 2
    97                              <4> CLOSE_BTN_SIZE      equ 18
    98                              <4> MIN_BTN_SIZE        equ 18
    99                              <4> MIN_WINDOW_W        equ 200
   100                              <4> MIN_WINDOW_H        equ 100
   101                              <4> 
   102                              <4> ; --- Taskbar ---
   103                              <4> TASKBAR_HEIGHT      equ 36
   104                              <4> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
   105                              <4> START_BTN_W         equ 70
   106                              <4> START_BTN_H         equ 28
   107                              <4> START_BTN_X         equ 4
   108                              <4> START_BTN_Y         equ (TASKBAR_Y + 4)
   109                              <4> CLOCK_WIDTH         equ 64
   110                              <4> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
   111                              <4> CLOCK_Y             equ (TASKBAR_Y + 10)
   112                              <4> 
   113                              <4> ; --- Keyboard ---
   114                              <4> KB_BUFFER_SIZE      equ 64
   115                              <4> 
   116                              <4> ; --- Mouse ---
   117                              <4> MOUSE_BUFFER_SIZE   equ 64
   118                              <4> CURSOR_WIDTH        equ 12
   119                              <4> CURSOR_HEIGHT       equ 19
   120                              <4> 
   121                              <4> ; --- PIT ---
   122                              <4> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   123                              <4> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   124                              <4> 
   125                              <4> ; --- PIC vectors ---
   126                              <4> IRQ_BASE_MASTER     equ 32
   127                              <4> IRQ_BASE_SLAVE      equ 40
   128                              <4> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   129                              <4> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   130                              <4> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   131                              <4> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   132                              <4> 
   133                              <4> ; --- Font ---
   134                              <4> FONT_WIDTH          equ 8
   135                              <4> FONT_HEIGHT         equ 16
   136                              <4> FONT_FIRST_CHAR     equ 32           ; Space
   137                              <4> FONT_LAST_CHAR      equ 126          ; Tilde
   138                              <4> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   139                              <4> 
   140                              <4> ; --- Window flags ---
   141                              <4> WF_VISIBLE          equ 0x01
   142                              <4> WF_FOCUSED          equ 0x02
   143                              <4> WF_DRAGGING         equ 0x04
   144                              <4> WF_MINIMIZED        equ 0x08
   145                              <4> WF_ACTIVE           equ 0x10         ; Slot is in use
   146                              <4> 
   147                              <4> ; --- Mouse event types ---
   148                              <4> MEVT_MOVE           equ 1
   149                              <4> MEVT_LCLICK         equ 2
   150                              <4> MEVT_RCLICK         equ 3
   151                              <4> MEVT_LRELEASE       equ 4
   152                              <4> MEVT_RRELEASE       equ 5
   153                              <4> 
   154                              <4> ; --- Key modifier flags ---
   155                              <4> KMOD_SHIFT          equ 0x01
   156                              <4> KMOD_CTRL           equ 0x02
   157                              <4> KMOD_ALT            equ 0x04
   158                              <4> 
   159                              <4> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   160                              <4> KEY_F1              equ 0xF1
   161                              <4> KEY_F2              equ 0xF2
   162                              <4> KEY_F3              equ 0xF3
   163                              <4> KEY_F4              equ 0xF4
   164                              <4> KEY_F5              equ 0xF5
   165                              <4> KEY_F6              equ 0xF6
   166                              <4> KEY_F7              equ 0xF7
   167                              <4> KEY_F8              equ 0xF8
   168                              <4> KEY_F9              equ 0xF9
   169                              <4> KEY_F10             equ 0xFA
   170                              <4> KEY_F11             equ 0xFB
   171                              <4> KEY_F12             equ 0xFC
   172                              <4> 
   173                              <4> ; --- USB/XHCI Memory Layout ---
   174                              <4> %ifdef NEXUS_CACHE32_MAX
   175                              <4> XHCI_DCBAA_ADDR     equ 0x1900000    ; Cold DMA region outside GUI LLC arena
   176                              <4> XHCI_CMD_RING_ADDR  equ 0x1910000
   177                              <4> XHCI_ERST_ADDR      equ 0x1920000
   178                              <4> XHCI_EVT_RING_ADDR  equ 0x1930000
   179                              <4> XHCI_SCRATCH_ADDR   equ 0x1940000
   180                              <4> XHCI_DEV_CTX_ADDR   equ 0x1950000
   181                              <4> XHCI_INPUT_CTX_ADDR equ 0x1960000
   182                              <4> XHCI_CTRL_RING_ADDR equ 0x1970000
   183                              <4> XHCI_INT_RING_ADDR  equ 0x1980000
   184                              <4> XHCI_CTRL_BUF_ADDR  equ 0x1990000
   185                              <4> XHCI_MOUSE_BUF_ADDR equ 0x19A0000
   186                              <4> XHCI_DEV_CTX2_ADDR  equ 0x19B0000
   187                              <4> XHCI_INT_RING2_ADDR equ 0x19C0000
   188                              <4> XHCI_MOUSE_BUF2_ADDR equ 0x19D0000
   189                              <4> XHCI_CTRL_RING2_ADDR equ 0x19E0000
   190                              <4> XHCI_MEM_END        equ 0x19F0000
   191                              <4> %else
   192                              <4> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   193                              <4> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   194                              <4> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   195                              <4> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   196                              <4> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   197                              <4> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   198                              <4> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   199                              <4> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   200                              <4> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   201                              <4> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   202                              <4> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   203                              <4> ; Slot 2 device support
   204                              <4> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   205                              <4> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   206                              <4> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   207                              <4> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   208                              <4> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   209                              <4> %endif
   210                              <4> 
   211                              <4> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   212                              <4> XHCI_CAP_CAPLENGTH  equ 0x00
   213                              <4> XHCI_CAP_HCSPARAMS1 equ 0x04
   214                              <4> XHCI_CAP_HCSPARAMS2 equ 0x08
   215                              <4> XHCI_CAP_HCCPARAMS1 equ 0x10
   216                              <4> XHCI_CAP_DBOFF      equ 0x14
   217                              <4> XHCI_CAP_RTSOFF     equ 0x18
   218                              <4> 
   219                              <4> ; --- XHCI Operational Register Offsets (from OpBase) ---
   220                              <4> XHCI_OP_USBCMD      equ 0x00
   221                              <4> XHCI_OP_USBSTS      equ 0x04
   222                              <4> XHCI_OP_PAGESIZE     equ 0x08
   223                              <4> XHCI_OP_DNCTRL      equ 0x14
   224                              <4> XHCI_OP_CRCR_LO     equ 0x18
   225                              <4> XHCI_OP_CRCR_HI     equ 0x1C
   226                              <4> XHCI_OP_DCBAAP_LO   equ 0x30
   227                              <4> XHCI_OP_DCBAAP_HI   equ 0x34
   228                              <4> XHCI_OP_CONFIG      equ 0x38
   229                              <4> 
   230                              <4> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   231                              <4> XHCI_PORTSC         equ 0x00
   232                              <4> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   233                              <4> 
   234                              <4> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   235                              <4> XHCI_RT_IR0_IMAN    equ 0x20
   236                              <4> XHCI_RT_IR0_IMOD    equ 0x24
   237                              <4> XHCI_RT_IR0_ERSTSZ  equ 0x28
   238                              <4> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   239                              <4> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   240                              <4> XHCI_RT_IR0_ERDP_LO equ 0x38
   241                              <4> XHCI_RT_IR0_ERDP_HI equ 0x3C
   242                              <4> 
   243                              <4> ; --- USBCMD bits ---
   244                              <4> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   245                              <4> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   246                              <4> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   247                              <4> 
   248                              <4> ; --- USBSTS bits ---
   249                              <4> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   250                              <4> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   251                              <4> 
   252                              <4> ; --- PORTSC bits ---
   253                              <4> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   254                              <4> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   255                              <4> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   256                              <4> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   257                              <4> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   258                              <4> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   259                              <4> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   260                              <4> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   261                              <4> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   262                              <4> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   263                              <4> 
   264                              <4> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   265                              <4> TRB_NORMAL           equ (1 << 10)
   266                              <4> TRB_SETUP            equ (2 << 10)
   267                              <4> TRB_DATA             equ (3 << 10)
   268                              <4> TRB_STATUS           equ (4 << 10)
   269                              <4> TRB_LINK             equ (6 << 10)
   270                              <4> TRB_ENABLE_SLOT      equ (9 << 10)
   271                              <4> TRB_ADDRESS_DEV      equ (11 << 10)
   272                              <4> TRB_CONFIG_EP        equ (12 << 10)
   273                              <4> TRB_EVAL_CTX         equ (13 << 10)
   274                              <4> TRB_TRANSFER_EVT     equ (32 << 10)
   275                              <4> TRB_CMD_COMPLETION   equ (33 << 10)
   276                              <4> TRB_PORT_STATUS_CHG  equ (34 << 10)
   277                              <4> 
   278                              <4> ; --- TRB Flag Bits (dword 3) ---
   279                              <4> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   280                              <4> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   281                              <4> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   282                              <4> TRB_IDT              equ (1 << 6)     ; Immediate Data
   283                              <4> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   284                              <4> 
   285                              <4> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   286                              <4> TRB_TRT_NO_DATA      equ (0 << 16)
   287                              <4> TRB_TRT_OUT          equ (2 << 16)
   288                              <4> TRB_TRT_IN           equ (3 << 16)
   289                              <4> 
   290                              <4> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   291                              <4> TRB_DIR_OUT          equ (0 << 16)
   292                              <4> TRB_DIR_IN           equ (1 << 16)
   293                              <4> 
   294                              <4> ; --- Ring sizes ---
   295                              <4> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   296                              <4> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   297                              <4> 
   298                              <4> ; --- USB Standard Request Codes ---
   299                              <4> USB_REQ_GET_DESC     equ 0x06
   300                              <4> USB_REQ_SET_CONFIG   equ 0x09
   301                              <4> USB_REQ_SET_IFACE    equ 0x0B
   302                              <4> 
   303                              <4> ; --- USB HID Request Codes ---
   304                              <4> USB_HID_SET_PROTOCOL equ 0x0B
   305                              <4> 
   306                              <4> ; --- USB Descriptor Types ---
   307                              <4> USB_DESC_DEVICE      equ 0x01
   308                              <4> USB_DESC_CONFIG      equ 0x02
   309                              <4> USB_DESC_INTERFACE   equ 0x04
   310                              <4> USB_DESC_ENDPOINT    equ 0x05
   311                              <4> USB_DESC_HID         equ 0x21
   312                              <4> 
   313                              <4> ; --- USB Endpoint Types ---
   314                              <4> USB_EP_CONTROL       equ 0
   315                              <4> USB_EP_ISOCH         equ 1
   316                              <4> USB_EP_BULK          equ 2
   317                              <4> USB_EP_INTERRUPT     equ 3
   318                              <4> 
   319                              <4> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   320                              <4> XHCI_EP_NOT_VALID    equ 0
   321                              <4> XHCI_EP_ISOCH_OUT    equ 1
   322                              <4> XHCI_EP_BULK_OUT     equ 2
   323                              <4> XHCI_EP_INT_OUT      equ 3
   324                              <4> XHCI_EP_CONTROL      equ 4
   325                              <4> XHCI_EP_ISOCH_IN     equ 5
   326                              <4> XHCI_EP_BULK_IN      equ 6
   327                              <4> XHCI_EP_INT_IN       equ 7
   328                              <4> 
   329                              <4> ; --- XHCI Port Speeds ---
   330                              <4> XHCI_SPEED_FULL      equ 1
   331                              <4> XHCI_SPEED_LOW       equ 2
   332                              <4> XHCI_SPEED_HIGH      equ 3
