   277 000043A1 C1E310              <1>     shl ebx, 16
   278 000043A4 09D8                <1>     or eax, ebx
   279 000043A6 4489F3              <1>     mov ebx, r14d
   280 000043A9 C1E30B              <1>     shl ebx, 11
   281 000043AC 09D8                <1>     or eax, ebx
