    17 000110E6 30C0                <1>     xor al, al              ; Searching for null
    18 000110E8 F2AE                <1>     repne scasb
    19 000110EA 48F7D1              <1>     not rcx
    20 000110ED 48FFC9              <1>     dec rcx                  ; RCX = length
