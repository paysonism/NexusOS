    66                              <2>  mov edi, %1
    67                              <2> %endif
    68                              <2>  movzx esi, byte [rel trace_active_slot]
    69                              <2>  call trace_fn_enter
    70                              <2>  pop r11
    71                              <2>  pop r10
    72                              <2>  pop r9
    73                              <2>  pop r8
    74                              <2>  pop rdi
    75                              <2>  pop rsi
