   133 00007D21 83F801              <1>     cmp eax, 1
   134 00007D24 0F823B010000        <1>     jb .init_fail
   135 00007D2A 83F802              <1>     cmp eax, 2
   136 00007D2D 0F8732010000        <1>     ja .init_fail
   137 00007D33 8805(E70D0000)      <1>     mov [fat16_num_fats], al
