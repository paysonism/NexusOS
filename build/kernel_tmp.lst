   111                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
   112                              <2> 
   113                              <2> ; --- Keyboard ---
   114                              <2> KB_BUFFER_SIZE      equ 64
   115                              <2> 
   116                              <2> ; --- Mouse ---
   117                              <2> MOUSE_BUFFER_SIZE   equ 64
   118                              <2> CURSOR_WIDTH        equ 12
   119                              <2> CURSOR_HEIGHT       equ 19
   120                              <2> 
   121                              <2> ; --- PIT ---
   122                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   123                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   124                              <2> 
   125                              <2> ; --- PIC vectors ---
   126                              <2> IRQ_BASE_MASTER     equ 32
   127                              <2> IRQ_BASE_SLAVE      equ 40
   128                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   129                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   130                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   131                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   132                              <2> 
   133                              <2> ; --- Font ---
   134                              <2> FONT_WIDTH          equ 8
   135                              <2> FONT_HEIGHT         equ 16
   136                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   137                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   138                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   139                              <2> 
   140                              <2> ; --- Window flags ---
   141                              <2> WF_VISIBLE          equ 0x01
   142                              <2> WF_FOCUSED          equ 0x02
   143                              <2> WF_DRAGGING         equ 0x04
   144                              <2> WF_MINIMIZED        equ 0x08
   145                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   146                              <2> 
   147                              <2> ; --- Mouse event types ---
   148                              <2> MEVT_MOVE           equ 1
   149                              <2> MEVT_LCLICK         equ 2
   150                              <2> MEVT_RCLICK         equ 3
   151                              <2> MEVT_LRELEASE       equ 4
   152                              <2> MEVT_RRELEASE       equ 5
   153                              <2> 
   154                              <2> ; --- Key modifier flags ---
   155                              <2> KMOD_SHIFT          equ 0x01
   156                              <2> KMOD_CTRL           equ 0x02
   157                              <2> KMOD_ALT            equ 0x04
   158                              <2> 
   159                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   160                              <2> KEY_F1              equ 0xF1
   161                              <2> KEY_F2              equ 0xF2
   162                              <2> KEY_F3              equ 0xF3
   163                              <2> KEY_F4              equ 0xF4
   164                              <2> KEY_F5              equ 0xF5
   165                              <2> KEY_F6              equ 0xF6
   166                              <2> KEY_F7              equ 0xF7
   167                              <2> KEY_F8              equ 0xF8
   168                              <2> KEY_F9              equ 0xF9
   169                              <2> KEY_F10             equ 0xFA
   170                              <2> KEY_F11             equ 0xFB
   171                              <2> KEY_F12             equ 0xFC
   172                              <2> 
   173                              <2> ; --- USB/XHCI Memory Layout ---
   174                              <2> %ifdef NEXUS_CACHE32_MAX
   175                              <2> XHCI_DCBAA_ADDR     equ 0x1900000    ; Cold DMA region outside GUI LLC arena
   176                              <2> XHCI_CMD_RING_ADDR  equ 0x1910000
   177                              <2> XHCI_ERST_ADDR      equ 0x1920000
   178                              <2> XHCI_EVT_RING_ADDR  equ 0x1930000
   179                              <2> XHCI_SCRATCH_ADDR   equ 0x1940000
   180                              <2> XHCI_DEV_CTX_ADDR   equ 0x1950000
   181                              <2> XHCI_INPUT_CTX_ADDR equ 0x1960000
   182                              <2> XHCI_CTRL_RING_ADDR equ 0x1970000
   183                              <2> XHCI_INT_RING_ADDR  equ 0x1980000
   184                              <2> XHCI_CTRL_BUF_ADDR  equ 0x1990000
   185                              <2> XHCI_MOUSE_BUF_ADDR equ 0x19A0000
   186                              <2> XHCI_DEV_CTX2_ADDR  equ 0x19B0000
   187                              <2> XHCI_INT_RING2_ADDR equ 0x19C0000
   188                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x19D0000
   189                              <2> XHCI_CTRL_RING2_ADDR equ 0x19E0000
   190                              <2> XHCI_MEM_END        equ 0x19F0000
   191                              <2> %else
   192                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   193                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   194                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   195                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   196                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   197                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   198                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   199                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   200                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   201                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   202                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   203                              <2> ; Slot 2 device support
   204                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   205                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   206                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   207                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   208                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   209                              <2> %endif
   210                              <2> 
   211                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   212                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   213                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   214                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   215                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   216                              <2> XHCI_CAP_DBOFF      equ 0x14
   217                              <2> XHCI_CAP_RTSOFF     equ 0x18
   218                              <2> 
   219                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   220                              <2> XHCI_OP_USBCMD      equ 0x00
   221                              <2> XHCI_OP_USBSTS      equ 0x04
   222                              <2> XHCI_OP_PAGESIZE     equ 0x08
   223                              <2> XHCI_OP_DNCTRL      equ 0x14
   224                              <2> XHCI_OP_CRCR_LO     equ 0x18
   225                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   226                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   227                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   228                              <2> XHCI_OP_CONFIG      equ 0x38
   229                              <2> 
   230                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   231                              <2> XHCI_PORTSC         equ 0x00
   232                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   233                              <2> 
   234                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   235                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   236                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   237                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   238                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   239                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   240                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   241                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   242                              <2> 
   243                              <2> ; --- USBCMD bits ---
   244                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   245                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   246                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   247                              <2> 
   248                              <2> ; --- USBSTS bits ---
   249                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   250                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   251                              <2> 
   252                              <2> ; --- PORTSC bits ---
   253                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   254                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   255                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   256                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   257                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   258                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   259                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   260                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   261                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   262                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   263                              <2> 
   264                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   265                              <2> TRB_NORMAL           equ (1 << 10)
   266                              <2> TRB_SETUP            equ (2 << 10)
   267                              <2> TRB_DATA             equ (3 << 10)
   268                              <2> TRB_STATUS           equ (4 << 10)
   269                              <2> TRB_LINK             equ (6 << 10)
   270                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   271                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   272                              <2> TRB_CONFIG_EP        equ (12 << 10)
   273                              <2> TRB_EVAL_CTX         equ (13 << 10)
   274                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   275                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   276                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   277                              <2> 
   278                              <2> ; --- TRB Flag Bits (dword 3) ---
   279                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   280                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   281                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   282                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   283                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   284                              <2> 
   285                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   286                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   287                              <2> TRB_TRT_OUT          equ (2 << 16)
   288                              <2> TRB_TRT_IN           equ (3 << 16)
   289                              <2> 
   290                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   291                              <2> TRB_DIR_OUT          equ (0 << 16)
   292                              <2> TRB_DIR_IN           equ (1 << 16)
   293                              <2> 
   294                              <2> ; --- Ring sizes ---
   295                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   296                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   297                              <2> 
   298                              <2> ; --- USB Standard Request Codes ---
   299                              <2> USB_REQ_GET_DESC     equ 0x06
   300                              <2> USB_REQ_SET_CONFIG   equ 0x09
   301                              <2> USB_REQ_SET_IFACE    equ 0x0B
   302                              <2> 
   303                              <2> ; --- USB HID Request Codes ---
   304                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   305                              <2> 
   306                              <2> ; --- USB Descriptor Types ---
   307                              <2> USB_DESC_DEVICE      equ 0x01
   308                              <2> USB_DESC_CONFIG      equ 0x02
   309                              <2> USB_DESC_INTERFACE   equ 0x04
   310                              <2> USB_DESC_ENDPOINT    equ 0x05
   311                              <2> USB_DESC_HID         equ 0x21
   312                              <2> 
   313                              <2> ; --- USB Endpoint Types ---
   314                              <2> USB_EP_CONTROL       equ 0
   315                              <2> USB_EP_ISOCH         equ 1
   316                              <2> USB_EP_BULK          equ 2
   317                              <2> USB_EP_INTERRUPT     equ 3
   318                              <2> 
   319                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   320                              <2> XHCI_EP_NOT_VALID    equ 0
   321                              <2> XHCI_EP_ISOCH_OUT    equ 1
   322                              <2> XHCI_EP_BULK_OUT     equ 2
   323                              <2> XHCI_EP_INT_OUT      equ 3
   324                              <2> XHCI_EP_CONTROL      equ 4
   325                              <2> XHCI_EP_ISOCH_IN     equ 5
   326                              <2> XHCI_EP_BULK_IN      equ 6
   327                              <2> XHCI_EP_INT_IN       equ 7
   328                              <2> 
   329                              <2> ; --- XHCI Port Speeds ---
   330                              <2> XHCI_SPEED_FULL      equ 1
   331                              <2> XHCI_SPEED_LOW       equ 2
   332                              <2> XHCI_SPEED_HIGH      equ 3
   333                              <2> XHCI_SPEED_SUPER     equ 4
     8                              <1> 
     9                              <1> ; Icon layout
    10                              <1> ICON_SIZE       equ 48
    11                              <1> ICON_STRIDE     equ 84         ; vertical spacing per icon (48 + 20 gap + 16 label)
    12                              <1> ICON_X          equ 24
    13                              <1> ICON_BASE_Y     equ 24
    14                              <1> ICON_HIT_X      equ 20
    15                              <1> ICON_HIT_W      equ 96
    16                              <1> MAX_DESK_ICONS  equ 8
    17                              <1> 
    18                              <1> section .text
    19                              <1> global desktop_draw_icons
    20                              <1> global desktop_handle_click
    21                              <1> global desktop_has_icon
    22                              <1> global desktop_add_icon
    23                              <1> global desktop_remove_icon
    24                              <1> global desktop_icons
    25                              <1> 
    26                              <1> extern render_rect
    27                              <1> extern render_text
    28                              <1> extern app_launch
    29                              <1> extern tb_start_menu_open
    30                              <1> 
    31                              <1> ; ============================================================================
    32                              <1> ; Draw all desktop icons from the icon table
    33                              <1> ; ============================================================================
    34                              <1> desktop_draw_icons:
    35 000099EB 53                  <1>     push rbx
    36 000099EC 4154                <1>     push r12
    37 000099EE 4155                <1>     push r13
    38 000099F0 4156                <1>     push r14
    39                              <1> 
    40 000099F2 4531E4              <1>     xor r12d, r12d           ; slot index
    41 000099F5 41BE18000000        <1>     mov r14d, ICON_BASE_Y    ; current Y position
    42                              <1> 
    43                              <1> .draw_loop:
    44 000099FB 4183FC08            <1>     cmp r12d, MAX_DESK_ICONS
    45 000099FF 0F8D10020000        <1>     jge .draw_done
    46                              <1> 
    47 00009A05 410FB68424-         <1>     movzx eax, byte [desktop_icons + r12]
    47 00009A0A [F8110000]          <1>
    48 00009A0E 84C0                <1>     test al, al
    49 00009A10 0F84F3010000        <1>     jz .draw_next             ; empty slot
    50                              <1> 
    51                              <1>     ; al = app ID. Look up icon info.
    52 00009A16 4189C5              <1>     mov r13d, eax             ; save app ID
    53 00009A19 488D1D(00120000)    <1>     lea rbx, [icon_table]
    54                              <1>     ; index = app_id - 2 (apps start at ID 2)
    55 00009A20 83E802              <1>     sub eax, 2
    56 00009A23 0F88E0010000        <1>     js .draw_next
    57 00009A29 83F806              <1>     cmp eax, 6
    58 00009A2C 0F8DD7010000        <1>     jge .draw_next
    59 00009A32 6BC014              <1>     imul eax, eax, 20        ; 20 bytes per entry: 4 color + 8 label_ptr + 4 detail_color + 4 pad
    60 00009A35 4801C3              <1>     add rbx, rax
    61                              <1> 
    62                              <1>     ; Draw icon background
    63 00009A38 BF18000000          <1>     mov rdi, ICON_X
    64 00009A3D 4C89F6              <1>     mov rsi, r14
    65 00009A40 BA30000000          <1>     mov rdx, ICON_SIZE
    66 00009A45 B930000000          <1>     mov rcx, ICON_SIZE
    67 00009A4A 448B03              <1>     mov r8d, [rbx]            ; icon color
    68 00009A4D E813EAFFFF          <1>     call render_rect
    69                              <1> 
    70                              <1>     ; Draw icon detail based on app type
    71 00009A52 4183FD02            <1>     cmp r13d, 2
    72 00009A56 7425                <1>     je .detail_explorer
    73 00009A58 4183FD03            <1>     cmp r13d, 3
    74 00009A5C 7441                <1>     je .detail_terminal
    75 00009A5E 4183FD04            <1>     cmp r13d, 4
    76 00009A62 7464                <1>     je .detail_notepad
    77 00009A64 4183FD05            <1>     cmp r13d, 5
    78 00009A68 0F84BC000000        <1>     je .detail_settings
    79 00009A6E 4183FD06            <1>     cmp r13d, 6
    80 00009A72 0F84F5000000        <1>     je .detail_paint
    81 00009A78 E96E010000          <1>     jmp .draw_label
    82                              <1> 
    83                              <1> .detail_explorer:
    84                              <1>     ; Folder tab
    85 00009A7D BF18000000          <1>     mov rdi, ICON_X
    86 00009A82 4C89F6              <1>     mov rsi, r14
    87 00009A85 BA14000000          <1>     mov rdx, 20
    88 00009A8A B908000000          <1>     mov rcx, 8
    89 00009A8F 41B82288AA00        <1>     mov r8d, 0x00AA8822
    90 00009A95 E8CBE9FFFF          <1>     call render_rect
    91 00009A9A E94C010000          <1>     jmp .draw_label
    92                              <1> 
    93                              <1> .detail_terminal:
    94                              <1>     ; Green prompt ">_"
    95 00009A9F BF20000000          <1>     mov rdi, ICON_X + 8
    96 00009AA4 67418D7610          <1>     lea esi, [r14d + 16]
    97 00009AA9 48BA-               <1>     mov rdx, szPromptIcon
    97 00009AAB [A412000000000000]  <1>
    98 00009AB3 B954FC5400          <1>     mov ecx, 0x0054FC54   ; VGA lightgreen
    99 00009AB8 41B800000000        <1>     mov r8d, 0x00000000   ; VGA black bg
   100 00009ABE E8A7E9FFFF          <1>     call render_text
   101 00009AC3 E923010000          <1>     jmp .draw_label
   102                              <1> 
   103                              <1> .detail_notepad:
   104                              <1>     ; Lines on notepad
   105 00009AC8 BF20000000          <1>     mov rdi, ICON_X + 8
   106 00009ACD 67418D760C          <1>     lea esi, [r14d + 12]
   107 00009AD2 BA20000000          <1>     mov rdx, 32
   108 00009AD7 B902000000          <1>     mov rcx, 2
   109 00009ADC 41B8CCCCCC00        <1>     mov r8d, 0x00CCCCCC
   110 00009AE2 E87EE9FFFF          <1>     call render_rect
   111 00009AE7 BF20000000          <1>     mov rdi, ICON_X + 8
   112 00009AEC 67418D7614          <1>     lea esi, [r14d + 20]
   113 00009AF1 BA1C000000          <1>     mov rdx, 28
   114 00009AF6 B902000000          <1>     mov rcx, 2
   115 00009AFB 41B8CCCCCC00        <1>     mov r8d, 0x00CCCCCC
   116 00009B01 E85FE9FFFF          <1>     call render_rect
   117 00009B06 BF20000000          <1>     mov rdi, ICON_X + 8
   118 00009B0B 67418D761C          <1>     lea esi, [r14d + 28]
   119 00009B10 BA20000000          <1>     mov rdx, 32
   120 00009B15 B902000000          <1>     mov rcx, 2
   121 00009B1A 41B8CCCCCC00        <1>     mov r8d, 0x00CCCCCC
   122 00009B20 E840E9FFFF          <1>     call render_rect
   123 00009B25 E9C1000000          <1>     jmp .draw_label
   124                              <1> 
   125                              <1> .detail_settings:
   126                              <1>     ; Gear-like crosshair
   127 00009B2A BF2C000000          <1>     mov rdi, ICON_X + 20
   128 00009B2F 67418D7608          <1>     lea esi, [r14d + 8]
   129 00009B34 BA08000000          <1>     mov rdx, 8
   130 00009B39 B920000000          <1>     mov rcx, 32
   131 00009B3E 41B8AAAAAA00        <1>     mov r8d, 0x00AAAAAA
   132 00009B44 E81CE9FFFF          <1>     call render_rect
   133 00009B49 BF20000000          <1>     mov rdi, ICON_X + 8
   134 00009B4E 67418D7614          <1>     lea esi, [r14d + 20]
   135 00009B53 BA20000000          <1>     mov rdx, 32
   136 00009B58 B908000000          <1>     mov rcx, 8
   137 00009B5D 41B8AAAAAA00        <1>     mov r8d, 0x00AAAAAA
   138 00009B63 E8FDE8FFFF          <1>     call render_rect
   139 00009B68 E97E000000          <1>     jmp .draw_label
   140                              <1> 
   141                              <1> .detail_paint:
   142                              <1>     ; Color swatch
   143 00009B6D BF20000000          <1>     mov rdi, ICON_X + 8
   144 00009B72 67418D7608          <1>     lea esi, [r14d + 8]
   145 00009B77 BA0E000000          <1>     mov rdx, 14
   146 00009B7C B90E000000          <1>     mov rcx, 14
   147 00009B81 41B80000FF00        <1>     mov r8d, 0x00FF0000
   148 00009B87 E8D9E8FFFF          <1>     call render_rect
   149 00009B8C BF32000000          <1>     mov rdi, ICON_X + 26
   150 00009B91 67418D7608          <1>     lea esi, [r14d + 8]
   151 00009B96 BA0E000000          <1>     mov rdx, 14
   152 00009B9B B90E000000          <1>     mov rcx, 14
   153 00009BA0 41B8FF000000        <1>     mov r8d, 0x000000FF
   154 00009BA6 E8BAE8FFFF          <1>     call render_rect
   155 00009BAB BF20000000          <1>     mov rdi, ICON_X + 8
   156 00009BB0 67418D761A          <1>     lea esi, [r14d + 26]
   157 00009BB5 BA0E000000          <1>     mov rdx, 14
   158 00009BBA B90E000000          <1>     mov rcx, 14
   159 00009BBF 41B800FF0000        <1>     mov r8d, 0x0000FF00
   160 00009BC5 E89BE8FFFF          <1>     call render_rect
   161 00009BCA BF32000000          <1>     mov rdi, ICON_X + 26
   162 00009BCF 67418D761A          <1>     lea esi, [r14d + 26]
   163 00009BD4 BA0E000000          <1>     mov rdx, 14
   164 00009BD9 B90E000000          <1>     mov rcx, 14
   165 00009BDE 41B800FFFF00        <1>     mov r8d, 0x00FFFF00
   166 00009BE4 E87CE8FFFF          <1>     call render_rect
   167 00009BE9 EB00                <1>     jmp .draw_label
   168                              <1> 
   169                              <1> .draw_label:
   170                              <1>     ; Draw label below icon
   171 00009BEB BF18000000          <1>     mov rdi, ICON_X
   172 00009BF0 67418D7634          <1>     lea esi, [r14d + ICON_SIZE + 4]
   173 00009BF5 488B5304            <1>     mov rdx, [rbx + 4]       ; label string pointer
   174 00009BF9 B9FCFCFC00          <1>     mov ecx, COLOR_TEXT_WHITE
   175 00009BFE 41B8FFFFFFFF        <1>     mov r8d, -1               ; transparent bg
   176 00009C04 E861E8FFFF          <1>     call render_text
   177                              <1> 
   178                              <1> .draw_next:
   179 00009C09 41FFC4              <1>     inc r12d
   180 00009C0C 4183C654            <1>     add r14d, ICON_STRIDE
   181 00009C10 E9E6FDFFFF          <1>     jmp .draw_loop
   182                              <1> 
   183                              <1> .draw_done:
   184 00009C15 415E                <1>     pop r14
   185 00009C17 415D                <1>     pop r13
   186 00009C19 415C                <1>     pop r12
   187 00009C1B 5B                  <1>     pop rbx
   188 00009C1C C3                  <1>     ret
   189                              <1> 
   190                              <1> ; ============================================================================
   191                              <1> ; Handle desktop clicks: RDI=mouseX, RSI=mouseY
   192                              <1> ; Returns RAX: 0=not handled, 1=handled
   193                              <1> ; ============================================================================
   194                              <1> desktop_handle_click:
   195 00009C1D 53                  <1>     push rbx
   196 00009C1E 4154                <1>     push r12
   197 00009C20 4155                <1>     push r13
   198                              <1> 
   199                              <1>     ; Close start menu
   200 00009C22 C605(DD110000)00    <1>     mov byte [tb_start_menu_open], 0
   201                              <1> 
   202                              <1>     ; Accept clicks on the icon and its label, not just the 48px icon box.
   203 00009C29 83FF14              <1>     cmp edi, ICON_HIT_X
   204 00009C2C 7C4D                <1>     jl .click_none
   205 00009C2E 83FF74              <1>     cmp edi, ICON_HIT_X + ICON_HIT_W
   206 00009C31 7F48                <1>     jg .click_none
   207                              <1> 
   208                              <1>     ; Find which icon slot
   209 00009C33 4531E4              <1>     xor r12d, r12d
   210 00009C36 41BD18000000        <1>     mov r13d, ICON_BASE_Y
   211                              <1> 
   212                              <1> .click_loop:
   213 00009C3C 4183FC08            <1>     cmp r12d, MAX_DESK_ICONS
   214 00009C40 7D39                <1>     jge .click_none
   215                              <1> 
   216 00009C42 410FB68424-         <1>     movzx eax, byte [desktop_icons + r12]
   216 00009C47 [F8110000]          <1>
   217 00009C4B 84C0                <1>     test al, al
   218 00009C4D 7423                <1>     jz .click_next
   219                              <1> 
   220                              <1>     ; Check Y range (icon + label area)
   221 00009C4F 4439EE              <1>     cmp esi, r13d
   222 00009C52 7C1E                <1>     jl .click_next
   223 00009C54 67418D4D44          <1>     lea ecx, [r13d + ICON_SIZE + 20]
   224 00009C59 39CE                <1>     cmp esi, ecx
   225 00009C5B 7F15                <1>     jg .click_next
   226                              <1> 
   227                              <1>     ; Hit! Launch this app
   228 00009C5D 410FB6BC24-         <1>     movzx edi, byte [desktop_icons + r12]
   228 00009C62 [F8110000]          <1>
   229 00009C66 E83B060000          <1>     call app_launch
   230 00009C6B B801000000          <1>     mov rax, 1
   231 00009C70 EB0B                <1>     jmp .click_ret
   232                              <1> 
   233                              <1> .click_next:
   234 00009C72 41FFC4              <1>     inc r12d
   235 00009C75 4183C554            <1>     add r13d, ICON_STRIDE
   236 00009C79 EBC1                <1>     jmp .click_loop
   237                              <1> 
   238                              <1> .click_none:
   239 00009C7B 31C0                <1>     xor eax, eax
   240                              <1> .click_ret:
   241 00009C7D 415D                <1>     pop r13
   242 00009C7F 415C                <1>     pop r12
   243 00009C81 5B                  <1>     pop rbx
   244 00009C82 C3                  <1>     ret
   245                              <1> 
   246                              <1> ; ============================================================================
   247                              <1> ; desktop_has_icon: EDI=app_id -> EAX=1 if on desktop, 0 if not
   248                              <1> ; ============================================================================
   249                              <1> desktop_has_icon:
   250 00009C83 31C9                <1>     xor ecx, ecx
   251                              <1> .has_loop:
   252 00009C85 83F908              <1>     cmp ecx, MAX_DESK_ICONS
   253 00009C88 7D13                <1>     jge .has_no
   254 00009C8A 4038B9[F8110000]    <1>     cmp byte [desktop_icons + rcx], dil
   255 00009C91 7404                <1>     je .has_yes
   256 00009C93 FFC1                <1>     inc ecx
   257 00009C95 EBEE                <1>     jmp .has_loop
   258                              <1> .has_yes:
   259 00009C97 B801000000          <1>     mov eax, 1
   260 00009C9C C3                  <1>     ret
   261                              <1> .has_no:
   262 00009C9D 31C0                <1>     xor eax, eax
   263 00009C9F C3                  <1>     ret
   264                              <1> 
   265                              <1> ; ============================================================================
   266                              <1> ; desktop_add_icon: EDI=app_id -> adds to first empty slot
   267                              <1> ; ============================================================================
   268                              <1> desktop_add_icon:
   269                              <1>     ; First check if already present
   270 00009CA0 57                  <1>     push rdi
   271 00009CA1 E8DDFFFFFF          <1>     call desktop_has_icon
   272 00009CA6 5F                  <1>     pop rdi
   273 00009CA7 85C0                <1>     test eax, eax
   274 00009CA9 751B                <1>     jnz .add_done             ; already there
   275                              <1> 
   276 00009CAB 31C9                <1>     xor ecx, ecx
   277                              <1> .add_loop:
   278 00009CAD 83F908              <1>     cmp ecx, MAX_DESK_ICONS
   279 00009CB0 7D14                <1>     jge .add_done             ; no room
   280 00009CB2 80B9[F8110000]00    <1>     cmp byte [desktop_icons + rcx], 0
   281 00009CB9 7404                <1>     je .add_found
   282 00009CBB FFC1                <1>     inc ecx
   283 00009CBD EBEE                <1>     jmp .add_loop
   284                              <1> .add_found:
   285 00009CBF 4088B9[F8110000]    <1>     mov byte [desktop_icons + rcx], dil
   286                              <1> .add_done:
   287 00009CC6 C3                  <1>     ret
   288                              <1> 
   289                              <1> ; ============================================================================
   290                              <1> ; desktop_remove_icon: EDI=app_id -> removes from desktop
   291                              <1> ; ============================================================================
   292                              <1> desktop_remove_icon:
   293 00009CC7 31C9                <1>     xor ecx, ecx
   294                              <1> .rem_loop:
   295 00009CC9 83F908              <1>     cmp ecx, MAX_DESK_ICONS
   296 00009CCC 7D3E                <1>     jge .rem_done
   297 00009CCE 4038B9[F8110000]    <1>     cmp byte [desktop_icons + rcx], dil
   298 00009CD5 7404                <1>     je .rem_found
   299 00009CD7 FFC1                <1>     inc ecx
   300 00009CD9 EBEE                <1>     jmp .rem_loop
   301                              <1> .rem_found:
   302 00009CDB C681[F8110000]00    <1>     mov byte [desktop_icons + rcx], 0
   303                              <1>     ; Compact: shift remaining entries down
   304 00009CE2 678D5101            <1>     lea edx, [ecx + 1]
   305                              <1> .compact:
   306 00009CE6 83FA08              <1>     cmp edx, MAX_DESK_ICONS
   307 00009CE9 7D1A                <1>     jge .compact_zero
   308 00009CEB 0FB682[F8110000]    <1>     movzx eax, byte [desktop_icons + rdx]
   309 00009CF2 8881[F8110000]      <1>     mov byte [desktop_icons + rcx], al
   310 00009CF8 C682[F8110000]00    <1>     mov byte [desktop_icons + rdx], 0
   311 00009CFF FFC1                <1>     inc ecx
   312 00009D01 FFC2                <1>     inc edx
   313 00009D03 EBE1                <1>     jmp .compact
   314                              <1> .compact_zero:
   315 00009D05 C681[F8110000]00    <1>     mov byte [desktop_icons + rcx], 0
   316                              <1> .rem_done:
   317 00009D0C C3                  <1>     ret
