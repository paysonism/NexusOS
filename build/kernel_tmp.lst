    13                              <3> ; Callback ABI
    14                              <3> ; ------------
    15                              <3> ; draw/click handlers:
    16                              <3> ;   RDI = pointer to the shadow window struct in the app slot arena
    17                              <3> ; click handlers:
    18                              <3> ;   RSI = mouse X
    19                              <3> ;   RDX = mouse Y
    20                              <3> ; key handlers:
    21                              <3> ;   RSI = key code / translated character value
    22                              <3> ;
    23                              <3> ; Handlers execute in ring 3 and must return with RET unless they terminate the
    24                              <3> ; callback explicitly through SYS_APP_DONE.
    25                              <3> 
    26                              <3> %endif
