   362                              <1> ; ============================================================================
   363                              <1> ; i2c_init_controller - Initialize DesignWare I2C controller
   364                              <1> ; RSI = controller base address, EDI = 7-bit device address
   365                              <1> ; Returns: EAX = 1 success, 0 fail
   366                              <1> ; ============================================================================
   367                              <1> i2c_init_controller:
   368 00006754 51                  <1>     push rcx
   369                              <1> 
   370                              <1>     ; Disable controller first
   371 00006755 C7466C00000000      <1>     mov dword [rsi + DW_IC_ENABLE], 0
   372                              <1> 
   373                              <1>     ; Wait for disabled (activity bit clear)
   374 0000675C B988130000          <1>     mov ecx, 5000
   375                              <1> .wait_dis:
   376 00006761 8B869C000000        <1>     mov eax, [rsi + DW_IC_ENABLE_STATUS]
   377 00006767 A901000000          <1>     test eax, 1                 ; IC_EN bit
   378 0000676C 7408                <1>     jz .dis_ok
   379 0000676E FFC9                <1>     dec ecx
   380 00006770 75EF                <1>     jnz .wait_dis
   381 00006772 31C0                <1>     xor eax, eax
   382 00006774 59                  <1>     pop rcx
   383 00006775 C3                  <1>     ret
   384                              <1> .dis_ok:
   385                              <1> 
   386                              <1>     ; Preserve firmware IC_CON speed/timing bits - UEFI already set correct
   387                              <1>     ; values for this platform's I2C clock. Only enforce master mode flags.
   388 00006776 8B06                <1>     mov eax, [rsi + DW_IC_CON]
   389 00006778 83C861              <1>     or eax, IC_CON_MASTER_MODE | IC_CON_RESTART_EN | IC_CON_SLAVE_DISABLE
   390 0000677B 8906                <1>     mov [rsi + DW_IC_CON], eax
   391                              <1> 
   392                              <1>     ; Set target address
   393 0000677D 897E04              <1>     mov [rsi + DW_IC_TAR], edi
   394                              <1> 
   395                              <1>     ; Do NOT overwrite SCL HCNT/LCNT/SDA_HOLD - firmware values are correct
   396                              <1>     ; for this platform's FCH I2C clock (varies: 100/133/150MHz by platform)
   397                              <1> 
   398                              <1>     ; Mask all interrupts (we poll)
   399 00006780 C7463000000000      <1>     mov dword [rsi + DW_IC_INTR_MASK], 0
   400                              <1> 
   401                              <1>     ; Set RX threshold to 0 (notify on any byte)
   402 00006787 C7463800000000      <1>     mov dword [rsi + DW_IC_RX_TL], 0
   403                              <1> 
   404                              <1>     ; Clear any pending interrupts/aborts
   405 0000678E 8B4640              <1>     mov eax, [rsi + DW_IC_CLR_INTR]
   406 00006791 8B4654              <1>     mov eax, [rsi + DW_IC_CLR_TX_ABRT]
   407                              <1> 
   408                              <1>     ; Enable controller
   409 00006794 C7466C01000000      <1>     mov dword [rsi + DW_IC_ENABLE], 1
   410                              <1> 
   411                              <1>     ; Wait for enabled
   412 0000679B B988130000          <1>     mov ecx, 5000
   413                              <1> .wait_en:
   414 000067A0 8B869C000000        <1>     mov eax, [rsi + DW_IC_ENABLE_STATUS]
   415 000067A6 A901000000          <1>     test eax, 1
   416 000067AB 7508                <1>     jnz .en_ok
   417 000067AD FFC9                <1>     dec ecx
   418 000067AF 75EF                <1>     jnz .wait_en
   419 000067B1 31C0                <1>     xor eax, eax
   420 000067B3 59                  <1>     pop rcx
   421 000067B4 C3                  <1>     ret
   422                              <1> .en_ok:
   423                              <1> 
   424 000067B5 B801000000          <1>     mov eax, 1
   425 000067BA 59                  <1>     pop rcx
   426 000067BB C3                  <1>     ret
   427                              <1> 
   428                              <1> ; ============================================================================
   429                              <1> ; i2c_write_byte / i2c_write_byte_stop - Write to I2C bus
   430                              <1> ; ============================================================================
   431                              <1> i2c_write_byte:
   432 000067BC 0FB6C0              <1>     movzx eax, al
   433 000067BF 894610              <1>     mov [rsi + DW_IC_DATA_CMD], eax
   434 000067C2 C3                  <1>     ret
   435                              <1> 
   436                              <1> i2c_write_byte_stop:
   437 000067C3 0FB6C0              <1>     movzx eax, al
   438 000067C6 0D00020000          <1>     or eax, IC_CMD_STOP
   439 000067CB 894610              <1>     mov [rsi + DW_IC_DATA_CMD], eax
   440 000067CE C3                  <1>     ret
   441                              <1> 
   442                              <1> ; ============================================================================
   443                              <1> ; i2c_wait_tx_empty - Wait for TX FIFO empty
   444                              <1> ; Returns CF=0 ok, CF=1 timeout
   445                              <1> ; ============================================================================
   446                              <1> i2c_wait_tx_empty:
   447 000067CF 51                  <1>     push rcx
   448 000067D0 B9A0860100          <1>     mov ecx, 100000
   449                              <1> .loop:
   450 000067D5 8B4670              <1>     mov eax, [rsi + DW_IC_STATUS]
   451 000067D8 A904000000          <1>     test eax, IC_STATUS_TFE
   452 000067DD 7517                <1>     jnz .ok
   453                              <1>     ; Check for abort
   454 000067DF 8B4634              <1>     mov eax, [rsi + DW_IC_RAW_INTR_STAT]
   455 000067E2 A940000000          <1>     test eax, (1 << 6)         ; TX_ABRT
   456 000067E7 7507                <1>     jnz .abort
   457 000067E9 FFC9                <1>     dec ecx
   458 000067EB 75E8                <1>     jnz .loop
   459 000067ED 59                  <1>     pop rcx
   460 000067EE F9                  <1>     stc
   461 000067EF C3                  <1>     ret
   462                              <1> .abort:
   463 000067F0 8B4654              <1>     mov eax, [rsi + DW_IC_CLR_TX_ABRT]
   464 000067F3 59                  <1>     pop rcx
   465 000067F4 F9                  <1>     stc
   466 000067F5 C3                  <1>     ret
   467                              <1> .ok:
   468 000067F6 59                  <1>     pop rcx
   469 000067F7 F8                  <1>     clc
   470 000067F8 C3                  <1>     ret
   471                              <1> 
   472                              <1> ; ============================================================================
   473                              <1> ; i2c_wait_rx_avail - Wait for N bytes in RX FIFO
   474                              <1> ; ECX = count to wait for
   475                              <1> ; Returns CF=0 ok, CF=1 timeout
   476                              <1> ; ============================================================================
   477                              <1> i2c_wait_rx_avail:
   478 000067F9 51                  <1>     push rcx
   479 000067FA 52                  <1>     push rdx
   480 000067FB 89CA                <1>     mov edx, ecx               ; Save wanted count
   481 000067FD B9A0860100          <1>     mov ecx, 100000
   482                              <1> .loop:
   483 00006802 8B4678              <1>     mov eax, [rsi + DW_IC_RXFLR]
   484 00006805 39D0                <1>     cmp eax, edx
   485 00006807 7D19                <1>     jge .ok
   486                              <1>     ; Check abort
   487 00006809 8B4634              <1>     mov eax, [rsi + DW_IC_RAW_INTR_STAT]
