    84                              <1>     ; Read boot sector of FAT16 partition
    85                              <1>     ; First attempt with default drive (0xE0)
    86 00007C74 BF40010000          <1>     mov rdi, FAT16_PART_LBA
    87 00007C79 BE0000D000          <1>     mov rsi, FAT16_SECTOR_BUF
    88 00007C7E BA01000000          <1>     mov edx, 1
    89 00007C83 E81EC3FFFF          <1>     call ata_read_sectors
    90 00007C88 85C0                <1>     test eax, eax
    91 00007C8A 750C                <1>     jnz .try_next_drive
    92                              <1> 
    93                              <1>     ; Check partition signature
    94 00007C8C 66813C25FE01D00055- <1>     cmp word [abs FAT16_SECTOR_BUF + 510], 0xAA55
    94 00007C95 AA                  <1>
    95 00007C96 743A                <1>     je .bpb_found
