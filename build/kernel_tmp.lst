   342 0000673B E8F3010000          <1>     call i2c_hid_read_report_desc
   343                              <1> 
   344 00006740 59                  <1>     pop rcx
   345 00006741 B801000000          <1>     mov eax, 1
   346 00006746 EB07                <1>     jmp .addr_ret
   347                              <1> 
