   306                              <2> 
   307                              <2>     ; Write to framebuffer
   308 0000F0BF 57                  <2>     push rdi
   309 0000F0C0 488B05(2A020000)    <2>     mov rax, [bb_addr]        ; RELOAD bb_addr (eax clobbered by source calc)
   310 0000F0C7 4801C7              <2>     add rdi, rax
   311 0000F0CA 44891C9F            <2>     mov [rdi + rbx * 4], r11d
   312 0000F0CE 5F                  <2>     pop rdi
   313                              <2> 
   314 0000F0CF FFC1                <2>     inc ecx
   315 0000F0D1 EBB4                <2>     jmp .bmp_col_loop
   316                              <2> 
   317                              <2> .bmp_row_done:
   318 0000F0D3 41FFCF              <2>     dec r15d
   319 0000F0D6 FFC2                <2>     inc edx
   320 0000F0D8 EB81                <2>     jmp .bmp_row_loop
   321                              <2> 
