     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - Common Macros
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> %ifndef MACROS_INC
     6                              <2> %define MACROS_INC
     7                              <2> 
     8                              <2> %include "trace.inc"
     1                              <3> ; ============================================================================
     2                              <3> ; NexusOS v3.0 - Function signature and trace macros
     3                              <3> ; ============================================================================
     4                              <3> 
     5                              <3> %ifndef TRACE_INC
     6                              <3> %define TRACE_INC
     7                              <3> 
     8                              <3> FN_KIND_SCALAR  equ 0
     9                              <3> FN_KIND_PTR     equ 1
    10                              <3> FN_KIND_CSTRING equ 2
    11                              <3> FN_KIND_HANDLE  equ 3
    12                              <3> 
    13                              <3> FN_RET_VOID     equ 0
    14                              <3> FN_RET_SCALAR   equ 1
    15                              <3> FN_RET_PTR      equ 2
    16                              <3> FN_RET_HANDLE   equ 3
    17                              <3> 
    18                              <3> TRACE_FLAG_ENTER         equ 1
    19                              <3> TRACE_FLAG_EXIT          equ 2
    20                              <3> TRACE_FLAG_SYSCALL_ENTER equ 4
    21                              <3> TRACE_FLAG_SYSCALL_EXIT  equ 8
    22                              <3> TRACE_FLAG_VALIDATE_FAIL equ 16
    23                              <3> 
    24                              <3> ; FN_BEGIN emits a normal function label plus machine-readable metadata.
    25                              <3> ; Slot is read from the global trace_active_slot (set by syscall entry).
    26                              <3> ; All caller-saved registers are preserved so this is safe to drop into
    27                              <3> ; ISR/IRQ landing pads as well as ordinary kernel functions.
    28                              <3> %macro FN_BEGIN 4
    29                              <3> %define __fn_prev_section __?SECT?__
    30                              <3>     global %1
    31                              <3> %1:
    32                              <3> %assign %{1}__argc %2
    33                              <3> %assign %{1}__kindmask %3
    34                              <3> %assign %{1}__retkind %4
    35                              <3> %ifdef ENABLE_SIG_SECTION
    36                              <3>     [section .signature]
    37                              <3> %{1}__sigmeta:
    38                              <3> %ifdef %{1}__hash
    39                              <3>     dq %{1}__hash
    40                              <3> %else
    41                              <3>     dq 0
    42                              <3> %endif
    43                              <3>     db %2
    44                              <3>     dd %3
    45                              <3>     db %4
    46                              <3>     dd __LINE__
    47                              <3>     dq %{1}__name
    48                              <3> %{1}__name:
    49                              <3>     db %str(%1), 0
    50                              <3>     __fn_prev_section
    51                              <3> %endif
    52                              <3> %ifdef ENABLE_TRACE
    53                              <3> %ifndef DISABLE_FN_RUNTIME_TRACE
    54                              <3>     push rax
    55                              <3>     push rcx
    56                              <3>     push rdx
    57                              <3>     push rsi
    58                              <3>     push rdi
    59                              <3>     push r8
    60                              <3>     push r9
    61                              <3>     push r10
    62                              <3>     push r11
    63                              <3> %ifdef %{1}__hash32
    64                              <3>     mov edi, %{1}__hash32
    65                              <3> %else
    66                              <3>     mov edi, %1
    67                              <3> %endif
    68                              <3>     movzx esi, byte [rel trace_active_slot]
    69                              <3>     call trace_fn_enter
    70                              <3>     pop r11
    71                              <3>     pop r10
    72                              <3>     pop r9
    73                              <3>     pop r8
    74                              <3>     pop rdi
    75                              <3>     pop rsi
    76                              <3>     pop rdx
    77                              <3>     pop rcx
    78                              <3>     pop rax
    79                              <3> %endif
    80                              <3> %endif
    81                              <3> %endmacro
    82                              <3> 
    83                              <3> ; FN_ARG is intentionally doc-only for now. The registry builder reads source
    84                              <3> ; FN_ARG lines and attaches arg names/kinds to the JSON sidecar.
    85                              <3> %macro FN_ARG 3
    86                              <3> %endmacro
    87                              <3> 
    88                              <3> %macro FN_END 1
    89                              <3> %ifdef ENABLE_TRACE
    90                              <3> %ifndef DISABLE_FN_RUNTIME_TRACE
    91                              <3>     push rax                        ; preserve retval at top of save area
    92                              <3>     push rcx
    93                              <3>     push rdx
    94                              <3>     push rsi
    95                              <3>     push rdi
    96                              <3>     push r8
    97                              <3>     push r9
    98                              <3>     push r10
    99                              <3>     push r11
   100                              <3> %ifdef %{1}__hash32
   101                              <3>     mov edi, %{1}__hash32
   102                              <3> %else
   103                              <3>     mov edi, %1
   104                              <3> %endif
   105                              <3>     movzx esi, byte [rel trace_active_slot]
   106                              <3>     mov rdx, [rsp + 8*8]            ; saved RAX (retval) sits 8 qwords below top
   107                              <3>     call trace_fn_exit
   108                              <3>     pop r11
   109                              <3>     pop r10
   110                              <3>     pop r9
   111                              <3>     pop r8
   112                              <3>     pop rdi
   113                              <3>     pop rsi
   114                              <3>     pop rdx
   115                              <3>     pop rcx
   116                              <3>     pop rax
   117                              <3> %endif
   118                              <3> %endif
   119                              <3> %endmacro
   120                              <3> 
   121                              <3> %macro FN_CALL 2
   122                              <3> %ifdef %{1}__argc
   123                              <3>     %if %{1}__argc != %2
   124                              <3>         %error "FN_CALL argc mismatch"
   125                              <3>     %endif
   126                              <3> %endif
   127                              <3>     call %1
   128                              <3> %endmacro
   129                              <3> 
   130                              <3> %macro FN_BEGIN_FULL 4
   131                              <3>     FN_BEGIN %1, %2, %3, %4
   132                              <3> %endmacro
   133                              <3> 
   134                              <3> ; Lightweight: declares signature only, no runtime trace (use in ISR/IRQ
   135                              <3> ; landing pads where calling helpers before the iretq frame is unsafe).
   136                              <3> %macro FN_DECL 4
   137                              <3>     global %1
   138                              <3> %1:
   139                              <3> %assign %{1}__argc %2
   140                              <3> %assign %{1}__kindmask %3
   141                              <3> %assign %{1}__retkind %4
   142                              <3> %ifdef ENABLE_SIG_SECTION
   143                              <3>     [section .signature]
   144                              <3> %{1}__sigmeta_decl:
   145                              <3> %ifdef %{1}__hash
   146                              <3>     dq %{1}__hash
   147                              <3> %else
   148                              <3>     dq 0
   149                              <3> %endif
   150                              <3>     db %2
   151                              <3>     dd %3
   152                              <3>     db %4
   153                              <3>     dd __LINE__
   154                              <3>     dq %{1}__name_decl
   155                              <3> %{1}__name_decl:
   156                              <3>     db %str(%1), 0
   157                              <3>     __SECT__
   158                              <3> %endif
   159                              <3> %endmacro
   160                              <3> 
   161                              <3> %endif
     9                              <2> 
