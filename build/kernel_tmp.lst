   251 0000668D 4531FF              <1>     xor r15d, r15d
   252 00006690 41FFC6              <1>     inc r14d
   253 00006693 4183FE20            <1>     cmp r14d, 32
   254 00006697 0F8C4BFFFFFF        <1>     jl .pci_scan
   255 0000669D 4531F6              <1>     xor r14d, r14d
   256 000066A0 41FFC5              <1>     inc r13d
   257 000066A3 4181FD00010000      <1>     cmp r13d, 256
