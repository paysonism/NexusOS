     7                              <3> 
     8                              <3> %include "trace.inc"
     9                              <3> 
    10                              <3> ; tools/build_sig_registry.py emits build/sig_hashes.inc before the kernel
    11                              <3> ; assembles; it provides `%define <name>__hash` lines so FN_BEGIN stamps the
    12                              <3> ; real FNV-1a fn_id into the .signature section instead of `dq 0`.
    13                              <3> %include "sig_hashes.inc"
    14                              <3> 
    15                              <3> ; Optional trace instrumentation is enabled by passing -dENABLE_TRACE to NASM.
    16                              <3> ; It mirrors ENABLE_DEBUG_SERIAL: release builds pay no macro/runtime cost.
    17                              <3> 
    18                              <3> ; Output character to COM1 for debugging
    19                              <3> %macro SER 1
    20                              <3> %ifdef ENABLE_DEBUG_SERIAL
    21                              <3>     push rax
    22                              <3>     push rdx
    23                              <3>     mov dx, 0x3F8
    24                              <3>     mov al, %1
    25                              <3>     out dx, al
    26                              <3>     pop rdx
    27                              <3>     pop rax
    28                              <3> %endif
    29                              <3> %endmacro
    30                              <3> 
    31                              <3> ; Save all general-purpose registers (64-bit)
    32                              <3> %macro PUSH_ALL 0
    33                              <3>     push rax
    34                              <3>     push rbx
    35                              <3>     push rcx
    36                              <3>     push rdx
    37                              <3>     push rsi
    38                              <3>     push rdi
    39                              <3>     push rbp
    40                              <3>     push r8
    41                              <3>     push r9
    42                              <3>     push r10
    43                              <3>     push r11
    44                              <3>     push r12
    45                              <3>     push r13
    46                              <3>     push r14
    47                              <3>     push r15
    48                              <3> %endmacro
    49                              <3> 
    50                              <3> ; Offset of registers in PUSH_ALL frame
    51                              <3> ALL_R15 equ 0
    52                              <3> ALL_R14 equ 8
    53                              <3> ALL_R13 equ 16
    54                              <3> ALL_R12 equ 24
    55                              <3> ALL_R11 equ 32
    56                              <3> ALL_R10 equ 40
    57                              <3> ALL_R9  equ 48
    58                              <3> ALL_R8  equ 56
    59                              <3> ALL_RBP equ 64
    60                              <3> ALL_RDI equ 72
    61                              <3> ALL_RSI equ 80
    62                              <3> ALL_RDX equ 88
    63                              <3> ALL_RCX equ 96
    64                              <3> ALL_RBX equ 104
    65                              <3> ALL_RAX equ 112
    66                              <3> 
    67                              <3> ; Restore all general-purpose registers (64-bit)
    68                              <3> %macro POP_ALL 0
    69                              <3>     pop r15
    70                              <3>     pop r14
    71                              <3>     pop r13
    72                              <3>     pop r12
    73                              <3>     pop r11
    74                              <3>     pop r10
    75                              <3>     pop r9
    76                              <3>     pop r8
    77                              <3>     pop rbp
    78                              <3>     pop rdi
    79                              <3>     pop rsi
    80                              <3>     pop rdx
    81                              <3>     pop rcx
    82                              <3>     pop rbx
    83                              <3>     pop rax
    84                              <3> %endmacro
    85                              <3> 
    86                              <3> ; Output byte to port with I/O delay
    87                              <3> %macro OUTB 2
    88                              <3>     mov al, %2
    89                              <3>     out %1, al
    90                              <3> %endmacro
    91                              <3> 
    92                              <3> ; Input byte from port
    93                              <3> %macro INB 1
    94                              <3>     in al, %1
    95                              <3> %endmacro
    96                              <3> 
    97                              <3> ; I/O wait (small delay for PIC/PIT programming)
    98                              <3> %macro IO_WAIT 0
    99                              <3>     out 0x80, al
   100                              <3> %endmacro
   101                              <3> 
   102                              <3> ; ISR stub that pushes a dummy error code (for exceptions without one)
   103                              <3> %macro ISR_NOERRCODE 1
   104                              <3> FN_BEGIN isr_%1, 0, 0, FN_RET_VOID
   105                              <3>     push qword 0           ; Dummy error code
   106                              <3>     push qword %1          ; Interrupt number
   107                              <3>     FN_END isr_%1
   108                              <3>     jmp isr_common_stub
   109                              <3> %endmacro
   110                              <3> 
   111                              <3> ; ISR stub for exceptions that push their own error code
   112                              <3> %macro ISR_ERRCODE 1
   113                              <3> FN_BEGIN isr_%1, 0, 0, FN_RET_VOID
   114                              <3>     push qword %1          ; Interrupt number (error code already on stack)
   115                              <3>     FN_END isr_%1
   116                              <3>     jmp isr_common_stub
   117                              <3> %endmacro
   118                              <3> 
   119                              <3> ; IRQ stub macro
   120                              <3> %macro IRQ_STUB 2
   121                              <3> FN_BEGIN irq_%1, 0, 0, FN_RET_VOID
   122                              <3>     push qword 0           ; Dummy error code
   123                              <3>     push qword %2          ; Interrupt vector number
   124                              <3>     FN_END irq_%1
   125                              <3>     jmp irq_common_stub
   126                              <3> %endmacro
   127                              <3> 
   128                              <3> %endif
