   226 0000EFF1 4889FB              <2>     mov rbx, rdi
   227 0000EFF4 4C8B6308            <2>     mov r12, [rbx + WIN_OFF_X]    ; window X
   228 0000EFF8 4C8B6B10            <2>     mov r13, [rbx + WIN_OFF_Y]    ; window Y
   229                              <2> 
   230                              <2>     ; Get BMP parameters
   231 0000EFFC 8B0D(BB1E0000)      <2>     mov ecx, [bmp_width]
   232 0000F002 8B15(BF1E0000)      <2>     mov edx, [bmp_height]
   233 0000F008 85C9                <2>     test ecx, ecx
   234 0000F00A 0F84CA000000        <2>     jz .bmp_draw_done
   235 0000F010 85D2                <2>     test edx, edx
   236 0000F012 0F84C2000000        <2>     jz .bmp_draw_done
   237                              <2> 
   238                              <2>     ; Calculate BMP row size (padded to 4 bytes)
   239 0000F018 8B05(C71E0000)      <2>     mov eax, [bmp_bpp]
   240 0000F01E 83F818              <2>     cmp eax, 24
   241 0000F021 0F85B3000000        <2>     jne .bmp_draw_done        ; only support 24bpp for now
   242                              <2> 
   243 0000F027 89C8                <2>     mov eax, ecx
   244 0000F029 6BC003              <2>     imul eax, 3               ; bytes per row (24bpp)
   245 0000F02C 83C003              <2>     add eax, 3
   246 0000F02F 83E0FC              <2>     and eax, ~3               ; pad to 4 bytes
   247 0000F032 4189C6              <2>     mov r14d, eax             ; row stride
   248                              <2> 
   249                              <2>     ; BMP is bottom-up, so row 0 is at bottom
   250 0000F035 4189D7              <2>     mov r15d, edx             ; height
   251 0000F038 41FFCF              <2>     dec r15d                  ; start from last row
   252                              <2> 
   253                              <2>     ; Source = slot-local BMP buffer + data_offset
   254 0000F03B 488B8388000000      <2>     mov rax, [rbx + WIN_OFF_APPDATA]
   255 0000F042 480500000400        <2>     add rax, APP_SLOT_BMP_FILE_OFF
   256 0000F048 480305(C31E0000)    <2>     add rax, [bmp_data_offset]
   257 0000F04F 4989C0              <2>     mov r8, rax
   258                              <2> 
   259                              <2>     ; Get framebuffer address
   260 0000F052 488B05(2A020000)    <2>     mov rax, [bb_addr]         ; backbuffer logic
   261                              <2> 
   262                              <2>     ; Draw pixel by pixel
   263 0000F059 31D2                <2>     xor edx, edx              ; dest Y counter (0 = top)
   264                              <2> .bmp_row_loop:
   265 0000F05B 3B15(BF1E0000)      <2>     cmp edx, [bmp_height]
   266 0000F061 7D77                <2>     jge .bmp_draw_done
   267                              <2> 
   268                              <2>     ; Source row = r15d (counts down from height-1)
   269 0000F063 4489F8              <2>     mov eax, r15d
   270 0000F066 410FAFC6            <2>     imul eax, r14d            ; row * stride
   271 0000F06A 498D3400            <2>     lea rsi, [r8 + rax]      ; source pixel row
   272                              <2> 
   273                              <2>     ; Dest pixel Y = window_Y + titlebar + edx
   274 0000F06E 4489EF              <2>     mov edi, r13d
   275 0000F071 83C718              <2>     add edi, TITLEBAR_HEIGHT
   276 0000F074 01D7                <2>     add edi, edx
   277                              <2>     ; Check Y bounds
   278 0000F076 81FF00030000        <2>     cmp edi, SCREEN_HEIGHT
   279 0000F07C 7D5C                <2>     jge .bmp_draw_done
   280                              <2> 
   281 0000F07E 0FAF3D(3A020000)    <2>     imul edi, [scr_pitch]    ; Y * pitch (use variable pitch)
   282                              <2> 
   283 0000F085 31C9                <2>     xor ecx, ecx              ; X counter
   284                              <2> .bmp_col_loop:
   285 0000F087 3B0D(BB1E0000)      <2>     cmp ecx, [bmp_width]
   286 0000F08D 7D44                <2>     jge .bmp_row_done
   287                              <2> 
   288                              <2>     ; Dest pixel X = window_X + border + ecx
   289 0000F08F 4489E3              <2>     mov ebx, r12d
   290 0000F092 83C302              <2>     add ebx, BORDER_WIDTH
   291 0000F095 01CB                <2>     add ebx, ecx
   292 0000F097 81FB00040000        <2>     cmp ebx, SCREEN_WIDTH
   293 0000F09D 7D34                <2>     jge .bmp_row_done
   294                              <2> 
   295                              <2>     ; Read BGR from source
   296 0000F09F 440FB60E            <2>     movzx r9d, byte [rsi]      ; B
   297 0000F0A3 440FB65601          <2>     movzx r10d, byte [rsi + 1] ; G
   298 0000F0A8 440FB65E02          <2>     movzx r11d, byte [rsi + 2] ; R
   299 0000F0AD 4883C603            <2>     add rsi, 3
   300                              <2> 
   301                              <2>     ; Compose 32-bit pixel: 0x00RRGGBB
   302 0000F0B1 41C1E310            <2>     shl r11d, 16
