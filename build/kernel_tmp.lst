   536                              <1> ; ============================================================================
   537                              <1> ; xhci_reset - Reset the XHCI controller
   538                              <1> ; Returns: EAX = 1 on success, 0 on timeout
   539                              <1> ; Uses PIT-based timeouts so they work on any CPU speed.
   540                              <1> ; ============================================================================
   541                              <1> xhci_reset:
   542 000045E0 56                  <1>     push rsi
   543 000045E1 51                  <1>     push rcx
   544 000045E2 53                  <1>     push rbx
   545                              <1> 
   546 000045E3 488B35(92050000)    <1>     mov rsi, [xhci_op_base]
   547                              <1> 
   548                              <1>     ; Stop controller: clear Run/Stop
   549 000045EA 8B06                <1>     mov eax, [rsi + XHCI_OP_USBCMD]
   550 000045EC 83E0FE              <1>     and eax, ~XHCI_CMD_RS
