    73                              <1> ; ============================================================================
    74                              <1> ; fat16_init - Initialize FAT16 driver, read BPB and cache FAT + root dir
    75                              <1> ; Returns: eax = 0 on success
    76                              <1> ; ============================================================================
    77                              <1> FN_BEGIN fat16_init, 0, 0, FN_RET_SCALAR
    29                              <2> %define __fn_prev_section __?SECT?__
