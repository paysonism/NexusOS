   225 00006648 8B8EF4000000        <1>     mov ecx, [rsi + DW_IC_COMP_PARAM_1]
   226 0000664E 85C9                <1>     test ecx, ecx
   227 00006650 742D                <1>     jz .pci_next_pop
   228 00006652 83F9FF              <1>     cmp ecx, 0xFFFFFFFF
   229 00006655 7428                <1>     je .pci_next_pop
   230                              <1> 
   231 00006657 488935(7F090000)    <1>     mov [i2c_base_addr], rsi
   232 0000665E C605(7D090000)01    <1>     mov byte [i2c_is_intel], 1
   233                              <1> 
   234 00006665 56                  <1>     push rsi
   235 00006666 48BE-               <1>     mov rsi, szI2cIntelFound
   235 00006668 [130D000000000000]  <1>
   236 00006670 E89C9AFFFF          <1>     call debug_print
