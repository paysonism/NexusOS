   586 0000463B 83C802              <1>     or eax, XHCI_CMD_HCRST
   587 0000463E 8906                <1>     mov [rsi + XHCI_OP_USBCMD], eax
   588                              <1> 
   589                              <1>     ; Wait for HCRST to clear - up to 1 second
   590 00004640 488B1D(40000000)    <1>     mov rbx, [tick_count]
   591 00004647 4883C364            <1>     add rbx, 100             ; 100 PIT ticks = 1 second
   592 0000464B B9002D3101          <1>     mov ecx, 20000000
   593                              <1> .wait_rst:
   594 00004650 8B06                <1>     mov eax, [rsi + XHCI_OP_USBCMD]
   595 00004652 A902000000          <1>     test eax, XHCI_CMD_HCRST
   596 00004657 7414                <1>     jz .rst_done
   597 00004659 FFC9                <1>     dec ecx
   598 0000465B 7457                <1>     jz .reset_fail
   599 0000465D 488B05(40000000)    <1>     mov rax, [tick_count]
   600 00004664 4839D8              <1>     cmp rax, rbx
   601 00004667 7D4B                <1>     jge .reset_fail          ; Timeout
   602 00004669 F390                <1>     pause
   603 0000466B EBE3                <1>     jmp .wait_rst
   604                              <1> .rst_done:
   605                              <1> 
   606                              <1>     ; Serial: 'c' (reset done)
   607 0000466D 52                  <1>     push rdx
   608 0000466E 66BAF803            <1>     mov dx, 0x3F8
   609 00004672 B063                <1>     mov al, 'c'
   610 00004674 EE                  <1>     out dx, al
   611 00004675 5A                  <1>     pop rdx
   612                              <1> 
   613                              <1>     ; Wait for CNR = 0 - up to 1 second
   614 00004676 488B1D(40000000)    <1>     mov rbx, [tick_count]
   615 0000467D 4883C364            <1>     add rbx, 100
   616 00004681 B9002D3101          <1>     mov ecx, 20000000
   617                              <1> .wait_cnr:
   618 00004686 8B4604              <1>     mov eax, [rsi + XHCI_OP_USBSTS]
   619 00004689 A900080000          <1>     test eax, XHCI_STS_CNR
   620 0000468E 7414                <1>     jz .reset_ok
   621 00004690 FFC9                <1>     dec ecx
   622 00004692 7420                <1>     jz .reset_fail
   623 00004694 488B05(40000000)    <1>     mov rax, [tick_count]
   624 0000469B 4839D8              <1>     cmp rax, rbx
   625 0000469E 7D14                <1>     jge .reset_fail
   626 000046A0 F390                <1>     pause
   627 000046A2 EBE2                <1>     jmp .wait_cnr
   628                              <1> 
   629                              <1> .reset_ok:
   630                              <1>     ; Serial: 'd' (CNR clear)
   631 000046A4 52                  <1>     push rdx
   632 000046A5 66BAF803            <1>     mov dx, 0x3F8
   633 000046A9 B064                <1>     mov al, 'd'
   634 000046AB EE                  <1>     out dx, al
   635 000046AC 5A                  <1>     pop rdx
   636 000046AD B801000000          <1>     mov eax, 1
   637 000046B2 EB0B                <1>     jmp .reset_ret
   638                              <1> .reset_fail:
   639                              <1>     ; Serial: 'e' (reset fail)
   640 000046B4 52                  <1>     push rdx
   641 000046B5 66BAF803            <1>     mov dx, 0x3F8
   642 000046B9 B065                <1>     mov al, 'e'
   643 000046BB EE                  <1>     out dx, al
   644 000046BC 5A                  <1>     pop rdx
   645 000046BD 31C0                <1>     xor eax, eax
   646                              <1> .reset_ret:
   647 000046BF 5B                  <1>     pop rbx
   648 000046C0 59                  <1>     pop rcx
   649 000046C1 5E                  <1>     pop rsi
   650 000046C2 C3                  <1>     ret
