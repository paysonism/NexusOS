   302                              <1> ; ============================================================================
   303                              <1> ; i2c_try_all_addresses - Try all known touchpad I2C addresses
   304                              <1> ; RSI = I2C controller base
   305                              <1> ; Returns: EAX = 1 if found, 0 if not
   306                              <1> ; ============================================================================
   307                              <1> i2c_try_all_addresses:
   308 00006700 51                  <1>     push rcx
   309 00006701 57                  <1>     push rdi
   310 00006702 4156                <1>     push r14
   311                              <1> 
   312 00006704 4C8D35(6D090000)    <1>     lea r14, [i2c_tp_addrs]
   313 0000670B 31C9                <1>     xor ecx, ecx
   314                              <1> 
   315                              <1> .try_addr:
   316 0000670D 83F90D              <1>     cmp ecx, I2C_TP_ADDR_COUNT
   317 00006710 7D3B                <1>     jge .addr_fail
   318                              <1> 
   319 00006712 410FB63C0E          <1>     movzx edi, byte [r14 + rcx]
   320 00006717 51                  <1>     push rcx
   321                              <1> 
   322                              <1>     ; Initialize this I2C controller with target address
   323 00006718 E837000000          <1>     call i2c_init_controller
   324 0000671D 85C0                <1>     test eax, eax
