   508 0000F1CB FFC1                <2>     inc ecx
   509 0000F1CD 85C0                <2>     test eax, eax
   510 0000F1CF 75F2                <2>     jnz .u2s_div
   511                              <2> 
   512                              <2>     ; Pop digits into buffer
