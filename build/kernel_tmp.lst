   384 00004499 415D                <1>     pop r13
   385 0000449B 415C                <1>     pop r12
   386 0000449D 5D                  <1>     pop rbp
   387 0000449E 5F                  <1>     pop rdi
   388 0000449F 5E                  <1>     pop rsi
   389 000044A0 5A                  <1>     pop rdx
   390 000044A1 59                  <1>     pop rcx
   391 000044A2 5B                  <1>     pop rbx
   392 000044A3 C3                  <1>     ret
