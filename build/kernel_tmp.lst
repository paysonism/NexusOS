   158                              <1>     ; === Phase 2: Try Intel LPSS I2C via PCI ===
   159                              <1> .try_intel:
   160 000065D0 48BE-               <1>     mov rsi, szI2cIntel
   160 000065D2 [F30C000000000000]  <1>
