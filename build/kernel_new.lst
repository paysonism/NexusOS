   369                              <1> section .bss
   370                              <1> SPI_TX_BUF_SIZE     equ 16
   371                              <1> SPI_RX_BUF_SIZE     equ 72
   372                              <1> SPI_RDESC_BUF_SIZE  equ 512
   373                              <1> 
   374 000298C6 <res 10h>           <1> spi_tx_buf:     resb SPI_TX_BUF_SIZE
