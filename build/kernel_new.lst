   550                              <1> 
   551                              <1>     ; RSI = report data pointer (from stack, original)
   552 00006AB5 488B3424            <1>     mov rsi, [rsp]              ; get original RSI from push
   553                              <1> 
   554                              <1>     ; Calculate byte offset and bit shift
   555 00006AB9 89F8                <1>     mov eax, edi
   556 00006ABB C1E803              <1>     shr eax, 3                  ; byte offset = bit_offset / 8
   557 00006ABE 4801C6              <1>     add rsi, rax                ; point to starting byte
   558                              <1> 
   559 00006AC1 89F9                <1>     mov ecx, edi
   560 00006AC3 83E107              <1>     and ecx, 7                  ; bit shift within byte = bit_offset % 8
   561                              <1> 
   562                              <1>     ; Read up to 4 bytes starting from this position
   563 00006AC6 31C0                <1>     xor eax, eax
   564 00006AC8 0FB616              <1>     movzx edx, byte [rsi]
   565 00006ACB 89D0                <1>     mov eax, edx
   566 00006ACD 4183F808            <1>     cmp r8d, 8
   567 00006AD1 7E27                <1>     jle .shift
   568 00006AD3 0FB65601            <1>     movzx edx, byte [rsi + 1]
   569 00006AD7 C1E208              <1>     shl edx, 8
   570 00006ADA 09D0                <1>     or eax, edx
   571 00006ADC 4183F810            <1>     cmp r8d, 16
   572 00006AE0 7E18                <1>     jle .shift
   573 00006AE2 0FB65602            <1>     movzx edx, byte [rsi + 2]
   574 00006AE6 C1E210              <1>     shl edx, 16
   575 00006AE9 09D0                <1>     or eax, edx
   576 00006AEB 4183F818            <1>     cmp r8d, 24
   577 00006AEF 7E09                <1>     jle .shift
   578 00006AF1 0FB65603            <1>     movzx edx, byte [rsi + 3]
   579 00006AF5 C1E218              <1>     shl edx, 24
   580 00006AF8 09D0                <1>     or eax, edx
