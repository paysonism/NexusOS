   107                              <1> ; ============================================================================
   108                              <1> ; spi_hid_send_reset - Send HID RESET command over SPI
   109                              <1> ; ============================================================================
   110                              <1> spi_hid_send_reset:
   111 000058FE 53                  <1>     push rbx
   112                              <1>     ; Build reset packet: SYNC + CID_RESET + LENGTH=0x0002 + OPCODE_RESET=0x0001
   113 000058FF C605(C6980200)FF    <1>     mov byte [spi_tx_buf + 0], SPI_SYNC_HOST
   114 00005906 C605(C7980200)04    <1>     mov byte [spi_tx_buf + 1], SPI_CID_RESET
   115 0000590D C605(C8980200)04    <1>     mov byte [spi_tx_buf + 2], 0x04    ; length (4 bytes total including header)
   116 00005914 C605(C9980200)00    <1>     mov byte [spi_tx_buf + 3], 0x00
   117 0000591B C605(CA980200)01    <1>     mov byte [spi_tx_buf + 4], 0x01    ; RESET opcode
   118 00005922 C605(CB980200)00    <1>     mov byte [spi_tx_buf + 5], 0x00
   119                              <1> 
   120 00005929 488D3D(C6980200)    <1>     lea rdi, [spi_tx_buf]
   121 00005930 BE06000000          <1>     mov rsi, 6
   122 00005935 4831D2              <1>     xor rdx, rdx
   123 00005938 4831C9              <1>     xor rcx, rcx
   124 0000593B E8B7FEFFFF          <1>     call spi_transfer
   125 00005940 5B                  <1>     pop rbx
   126 00005941 C3                  <1>     ret
   127                              <1> 
   128                              <1> ; ============================================================================
   129                              <1> ; spi_hid_get_device_desc - Fetch 22-byte HID device descriptor
   130                              <1> ; Returns: EAX = 1 success, 0 fail
   131                              <1> ; ============================================================================
   132                              <1> spi_hid_get_device_desc:
   133 00005942 53                  <1>     push rbx
   134 00005943 51                  <1>     push rcx
   135                              <1> 
   136                              <1>     ; Request device descriptor: SYNC + CID_DESC + length + register 0x0000
   137 00005944 C605(C6980200)FF    <1>     mov byte [spi_tx_buf + 0], SPI_SYNC_HOST
   138 0000594B C605(C7980200)05    <1>     mov byte [spi_tx_buf + 1], SPI_CID_DESC
   139 00005952 C605(C8980200)04    <1>     mov byte [spi_tx_buf + 2], 0x04
   140 00005959 C605(C9980200)00    <1>     mov byte [spi_tx_buf + 3], 0x00
   141 00005960 C605(CA980200)00    <1>     mov byte [spi_tx_buf + 4], 0x00    ; wDescriptorAddress low
   142 00005967 C605(CB980200)00    <1>     mov byte [spi_tx_buf + 5], 0x00    ; wDescriptorAddress high
   143                              <1> 
   144 0000596E 488D3D(C6980200)    <1>     lea rdi, [spi_tx_buf]
   145 00005975 BE06000000          <1>     mov rsi, 6
   146 0000597A 488D15(D6980200)    <1>     lea rdx, [spi_rx_buf]
   147 00005981 B91E000000          <1>     mov rcx, 30
   148 00005986 E86CFEFFFF          <1>     call spi_transfer
   149 0000598B 85C0                <1>     test eax, eax
   150 0000598D 7429                <1>     jz .fail_desc
   151                              <1> 
   152                              <1>     ; Validate: device byte 0 should be SPI_SYNC_DEV (0x80)
   153 0000598F 803D(D6980200)80    <1>     cmp byte [spi_rx_buf + 0], SPI_SYNC_DEV
   154 00005996 7520                <1>     jne .fail_desc
   155                              <1> 
   156                              <1>     ; Parse device descriptor response
   157                              <1>     ; [0] sync [1] CID [2-3] length [4-5] wHIDDescLength
   158                              <1>     ; [6-7] bcdVersion [8-9] wReportDescLength
   159                              <1>     ; [10-11] wInputRegister [12-13] wOutputRegister
   160                              <1>     ; [14-15] wCommandRegister [16-17] wDataRegister
   161                              <1>     ; [18-19] wVendorID [20-21] wProductID
   162                              <1> 
   163 00005998 0FB705(DE980200)    <1>     movzx eax, word [spi_rx_buf + 8]   ; wReportDescLength
   164 0000599F 85C0                <1>     test eax, eax
   165 000059A1 7415                <1>     jz .fail_desc
   166 000059A3 3D00020000          <1>     cmp eax, SPI_RDESC_BUF_SIZE
   167 000059A8 7F0E                <1>     jg .fail_desc
   168 000059AA 668905(0D090000)    <1>     mov [spi_report_desc_len], ax
   169                              <1> 
   170 000059B1 B801000000          <1>     mov eax, 1
   171 000059B6 EB02                <1>     jmp .desc_ret
   172                              <1> .fail_desc:
   173 000059B8 31C0                <1>     xor eax, eax
   174                              <1> .desc_ret:
   175 000059BA 59                  <1>     pop rcx
   176 000059BB 5B                  <1>     pop rbx
   177 000059BC C3                  <1>     ret
   178                              <1> 
   179                              <1> ; ============================================================================
   180                              <1> ; spi_hid_get_report_desc - Fetch and parse HID report descriptor
   181                              <1> ; ============================================================================
   182                              <1> spi_hid_get_report_desc:
   183 000059BD 53                  <1>     push rbx
   184 000059BE 51                  <1>     push rcx
   185 000059BF 52                  <1>     push rdx
   186 000059C0 57                  <1>     push rdi
   187 000059C1 56                  <1>     push rsi
   188                              <1> 
   189 000059C2 0FB70D(0D090000)    <1>     movzx ecx, word [spi_report_desc_len]
   190 000059C9 85C9                <1>     test ecx, ecx
   191 000059CB 0F8482000000        <1>     jz .rdesc_fail
   192                              <1> 
   193                              <1>     ; Request report descriptor: register 0x0001
   194 000059D1 C605(C6980200)FF    <1>     mov byte [spi_tx_buf + 0], SPI_SYNC_HOST
   195 000059D8 C605(C7980200)05    <1>     mov byte [spi_tx_buf + 1], SPI_CID_DESC
   196 000059DF 83C104              <1>     add ecx, 4                          ; add header overhead
   197 000059E2 880D(C8980200)      <1>     mov [spi_tx_buf + 2], cl
   198 000059E8 C1E908              <1>     shr ecx, 8
   199 000059EB 880D(C9980200)      <1>     mov [spi_tx_buf + 3], cl
   200 000059F1 0FB70D(0D090000)    <1>     movzx ecx, word [spi_report_desc_len]
   201 000059F8 C605(CA980200)01    <1>     mov byte [spi_tx_buf + 4], 0x01    ; register 0x0001 (report descriptor)
   202 000059FF C605(CB980200)00    <1>     mov byte [spi_tx_buf + 5], 0x00
   203                              <1> 
   204 00005A06 488D3D(C6980200)    <1>     lea rdi, [spi_tx_buf]
   205 00005A0D BE06000000          <1>     mov rsi, 6
   206 00005A12 488D15(1E990200)    <1>     lea rdx, [spi_rdesc_buf]
   207                              <1>     ; read descriptor length + 4 header bytes
   208 00005A19 488B0D(0D090000)    <1>     mov rcx, [spi_report_desc_len]
   209 00005A20 480FB70D(0D090000)  <1>     movzx rcx, word [spi_report_desc_len]
   210 00005A28 4883C104            <1>     add rcx, 4
   211 00005A2C E8C6FDFFFF          <1>     call spi_transfer
   212 00005A31 85C0                <1>     test eax, eax
   213 00005A33 741E                <1>     jz .rdesc_fail
   214                              <1> 
   215                              <1>     ; Check sync
   216 00005A35 803D(1E990200)80    <1>     cmp byte [spi_rdesc_buf + 0], SPI_SYNC_DEV
   217 00005A3C 7515                <1>     jne .rdesc_fail
   218                              <1> 
   219                              <1>     ; Parse: descriptor starts at offset 4
   220 00005A3E 488D35(22990200)    <1>     lea rsi, [spi_rdesc_buf + 4]
   221 00005A45 0FB70D(0D090000)    <1>     movzx ecx, word [spi_report_desc_len]
   222 00005A4C E8140B0000          <1>     call hid_parse_report_desc
   223                              <1>     ; EAX = 1 if parsed ok
   224 00005A51 EB02                <1>     jmp .rdesc_ret
   225                              <1> .rdesc_fail:
   226 00005A53 31C0                <1>     xor eax, eax
   227                              <1> .rdesc_ret:
   228 00005A55 5E                  <1>     pop rsi
   229 00005A56 5F                  <1>     pop rdi
   230 00005A57 5A                  <1>     pop rdx
   231 00005A58 59                  <1>     pop rcx
   232 00005A59 5B                  <1>     pop rbx
   233 00005A5A C3                  <1>     ret
   234                              <1> 
   235                              <1> ; ============================================================================
   236                              <1> ; spi_hid_poll - Non-blocking SPI HID poll (called from main loop)
   237                              <1> ; ============================================================================
   238                              <1> spi_hid_poll:
   239 00005A5B 803D(0B090000)01    <1>     cmp byte [spi_hid_active], 1
   240 00005A62 0F8595010000        <1>     jne .poll_ret
   241                              <1> 
   242                              <1>     ; Request input report: SYNC + CID_OUTPUT + length=4 + register=0x0003
   243 00005A68 C605(C6980200)FF    <1>     mov byte [spi_tx_buf + 0], SPI_SYNC_HOST
   244 00005A6F C605(C7980200)0F    <1>     mov byte [spi_tx_buf + 1], SPI_CID_OUTPUT
   245 00005A76 C605(C8980200)04    <1>     mov byte [spi_tx_buf + 2], 0x04
   246 00005A7D C605(C9980200)00    <1>     mov byte [spi_tx_buf + 3], 0x00
   247 00005A84 C605(CA980200)03    <1>     mov byte [spi_tx_buf + 4], 0x03    ; wInputRegister = 0x0003
   248 00005A8B C605(CB980200)00    <1>     mov byte [spi_tx_buf + 5], 0x00
   249                              <1> 
   250                              <1>     ; Read response: header (4B) + up to 64B report
   251 00005A92 488D3D(C6980200)    <1>     lea rdi, [spi_tx_buf]
   252 00005A99 BE06000000          <1>     mov rsi, 6
   253 00005A9E 488D15(D6980200)    <1>     lea rdx, [spi_rx_buf]
   254 00005AA5 B944000000          <1>     mov rcx, 68
   255 00005AAA E848FDFFFF          <1>     call spi_transfer
   256 00005AAF 85C0                <1>     test eax, eax
   257 00005AB1 0F8446010000        <1>     jz .poll_ret
   258                              <1> 
   259                              <1>     ; Check sync byte - if not 0x80, device has no data
   260 00005AB7 803D(D6980200)80    <1>     cmp byte [spi_rx_buf + 0], SPI_SYNC_DEV
   261 00005ABE 0F8539010000        <1>     jne .poll_ret
   262                              <1> 
   263                              <1>     ; Get report length from header [2-3]
   264 00005AC4 0FB70D(D8980200)    <1>     movzx ecx, word [spi_rx_buf + 2]
   265 00005ACB 85C9                <1>     test ecx, ecx
   266 00005ACD 0F842A010000        <1>     jz .poll_ret
   267 00005AD3 81F9FFFF0000        <1>     cmp ecx, 0xFFFF
   268 00005AD9 0F841E010000        <1>     je .poll_ret
   269 00005ADF 83E904              <1>     sub ecx, 4                         ; subtract header
   270 00005AE2 0F8E15010000        <1>     jle .poll_ret
   271                              <1> 
   272                              <1>     ; Process data at spi_rx_buf + 4
   273 00005AE8 488D35(DA980200)    <1>     lea rsi, [spi_rx_buf + 4]
   274                              <1> 
   275                              <1>     ; Check if we parsed the report descriptor
   276 00005AEF 803D(390D0000)00    <1>     cmp byte [hid_parsed_report_bytes], 0
   277 00005AF6 741F                <1>     je .fallback_parse
   278                              <1> 
   279                              <1>     ; Use hid_parser path
   280 00005AF8 803D(360D0000)01    <1>     cmp byte [hid_parsed_has_report_id], 1
   281 00005AFF 7505                <1>     jne .no_skip_id
   282 00005B01 48FFC6              <1>     inc rsi
   283 00005B04 FFC9                <1>     dec ecx
   284                              <1> .no_skip_id:
   285 00005B06 E82B100000          <1>     call hid_process_touchpad_report
   286 00005B0B C605(2C050000)01    <1>     mov byte [mouse_moved], 1
   287 00005B12 E9E6000000          <1>     jmp .poll_ret
   288                              <1> 
   289                              <1> .fallback_parse:
   290                              <1>     ; Fallback: parse as 5-byte absolute or relative report
   291                              <1>     ; [0]=buttons [1-2]=X (LE) [3-4]=Y (LE)
   292 00005B17 83F905              <1>     cmp ecx, 5
   293 00005B1A 7C64                <1>     jl .try_3byte
   294                              <1> 
   295 00005B1C 0FB606              <1>     movzx eax, byte [rsi]
   296 00005B1F 2407                <1>     and al, 0x07
   297 00005B21 8805(2B050000)      <1>     mov [mouse_buttons], al
   298                              <1> 
   299 00005B27 803D(370D0000)01    <1>     cmp byte [hid_parsed_is_absolute], 1
   300 00005B2E 7416                <1>     je .fallback_abs
   301                              <1> 
   302                              <1>     ; Relative
   303 00005B30 0FBE4601            <1>     movsx eax, byte [rsi + 1]
   304 00005B34 0105(23050000)      <1>     add [mouse_x], eax
   305 00005B3A 0FBE4602            <1>     movsx eax, byte [rsi + 2]
   306 00005B3E 0105(27050000)      <1>     add [mouse_y], eax
   307 00005B44 EB5E                <1>     jmp .fallback_clamp
   308                              <1> 
   309                              <1> .fallback_abs:
   310 00005B46 0FB74601            <1>     movzx eax, word [rsi + 1]
   311 00005B4A 8B0D(4E020000)      <1>     mov ecx, [scr_width]
   312 00005B50 0FAFC1              <1>     imul eax, ecx
   313 00005B53 B9FF7F0000          <1>     mov ecx, 0x7FFF
   314 00005B58 31D2                <1>     xor edx, edx
   315 00005B5A F7F1                <1>     div ecx
   316 00005B5C 8905(23050000)      <1>     mov [mouse_x], eax
   317                              <1> 
   318 00005B62 0FB74603            <1>     movzx eax, word [rsi + 3]
   319 00005B66 8B0D(52020000)      <1>     mov ecx, [scr_height]
   320 00005B6C 0FAFC1              <1>     imul eax, ecx
   321 00005B6F B9FF7F0000          <1>     mov ecx, 0x7FFF
   322 00005B74 31D2                <1>     xor edx, edx
   323 00005B76 F7F1                <1>     div ecx
   324 00005B78 8905(27050000)      <1>     mov [mouse_y], eax
   325 00005B7E EB24                <1>     jmp .fallback_clamp
   326                              <1> 
   327                              <1> .try_3byte:
   328 00005B80 83F903              <1>     cmp ecx, 3
   329 00005B83 7C78                <1>     jl .poll_ret
   330 00005B85 0FB606              <1>     movzx eax, byte [rsi]
   331 00005B88 2407                <1>     and al, 0x07
   332 00005B8A 8805(2B050000)      <1>     mov [mouse_buttons], al
   333 00005B90 0FBE4601            <1>     movsx eax, byte [rsi + 1]
   334 00005B94 0105(23050000)      <1>     add [mouse_x], eax
   335 00005B9A 0FBE4602            <1>     movsx eax, byte [rsi + 2]
   336 00005B9E 0105(27050000)      <1>     add [mouse_y], eax
   337                              <1> 
   338                              <1> .fallback_clamp:
   339 00005BA4 833D(23050000)00    <1>     cmp dword [mouse_x], 0
   340 00005BAB 7D0A                <1>     jge .cx_ok
   341 00005BAD C705(23050000)0000- <1>     mov dword [mouse_x], 0
   341 00005BB5 0000                <1>
   342                              <1> .cx_ok:
   343 00005BB7 8B05(4E020000)      <1>     mov eax, [scr_width]
   344 00005BBD FFC8                <1>     dec eax
   345 00005BBF 3905(23050000)      <1>     cmp [mouse_x], eax
   346 00005BC5 7E06                <1>     jle .cy_check
   347 00005BC7 8905(23050000)      <1>     mov [mouse_x], eax
   348                              <1> .cy_check:
