  1339 00000807 1E302E2012212223    <1>     db 0x1E, 0x30, 0x2E, 0x20, 0x12, 0x21, 0x22, 0x23  ; a b c d e f g h
  1340 0000080F 1724252632311819    <1>     db 0x17, 0x24, 0x25, 0x26, 0x32, 0x31, 0x18, 0x19  ; i j k l m n o p
  1341 00000817 10131F14162F112D    <1>     db 0x10, 0x13, 0x1F, 0x14, 0x16, 0x2F, 0x11, 0x2D  ; q r s t u v w x
