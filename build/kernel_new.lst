    43                                  
    44                                  ; --- ACPI & APIC Core ---
    45                                  section .text
    46                                  %include "src/kernel/rsdp.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - ACPI RSDP Locator
     3                              <1> ; Locates the Root System Description Pointer from memory/UEFI
     4                              <1> ; ============================================================================
     5                              <1> bits 64
     6                              <1> 
     7                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> L3_SYSCALL_STACK_ADDR equ 0xC00000   ; Kernel-only syscall stacks
    33                              <2> 
    34                              <2> ; --- Stage 2 disk layout ---
    35                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    36                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    37                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    38                              <2> 
    39                              <2> ; --- Screen ---
    40                              <2> SCREEN_WIDTH        equ 1024
    41                              <2> SCREEN_HEIGHT       equ 768
    42                              <2> SCREEN_BPP          equ 32
    43                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    44                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    45                              <2> 
    46                              <2> 
    47                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    48                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    49                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    50                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    51                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    52                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    53                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    54                              <2> 
    55                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    56                              <2> COLOR_BLACK         equ 0x00000000
    57                              <2> COLOR_WHITE         equ 0x00FFFFFF
    58                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    59                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    60                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    61                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    62                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    63                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    64                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    65                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    66                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    67                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    68                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    69                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    70                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    71                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    72                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    73                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    74                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    75                              <2> COLOR_START_HOVER    equ 0x00338833
    76                              <2> 
    77                              <2> ; --- Window Manager ---
    78                              <2> MAX_WINDOWS         equ 8
    79                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    80                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    81                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    82                              <2> TITLEBAR_HEIGHT     equ 24
    83                              <2> BORDER_WIDTH        equ 2
    84                              <2> CLOSE_BTN_SIZE      equ 18
    85                              <2> MIN_BTN_SIZE        equ 18
    86                              <2> MIN_WINDOW_W        equ 200
    87                              <2> MIN_WINDOW_H        equ 100
    88                              <2> 
    89                              <2> ; --- Taskbar ---
    90                              <2> TASKBAR_HEIGHT      equ 36
    91                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    92                              <2> START_BTN_W         equ 70
    93                              <2> START_BTN_H         equ 28
    94                              <2> START_BTN_X         equ 4
    95                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    96                              <2> CLOCK_WIDTH         equ 64
    97                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    98                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    99                              <2> 
   100                              <2> ; --- Keyboard ---
   101                              <2> KB_BUFFER_SIZE      equ 64
   102                              <2> 
   103                              <2> ; --- Mouse ---
   104                              <2> MOUSE_BUFFER_SIZE   equ 64
   105                              <2> CURSOR_WIDTH        equ 12
   106                              <2> CURSOR_HEIGHT       equ 19
   107                              <2> 
   108                              <2> ; --- PIT ---
   109                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   110                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   111                              <2> 
   112                              <2> ; --- PIC vectors ---
   113                              <2> IRQ_BASE_MASTER     equ 32
   114                              <2> IRQ_BASE_SLAVE      equ 40
   115                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   116                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   117                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   118                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   119                              <2> 
   120                              <2> ; --- Font ---
   121                              <2> FONT_WIDTH          equ 8
   122                              <2> FONT_HEIGHT         equ 16
   123                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   124                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   125                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   126                              <2> 
   127                              <2> ; --- Window flags ---
   128                              <2> WF_VISIBLE          equ 0x01
   129                              <2> WF_FOCUSED          equ 0x02
   130                              <2> WF_DRAGGING         equ 0x04
   131                              <2> WF_MINIMIZED        equ 0x08
   132                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   133                              <2> 
   134                              <2> ; --- Mouse event types ---
   135                              <2> MEVT_MOVE           equ 1
   136                              <2> MEVT_LCLICK         equ 2
   137                              <2> MEVT_RCLICK         equ 3
   138                              <2> MEVT_LRELEASE       equ 4
   139                              <2> MEVT_RRELEASE       equ 5
   140                              <2> 
   141                              <2> ; --- Key modifier flags ---
   142                              <2> KMOD_SHIFT          equ 0x01
   143                              <2> KMOD_CTRL           equ 0x02
   144                              <2> KMOD_ALT            equ 0x04
   145                              <2> 
   146                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   147                              <2> KEY_F1              equ 0xF1
   148                              <2> KEY_F2              equ 0xF2
   149                              <2> KEY_F3              equ 0xF3
   150                              <2> KEY_F4              equ 0xF4
   151                              <2> KEY_F5              equ 0xF5
   152                              <2> KEY_F6              equ 0xF6
   153                              <2> KEY_F7              equ 0xF7
   154                              <2> KEY_F8              equ 0xF8
   155                              <2> KEY_F9              equ 0xF9
   156                              <2> KEY_F10             equ 0xFA
   157                              <2> KEY_F11             equ 0xFB
   158                              <2> KEY_F12             equ 0xFC
   159                              <2> 
   160                              <2> ; --- USB/XHCI Memory Layout ---
   161                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   162                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   163                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   164                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   165                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   166                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   167                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   168                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   169                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   170                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   171                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   172                              <2> ; Slot 2 device support
   173                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   174                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   175                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   176                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   177                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   178                              <2> 
   179                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   180                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   181                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   182                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   183                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   184                              <2> XHCI_CAP_DBOFF      equ 0x14
   185                              <2> XHCI_CAP_RTSOFF     equ 0x18
   186                              <2> 
   187                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   188                              <2> XHCI_OP_USBCMD      equ 0x00
   189                              <2> XHCI_OP_USBSTS      equ 0x04
   190                              <2> XHCI_OP_PAGESIZE     equ 0x08
   191                              <2> XHCI_OP_DNCTRL      equ 0x14
   192                              <2> XHCI_OP_CRCR_LO     equ 0x18
   193                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   194                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   195                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   196                              <2> XHCI_OP_CONFIG      equ 0x38
   197                              <2> 
   198                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   199                              <2> XHCI_PORTSC         equ 0x00
   200                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   201                              <2> 
   202                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   203                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   204                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   205                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   206                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   207                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   208                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   209                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   210                              <2> 
   211                              <2> ; --- USBCMD bits ---
   212                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   213                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   214                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   215                              <2> 
   216                              <2> ; --- USBSTS bits ---
   217                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   218                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   219                              <2> 
   220                              <2> ; --- PORTSC bits ---
   221                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   222                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   223                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   224                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   225                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   226                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   227                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   228                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   229                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   230                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   231                              <2> 
   232                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   233                              <2> TRB_NORMAL           equ (1 << 10)
   234                              <2> TRB_SETUP            equ (2 << 10)
   235                              <2> TRB_DATA             equ (3 << 10)
   236                              <2> TRB_STATUS           equ (4 << 10)
   237                              <2> TRB_LINK             equ (6 << 10)
   238                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   239                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   240                              <2> TRB_CONFIG_EP        equ (12 << 10)
   241                              <2> TRB_EVAL_CTX         equ (13 << 10)
   242                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   243                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   244                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   245                              <2> 
   246                              <2> ; --- TRB Flag Bits (dword 3) ---
   247                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   248                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   249                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   250                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   251                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   252                              <2> 
   253                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   254                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   255                              <2> TRB_TRT_OUT          equ (2 << 16)
   256                              <2> TRB_TRT_IN           equ (3 << 16)
   257                              <2> 
   258                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   259                              <2> TRB_DIR_OUT          equ (0 << 16)
   260                              <2> TRB_DIR_IN           equ (1 << 16)
   261                              <2> 
   262                              <2> ; --- Ring sizes ---
   263                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   264                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   265                              <2> 
   266                              <2> ; --- USB Standard Request Codes ---
   267                              <2> USB_REQ_GET_DESC     equ 0x06
   268                              <2> USB_REQ_SET_CONFIG   equ 0x09
   269                              <2> USB_REQ_SET_IFACE    equ 0x0B
   270                              <2> 
   271                              <2> ; --- USB HID Request Codes ---
   272                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   273                              <2> 
   274                              <2> ; --- USB Descriptor Types ---
   275                              <2> USB_DESC_DEVICE      equ 0x01
   276                              <2> USB_DESC_CONFIG      equ 0x02
   277                              <2> USB_DESC_INTERFACE   equ 0x04
   278                              <2> USB_DESC_ENDPOINT    equ 0x05
   279                              <2> USB_DESC_HID         equ 0x21
   280                              <2> 
   281                              <2> ; --- USB Endpoint Types ---
   282                              <2> USB_EP_CONTROL       equ 0
   283                              <2> USB_EP_ISOCH         equ 1
   284                              <2> USB_EP_BULK          equ 2
   285                              <2> USB_EP_INTERRUPT     equ 3
   286                              <2> 
   287                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   288                              <2> XHCI_EP_NOT_VALID    equ 0
   289                              <2> XHCI_EP_ISOCH_OUT    equ 1
   290                              <2> XHCI_EP_BULK_OUT     equ 2
   291                              <2> XHCI_EP_INT_OUT      equ 3
   292                              <2> XHCI_EP_CONTROL      equ 4
   293                              <2> XHCI_EP_ISOCH_IN     equ 5
   294                              <2> XHCI_EP_BULK_IN      equ 6
   295                              <2> XHCI_EP_INT_IN       equ 7
   296                              <2> 
   297                              <2> ; --- XHCI Port Speeds ---
   298                              <2> XHCI_SPEED_FULL      equ 1
   299                              <2> XHCI_SPEED_LOW       equ 2
   300                              <2> XHCI_SPEED_HIGH      equ 3
   301                              <2> XHCI_SPEED_SUPER     equ 4
     8                              <1> 
     9                              <1> section .text
    10                              <1> global rsdp_find
    11                              <1> 
    12                              <1> ; Returns RAX = pointer to RSDP, or 0 if not found
    13                              <1> rsdp_find:
    14 00002091 53                  <1>     push rbx
    15 00002092 51                  <1>     push rcx
    16 00002093 56                  <1>     push rsi
    17 00002094 57                  <1>     push rdi
    18                              <1> 
    19                              <1>     ; Range 1: E0000h to FFFFFh
    20 00002095 BE00000E00          <1>     mov rsi, 0xE0000
    21 0000209A B9FF1F0000          <1>     mov rcx, 0x1FFFF / 16
    22                              <1> .scan1:
    23 0000209F 813E52534420        <1>     cmp dword [rsi], 'RSD '
    24 000020A5 7509                <1>     jne .next1
    25 000020A7 817E0450545220      <1>     cmp dword [rsi+4], 'PTR '
    26 000020AE 743E                <1>     je .found
    27                              <1> .next1:
    28 000020B0 4883C610            <1>     add rsi, 16
    29 000020B4 48FFC9              <1>     dec rcx
    30 000020B7 75E6                <1>     jnz .scan1
    31                              <1> 
    32                              <1>     ; Range 2: EBDA (find base first)
    33                              <1>     ; In UEFI we usually get ACPI table from EFI System Table instead.
    34                              <1>     ; But for fallback standard memory scanning:
    35 000020B9 480FB734250E040000  <1>     movzx rsi, word [0x040E] ; EBDA segment
    35          ******************  <1>  warning: absolute address can not be RIP-relative [-w+ea-absolute]
    36 000020C2 48C1E604            <1>     shl rsi, 4
    37 000020C6 4885F6              <1>     test rsi, rsi
    38 000020C9 741F                <1>     jz .fail
    39 000020CB B940000000          <1>     mov rcx, 1024 / 16       ; Scam 1KB
    40                              <1> .scan2:
    41 000020D0 813E52534420        <1>     cmp dword [rsi], 'RSD '
    42 000020D6 7509                <1>     jne .next2
    43 000020D8 817E0450545220      <1>     cmp dword [rsi+4], 'PTR '
    44 000020DF 740D                <1>     je .found
    45                              <1> .next2:
    46 000020E1 4883C610            <1>     add rsi, 16
    47 000020E5 48FFC9              <1>     dec rcx
    48 000020E8 75E6                <1>     jnz .scan2
    49                              <1> 
    50                              <1> .fail:
    51 000020EA 31C0                <1>     xor eax, eax
    52 000020EC EB03                <1>     jmp .done
    53                              <1> 
    54                              <1> .found:
    55 000020EE 4889F0              <1>     mov rax, rsi
    56                              <1> .done:
    57 000020F1 5F                  <1>     pop rdi
    58 000020F2 5E                  <1>     pop rsi
    59 000020F3 59                  <1>     pop rcx
    60 000020F4 5B                  <1>     pop rbx
    61 000020F5 C3                  <1>     ret
    47                                  section .text
    48                                  %include "src/kernel/acpi.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - ACPI Table Setup
     3                              <1> ; Discovers and parses FACP, MADT, MCFG, DSDT/SSDT config
     4                              <1> ; ============================================================================
     5                              <1> bits 64
     6                              <1> 
     7                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> L3_SYSCALL_STACK_ADDR equ 0xC00000   ; Kernel-only syscall stacks
    33                              <2> 
    34                              <2> ; --- Stage 2 disk layout ---
    35                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    36                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    37                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    38                              <2> 
    39                              <2> ; --- Screen ---
    40                              <2> SCREEN_WIDTH        equ 1024
    41                              <2> SCREEN_HEIGHT       equ 768
    42                              <2> SCREEN_BPP          equ 32
    43                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    44                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    45                              <2> 
    46                              <2> 
    47                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    48                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    49                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    50                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    51                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    52                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    53                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    54                              <2> 
    55                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    56                              <2> COLOR_BLACK         equ 0x00000000
    57                              <2> COLOR_WHITE         equ 0x00FFFFFF
    58                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    59                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    60                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    61                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    62                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    63                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    64                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    65                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    66                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    67                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    68                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    69                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    70                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    71                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    72                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    73                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    74                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    75                              <2> COLOR_START_HOVER    equ 0x00338833
    76                              <2> 
    77                              <2> ; --- Window Manager ---
    78                              <2> MAX_WINDOWS         equ 8
    79                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    80                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    81                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    82                              <2> TITLEBAR_HEIGHT     equ 24
    83                              <2> BORDER_WIDTH        equ 2
    84                              <2> CLOSE_BTN_SIZE      equ 18
    85                              <2> MIN_BTN_SIZE        equ 18
    86                              <2> MIN_WINDOW_W        equ 200
    87                              <2> MIN_WINDOW_H        equ 100
    88                              <2> 
    89                              <2> ; --- Taskbar ---
    90                              <2> TASKBAR_HEIGHT      equ 36
    91                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    92                              <2> START_BTN_W         equ 70
    93                              <2> START_BTN_H         equ 28
    94                              <2> START_BTN_X         equ 4
    95                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    96                              <2> CLOCK_WIDTH         equ 64
    97                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    98                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    99                              <2> 
   100                              <2> ; --- Keyboard ---
   101                              <2> KB_BUFFER_SIZE      equ 64
   102                              <2> 
   103                              <2> ; --- Mouse ---
   104                              <2> MOUSE_BUFFER_SIZE   equ 64
   105                              <2> CURSOR_WIDTH        equ 12
   106                              <2> CURSOR_HEIGHT       equ 19
   107                              <2> 
   108                              <2> ; --- PIT ---
   109                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   110                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   111                              <2> 
   112                              <2> ; --- PIC vectors ---
   113                              <2> IRQ_BASE_MASTER     equ 32
   114                              <2> IRQ_BASE_SLAVE      equ 40
   115                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   116                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   117                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   118                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   119                              <2> 
   120                              <2> ; --- Font ---
   121                              <2> FONT_WIDTH          equ 8
   122                              <2> FONT_HEIGHT         equ 16
   123                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   124                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   125                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   126                              <2> 
   127                              <2> ; --- Window flags ---
   128                              <2> WF_VISIBLE          equ 0x01
   129                              <2> WF_FOCUSED          equ 0x02
   130                              <2> WF_DRAGGING         equ 0x04
   131                              <2> WF_MINIMIZED        equ 0x08
   132                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   133                              <2> 
   134                              <2> ; --- Mouse event types ---
   135                              <2> MEVT_MOVE           equ 1
   136                              <2> MEVT_LCLICK         equ 2
   137                              <2> MEVT_RCLICK         equ 3
   138                              <2> MEVT_LRELEASE       equ 4
   139                              <2> MEVT_RRELEASE       equ 5
   140                              <2> 
   141                              <2> ; --- Key modifier flags ---
   142                              <2> KMOD_SHIFT          equ 0x01
   143                              <2> KMOD_CTRL           equ 0x02
   144                              <2> KMOD_ALT            equ 0x04
   145                              <2> 
   146                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   147                              <2> KEY_F1              equ 0xF1
   148                              <2> KEY_F2              equ 0xF2
   149                              <2> KEY_F3              equ 0xF3
   150                              <2> KEY_F4              equ 0xF4
   151                              <2> KEY_F5              equ 0xF5
   152                              <2> KEY_F6              equ 0xF6
   153                              <2> KEY_F7              equ 0xF7
   154                              <2> KEY_F8              equ 0xF8
   155                              <2> KEY_F9              equ 0xF9
   156                              <2> KEY_F10             equ 0xFA
   157                              <2> KEY_F11             equ 0xFB
   158                              <2> KEY_F12             equ 0xFC
   159                              <2> 
   160                              <2> ; --- USB/XHCI Memory Layout ---
   161                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   162                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   163                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   164                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   165                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   166                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   167                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   168                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   169                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   170                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   171                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   172                              <2> ; Slot 2 device support
   173                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   174                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   175                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   176                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   177                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   178                              <2> 
   179                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   180                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   181                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   182                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   183                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   184                              <2> XHCI_CAP_DBOFF      equ 0x14
   185                              <2> XHCI_CAP_RTSOFF     equ 0x18
   186                              <2> 
   187                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   188                              <2> XHCI_OP_USBCMD      equ 0x00
   189                              <2> XHCI_OP_USBSTS      equ 0x04
   190                              <2> XHCI_OP_PAGESIZE     equ 0x08
   191                              <2> XHCI_OP_DNCTRL      equ 0x14
   192                              <2> XHCI_OP_CRCR_LO     equ 0x18
   193                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   194                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   195                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   196                              <2> XHCI_OP_CONFIG      equ 0x38
   197                              <2> 
   198                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   199                              <2> XHCI_PORTSC         equ 0x00
   200                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   201                              <2> 
   202                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   203                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   204                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   205                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   206                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   207                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   208                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   209                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   210                              <2> 
   211                              <2> ; --- USBCMD bits ---
   212                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   213                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   214                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   215                              <2> 
   216                              <2> ; --- USBSTS bits ---
   217                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   218                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   219                              <2> 
   220                              <2> ; --- PORTSC bits ---
   221                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   222                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   223                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   224                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   225                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   226                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   227                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   228                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   229                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   230                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   231                              <2> 
   232                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   233                              <2> TRB_NORMAL           equ (1 << 10)
   234                              <2> TRB_SETUP            equ (2 << 10)
   235                              <2> TRB_DATA             equ (3 << 10)
   236                              <2> TRB_STATUS           equ (4 << 10)
   237                              <2> TRB_LINK             equ (6 << 10)
   238                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   239                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   240                              <2> TRB_CONFIG_EP        equ (12 << 10)
   241                              <2> TRB_EVAL_CTX         equ (13 << 10)
   242                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   243                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   244                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   245                              <2> 
   246                              <2> ; --- TRB Flag Bits (dword 3) ---
   247                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   248                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   249                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   250                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   251                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   252                              <2> 
   253                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   254                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   255                              <2> TRB_TRT_OUT          equ (2 << 16)
   256                              <2> TRB_TRT_IN           equ (3 << 16)
   257                              <2> 
   258                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   259                              <2> TRB_DIR_OUT          equ (0 << 16)
   260                              <2> TRB_DIR_IN           equ (1 << 16)
   261                              <2> 
   262                              <2> ; --- Ring sizes ---
   263                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   264                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   265                              <2> 
   266                              <2> ; --- USB Standard Request Codes ---
   267                              <2> USB_REQ_GET_DESC     equ 0x06
   268                              <2> USB_REQ_SET_CONFIG   equ 0x09
   269                              <2> USB_REQ_SET_IFACE    equ 0x0B
   270                              <2> 
   271                              <2> ; --- USB HID Request Codes ---
   272                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   273                              <2> 
   274                              <2> ; --- USB Descriptor Types ---
   275                              <2> USB_DESC_DEVICE      equ 0x01
   276                              <2> USB_DESC_CONFIG      equ 0x02
   277                              <2> USB_DESC_INTERFACE   equ 0x04
   278                              <2> USB_DESC_ENDPOINT    equ 0x05
   279                              <2> USB_DESC_HID         equ 0x21
   280                              <2> 
   281                              <2> ; --- USB Endpoint Types ---
   282                              <2> USB_EP_CONTROL       equ 0
   283                              <2> USB_EP_ISOCH         equ 1
   284                              <2> USB_EP_BULK          equ 2
   285                              <2> USB_EP_INTERRUPT     equ 3
   286                              <2> 
   287                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   288                              <2> XHCI_EP_NOT_VALID    equ 0
   289                              <2> XHCI_EP_ISOCH_OUT    equ 1
   290                              <2> XHCI_EP_BULK_OUT     equ 2
   291                              <2> XHCI_EP_INT_OUT      equ 3
   292                              <2> XHCI_EP_CONTROL      equ 4
   293                              <2> XHCI_EP_ISOCH_IN     equ 5
   294                              <2> XHCI_EP_BULK_IN      equ 6
   295                              <2> XHCI_EP_INT_IN       equ 7
   296                              <2> 
   297                              <2> ; --- XHCI Port Speeds ---
   298                              <2> XHCI_SPEED_FULL      equ 1
   299                              <2> XHCI_SPEED_LOW       equ 2
   300                              <2> XHCI_SPEED_HIGH      equ 3
   301                              <2> XHCI_SPEED_SUPER     equ 4
     8                              <1> 
     9                              <1> extern rsdp_find
    10                              <1> extern madt_init
    11                              <1> extern acpi_pci_init
    12                              <1> extern aml_init
    13                              <1> extern aml_find_object
    14                              <1> extern spi_base
    15                              <1> extern touchpad_irq
    16                              <1> 
    17                              <1> section .text
    18                              <1> global acpi_init
    19                              <1> 
    20                              <1> acpi_init:
    21 000020F6 53                  <1>     push rbx
    22 000020F7 51                  <1>     push rcx
    23 000020F8 56                  <1>     push rsi
    24 000020F9 57                  <1>     push rdi
    25                              <1> 
    26 000020FA E892FFFFFF          <1>     call rsdp_find
    27 000020FF 4885C0              <1>     test rax, rax
    28 00002102 0F84FD000000        <1>     jz .done            ; RSDP not found
    29                              <1> 
    30                              <1>     ; Extract XSDT pointer (offset 24) for ACPI 2.0+
    31 00002108 488B7018            <1>     mov rsi, qword [rax + 24]
    32 0000210C 4885F6              <1>     test rsi, rsi
    33 0000210F 750C                <1>     jnz .got_xsdt
    34                              <1>     
    35                              <1>     ; Fallback to RSDT (offset 16) for legacy
    36 00002111 8B7010              <1>     mov esi, dword [rax + 16]
    37 00002114 4885F6              <1>     test rsi, rsi
    38 00002117 0F84E8000000        <1>     jz .done
    39                              <1> 
    40                              <1> .got_xsdt:
    41                              <1>     ; Table Header:
    42                              <1>     ; +0: Signature
    43                              <1>     ; +4: Length (dword)
    44                              <1>     ; Let's parse entries directly after header (length - 36)
    45 0000211D 8B4E04              <1>     mov ecx, [rsi + 4]
    46 00002120 83E924              <1>     sub ecx, 36         ; Subtract header size to get entries length
    47                              <1>     
    48                              <1>     ; If it's XSDT, entries are 64-bit. If RSDT, 32-bit.
    49 00002123 8B06                <1>     mov eax, [rsi]
    50 00002125 3D58534454          <1>     cmp eax, 'XSDT'
    51 0000212A 7409                <1>     je .parse_xsdt
    52                              <1> 
    53                              <1> .parse_rsdt:
    54 0000212C C1E902              <1>     shr ecx, 2          ; Divide by 4 (32-bit pointers)
    55 0000212F 488D5E24            <1>     lea rbx, [rsi + 36]
    56 00002133 EB07                <1>     jmp .loop_tables
    57                              <1> 
    58                              <1> .parse_xsdt:
    59 00002135 C1E903              <1>     shr ecx, 3          ; Divide by 8 (64-bit pointers)
    60 00002138 488D5E24            <1>     lea rbx, [rsi + 36]
    61                              <1> 
    62                              <1> .loop_tables:
    63 0000213C 85C9                <1>     test ecx, ecx
    64 0000213E 0F84C1000000        <1>     jz .done
    65                              <1> 
    66                              <1>     ; Load pointer (32 or 64 bit depending on table type)
    67 00002144 8B06                <1>     mov eax, [rsi]
    68 00002146 3D58534454          <1>     cmp eax, 'XSDT'
    69 0000214B 7408                <1>     je .load_xsdt_entry
    70                              <1> 
    71                              <1> .load_rsdt_entry:
    72 0000214D 8B3B                <1>     mov edi, dword [rbx]
    73 0000214F 4883C304            <1>     add rbx, 4
    74 00002153 EB07                <1>     jmp .handle_entry
    75                              <1> 
    76                              <1> .load_xsdt_entry:
    77 00002155 488B3B              <1>     mov rdi, qword [rbx]
    78 00002158 4883C308            <1>     add rbx, 8
    79                              <1> 
    80                              <1> .handle_entry:
    81                              <1>     
    82                              <1>     ; Check the table signature
    83 0000215C 8B07                <1>     mov eax, dword [rdi]
    84 0000215E 3D41504943          <1>     cmp eax, 'APIC'
    85 00002163 7412                <1>     je .handle_madt
    86 00002165 3D4D434647          <1>     cmp eax, 'MCFG'
    87 0000216A 7417                <1>     je .handle_mcfg
    88 0000216C 3D46414350          <1>     cmp eax, 'FACP'
    89 00002171 741C                <1>     je .handle_facp
    90                              <1>     
    91                              <1> .next_table:
    92 00002173 FFC9                <1>     dec ecx
    93 00002175 EBC5                <1>     jmp .loop_tables
    94                              <1> 
    95                              <1> .handle_madt:
    96 00002177 56                  <1>     push rsi
    97 00002178 4889FE              <1>     mov rsi, rdi
    98 0000217B E88A000000          <1>     call madt_init
    99 00002180 5E                  <1>     pop rsi
   100 00002181 EBF0                <1>     jmp .next_table
   101                              <1> 
   102                              <1> .handle_mcfg:
   103 00002183 56                  <1>     push rsi
   104 00002184 4889FE              <1>     mov rsi, rdi
   105 00002187 E894020000          <1>     call acpi_pci_init
   106 0000218C 5E                  <1>     pop rsi
   107 0000218D EBE4                <1>     jmp .next_table
   108                              <1> 
   109                              <1> .handle_facp:
   110 0000218F 56                  <1>     push rsi
   111 00002190 57                  <1>     push rdi
   112                              <1>     ; DSDT pointer is at FADT offset 40 (32-bit physical address)
   113 00002191 8B7728              <1>     mov esi, [rdi + 40]
   114 00002194 4885F6              <1>     test rsi, rsi
   115 00002197 7465                <1>     jz .facp_done
   116                              <1>     
   117                              <1>     ; Setup AML parser bounds
   118 00002199 E8F2000000          <1>     call aml_init
   119                              <1>     
   120                              <1>     ; Search for Touchpad: Try ELAN (Elantech)
   121 0000219E BF454C414E          <1>     mov edi, 'ELAN'
   122 000021A3 E801010000          <1>     call aml_find_object
   123 000021A8 85C0                <1>     test eax, eax
   124 000021AA 751C                <1>     jnz .found_touchpad
   125                              <1>     
   126                              <1>     ; Fallback: Try SYNA (Synaptics)
   127 000021AC BF53594E41          <1>     mov edi, 'SYNA'
   128 000021B1 E8F3000000          <1>     call aml_find_object
   129 000021B6 85C0                <1>     test eax, eax
   130 000021B8 7444                <1>     jz .facp_done
   131                              <1>     
   132                              <1>     ; Fallback: Try FTE (FocalTech)
   133 000021BA BF46544500          <1>     mov edi, 'FTE'
   134 000021BF E8E5000000          <1>     call aml_find_object
   135 000021C4 85C0                <1>     test eax, eax
   136 000021C6 7436                <1>     jz .facp_done
   137                              <1>     
   138                              <1> .found_touchpad:
   139                              <1>     ; Search raw AML bytes near object for _CRS hardware descriptor packets
   140 000021C8 4889C6              <1>     mov rsi, rax
   141 000021CB B900040000          <1>     mov rcx, 1024  ; Search window (generous size for trackpad components)
   142                              <1>     
   143                              <1> .scan_resources:
   144 000021D0 4885C9              <1>     test rcx, rcx
   145 000021D3 7429                <1>     jz .facp_done
   146                              <1>     
   147 000021D5 803E86              <1>     cmp byte [rsi], 0x86  ; Memory32Fixed Resource Descriptor (Length = 9)
   148 000021D8 750C                <1>     jne .check_irq
   149                              <1>     
   150                              <1>     ; Base address offset is 4
   151 000021DA 8B5604              <1>     mov edx, [rsi + 4]
   152 000021DD 488915(02090000)    <1>     mov qword [spi_base], rdx  ; spi_base is DQ
   153 000021E4 EB10                <1>     jmp .next_scan
   154                              <1>     
   155                              <1> .check_irq:
   156 000021E6 803E89              <1>     cmp byte [rsi], 0x89  ; Extended Interrupt Resource Descriptor (Length >= 5)
   157 000021E9 750B                <1>     jne .next_scan
   158                              <1>     
   159                              <1>     ; IRQ offset is 5
   160 000021EB 668B5605            <1>     mov dx, [rsi + 5]
   161 000021EF 668915(34020000)    <1>     mov word [touchpad_irq], dx  ; touchpad_irq is DW
   162                              <1>     
   163                              <1> .next_scan:
   164 000021F6 48FFC6              <1>     inc rsi
   165 000021F9 48FFC9              <1>     dec rcx
   166 000021FC EBD2                <1>     jmp .scan_resources
   167                              <1> 
   168                              <1> .facp_done:
   169 000021FE 5F                  <1>     pop rdi
   170 000021FF 5E                  <1>     pop rsi
   171 00002200 E96EFFFFFF          <1>     jmp .next_table
   172                              <1> 
   173                              <1> .done:
   174 00002205 5F                  <1>     pop rdi
   175 00002206 5E                  <1>     pop rsi
   176 00002207 59                  <1>     pop rcx
   177 00002208 5B                  <1>     pop rbx
   178 00002209 C3                  <1>     ret
    49                                  section .text
    50                                  %include "src/kernel/madt.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - MADT Parser
     3                              <1> ; Used for parsing ACPI Multiple APIC Description Table
     4                              <1> ; ============================================================================
     5                              <1> bits 64
     6                              <1> 
     7                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> L3_SYSCALL_STACK_ADDR equ 0xC00000   ; Kernel-only syscall stacks
    33                              <2> 
    34                              <2> ; --- Stage 2 disk layout ---
    35                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    36                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    37                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    38                              <2> 
    39                              <2> ; --- Screen ---
    40                              <2> SCREEN_WIDTH        equ 1024
    41                              <2> SCREEN_HEIGHT       equ 768
    42                              <2> SCREEN_BPP          equ 32
    43                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    44                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    45                              <2> 
    46                              <2> 
    47                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    48                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    49                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    50                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    51                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    52                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    53                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    54                              <2> 
    55                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    56                              <2> COLOR_BLACK         equ 0x00000000
    57                              <2> COLOR_WHITE         equ 0x00FFFFFF
    58                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    59                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    60                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    61                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    62                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    63                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    64                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    65                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    66                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    67                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    68                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    69                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    70                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    71                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    72                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    73                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    74                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    75                              <2> COLOR_START_HOVER    equ 0x00338833
    76                              <2> 
    77                              <2> ; --- Window Manager ---
    78                              <2> MAX_WINDOWS         equ 8
    79                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    80                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    81                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    82                              <2> TITLEBAR_HEIGHT     equ 24
    83                              <2> BORDER_WIDTH        equ 2
    84                              <2> CLOSE_BTN_SIZE      equ 18
    85                              <2> MIN_BTN_SIZE        equ 18
    86                              <2> MIN_WINDOW_W        equ 200
    87                              <2> MIN_WINDOW_H        equ 100
    88                              <2> 
    89                              <2> ; --- Taskbar ---
    90                              <2> TASKBAR_HEIGHT      equ 36
    91                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    92                              <2> START_BTN_W         equ 70
    93                              <2> START_BTN_H         equ 28
    94                              <2> START_BTN_X         equ 4
    95                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    96                              <2> CLOCK_WIDTH         equ 64
    97                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    98                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    99                              <2> 
   100                              <2> ; --- Keyboard ---
   101                              <2> KB_BUFFER_SIZE      equ 64
   102                              <2> 
   103                              <2> ; --- Mouse ---
   104                              <2> MOUSE_BUFFER_SIZE   equ 64
   105                              <2> CURSOR_WIDTH        equ 12
   106                              <2> CURSOR_HEIGHT       equ 19
   107                              <2> 
   108                              <2> ; --- PIT ---
   109                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   110                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   111                              <2> 
   112                              <2> ; --- PIC vectors ---
   113                              <2> IRQ_BASE_MASTER     equ 32
   114                              <2> IRQ_BASE_SLAVE      equ 40
   115                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   116                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   117                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   118                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   119                              <2> 
   120                              <2> ; --- Font ---
   121                              <2> FONT_WIDTH          equ 8
   122                              <2> FONT_HEIGHT         equ 16
   123                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   124                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   125                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   126                              <2> 
   127                              <2> ; --- Window flags ---
   128                              <2> WF_VISIBLE          equ 0x01
   129                              <2> WF_FOCUSED          equ 0x02
   130                              <2> WF_DRAGGING         equ 0x04
   131                              <2> WF_MINIMIZED        equ 0x08
   132                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   133                              <2> 
   134                              <2> ; --- Mouse event types ---
   135                              <2> MEVT_MOVE           equ 1
   136                              <2> MEVT_LCLICK         equ 2
   137                              <2> MEVT_RCLICK         equ 3
   138                              <2> MEVT_LRELEASE       equ 4
   139                              <2> MEVT_RRELEASE       equ 5
   140                              <2> 
   141                              <2> ; --- Key modifier flags ---
   142                              <2> KMOD_SHIFT          equ 0x01
   143                              <2> KMOD_CTRL           equ 0x02
   144                              <2> KMOD_ALT            equ 0x04
   145                              <2> 
   146                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   147                              <2> KEY_F1              equ 0xF1
   148                              <2> KEY_F2              equ 0xF2
   149                              <2> KEY_F3              equ 0xF3
   150                              <2> KEY_F4              equ 0xF4
   151                              <2> KEY_F5              equ 0xF5
   152                              <2> KEY_F6              equ 0xF6
   153                              <2> KEY_F7              equ 0xF7
   154                              <2> KEY_F8              equ 0xF8
   155                              <2> KEY_F9              equ 0xF9
   156                              <2> KEY_F10             equ 0xFA
   157                              <2> KEY_F11             equ 0xFB
   158                              <2> KEY_F12             equ 0xFC
   159                              <2> 
   160                              <2> ; --- USB/XHCI Memory Layout ---
   161                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   162                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   163                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   164                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   165                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   166                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   167                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   168                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   169                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   170                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   171                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   172                              <2> ; Slot 2 device support
   173                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   174                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   175                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   176                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   177                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   178                              <2> 
   179                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   180                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   181                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   182                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   183                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   184                              <2> XHCI_CAP_DBOFF      equ 0x14
   185                              <2> XHCI_CAP_RTSOFF     equ 0x18
   186                              <2> 
   187                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   188                              <2> XHCI_OP_USBCMD      equ 0x00
   189                              <2> XHCI_OP_USBSTS      equ 0x04
   190                              <2> XHCI_OP_PAGESIZE     equ 0x08
   191                              <2> XHCI_OP_DNCTRL      equ 0x14
   192                              <2> XHCI_OP_CRCR_LO     equ 0x18
   193                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   194                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   195                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   196                              <2> XHCI_OP_CONFIG      equ 0x38
   197                              <2> 
   198                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   199                              <2> XHCI_PORTSC         equ 0x00
   200                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   201                              <2> 
   202                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   203                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   204                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   205                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   206                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   207                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   208                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   209                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   210                              <2> 
   211                              <2> ; --- USBCMD bits ---
   212                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   213                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   214                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   215                              <2> 
   216                              <2> ; --- USBSTS bits ---
   217                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   218                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   219                              <2> 
   220                              <2> ; --- PORTSC bits ---
   221                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   222                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   223                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   224                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   225                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   226                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   227                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   228                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   229                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   230                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   231                              <2> 
   232                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   233                              <2> TRB_NORMAL           equ (1 << 10)
   234                              <2> TRB_SETUP            equ (2 << 10)
   235                              <2> TRB_DATA             equ (3 << 10)
   236                              <2> TRB_STATUS           equ (4 << 10)
   237                              <2> TRB_LINK             equ (6 << 10)
   238                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   239                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   240                              <2> TRB_CONFIG_EP        equ (12 << 10)
   241                              <2> TRB_EVAL_CTX         equ (13 << 10)
   242                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   243                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   244                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   245                              <2> 
   246                              <2> ; --- TRB Flag Bits (dword 3) ---
   247                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   248                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   249                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   250                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   251                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   252                              <2> 
   253                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   254                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   255                              <2> TRB_TRT_OUT          equ (2 << 16)
   256                              <2> TRB_TRT_IN           equ (3 << 16)
   257                              <2> 
   258                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   259                              <2> TRB_DIR_OUT          equ (0 << 16)
   260                              <2> TRB_DIR_IN           equ (1 << 16)
   261                              <2> 
   262                              <2> ; --- Ring sizes ---
   263                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   264                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   265                              <2> 
   266                              <2> ; --- USB Standard Request Codes ---
   267                              <2> USB_REQ_GET_DESC     equ 0x06
   268                              <2> USB_REQ_SET_CONFIG   equ 0x09
   269                              <2> USB_REQ_SET_IFACE    equ 0x0B
   270                              <2> 
   271                              <2> ; --- USB HID Request Codes ---
   272                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   273                              <2> 
   274                              <2> ; --- USB Descriptor Types ---
   275                              <2> USB_DESC_DEVICE      equ 0x01
   276                              <2> USB_DESC_CONFIG      equ 0x02
   277                              <2> USB_DESC_INTERFACE   equ 0x04
   278                              <2> USB_DESC_ENDPOINT    equ 0x05
   279                              <2> USB_DESC_HID         equ 0x21
   280                              <2> 
   281                              <2> ; --- USB Endpoint Types ---
   282                              <2> USB_EP_CONTROL       equ 0
   283                              <2> USB_EP_ISOCH         equ 1
   284                              <2> USB_EP_BULK          equ 2
   285                              <2> USB_EP_INTERRUPT     equ 3
   286                              <2> 
   287                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   288                              <2> XHCI_EP_NOT_VALID    equ 0
   289                              <2> XHCI_EP_ISOCH_OUT    equ 1
   290                              <2> XHCI_EP_BULK_OUT     equ 2
   291                              <2> XHCI_EP_INT_OUT      equ 3
   292                              <2> XHCI_EP_CONTROL      equ 4
   293                              <2> XHCI_EP_ISOCH_IN     equ 5
   294                              <2> XHCI_EP_BULK_IN      equ 6
   295                              <2> XHCI_EP_INT_IN       equ 7
   296                              <2> 
   297                              <2> ; --- XHCI Port Speeds ---
   298                              <2> XHCI_SPEED_FULL      equ 1
   299                              <2> XHCI_SPEED_LOW       equ 2
   300                              <2> XHCI_SPEED_HIGH      equ 3
   301                              <2> XHCI_SPEED_SUPER     equ 4
     8                              <1> %include "macros.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - Common Macros
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> %ifndef MACROS_INC
     6                              <2> %define MACROS_INC
     7                              <2> 
     8                              <2> ; Output character to COM1 for debugging
     9                              <2> %macro SER 1
    10                              <2>     push rax
    11                              <2>     push rdx
    12                              <2>     mov dx, 0x3F8
    13                              <2>     mov al, %1
    14                              <2>     out dx, al
    15                              <2>     pop rdx
    16                              <2>     pop rax
    17                              <2> %endmacro
    18                              <2> 
    19                              <2> ; Save all general-purpose registers (64-bit)
    20                              <2> %macro PUSH_ALL 0
    21                              <2>     push rax
    22                              <2>     push rbx
    23                              <2>     push rcx
    24                              <2>     push rdx
    25                              <2>     push rsi
    26                              <2>     push rdi
    27                              <2>     push rbp
    28                              <2>     push r8
    29                              <2>     push r9
    30                              <2>     push r10
    31                              <2>     push r11
    32                              <2>     push r12
    33                              <2>     push r13
    34                              <2>     push r14
    35                              <2>     push r15
    36                              <2> %endmacro
    37                              <2> 
    38                              <2> ; Offset of registers in PUSH_ALL frame
    39                              <2> ALL_R15 equ 0
    40                              <2> ALL_R14 equ 8
    41                              <2> ALL_R13 equ 16
    42                              <2> ALL_R12 equ 24
    43                              <2> ALL_R11 equ 32
    44                              <2> ALL_R10 equ 40
    45                              <2> ALL_R9  equ 48
    46                              <2> ALL_R8  equ 56
    47                              <2> ALL_RBP equ 64
    48                              <2> ALL_RDI equ 72
    49                              <2> ALL_RSI equ 80
    50                              <2> ALL_RDX equ 88
    51                              <2> ALL_RCX equ 96
    52                              <2> ALL_RBX equ 104
    53                              <2> ALL_RAX equ 112
    54                              <2> 
    55                              <2> ; Restore all general-purpose registers (64-bit)
    56                              <2> %macro POP_ALL 0
    57                              <2>     pop r15
    58                              <2>     pop r14
    59                              <2>     pop r13
    60                              <2>     pop r12
    61                              <2>     pop r11
    62                              <2>     pop r10
    63                              <2>     pop r9
    64                              <2>     pop r8
    65                              <2>     pop rbp
    66                              <2>     pop rdi
    67                              <2>     pop rsi
    68                              <2>     pop rdx
    69                              <2>     pop rcx
    70                              <2>     pop rbx
    71                              <2>     pop rax
    72                              <2> %endmacro
    73                              <2> 
    74                              <2> ; Output byte to port with I/O delay
    75                              <2> %macro OUTB 2
    76                              <2>     mov al, %2
    77                              <2>     out %1, al
    78                              <2> %endmacro
    79                              <2> 
    80                              <2> ; Input byte from port
    81                              <2> %macro INB 1
    82                              <2>     in al, %1
    83                              <2> %endmacro
    84                              <2> 
    85                              <2> ; I/O wait (small delay for PIC/PIT programming)
    86                              <2> %macro IO_WAIT 0
    87                              <2>     out 0x80, al
    88                              <2> %endmacro
    89                              <2> 
    90                              <2> ; Bochs magic breakpoint
    91                              <2> %macro BOCHS_BREAK 0
    92                              <2>     xchg bx, bx
    93                              <2> %endmacro
    94                              <2> 
    95                              <2> ; ISR stub that pushes a dummy error code (for exceptions without one)
    96                              <2> %macro ISR_NOERRCODE 1
    97                              <2> global isr_%1
    98                              <2> isr_%1:
    99                              <2>     push qword 0           ; Dummy error code
   100                              <2>     push qword %1          ; Interrupt number
   101                              <2>     jmp isr_common_stub
   102                              <2> %endmacro
   103                              <2> 
   104                              <2> ; ISR stub for exceptions that push their own error code
   105                              <2> %macro ISR_ERRCODE 1
   106                              <2> global isr_%1
   107                              <2> isr_%1:
   108                              <2>     push qword %1          ; Interrupt number (error code already on stack)
   109                              <2>     jmp isr_common_stub
   110                              <2> %endmacro
   111                              <2> 
   112                              <2> ; IRQ stub macro
   113                              <2> %macro IRQ_STUB 2
   114                              <2> global irq_%1
   115                              <2> irq_%1:
   116                              <2>     push qword 0           ; Dummy error code
   117                              <2>     push qword %2          ; Interrupt vector number
   118                              <2>     jmp irq_common_stub
   119                              <2> %endmacro
   120                              <2> 
   121                              <2> %endif
     9                              <1> 
    10                              <1> ; Serial char macro for debugging
    11                              <1> 
    12                              <1> 
    13                              <1> extern ioapic_base
    14                              <1> extern debug_print
    15                              <1> 
    16                              <1> section .text
    17                              <1> global madt_init
    18                              <1> 
    19                              <1> ; RSI = pointer to MADT table (starts with signature "APIC", length, revision...)
    20                              <1> madt_init:
    21 0000220A 53                  <1>     push rbx
    22 0000220B 51                  <1>     push rcx
    23 0000220C 52                  <1>     push rdx
    24 0000220D 56                  <1>     push rsi
    25 0000220E 57                  <1>     push rdi
    26 0000220F 4150                <1>     push r8
    27                              <1>     SER 'M'
    10 00002211 50                  <2>  push rax
    11 00002212 52                  <2>  push rdx
    12 00002213 66BAF803            <2>  mov dx, 0x3F8
    13 00002217 B04D                <2>  mov al, %1
    14 00002219 EE                  <2>  out dx, al
    15 0000221A 5A                  <2>  pop rdx
    16 0000221B 58                  <2>  pop rax
    28                              <1>     
    29                              <1>     ; MADT Header size is 44 bytes
    30                              <1>     ; +0: Signature (4)
    31                              <1>     ; +4: Length (4)
    32                              <1>     ; ...
    33                              <1>     ; +36: Local APIC Address (4)
    34                              <1>     ; +40: Flags (4)
    35                              <1>     
    36 0000221C 8B4E04              <1>     mov ecx, [rsi + 4]      ; Total table length
    37                              <1>     
    38 0000221F 488D5E2C            <1>     lea rbx, [rsi + 44]     ; First entry
    39 00002223 4801F1              <1>     add rcx, rsi            ; End of table
    40                              <1>     
    41                              <1> .scan_loop:
    42 00002226 4839CB              <1>     cmp rbx, rcx
    43 00002229 735D                <1>     jae .done
    44                              <1>     
    45 0000222B 0FB603              <1>     movzx eax, byte [rbx]   ; Type
    46 0000222E 0FB65301            <1>     movzx edx, byte [rbx + 1] ; Length
    47                              <1>     
    48 00002232 83F800              <1>     cmp eax, 0              ; Type 0: Local APIC
    49 00002235 744C                <1>     je .next
    50 00002237 83F801              <1>     cmp eax, 1              ; Type 1: I/O APIC
    51 0000223A 7407                <1>     je .found_ioapic
    52 0000223C 83F802              <1>     cmp eax, 2              ; Type 2: Interrupt Source Override
    53 0000223F 740E                <1>     je .found_iso
    54                              <1>     
    55 00002241 EB40                <1>     jmp .next
    56                              <1> 
    57                              <1> .found_ioapic:
    58                              <1>     ; +2: I/O APIC ID
    59                              <1>     ; +3: Reserved
    60                              <1>     ; +4: I/O APIC Address (4 bytes)
    61                              <1>     ; +8: Global System Interrupt Base (4 bytes)
    62 00002243 8B4304              <1>     mov eax, [rbx + 4]
    63 00002246 488905(2C020000)    <1>     mov [ioapic_base], rax
    64 0000224D EB34                <1>     jmp .next
    65                              <1> 
    66                              <1> .found_iso:
    67                              <1>     ; +2: Bus Source (usually 0 = ISA)
    68                              <1>     ; +3: IRQ Source
    69                              <1>     ; +4: Global System Interrupt (4 bytes)
    70                              <1>     ; +8: Flags (2 bytes)
    71                              <1>     ; If IRQ Source is 0 (Timer), log the Global System Interrupt
    72 0000224F 807B0300            <1>     cmp byte [rbx + 3], 0
    73 00002253 752E                <1>     jne .next
    74                              <1>     
    75                              <1>     ; Found Timer ISO
    76                              <1>     SER 'I'
    10 00002255 50                  <2>  push rax
    11 00002256 52                  <2>  push rdx
    12 00002257 66BAF803            <2>  mov dx, 0x3F8
    13 0000225B B049                <2>  mov al, %1
    14 0000225D EE                  <2>  out dx, al
    15 0000225E 5A                  <2>  pop rdx
    16 0000225F 58                  <2>  pop rax
    77                              <1>     SER 'S'
    10 00002260 50                  <2>  push rax
    11 00002261 52                  <2>  push rdx
    12 00002262 66BAF803            <2>  mov dx, 0x3F8
    13 00002266 B053                <2>  mov al, %1
    14 00002268 EE                  <2>  out dx, al
    15 00002269 5A                  <2>  pop rdx
    16 0000226A 58                  <2>  pop rax
    78                              <1>     SER 'O'
    10 0000226B 50                  <2>  push rax
    11 0000226C 52                  <2>  push rdx
    12 0000226D 66BAF803            <2>  mov dx, 0x3F8
    13 00002271 B04F                <2>  mov al, %1
    14 00002273 EE                  <2>  out dx, al
    15 00002274 5A                  <2>  pop rdx
    16 00002275 58                  <2>  pop rax
    79 00002276 8B4304              <1>     mov eax, [rbx + 4]
    80 00002279 0430                <1>     add al, '0'
    81 0000227B BAF8030000          <1>     mov edx, 0x3F8
    82 00002280 EE                  <1>     out dx, al
    83 00002281 EB00                <1>     jmp .next
    84                              <1> 
    85                              <1> .next:
    86 00002283 4801D3              <1>     add rbx, rdx            ; Advance to next entry
    87 00002286 EB9E                <1>     jmp .scan_loop
    88                              <1> 
    89                              <1> .done:
    90 00002288 4158                <1>     pop r8
    91 0000228A 5F                  <1>     pop rdi
    92 0000228B 5E                  <1>     pop rsi
    93 0000228C 5A                  <1>     pop rdx
    94 0000228D 59                  <1>     pop rcx
    95 0000228E 5B                  <1>     pop rbx
    96 0000228F C3                  <1>     ret
    51                                  section .text
    52                                  %include "src/kernel/aml_parser.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - AML Bytecode Interpreter
     3                              <1> ; Evaluates basic ACPI Machine Language objects like _HID, _CRS
     4                              <1> ; ============================================================================
     5                              <1> bits 64
     6                              <1> 
     7                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> L3_SYSCALL_STACK_ADDR equ 0xC00000   ; Kernel-only syscall stacks
    33                              <2> 
    34                              <2> ; --- Stage 2 disk layout ---
    35                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    36                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    37                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    38                              <2> 
    39                              <2> ; --- Screen ---
    40                              <2> SCREEN_WIDTH        equ 1024
    41                              <2> SCREEN_HEIGHT       equ 768
    42                              <2> SCREEN_BPP          equ 32
    43                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    44                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    45                              <2> 
    46                              <2> 
    47                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    48                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    49                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    50                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    51                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    52                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    53                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    54                              <2> 
    55                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    56                              <2> COLOR_BLACK         equ 0x00000000
    57                              <2> COLOR_WHITE         equ 0x00FFFFFF
    58                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    59                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    60                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    61                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    62                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    63                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    64                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    65                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    66                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    67                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    68                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    69                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    70                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    71                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    72                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    73                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    74                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    75                              <2> COLOR_START_HOVER    equ 0x00338833
    76                              <2> 
    77                              <2> ; --- Window Manager ---
    78                              <2> MAX_WINDOWS         equ 8
    79                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    80                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    81                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    82                              <2> TITLEBAR_HEIGHT     equ 24
    83                              <2> BORDER_WIDTH        equ 2
    84                              <2> CLOSE_BTN_SIZE      equ 18
    85                              <2> MIN_BTN_SIZE        equ 18
    86                              <2> MIN_WINDOW_W        equ 200
    87                              <2> MIN_WINDOW_H        equ 100
    88                              <2> 
    89                              <2> ; --- Taskbar ---
    90                              <2> TASKBAR_HEIGHT      equ 36
    91                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    92                              <2> START_BTN_W         equ 70
    93                              <2> START_BTN_H         equ 28
    94                              <2> START_BTN_X         equ 4
    95                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    96                              <2> CLOCK_WIDTH         equ 64
    97                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    98                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    99                              <2> 
   100                              <2> ; --- Keyboard ---
   101                              <2> KB_BUFFER_SIZE      equ 64
   102                              <2> 
   103                              <2> ; --- Mouse ---
   104                              <2> MOUSE_BUFFER_SIZE   equ 64
   105                              <2> CURSOR_WIDTH        equ 12
   106                              <2> CURSOR_HEIGHT       equ 19
   107                              <2> 
   108                              <2> ; --- PIT ---
   109                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   110                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   111                              <2> 
   112                              <2> ; --- PIC vectors ---
   113                              <2> IRQ_BASE_MASTER     equ 32
   114                              <2> IRQ_BASE_SLAVE      equ 40
   115                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   116                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   117                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   118                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   119                              <2> 
   120                              <2> ; --- Font ---
   121                              <2> FONT_WIDTH          equ 8
   122                              <2> FONT_HEIGHT         equ 16
   123                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   124                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   125                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   126                              <2> 
   127                              <2> ; --- Window flags ---
   128                              <2> WF_VISIBLE          equ 0x01
   129                              <2> WF_FOCUSED          equ 0x02
   130                              <2> WF_DRAGGING         equ 0x04
   131                              <2> WF_MINIMIZED        equ 0x08
   132                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   133                              <2> 
   134                              <2> ; --- Mouse event types ---
   135                              <2> MEVT_MOVE           equ 1
   136                              <2> MEVT_LCLICK         equ 2
   137                              <2> MEVT_RCLICK         equ 3
   138                              <2> MEVT_LRELEASE       equ 4
   139                              <2> MEVT_RRELEASE       equ 5
   140                              <2> 
   141                              <2> ; --- Key modifier flags ---
   142                              <2> KMOD_SHIFT          equ 0x01
   143                              <2> KMOD_CTRL           equ 0x02
   144                              <2> KMOD_ALT            equ 0x04
   145                              <2> 
   146                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   147                              <2> KEY_F1              equ 0xF1
   148                              <2> KEY_F2              equ 0xF2
   149                              <2> KEY_F3              equ 0xF3
   150                              <2> KEY_F4              equ 0xF4
   151                              <2> KEY_F5              equ 0xF5
   152                              <2> KEY_F6              equ 0xF6
   153                              <2> KEY_F7              equ 0xF7
   154                              <2> KEY_F8              equ 0xF8
   155                              <2> KEY_F9              equ 0xF9
   156                              <2> KEY_F10             equ 0xFA
   157                              <2> KEY_F11             equ 0xFB
   158                              <2> KEY_F12             equ 0xFC
   159                              <2> 
   160                              <2> ; --- USB/XHCI Memory Layout ---
   161                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   162                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   163                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   164                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   165                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   166                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   167                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   168                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   169                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   170                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   171                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   172                              <2> ; Slot 2 device support
   173                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   174                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   175                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   176                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   177                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   178                              <2> 
   179                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   180                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   181                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   182                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   183                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   184                              <2> XHCI_CAP_DBOFF      equ 0x14
   185                              <2> XHCI_CAP_RTSOFF     equ 0x18
   186                              <2> 
   187                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   188                              <2> XHCI_OP_USBCMD      equ 0x00
   189                              <2> XHCI_OP_USBSTS      equ 0x04
   190                              <2> XHCI_OP_PAGESIZE     equ 0x08
   191                              <2> XHCI_OP_DNCTRL      equ 0x14
   192                              <2> XHCI_OP_CRCR_LO     equ 0x18
   193                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   194                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   195                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   196                              <2> XHCI_OP_CONFIG      equ 0x38
   197                              <2> 
   198                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   199                              <2> XHCI_PORTSC         equ 0x00
   200                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   201                              <2> 
   202                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   203                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   204                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   205                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   206                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   207                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   208                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   209                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   210                              <2> 
   211                              <2> ; --- USBCMD bits ---
   212                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   213                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   214                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   215                              <2> 
   216                              <2> ; --- USBSTS bits ---
   217                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   218                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   219                              <2> 
   220                              <2> ; --- PORTSC bits ---
   221                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   222                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   223                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   224                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   225                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   226                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   227                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   228                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   229                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   230                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   231                              <2> 
   232                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   233                              <2> TRB_NORMAL           equ (1 << 10)
   234                              <2> TRB_SETUP            equ (2 << 10)
   235                              <2> TRB_DATA             equ (3 << 10)
   236                              <2> TRB_STATUS           equ (4 << 10)
   237                              <2> TRB_LINK             equ (6 << 10)
   238                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   239                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   240                              <2> TRB_CONFIG_EP        equ (12 << 10)
   241                              <2> TRB_EVAL_CTX         equ (13 << 10)
   242                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   243                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   244                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   245                              <2> 
   246                              <2> ; --- TRB Flag Bits (dword 3) ---
   247                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   248                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   249                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   250                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   251                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   252                              <2> 
   253                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   254                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   255                              <2> TRB_TRT_OUT          equ (2 << 16)
   256                              <2> TRB_TRT_IN           equ (3 << 16)
   257                              <2> 
   258                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   259                              <2> TRB_DIR_OUT          equ (0 << 16)
   260                              <2> TRB_DIR_IN           equ (1 << 16)
   261                              <2> 
   262                              <2> ; --- Ring sizes ---
   263                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   264                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   265                              <2> 
   266                              <2> ; --- USB Standard Request Codes ---
   267                              <2> USB_REQ_GET_DESC     equ 0x06
   268                              <2> USB_REQ_SET_CONFIG   equ 0x09
   269                              <2> USB_REQ_SET_IFACE    equ 0x0B
   270                              <2> 
   271                              <2> ; --- USB HID Request Codes ---
   272                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   273                              <2> 
   274                              <2> ; --- USB Descriptor Types ---
   275                              <2> USB_DESC_DEVICE      equ 0x01
   276                              <2> USB_DESC_CONFIG      equ 0x02
   277                              <2> USB_DESC_INTERFACE   equ 0x04
   278                              <2> USB_DESC_ENDPOINT    equ 0x05
   279                              <2> USB_DESC_HID         equ 0x21
   280                              <2> 
   281                              <2> ; --- USB Endpoint Types ---
   282                              <2> USB_EP_CONTROL       equ 0
   283                              <2> USB_EP_ISOCH         equ 1
   284                              <2> USB_EP_BULK          equ 2
   285                              <2> USB_EP_INTERRUPT     equ 3
   286                              <2> 
   287                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   288                              <2> XHCI_EP_NOT_VALID    equ 0
   289                              <2> XHCI_EP_ISOCH_OUT    equ 1
   290                              <2> XHCI_EP_BULK_OUT     equ 2
   291                              <2> XHCI_EP_INT_OUT      equ 3
   292                              <2> XHCI_EP_CONTROL      equ 4
   293                              <2> XHCI_EP_ISOCH_IN     equ 5
   294                              <2> XHCI_EP_BULK_IN      equ 6
   295                              <2> XHCI_EP_INT_IN       equ 7
   296                              <2> 
   297                              <2> ; --- XHCI Port Speeds ---
   298                              <2> XHCI_SPEED_FULL      equ 1
   299                              <2> XHCI_SPEED_LOW       equ 2
   300                              <2> XHCI_SPEED_HIGH      equ 3
   301                              <2> XHCI_SPEED_SUPER     equ 4
     8                              <1> 
     9                              <1> section .data
    10                              <1> global aml_dsdt_base
    11                              <1> global aml_dsdt_end
    12 00000214 0000000000000000    <1> aml_dsdt_base dq 0
    13 0000021C 0000000000000000    <1> aml_dsdt_end  dq 0
    14                              <1> 
    15                              <1> section .text
    16                              <1> global aml_init
    17                              <1> global aml_find_object
    18                              <1> global aml_evaluate
    19                              <1> 
    20                              <1> ; RSI = DSDT pointer (beginning with "DSDT", length, etc)
    21                              <1> aml_init:
    22                              <1>     ; Table length is at offset 4
    23 00002290 8B4E04              <1>     mov ecx, [rsi + 4]
    24                              <1>     
    25                              <1>     ; The actual AML code starts at offset 36
    26 00002293 488D4624            <1>     lea rax, [rsi + 36]
    27 00002297 488905(14020000)    <1>     mov [aml_dsdt_base], rax
    28                              <1>     
    29 0000229E 4801F1              <1>     add rcx, rsi
    30 000022A1 48890D(1C020000)    <1>     mov [aml_dsdt_end], rcx
    31 000022A8 C3                  <1>     ret
    32                              <1> 
    33                              <1> ; ============================================================================
    34                              <1> ; aml_find_object
    35                              <1> ; Scans DSDT for a 4-byte ACPI NameString (e.g. "_HID" or "_CRS")
    36                              <1> ; RDI = exact 4-byte string (padded with spaces if shorter)
    37                              <1> ; Returns EAX = pointer to object in memory, or 0 if not found
    38                              <1> ; ============================================================================
    39                              <1> aml_find_object:
    40 000022A9 53                  <1>     push rbx
    41 000022AA 51                  <1>     push rcx
    42 000022AB 57                  <1>     push rdi
    43 000022AC 4150                <1>     push r8
    44 000022AE 4151                <1>     push r9
    45                              <1>     
    46 000022B0 4C8B05(14020000)    <1>     mov r8, [aml_dsdt_base]
    47 000022B7 4C8B0D(1C020000)    <1>     mov r9, [aml_dsdt_end]
    48 000022BE 89F8                <1>     mov eax, edi ; Search pattern
    49                              <1> 
    50                              <1> .scan_loop:
    51 000022C0 4D39C8              <1>     cmp r8, r9
    52 000022C3 7319                <1>     jae .not_found
    53                              <1>     
    54                              <1>     ; NameOp is 0x08 in AML
    55 000022C5 41803808            <1>     cmp byte [r8], 0x08
    56 000022C9 7508                <1>     jne .next_byte
    57                              <1>     
    58                              <1>     ; Matches NameString?
    59 000022CB 418B5801            <1>     mov ebx, dword [r8 + 1]
    60 000022CF 39C3                <1>     cmp ebx, eax
    61 000022D1 7405                <1>     je .found
    62                              <1>     
    63                              <1> .next_byte:
    64 000022D3 49FFC0              <1>     inc r8
    65 000022D6 EBE8                <1>     jmp .scan_loop
    66                              <1> 
    67                              <1> .found:
    68                              <1>     ; Return the pointer to the DataRefObject following the NameString
    69 000022D8 498D4005            <1>     lea rax, [r8 + 5]
    70 000022DC EB02                <1>     jmp .done
    71                              <1>     
    72                              <1> .not_found:
    73 000022DE 31C0                <1>     xor eax, eax
    74                              <1> 
    75                              <1> .done:
    76 000022E0 4159                <1>     pop r9
    77 000022E2 4158                <1>     pop r8
    78 000022E4 5F                  <1>     pop rdi
    79 000022E5 59                  <1>     pop rcx
    80 000022E6 5B                  <1>     pop rbx
    81 000022E7 C3                  <1>     ret
    82                              <1> 
    83                              <1> ; Legacy evaluate stub
    84                              <1> aml_evaluate:
    85 000022E8 31C0                <1>     xor eax, eax
    86 000022EA C3                  <1>     ret
    53                                  section .text
    54                                  %include "src/kernel/apic.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - Local APIC Driver
     3                              <1> ; Used for handling hardware interrupts on modern systems
     4                              <1> ; ============================================================================
     5                              <1> bits 64
     6                              <1> 
     7                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> L3_SYSCALL_STACK_ADDR equ 0xC00000   ; Kernel-only syscall stacks
    33                              <2> 
    34                              <2> ; --- Stage 2 disk layout ---
    35                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    36                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    37                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    38                              <2> 
    39                              <2> ; --- Screen ---
    40                              <2> SCREEN_WIDTH        equ 1024
    41                              <2> SCREEN_HEIGHT       equ 768
    42                              <2> SCREEN_BPP          equ 32
    43                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    44                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    45                              <2> 
    46                              <2> 
    47                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    48                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    49                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    50                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    51                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    52                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    53                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    54                              <2> 
    55                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    56                              <2> COLOR_BLACK         equ 0x00000000
    57                              <2> COLOR_WHITE         equ 0x00FFFFFF
    58                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    59                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    60                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    61                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    62                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    63                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    64                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    65                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    66                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    67                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    68                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    69                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    70                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    71                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    72                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    73                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    74                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    75                              <2> COLOR_START_HOVER    equ 0x00338833
    76                              <2> 
    77                              <2> ; --- Window Manager ---
    78                              <2> MAX_WINDOWS         equ 8
    79                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    80                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    81                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    82                              <2> TITLEBAR_HEIGHT     equ 24
    83                              <2> BORDER_WIDTH        equ 2
    84                              <2> CLOSE_BTN_SIZE      equ 18
    85                              <2> MIN_BTN_SIZE        equ 18
    86                              <2> MIN_WINDOW_W        equ 200
    87                              <2> MIN_WINDOW_H        equ 100
    88                              <2> 
    89                              <2> ; --- Taskbar ---
    90                              <2> TASKBAR_HEIGHT      equ 36
    91                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    92                              <2> START_BTN_W         equ 70
    93                              <2> START_BTN_H         equ 28
    94                              <2> START_BTN_X         equ 4
    95                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    96                              <2> CLOCK_WIDTH         equ 64
    97                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    98                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    99                              <2> 
   100                              <2> ; --- Keyboard ---
   101                              <2> KB_BUFFER_SIZE      equ 64
   102                              <2> 
   103                              <2> ; --- Mouse ---
   104                              <2> MOUSE_BUFFER_SIZE   equ 64
   105                              <2> CURSOR_WIDTH        equ 12
   106                              <2> CURSOR_HEIGHT       equ 19
   107                              <2> 
   108                              <2> ; --- PIT ---
   109                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   110                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   111                              <2> 
   112                              <2> ; --- PIC vectors ---
   113                              <2> IRQ_BASE_MASTER     equ 32
   114                              <2> IRQ_BASE_SLAVE      equ 40
   115                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   116                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   117                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   118                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   119                              <2> 
   120                              <2> ; --- Font ---
   121                              <2> FONT_WIDTH          equ 8
   122                              <2> FONT_HEIGHT         equ 16
   123                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   124                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   125                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   126                              <2> 
   127                              <2> ; --- Window flags ---
   128                              <2> WF_VISIBLE          equ 0x01
   129                              <2> WF_FOCUSED          equ 0x02
   130                              <2> WF_DRAGGING         equ 0x04
   131                              <2> WF_MINIMIZED        equ 0x08
   132                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   133                              <2> 
   134                              <2> ; --- Mouse event types ---
   135                              <2> MEVT_MOVE           equ 1
   136                              <2> MEVT_LCLICK         equ 2
   137                              <2> MEVT_RCLICK         equ 3
   138                              <2> MEVT_LRELEASE       equ 4
   139                              <2> MEVT_RRELEASE       equ 5
   140                              <2> 
   141                              <2> ; --- Key modifier flags ---
   142                              <2> KMOD_SHIFT          equ 0x01
   143                              <2> KMOD_CTRL           equ 0x02
   144                              <2> KMOD_ALT            equ 0x04
   145                              <2> 
   146                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   147                              <2> KEY_F1              equ 0xF1
   148                              <2> KEY_F2              equ 0xF2
   149                              <2> KEY_F3              equ 0xF3
   150                              <2> KEY_F4              equ 0xF4
   151                              <2> KEY_F5              equ 0xF5
   152                              <2> KEY_F6              equ 0xF6
   153                              <2> KEY_F7              equ 0xF7
   154                              <2> KEY_F8              equ 0xF8
   155                              <2> KEY_F9              equ 0xF9
   156                              <2> KEY_F10             equ 0xFA
   157                              <2> KEY_F11             equ 0xFB
   158                              <2> KEY_F12             equ 0xFC
   159                              <2> 
   160                              <2> ; --- USB/XHCI Memory Layout ---
   161                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   162                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   163                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   164                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   165                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   166                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   167                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   168                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   169                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   170                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   171                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   172                              <2> ; Slot 2 device support
   173                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   174                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   175                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   176                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   177                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   178                              <2> 
   179                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   180                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   181                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   182                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   183                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   184                              <2> XHCI_CAP_DBOFF      equ 0x14
   185                              <2> XHCI_CAP_RTSOFF     equ 0x18
   186                              <2> 
   187                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   188                              <2> XHCI_OP_USBCMD      equ 0x00
   189                              <2> XHCI_OP_USBSTS      equ 0x04
   190                              <2> XHCI_OP_PAGESIZE     equ 0x08
   191                              <2> XHCI_OP_DNCTRL      equ 0x14
   192                              <2> XHCI_OP_CRCR_LO     equ 0x18
   193                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   194                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   195                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   196                              <2> XHCI_OP_CONFIG      equ 0x38
   197                              <2> 
   198                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   199                              <2> XHCI_PORTSC         equ 0x00
   200                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   201                              <2> 
   202                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   203                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   204                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   205                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   206                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   207                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   208                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   209                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   210                              <2> 
   211                              <2> ; --- USBCMD bits ---
   212                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   213                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   214                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   215                              <2> 
   216                              <2> ; --- USBSTS bits ---
   217                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   218                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   219                              <2> 
   220                              <2> ; --- PORTSC bits ---
   221                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   222                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   223                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   224                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   225                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   226                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   227                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   228                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   229                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   230                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   231                              <2> 
   232                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   233                              <2> TRB_NORMAL           equ (1 << 10)
   234                              <2> TRB_SETUP            equ (2 << 10)
   235                              <2> TRB_DATA             equ (3 << 10)
   236                              <2> TRB_STATUS           equ (4 << 10)
   237                              <2> TRB_LINK             equ (6 << 10)
   238                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   239                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   240                              <2> TRB_CONFIG_EP        equ (12 << 10)
   241                              <2> TRB_EVAL_CTX         equ (13 << 10)
   242                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   243                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   244                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   245                              <2> 
   246                              <2> ; --- TRB Flag Bits (dword 3) ---
   247                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   248                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   249                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   250                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   251                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   252                              <2> 
   253                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   254                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   255                              <2> TRB_TRT_OUT          equ (2 << 16)
   256                              <2> TRB_TRT_IN           equ (3 << 16)
   257                              <2> 
   258                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   259                              <2> TRB_DIR_OUT          equ (0 << 16)
   260                              <2> TRB_DIR_IN           equ (1 << 16)
   261                              <2> 
   262                              <2> ; --- Ring sizes ---
   263                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   264                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   265                              <2> 
   266                              <2> ; --- USB Standard Request Codes ---
   267                              <2> USB_REQ_GET_DESC     equ 0x06
   268                              <2> USB_REQ_SET_CONFIG   equ 0x09
   269                              <2> USB_REQ_SET_IFACE    equ 0x0B
   270                              <2> 
   271                              <2> ; --- USB HID Request Codes ---
   272                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   273                              <2> 
   274                              <2> ; --- USB Descriptor Types ---
   275                              <2> USB_DESC_DEVICE      equ 0x01
   276                              <2> USB_DESC_CONFIG      equ 0x02
   277                              <2> USB_DESC_INTERFACE   equ 0x04
   278                              <2> USB_DESC_ENDPOINT    equ 0x05
   279                              <2> USB_DESC_HID         equ 0x21
   280                              <2> 
   281                              <2> ; --- USB Endpoint Types ---
   282                              <2> USB_EP_CONTROL       equ 0
   283                              <2> USB_EP_ISOCH         equ 1
   284                              <2> USB_EP_BULK          equ 2
   285                              <2> USB_EP_INTERRUPT     equ 3
   286                              <2> 
   287                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   288                              <2> XHCI_EP_NOT_VALID    equ 0
   289                              <2> XHCI_EP_ISOCH_OUT    equ 1
   290                              <2> XHCI_EP_BULK_OUT     equ 2
   291                              <2> XHCI_EP_INT_OUT      equ 3
   292                              <2> XHCI_EP_CONTROL      equ 4
   293                              <2> XHCI_EP_ISOCH_IN     equ 5
   294                              <2> XHCI_EP_BULK_IN      equ 6
   295                              <2> XHCI_EP_INT_IN       equ 7
   296                              <2> 
   297                              <2> ; --- XHCI Port Speeds ---
   298                              <2> XHCI_SPEED_FULL      equ 1
   299                              <2> XHCI_SPEED_LOW       equ 2
   300                              <2> XHCI_SPEED_HIGH      equ 3
   301                              <2> XHCI_SPEED_SUPER     equ 4
     8                              <1> 
     9                              <1> section .data
    10 00000224 0000E0FE00000000    <1> lapic_base dq 0xFEE00000
    11                              <1> 
    12                              <1> section .text
    13                              <1> global apic_init
    14                              <1> global apic_eoi
    15                              <1> 
    16                              <1> ; --- Initialize Local APIC ---
    17                              <1> apic_init:
    18                              <1>     ; Read APIC base from MSR 0x1B
    19 000022EB B91B000000          <1>     mov ecx, 0x1B
    20 000022F0 0F32                <1>     rdmsr                   ; EAX = low 32 bits of APIC_BASE
    21                              <1>     
    22                              <1>     ; Debug: Print the MSR value bits 11:8 (bit 10 is x2apic)
    23 000022F2 50                  <1>     push rax
    24 000022F3 52                  <1>     push rdx
    25                              <1>     SER 'M'
    10 000022F4 50                  <2>  push rax
    11 000022F5 52                  <2>  push rdx
    12 000022F6 66BAF803            <2>  mov dx, 0x3F8
    13 000022FA B04D                <2>  mov al, %1
    14 000022FC EE                  <2>  out dx, al
    15 000022FD 5A                  <2>  pop rdx
    16 000022FE 58                  <2>  pop rax
    26                              <1>     SER 'S'
    10 000022FF 50                  <2>  push rax
    11 00002300 52                  <2>  push rdx
    12 00002301 66BAF803            <2>  mov dx, 0x3F8
    13 00002305 B053                <2>  mov al, %1
    14 00002307 EE                  <2>  out dx, al
    15 00002308 5A                  <2>  pop rdx
    16 00002309 58                  <2>  pop rax
    27                              <1>     SER 'R'
    10 0000230A 50                  <2>  push rax
    11 0000230B 52                  <2>  push rdx
    12 0000230C 66BAF803            <2>  mov dx, 0x3F8
    13 00002310 B052                <2>  mov al, %1
    14 00002312 EE                  <2>  out dx, al
    15 00002313 5A                  <2>  pop rdx
    16 00002314 58                  <2>  pop rax
    28 00002315 89C2                <1>     mov edx, eax
    29 00002317 C1EA08              <1>     shr edx, 8
    30 0000231A 80E20F              <1>     and dl, 0x0F            ; Bits 11:8
    31 0000231D 80C230              <1>     add dl, '0'
    32 00002320 88D0                <1>     mov al, dl
    33 00002322 BAF8030000          <1>     mov edx, 0x3F8
    34 00002327 EE                  <1>     out dx, al           ; Output bit pattern (e.g. '8'=xAPIC, 'L'=x2APIC?)
    35 00002328 5A                  <1>     pop rdx
    36 00002329 58                  <1>     pop rax
    37                              <1> 
    38                              <1>     ; Ensure APIC is enabled (bit 11) and x2APIC is disabled (bit 10) for now
    39                              <1>     ; to keep the MMIO-based driver working.
    40 0000232A 80E4FB              <1>     and ah, 11111011b       ; Clear bit 10 (x2APIC)
    41 0000232D 0FBAE80B            <1>     bts eax, 11
    42 00002331 0F30                <1>     wrmsr
    43                              <1> 
    44                              <1>     ; Map the APIC base (mask out lower 12 bits)
    45 00002333 2500F0FFFF          <1>     and eax, 0xFFFFF000
    46 00002338 488905(24020000)    <1>     mov [lapic_base], rax
    47                              <1> 
    48                              <1>     ; Spurious Interrupt Vector Register (SIVR)
    49                              <1>     ; Enable APIC (bit 8) and set vector to 255
    50 0000233F 488B3D(24020000)    <1>     mov rdi, [lapic_base]
    51 00002346 C787F0000000FF0100- <1>     mov dword [rdi + 0x0F0], 0x1FF
    51 0000234F 00                  <1>
    52                              <1> 
    53                              <1>     ; Set Task Priority Register (TPR) to 0 to enable all interrupts
    54                              <1>     ; On many UEFI systems this is 0xFF by default, which blocks all IRQs.
    55 00002350 488B3D(24020000)    <1>     mov rdi, [lapic_base]
    56 00002357 C78780000000000000- <1>     mov dword [rdi + 0x080], 0
    56 00002360 00                  <1>
    57                              <1>     
    58 00002361 C3                  <1>     ret
    59                              <1> 
    60                              <1> ; --- Send End of Interrupt (EOI) ---
    61                              <1> apic_eoi:
    62 00002362 488B3D(24020000)    <1>     mov rdi, [lapic_base]
    63 00002369 C787B0000000000000- <1>     mov dword [rdi + 0x0B0], 0
    63 00002372 00                  <1>
    64 00002373 C3                  <1>     ret
    55                                  section .text
    56                                  %include "src/kernel/ioapic.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - I/O APIC Driver
     3                              <1> ; Used for routing hardware interrupts from advanced controllers
     4                              <1> ; ============================================================================
     5                              <1> bits 64
     6                              <1> 
     7                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> L3_SYSCALL_STACK_ADDR equ 0xC00000   ; Kernel-only syscall stacks
    33                              <2> 
    34                              <2> ; --- Stage 2 disk layout ---
    35                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    36                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    37                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    38                              <2> 
    39                              <2> ; --- Screen ---
    40                              <2> SCREEN_WIDTH        equ 1024
    41                              <2> SCREEN_HEIGHT       equ 768
    42                              <2> SCREEN_BPP          equ 32
    43                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    44                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    45                              <2> 
    46                              <2> 
    47                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    48                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    49                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    50                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    51                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    52                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    53                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    54                              <2> 
    55                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    56                              <2> COLOR_BLACK         equ 0x00000000
    57                              <2> COLOR_WHITE         equ 0x00FFFFFF
    58                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    59                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    60                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    61                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    62                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    63                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    64                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    65                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    66                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    67                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    68                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    69                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    70                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    71                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    72                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    73                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    74                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    75                              <2> COLOR_START_HOVER    equ 0x00338833
    76                              <2> 
    77                              <2> ; --- Window Manager ---
    78                              <2> MAX_WINDOWS         equ 8
    79                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    80                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    81                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    82                              <2> TITLEBAR_HEIGHT     equ 24
    83                              <2> BORDER_WIDTH        equ 2
    84                              <2> CLOSE_BTN_SIZE      equ 18
    85                              <2> MIN_BTN_SIZE        equ 18
    86                              <2> MIN_WINDOW_W        equ 200
    87                              <2> MIN_WINDOW_H        equ 100
    88                              <2> 
    89                              <2> ; --- Taskbar ---
    90                              <2> TASKBAR_HEIGHT      equ 36
    91                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    92                              <2> START_BTN_W         equ 70
    93                              <2> START_BTN_H         equ 28
    94                              <2> START_BTN_X         equ 4
    95                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    96                              <2> CLOCK_WIDTH         equ 64
    97                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    98                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    99                              <2> 
   100                              <2> ; --- Keyboard ---
   101                              <2> KB_BUFFER_SIZE      equ 64
   102                              <2> 
   103                              <2> ; --- Mouse ---
   104                              <2> MOUSE_BUFFER_SIZE   equ 64
   105                              <2> CURSOR_WIDTH        equ 12
   106                              <2> CURSOR_HEIGHT       equ 19
   107                              <2> 
   108                              <2> ; --- PIT ---
   109                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   110                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   111                              <2> 
   112                              <2> ; --- PIC vectors ---
   113                              <2> IRQ_BASE_MASTER     equ 32
   114                              <2> IRQ_BASE_SLAVE      equ 40
   115                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   116                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   117                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   118                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   119                              <2> 
   120                              <2> ; --- Font ---
   121                              <2> FONT_WIDTH          equ 8
   122                              <2> FONT_HEIGHT         equ 16
   123                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   124                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   125                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   126                              <2> 
   127                              <2> ; --- Window flags ---
   128                              <2> WF_VISIBLE          equ 0x01
   129                              <2> WF_FOCUSED          equ 0x02
   130                              <2> WF_DRAGGING         equ 0x04
   131                              <2> WF_MINIMIZED        equ 0x08
   132                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   133                              <2> 
   134                              <2> ; --- Mouse event types ---
   135                              <2> MEVT_MOVE           equ 1
   136                              <2> MEVT_LCLICK         equ 2
   137                              <2> MEVT_RCLICK         equ 3
   138                              <2> MEVT_LRELEASE       equ 4
   139                              <2> MEVT_RRELEASE       equ 5
   140                              <2> 
   141                              <2> ; --- Key modifier flags ---
   142                              <2> KMOD_SHIFT          equ 0x01
   143                              <2> KMOD_CTRL           equ 0x02
   144                              <2> KMOD_ALT            equ 0x04
   145                              <2> 
   146                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   147                              <2> KEY_F1              equ 0xF1
   148                              <2> KEY_F2              equ 0xF2
   149                              <2> KEY_F3              equ 0xF3
   150                              <2> KEY_F4              equ 0xF4
   151                              <2> KEY_F5              equ 0xF5
   152                              <2> KEY_F6              equ 0xF6
   153                              <2> KEY_F7              equ 0xF7
   154                              <2> KEY_F8              equ 0xF8
   155                              <2> KEY_F9              equ 0xF9
   156                              <2> KEY_F10             equ 0xFA
   157                              <2> KEY_F11             equ 0xFB
   158                              <2> KEY_F12             equ 0xFC
   159                              <2> 
   160                              <2> ; --- USB/XHCI Memory Layout ---
   161                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   162                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   163                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   164                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   165                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   166                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   167                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   168                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   169                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   170                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   171                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   172                              <2> ; Slot 2 device support
   173                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   174                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   175                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   176                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   177                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   178                              <2> 
   179                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   180                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   181                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   182                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   183                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   184                              <2> XHCI_CAP_DBOFF      equ 0x14
   185                              <2> XHCI_CAP_RTSOFF     equ 0x18
   186                              <2> 
   187                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   188                              <2> XHCI_OP_USBCMD      equ 0x00
   189                              <2> XHCI_OP_USBSTS      equ 0x04
   190                              <2> XHCI_OP_PAGESIZE     equ 0x08
   191                              <2> XHCI_OP_DNCTRL      equ 0x14
   192                              <2> XHCI_OP_CRCR_LO     equ 0x18
   193                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   194                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   195                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   196                              <2> XHCI_OP_CONFIG      equ 0x38
   197                              <2> 
   198                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   199                              <2> XHCI_PORTSC         equ 0x00
   200                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   201                              <2> 
   202                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   203                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   204                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   205                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   206                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   207                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   208                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   209                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   210                              <2> 
   211                              <2> ; --- USBCMD bits ---
   212                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   213                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   214                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   215                              <2> 
   216                              <2> ; --- USBSTS bits ---
   217                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   218                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   219                              <2> 
   220                              <2> ; --- PORTSC bits ---
   221                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   222                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   223                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   224                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   225                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   226                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   227                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   228                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   229                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   230                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   231                              <2> 
   232                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   233                              <2> TRB_NORMAL           equ (1 << 10)
   234                              <2> TRB_SETUP            equ (2 << 10)
   235                              <2> TRB_DATA             equ (3 << 10)
   236                              <2> TRB_STATUS           equ (4 << 10)
   237                              <2> TRB_LINK             equ (6 << 10)
   238                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   239                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   240                              <2> TRB_CONFIG_EP        equ (12 << 10)
   241                              <2> TRB_EVAL_CTX         equ (13 << 10)
   242                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   243                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   244                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   245                              <2> 
   246                              <2> ; --- TRB Flag Bits (dword 3) ---
   247                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   248                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   249                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   250                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   251                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   252                              <2> 
   253                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   254                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   255                              <2> TRB_TRT_OUT          equ (2 << 16)
   256                              <2> TRB_TRT_IN           equ (3 << 16)
   257                              <2> 
   258                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   259                              <2> TRB_DIR_OUT          equ (0 << 16)
   260                              <2> TRB_DIR_IN           equ (1 << 16)
   261                              <2> 
   262                              <2> ; --- Ring sizes ---
   263                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   264                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   265                              <2> 
   266                              <2> ; --- USB Standard Request Codes ---
   267                              <2> USB_REQ_GET_DESC     equ 0x06
   268                              <2> USB_REQ_SET_CONFIG   equ 0x09
   269                              <2> USB_REQ_SET_IFACE    equ 0x0B
   270                              <2> 
   271                              <2> ; --- USB HID Request Codes ---
   272                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   273                              <2> 
   274                              <2> ; --- USB Descriptor Types ---
   275                              <2> USB_DESC_DEVICE      equ 0x01
   276                              <2> USB_DESC_CONFIG      equ 0x02
   277                              <2> USB_DESC_INTERFACE   equ 0x04
   278                              <2> USB_DESC_ENDPOINT    equ 0x05
   279                              <2> USB_DESC_HID         equ 0x21
   280                              <2> 
   281                              <2> ; --- USB Endpoint Types ---
   282                              <2> USB_EP_CONTROL       equ 0
   283                              <2> USB_EP_ISOCH         equ 1
   284                              <2> USB_EP_BULK          equ 2
   285                              <2> USB_EP_INTERRUPT     equ 3
   286                              <2> 
   287                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   288                              <2> XHCI_EP_NOT_VALID    equ 0
   289                              <2> XHCI_EP_ISOCH_OUT    equ 1
   290                              <2> XHCI_EP_BULK_OUT     equ 2
   291                              <2> XHCI_EP_INT_OUT      equ 3
   292                              <2> XHCI_EP_CONTROL      equ 4
   293                              <2> XHCI_EP_ISOCH_IN     equ 5
   294                              <2> XHCI_EP_BULK_IN      equ 6
   295                              <2> XHCI_EP_INT_IN       equ 7
   296                              <2> 
   297                              <2> ; --- XHCI Port Speeds ---
   298                              <2> XHCI_SPEED_FULL      equ 1
   299                              <2> XHCI_SPEED_LOW       equ 2
   300                              <2> XHCI_SPEED_HIGH      equ 3
   301                              <2> XHCI_SPEED_SUPER     equ 4
     8                              <1> 
     9                              <1> section .data
    10                              <1> global ioapic_base
    11                              <1> global touchpad_irq
    12 0000022C 0000C0FE00000000    <1> ioapic_base dq 0xFEC00000
    13 00000234 1200                <1> touchpad_irq dw 18
    14                              <1> 
    15                              <1> section .text
    16                              <1> global ioapic_init
    17                              <1> global ioapic_set_irq
    18                              <1> 
    19                              <1> ; --- Initialize I/O APIC ---
    20                              <1> ioapic_init:
    21                              <1>     ; Base address is obtained from MADT, but we configure essential routes now
    22 00002374 57                  <1>     push rdi
    23 00002375 56                  <1>     push rsi
    24 00002376 52                  <1>     push rdx
    25 00002377 51                  <1>     push rcx
    26                              <1>     
    27                              <1>     ; 1. Route all first 16 GSIs (ISA range) to standard vectors (32-47)
    28                              <1>     ; This covers PIT on GSI 0 or 2, Keyboard on GSI 1, Mouse on GSI 12, etc.
    29 00002378 41B800000000        <1>     mov r8, 0
    30                              <1> .loop_gsis:
    31 0000237E 4C89C7              <1>     mov rdi, r8             ; GSI
    32 00002381 498D7020            <1>     lea rsi, [r8 + 32]      ; Vector (32, 33, ...)
    33 00002385 BA00000000          <1>     mov rdx, 0              ; Destination: CPU 0
    34 0000238A B900000000          <1>     mov rcx, 0              ; Flags: Edge, High, Physical
    35 0000238F E860000000          <1>     call ioapic_set_irq
    36 00002394 49FFC0              <1>     inc r8
    37 00002397 4983F810            <1>     cmp r8, 16
    38 0000239B 7CE1                <1>     jl .loop_gsis
    39                              <1> 
    40                              <1>     ; 2. Route PS/2 Mouse specifically to Vector 44 (GSI 12) - redundancy
    41 0000239D BF0C000000          <1>     mov rdi, 12
    42 000023A2 BE2C000000          <1>     mov rsi, 44
    43 000023A7 BA00000000          <1>     mov rdx, 0
    44 000023AC B900000000          <1>     mov rcx, 0      ; Edge, High
    45 000023B1 E83E000000          <1>     call ioapic_set_irq
    46                              <1> 
    47                              <1>     ; 3. Route SPI Touchpad specifically to Vector 50
    48 000023B6 0FB73D(34020000)    <1>     movzx edi, word [touchpad_irq]
    49 000023BD BE32000000          <1>     mov rsi, 50
    50 000023C2 BA00000000          <1>     mov rdx, 0
    51 000023C7 B900A00000          <1>     mov rcx, 0xA000 ; Level, Low
    52 000023CC E823000000          <1>     call ioapic_set_irq
    53                              <1>     
    54 000023D1 59                  <1>     pop rcx
    55 000023D2 5A                  <1>     pop rdx
    56 000023D3 5E                  <1>     pop rsi
    57 000023D4 5F                  <1>     pop rdi
    58 000023D5 C3                  <1>     ret
    59                              <1> 
    60                              <1> ; --- ioapic_read ---
    61                              <1> ; rdi = index
    62                              <1> ioapic_read:
    63 000023D6 4C8B05(2C020000)    <1>     mov r8, [ioapic_base]
    64 000023DD 418938              <1>     mov dword [r8], edi
    65 000023E0 418B4010            <1>     mov eax, [r8 + 0x10]
    66 000023E4 C3                  <1>     ret
    67                              <1> 
    68                              <1> ; --- ioapic_write ---
    69                              <1> ; rdi = index, rsi = value
    70                              <1> ioapic_write:
    71 000023E5 4C8B05(2C020000)    <1>     mov r8, [ioapic_base]
    72 000023EC 418938              <1>     mov dword [r8], edi
    73 000023EF 41897010            <1>     mov dword [r8 + 0x10], esi
    74 000023F3 C3                  <1>     ret
    75                              <1> 
    76                              <1> ; --- Route IRQ ---
    77                              <1> ; rdi = IRQ number
    78                              <1> ; rsi = Vector
    79                              <1> ; rdx = CPU APIC ID
    80                              <1> ; rcx = Flags (0 = Edge High, 0x8000 = Level High, 0x2000 = Edge Low, 0xA000 = Level Low)
    81                              <1> ioapic_set_irq:
    82 000023F4 53                  <1>     push rbx
    83                              <1>     
    84                              <1>     ; Register offset = 0x10 + (IRQ * 2)
    85 000023F5 4889FB              <1>     mov rbx, rdi
    86 000023F8 48D1E3              <1>     shl rbx, 1
    87 000023FB 4883C310            <1>     add rbx, 0x10
    88                              <1>     
    89                              <1>     ; Lower DWORD (Vector + Masks + Trigger Mode)
    90 000023FF 4889DF              <1>     mov rdi, rbx
    91                              <1>     
    92                              <1>     ; Combine Vector (rsi) and Flags (rcx)
    93                              <1>     ; Bit 13 = Polarity (0=High, 1=Low)
    94                              <1>     ; Bit 15 = Trigger Mode (0=Edge, 1=Level)
    95                              <1>     ; Bit 16 = Mask (0=Unmasked, 1=Masked)
    96 00002402 56                  <1>     push rsi
    97 00002403 4809CE              <1>     or rsi, rcx
    98 00002406 E8DAFFFFFF          <1>     call ioapic_write
    99                              <1> 
   100                              <1>     ; Upper DWORD (Destination CPU APIC ID)
   101 0000240B 4889DF              <1>     mov rdi, rbx
   102 0000240E 48FFC7              <1>     inc rdi
   103 00002411 4889D6              <1>     mov rsi, rdx
   104 00002414 48C1E618            <1>     shl rsi, 24
   105 00002418 E8C8FFFFFF          <1>     call ioapic_write
   106                              <1>     
   107 0000241D 5E                  <1>     pop rsi
   108 0000241E 5B                  <1>     pop rbx
   109 0000241F C3                  <1>     ret
    57                                  
    58                                  ; --- Drivers ---
    59                                  section .text
    60                                  %include "src/drivers/acpi_pci.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - ACPI PCI Enumerator (MCFG)
     3                              <1> ; Dynamically lists PCIe MMIO assignments using ACPI MCFG table
     4                              <1> ; ============================================================================
     5                              <1> bits 64
     6                              <1> 
     7                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> L3_SYSCALL_STACK_ADDR equ 0xC00000   ; Kernel-only syscall stacks
    33                              <2> 
    34                              <2> ; --- Stage 2 disk layout ---
    35                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    36                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    37                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    38                              <2> 
    39                              <2> ; --- Screen ---
    40                              <2> SCREEN_WIDTH        equ 1024
    41                              <2> SCREEN_HEIGHT       equ 768
    42                              <2> SCREEN_BPP          equ 32
    43                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    44                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    45                              <2> 
    46                              <2> 
    47                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    48                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    49                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    50                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    51                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    52                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    53                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    54                              <2> 
    55                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    56                              <2> COLOR_BLACK         equ 0x00000000
    57                              <2> COLOR_WHITE         equ 0x00FFFFFF
    58                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    59                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    60                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    61                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    62                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    63                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    64                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    65                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    66                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    67                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    68                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    69                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    70                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    71                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    72                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    73                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    74                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    75                              <2> COLOR_START_HOVER    equ 0x00338833
    76                              <2> 
    77                              <2> ; --- Window Manager ---
    78                              <2> MAX_WINDOWS         equ 8
    79                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    80                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    81                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    82                              <2> TITLEBAR_HEIGHT     equ 24
    83                              <2> BORDER_WIDTH        equ 2
    84                              <2> CLOSE_BTN_SIZE      equ 18
    85                              <2> MIN_BTN_SIZE        equ 18
    86                              <2> MIN_WINDOW_W        equ 200
    87                              <2> MIN_WINDOW_H        equ 100
    88                              <2> 
    89                              <2> ; --- Taskbar ---
    90                              <2> TASKBAR_HEIGHT      equ 36
    91                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    92                              <2> START_BTN_W         equ 70
    93                              <2> START_BTN_H         equ 28
    94                              <2> START_BTN_X         equ 4
    95                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    96                              <2> CLOCK_WIDTH         equ 64
    97                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    98                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    99                              <2> 
   100                              <2> ; --- Keyboard ---
   101                              <2> KB_BUFFER_SIZE      equ 64
   102                              <2> 
   103                              <2> ; --- Mouse ---
   104                              <2> MOUSE_BUFFER_SIZE   equ 64
   105                              <2> CURSOR_WIDTH        equ 12
   106                              <2> CURSOR_HEIGHT       equ 19
   107                              <2> 
   108                              <2> ; --- PIT ---
   109                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   110                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   111                              <2> 
   112                              <2> ; --- PIC vectors ---
   113                              <2> IRQ_BASE_MASTER     equ 32
   114                              <2> IRQ_BASE_SLAVE      equ 40
   115                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   116                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   117                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   118                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   119                              <2> 
   120                              <2> ; --- Font ---
   121                              <2> FONT_WIDTH          equ 8
   122                              <2> FONT_HEIGHT         equ 16
   123                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   124                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   125                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   126                              <2> 
   127                              <2> ; --- Window flags ---
   128                              <2> WF_VISIBLE          equ 0x01
   129                              <2> WF_FOCUSED          equ 0x02
   130                              <2> WF_DRAGGING         equ 0x04
   131                              <2> WF_MINIMIZED        equ 0x08
   132                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   133                              <2> 
   134                              <2> ; --- Mouse event types ---
   135                              <2> MEVT_MOVE           equ 1
   136                              <2> MEVT_LCLICK         equ 2
   137                              <2> MEVT_RCLICK         equ 3
   138                              <2> MEVT_LRELEASE       equ 4
   139                              <2> MEVT_RRELEASE       equ 5
   140                              <2> 
   141                              <2> ; --- Key modifier flags ---
   142                              <2> KMOD_SHIFT          equ 0x01
   143                              <2> KMOD_CTRL           equ 0x02
   144                              <2> KMOD_ALT            equ 0x04
   145                              <2> 
   146                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   147                              <2> KEY_F1              equ 0xF1
   148                              <2> KEY_F2              equ 0xF2
   149                              <2> KEY_F3              equ 0xF3
   150                              <2> KEY_F4              equ 0xF4
   151                              <2> KEY_F5              equ 0xF5
   152                              <2> KEY_F6              equ 0xF6
   153                              <2> KEY_F7              equ 0xF7
   154                              <2> KEY_F8              equ 0xF8
   155                              <2> KEY_F9              equ 0xF9
   156                              <2> KEY_F10             equ 0xFA
   157                              <2> KEY_F11             equ 0xFB
   158                              <2> KEY_F12             equ 0xFC
   159                              <2> 
   160                              <2> ; --- USB/XHCI Memory Layout ---
   161                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   162                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   163                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   164                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   165                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   166                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   167                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   168                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   169                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   170                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   171                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   172                              <2> ; Slot 2 device support
   173                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   174                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   175                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   176                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   177                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   178                              <2> 
   179                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   180                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   181                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   182                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   183                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   184                              <2> XHCI_CAP_DBOFF      equ 0x14
   185                              <2> XHCI_CAP_RTSOFF     equ 0x18
   186                              <2> 
   187                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   188                              <2> XHCI_OP_USBCMD      equ 0x00
   189                              <2> XHCI_OP_USBSTS      equ 0x04
   190                              <2> XHCI_OP_PAGESIZE     equ 0x08
   191                              <2> XHCI_OP_DNCTRL      equ 0x14
   192                              <2> XHCI_OP_CRCR_LO     equ 0x18
   193                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   194                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   195                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   196                              <2> XHCI_OP_CONFIG      equ 0x38
   197                              <2> 
   198                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   199                              <2> XHCI_PORTSC         equ 0x00
   200                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   201                              <2> 
   202                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   203                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   204                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   205                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   206                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   207                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   208                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   209                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   210                              <2> 
   211                              <2> ; --- USBCMD bits ---
   212                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   213                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   214                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   215                              <2> 
   216                              <2> ; --- USBSTS bits ---
   217                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   218                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   219                              <2> 
   220                              <2> ; --- PORTSC bits ---
   221                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   222                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   223                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   224                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   225                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   226                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   227                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   228                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   229                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   230                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   231                              <2> 
   232                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   233                              <2> TRB_NORMAL           equ (1 << 10)
   234                              <2> TRB_SETUP            equ (2 << 10)
   235                              <2> TRB_DATA             equ (3 << 10)
   236                              <2> TRB_STATUS           equ (4 << 10)
   237                              <2> TRB_LINK             equ (6 << 10)
   238                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   239                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   240                              <2> TRB_CONFIG_EP        equ (12 << 10)
   241                              <2> TRB_EVAL_CTX         equ (13 << 10)
   242                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   243                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   244                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   245                              <2> 
   246                              <2> ; --- TRB Flag Bits (dword 3) ---
   247                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   248                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   249                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   250                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   251                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   252                              <2> 
   253                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   254                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   255                              <2> TRB_TRT_OUT          equ (2 << 16)
   256                              <2> TRB_TRT_IN           equ (3 << 16)
   257                              <2> 
   258                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   259                              <2> TRB_DIR_OUT          equ (0 << 16)
   260                              <2> TRB_DIR_IN           equ (1 << 16)
   261                              <2> 
   262                              <2> ; --- Ring sizes ---
   263                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   264                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   265                              <2> 
   266                              <2> ; --- USB Standard Request Codes ---
   267                              <2> USB_REQ_GET_DESC     equ 0x06
   268                              <2> USB_REQ_SET_CONFIG   equ 0x09
   269                              <2> USB_REQ_SET_IFACE    equ 0x0B
   270                              <2> 
   271                              <2> ; --- USB HID Request Codes ---
   272                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   273                              <2> 
   274                              <2> ; --- USB Descriptor Types ---
   275                              <2> USB_DESC_DEVICE      equ 0x01
   276                              <2> USB_DESC_CONFIG      equ 0x02
   277                              <2> USB_DESC_INTERFACE   equ 0x04
   278                              <2> USB_DESC_ENDPOINT    equ 0x05
   279                              <2> USB_DESC_HID         equ 0x21
   280                              <2> 
   281                              <2> ; --- USB Endpoint Types ---
   282                              <2> USB_EP_CONTROL       equ 0
   283                              <2> USB_EP_ISOCH         equ 1
   284                              <2> USB_EP_BULK          equ 2
   285                              <2> USB_EP_INTERRUPT     equ 3
   286                              <2> 
   287                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   288                              <2> XHCI_EP_NOT_VALID    equ 0
   289                              <2> XHCI_EP_ISOCH_OUT    equ 1
   290                              <2> XHCI_EP_BULK_OUT     equ 2
   291                              <2> XHCI_EP_INT_OUT      equ 3
   292                              <2> XHCI_EP_CONTROL      equ 4
   293                              <2> XHCI_EP_ISOCH_IN     equ 5
   294                              <2> XHCI_EP_BULK_IN      equ 6
   295                              <2> XHCI_EP_INT_IN       equ 7
   296                              <2> 
   297                              <2> ; --- XHCI Port Speeds ---
   298                              <2> XHCI_SPEED_FULL      equ 1
   299                              <2> XHCI_SPEED_LOW       equ 2
   300                              <2> XHCI_SPEED_HIGH      equ 3
   301                              <2> XHCI_SPEED_SUPER     equ 4
     8                              <1> 
     9                              <1> section .data
    10                              <1> global mcfg_base
    11 00000236 0000000000000000    <1> mcfg_base dq 0
    12                              <1> 
    13                              <1> section .text
    14                              <1> global acpi_pci_init
    15                              <1> 
    16                              <1> ; RSI = pointer to MCFG table
    17                              <1> acpi_pci_init:
    18 00002420 53                  <1>     push rbx
    19 00002421 51                  <1>     push rcx
    20 00002422 52                  <1>     push rdx
    21                              <1>     
    22                              <1>     ; TableLength is at offset 4
    23 00002423 8B4E04              <1>     mov ecx, [rsi + 4]
    24                              <1>     
    25                              <1>     ; Base of Configuration space allocation structures is at offset 44
    26 00002426 488D5E2C            <1>     lea rbx, [rsi + 44]
    27 0000242A 4801F1              <1>     add rcx, rsi    ; End of table
    28                              <1>     
    29                              <1> .scan:
    30 0000242D 4839CB              <1>     cmp rbx, rcx
    31 00002430 7310                <1>     jae .done
    32                              <1>     
    33                              <1>     ; struct size = 16 bytes
    34                              <1>     ; +0: Base address (8 bytes)
    35                              <1>     ; +8: PCI Segment Group Number (2 bytes)
    36                              <1>     ; +10: Start Bus Number (1 byte)
    37                              <1>     ; +11: End Bus Number (1 byte)
    38                              <1>     ; +12: Reserved (4 bytes)
    39                              <1>     
    40 00002432 488B03              <1>     mov rax, [rbx]
    41                              <1>     ; just store the first one for now (Segment 0)
    42 00002435 488905(36020000)    <1>     mov [mcfg_base], rax
    43                              <1>     
    44 0000243C 4883C310            <1>     add rbx, 16
    45 00002440 EBEB                <1>     jmp .scan
    46                              <1> 
    47                              <1> .done:
    48 00002442 5A                  <1>     pop rdx
    49 00002443 59                  <1>     pop rcx
    50 00002444 5B                  <1>     pop rbx
    51 00002445 C3                  <1>     ret
    61                                  section .text
    62                                  %include "src/drivers/acpi_ec.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - ACPI Embedded Controller Driver
     3                              <1> ; Safely reads/writes EC registers per ACPI Specification 12.2
     4                              <1> ; Handles EmbeddedControl region operations for battery, thermals, etc
     5                              <1> ; ============================================================================
     6                              <1> bits 64
     7                              <1> 
     8                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> L3_SYSCALL_STACK_ADDR equ 0xC00000   ; Kernel-only syscall stacks
    33                              <2> 
    34                              <2> ; --- Stage 2 disk layout ---
    35                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    36                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    37                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    38                              <2> 
    39                              <2> ; --- Screen ---
    40                              <2> SCREEN_WIDTH        equ 1024
    41                              <2> SCREEN_HEIGHT       equ 768
    42                              <2> SCREEN_BPP          equ 32
    43                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    44                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    45                              <2> 
    46                              <2> 
    47                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    48                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    49                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    50                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    51                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    52                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    53                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    54                              <2> 
    55                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    56                              <2> COLOR_BLACK         equ 0x00000000
    57                              <2> COLOR_WHITE         equ 0x00FFFFFF
    58                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    59                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    60                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    61                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    62                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    63                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    64                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    65                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    66                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    67                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    68                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    69                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    70                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    71                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    72                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    73                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    74                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    75                              <2> COLOR_START_HOVER    equ 0x00338833
    76                              <2> 
    77                              <2> ; --- Window Manager ---
    78                              <2> MAX_WINDOWS         equ 8
    79                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    80                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    81                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    82                              <2> TITLEBAR_HEIGHT     equ 24
    83                              <2> BORDER_WIDTH        equ 2
    84                              <2> CLOSE_BTN_SIZE      equ 18
    85                              <2> MIN_BTN_SIZE        equ 18
    86                              <2> MIN_WINDOW_W        equ 200
    87                              <2> MIN_WINDOW_H        equ 100
    88                              <2> 
    89                              <2> ; --- Taskbar ---
    90                              <2> TASKBAR_HEIGHT      equ 36
    91                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    92                              <2> START_BTN_W         equ 70
    93                              <2> START_BTN_H         equ 28
    94                              <2> START_BTN_X         equ 4
    95                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    96                              <2> CLOCK_WIDTH         equ 64
    97                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    98                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    99                              <2> 
   100                              <2> ; --- Keyboard ---
   101                              <2> KB_BUFFER_SIZE      equ 64
   102                              <2> 
   103                              <2> ; --- Mouse ---
   104                              <2> MOUSE_BUFFER_SIZE   equ 64
   105                              <2> CURSOR_WIDTH        equ 12
   106                              <2> CURSOR_HEIGHT       equ 19
   107                              <2> 
   108                              <2> ; --- PIT ---
   109                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   110                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   111                              <2> 
   112                              <2> ; --- PIC vectors ---
   113                              <2> IRQ_BASE_MASTER     equ 32
   114                              <2> IRQ_BASE_SLAVE      equ 40
   115                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   116                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   117                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   118                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   119                              <2> 
   120                              <2> ; --- Font ---
   121                              <2> FONT_WIDTH          equ 8
   122                              <2> FONT_HEIGHT         equ 16
   123                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   124                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   125                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   126                              <2> 
   127                              <2> ; --- Window flags ---
   128                              <2> WF_VISIBLE          equ 0x01
   129                              <2> WF_FOCUSED          equ 0x02
   130                              <2> WF_DRAGGING         equ 0x04
   131                              <2> WF_MINIMIZED        equ 0x08
   132                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   133                              <2> 
   134                              <2> ; --- Mouse event types ---
   135                              <2> MEVT_MOVE           equ 1
   136                              <2> MEVT_LCLICK         equ 2
   137                              <2> MEVT_RCLICK         equ 3
   138                              <2> MEVT_LRELEASE       equ 4
   139                              <2> MEVT_RRELEASE       equ 5
