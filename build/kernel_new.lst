   856                              <1> ; i2c_hid_poll - Non-blocking touchpad poll (called from main loop)
   857                              <1> ;
   858                              <1> ; State machine (3 states for variable-length reports):
   859                              <1> ;   State 0: Issue wInputRegister address + queue header reads (2 bytes)
   860                              <1> ;            -> set state=1
   861                              <1> ;   State 1: Check if 2 header bytes available. Read length.
   862                              <1> ;            If length > 0, queue remaining reads. -> state=2
   863                              <1> ;            If length == 0, -> state=0 (no data)
   864                              <1> ;   State 2: Check if all data bytes available. Process report. -> state=0
   865                              <1> ; ============================================================================
