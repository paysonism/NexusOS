    52 00001838 0000                <1>
    53 0000183A 48C783B00000001000- <1>     mov qword [rbx + process_t.ss], GDT64_DATA_SEG
    53 00001843 0000                <1>
    54 00001845 48C783B80000000000- <1>     mov qword [rbx + process_t.kernel_rsp], 0x200000
    54 0000184E 2000                <1>
    55                              <1>     
    56 00001850 C705(E0010000)0000- <1>     mov dword [current_process_id], 0
    56 00001858 0000                <1>
    57 0000185A C705(E4010000)0100- <1>     mov dword [next_pid], 1
    57 00001862 0000                <1>
    58                              <1>     
    59 00001864 5B                  <1>     pop rbx
    60 00001865 58                  <1>     pop rax
    61 00001866 59                  <1>     pop rcx
    62 00001867 5F                  <1>     pop rdi
    63 00001868 C3                  <1>     ret
    64                              <1> 
    65                              <1> ; --- process_create ---
    66                              <1> ; RDI = Entry Point (RIP)
    67                              <1> ; RSI = Slot (App Arena / Stack index)
    68                              <1> ; RDX = Window ID
    69                              <1> ; Returns: RAX = Process ID or -1
    70                              <1> process_create:
    71 00001869 53                  <1>     push rbx
    72 0000186A 51                  <1>     push rcx
    73 0000186B 52                  <1>     push rdx
    74 0000186C 57                  <1>     push rdi
    75 0000186D 56                  <1>     push rsi
    76 0000186E 4154                <1>     push r12
    77 00001870 4155                <1>     push r13
    78 00001872 4156                <1>     push r14
    79                              <1>     
    80 00001874 4989FC              <1>     mov r12, rdi        ; entry
    81 00001877 4989F5              <1>     mov r13, rsi        ; slot
    82 0000187A 4989D6              <1>     mov r14, rdx        ; win_id
