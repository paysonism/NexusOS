    95 000018A2 E982000000          <1>     jmp .done
    96                              <1>     
    97                              <1> .found:
    98                              <1>     ; Initialize PCB
    99 000018A7 8B05(E4010000)      <1>     mov eax, [next_pid]
   100 000018AD FF05(E4010000)      <1>     inc dword [next_pid]
   101 000018B3 89839C000000        <1>     mov [rbx + process_t.id], eax
   102 000018B9 C78398000000010000- <1>     mov [rbx + process_t.state], dword 1 ; READY = 1
   102 000018C2 00                  <1>
   103 000018C3 4C89A380000000      <1>     mov [rbx + process_t.rip], r12
   104 000018CA 4489ABA4000000      <1>     mov [rbx + process_t.slot], r13d
