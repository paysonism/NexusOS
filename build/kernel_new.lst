   536                              <1> ; ============================================================================
   537                              <1> ; hid_extract_field - Extract a field value from a HID report
   538                              <1> ; Input:  RSI = pointer to report data (after report ID if present)
   539                              <1> ;         EDI = bit offset of field
   540                              <1> ;         ESI is NOT modified (uses RSI from stack)
   541                              <1> ;         R8D = bit size of field (1-32)
   542                              <1> ; Output: EAX = extracted value (zero-extended)
   543                              <1> ; ============================================================================
   544                              <1> global hid_extract_field
   545                              <1> hid_extract_field:
   546 00006AB1 53                  <1>     push rbx
   547 00006AB2 51                  <1>     push rcx
   548 00006AB3 52                  <1>     push rdx
