   652                              <1> ; ============================================================================
   653                              <1> ; xhci_setup_scratchpad - Allocate scratchpad buffers if needed
   654                              <1> ; ============================================================================
   655                              <1> xhci_setup_scratchpad:
   656 00003E68 51                  <1>     push rcx
   657 00003E69 57                  <1>     push rdi
   658                              <1> 
   659 00003E6A 0FB60D(78050000)    <1>     movzx ecx, byte [xhci_scratchpad_count]
   660 00003E71 85C9                <1>     test ecx, ecx
   661 00003E73 7435                <1>     jz .scratch_done              ; No scratchpads needed
   662                              <1> 
   663                              <1>     ; Cap at 4 (we have space for 4 buffer pages)
   664 00003E75 83F904              <1>     cmp ecx, 4
   665 00003E78 7E05                <1>     jle .scratch_ok
   666 00003E7A B904000000          <1>     mov ecx, 4
   667                              <1> .scratch_ok:
   668                              <1> 
   669                              <1>     ; Scratchpad array at XHCI_SCRATCH_ADDR
   670                              <1>     ; Buffers at XHCI_SCRATCH_ADDR + 0x1000, +0x2000, etc.
   671 00003E7F BF00009400          <1>     mov rdi, XHCI_SCRATCH_ADDR
   672 00003E84 31D2                <1>     xor edx, edx
   673                              <1> .scratch_loop:
   674 00003E86 39CA                <1>     cmp edx, ecx
   675 00003E88 7D14                <1>     jge .scratch_set_dcbaa
   676                              <1>     ; Buffer address = XHCI_SCRATCH_ADDR + 0x1000 * (edx + 1)
   677 00003E8A 89D0                <1>     mov eax, edx
   678 00003E8C FFC0                <1>     inc eax
   679 00003E8E C1E00C              <1>     shl eax, 12                   ; * 4096
   680 00003E91 0500009400          <1>     add eax, XHCI_SCRATCH_ADDR
   681 00003E96 488904D7            <1>     mov [rdi + rdx * 8], rax      ; Write 64-bit pointer to array
   682 00003E9A FFC2                <1>     inc edx
   683 00003E9C EBE8                <1>     jmp .scratch_loop
   684                              <1> 
   685                              <1> .scratch_set_dcbaa:
   686                              <1>     ; DCBAA[0] = scratchpad array pointer
   687 00003E9E BF00009000          <1>     mov rdi, XHCI_DCBAA_ADDR
   688 00003EA3 48C70700009400      <1>     mov qword [rdi], XHCI_SCRATCH_ADDR
   689                              <1> 
   690                              <1> .scratch_done:
   691 00003EAA 5F                  <1>     pop rdi
   692 00003EAB 59                  <1>     pop rcx
   693 00003EAC C3                  <1>     ret
   694                              <1> 
   695                              <1> ; ============================================================================
   696                              <1> ; xhci_setup_dcbaa - Setup Device Context Base Address Array
