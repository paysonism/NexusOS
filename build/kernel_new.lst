    92 00007910 7534                <1>     jne .do_full
    93                              <1> 
    94                              <1>     ; Flip each dirty rectangle
    95 00007912 8B1D(E30E0000)      <1>     mov ebx, [dirty_count]
    96 00007918 85DB                <1>     test ebx, ebx
    97 0000791A 7436                <1>     jz .flush_done
    98                              <1> 
    99 0000791C 31C0                <1>     xor eax, eax            ; Index
   100                              <1> .flush_loop:
   101 0000791E 39D8                <1>     cmp eax, ebx
   102 00007920 7D30                <1>     jge .flush_done
   103                              <1> 
   104 00007922 50                  <1>     push rax
   105 00007923 C1E004              <1>     shl eax, 4
   106 00007926 4C8D80[E80E0000]    <1>     lea r8, [dirty_rects + rax]
