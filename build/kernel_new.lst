    59                              <1> 
    60                              <1>     ; Store dirty rect
    61 000078D5 C1E004              <1>     shl eax, 4              ; * 16 bytes per rect
    62 000078D8 488D80[E80E0000]    <1>     lea rax, [dirty_rects + rax]
    63 000078DF 8938                <1>     mov [rax], edi           ; x
    64 000078E1 897004              <1>     mov [rax + 4], esi       ; y
    65 000078E4 895008              <1>     mov [rax + 8], edx       ; w
