   153 000049F1 C1E004              <1>     shl eax, 4
   154 000049F4 488B35(5C050000)    <1>     mov rsi, [xhci_op_base]
   155 000049FB 4881C600040000      <1>     add rsi, 0x400
   156 00004A02 8B1C06              <1>     mov ebx, [rsi + rax + XHCI_PORTSC]
   157 00004A05 81E3FFFF09FF        <1>     and ebx, ~XHCI_PORTSC_CHANGE_BITS
   158 00004A0B 81CB00002000        <1>     or  ebx, XHCI_PORTSC_PRC
