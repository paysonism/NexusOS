   450                              <1>     ; Fill bar inside battery body based on percentage
   451                              <1>     ; Fill width = percent * 14 / 100 (max fill = 14px inside 16px body)
   452 00008950 0FB605(A30D0000)    <1>     movzx eax, byte [battery_percent]
   453 00008957 6BC00E              <1>     imul eax, 14
