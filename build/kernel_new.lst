     7                              <1> 
     8                              <1> ; --- clamp: Clamp value to range ---
     9                              <1> ; EDI = value, ESI = min, EDX = max
    10                              <1> ; Returns: EAX = clamped value
    11                              <1> global fn_clamp
    12                              <1> fn_clamp:
    13 0000CEC9 89F8                <1>     mov eax, edi
    14 0000CECB 39F0                <1>     cmp eax, esi
    15 0000CECD 0F4CC6              <1>     cmovl eax, esi           ; If value < min, use min
    16 0000CED0 39D0                <1>     cmp eax, edx
    17 0000CED2 0F4FC2              <1>     cmovg eax, edx           ; If value > max, use max
    18 0000CED5 C3                  <1>     ret
    19                              <1> 
    20                              <1> ; --- min: Integer minimum ---
    21                              <1> ; EDI = a, ESI = b
    22                              <1> ; Returns: EAX = min(a, b)
    23                              <1> global fn_min
    24                              <1> fn_min:
    25 0000CED6 89F8                <1>     mov eax, edi
    26 0000CED8 39F0                <1>     cmp eax, esi
    27 0000CEDA 0F4FC6              <1>     cmovg eax, esi
    28 0000CEDD C3                  <1>     ret
    29                              <1> 
    30                              <1> ; --- max: Integer maximum ---
    31                              <1> ; EDI = a, ESI = b
    32                              <1> ; Returns: EAX = max(a, b)
    33                              <1> global fn_max
    34                              <1> fn_max:
    35 0000CEDE 89F8                <1>     mov eax, edi
    36 0000CEE0 39F0                <1>     cmp eax, esi
    37 0000CEE2 0F4CC6              <1>     cmovl eax, esi
    38 0000CEE5 C3                  <1>     ret
    39                              <1> 
    40                              <1> ; --- abs: Absolute value ---
    41                              <1> ; EDI = value
    42                              <1> ; Returns: EAX = |value|
    43                              <1> global fn_abs
    44                              <1> fn_abs:
    45 0000CEE6 89F8                <1>     mov eax, edi
    46 0000CEE8 99                  <1>     cdq
    47 0000CEE9 31D0                <1>     xor eax, edx
    48 0000CEEB 29D0                <1>     sub eax, edx
    49 0000CEED C3                  <1>     ret
    50                              <1> 
    51                              <1> ; --- rect_intersect: Test if two rectangles overlap ---
    52                              <1> ; RDI = rect1 pointer, RSI = rect2 pointer
    53                              <1> ; Returns: EAX = 1 if overlapping, 0 if not
    54                              <1> global fn_rect_intersect
    55                              <1> fn_rect_intersect:
    56                              <1>     ; rect1.x + rect1.w <= rect2.x?
    57 0000CEEE 8B07                <1>     mov eax, [rdi]           ; rect1.x
    58 0000CEF0 034708              <1>     add eax, [rdi + 8]      ; + rect1.w
