   134 000049B7 C1E004              <1>     shl eax, 4
   135 000049BA 488B35(5C050000)    <1>     mov rsi, [xhci_op_base]
   136 000049C1 4881C600040000      <1>     add rsi, 0x400
   137 000049C8 8B1406              <1>     mov edx, [rsi + rax + XHCI_PORTSC]
