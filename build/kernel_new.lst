   362                              <1> ; ============================================================================
   363                              <1> ; i2c_init_controller - Initialize DesignWare I2C controller
   364                              <1> ; RSI = controller base address, EDI = 7-bit device address
   365                              <1> ; Returns: EAX = 1 success, 0 fail
   366                              <1> ; ============================================================================
   367                              <1> i2c_init_controller:
   368 00005E0F 51                  <1>     push rcx
   369                              <1> 
   370                              <1>     ; Disable controller first
   371 00005E10 C7466C00000000      <1>     mov dword [rsi + DW_IC_ENABLE], 0
   372                              <1> 
   373                              <1>     ; Wait for disabled (activity bit clear)
   374 00005E17 B988130000          <1>     mov ecx, 5000
   375                              <1> .wait_dis:
   376 00005E1C 8B869C000000        <1>     mov eax, [rsi + DW_IC_ENABLE_STATUS]
   377 00005E22 A901000000          <1>     test eax, 1                 ; IC_EN bit
   378 00005E27 7408                <1>     jz .dis_ok
   379 00005E29 FFC9                <1>     dec ecx
   380 00005E2B 75EF                <1>     jnz .wait_dis
   381 00005E2D 31C0                <1>     xor eax, eax
   382 00005E2F 59                  <1>     pop rcx
   383 00005E30 C3                  <1>     ret
   384                              <1> .dis_ok:
   385                              <1> 
   386                              <1>     ; Preserve firmware IC_CON speed/timing bits - UEFI already set correct
   387                              <1>     ; values for this platform's I2C clock. Only enforce master mode flags.
   388 00005E31 8B06                <1>     mov eax, [rsi + DW_IC_CON]
   389 00005E33 83C861              <1>     or eax, IC_CON_MASTER_MODE | IC_CON_RESTART_EN | IC_CON_SLAVE_DISABLE
   390 00005E36 8906                <1>     mov [rsi + DW_IC_CON], eax
   391                              <1> 
   392                              <1>     ; Set target address
   393 00005E38 897E04              <1>     mov [rsi + DW_IC_TAR], edi
   394                              <1> 
   395                              <1>     ; Do NOT overwrite SCL HCNT/LCNT/SDA_HOLD - firmware values are correct
   396                              <1>     ; for this platform's FCH I2C clock (varies: 100/133/150MHz by platform)
   397                              <1> 
   398                              <1>     ; Mask all interrupts (we poll)
   399 00005E3B C7463000000000      <1>     mov dword [rsi + DW_IC_INTR_MASK], 0
   400                              <1> 
   401                              <1>     ; Set RX threshold to 0 (notify on any byte)
   402 00005E42 C7463800000000      <1>     mov dword [rsi + DW_IC_RX_TL], 0
   403                              <1> 
   404                              <1>     ; Clear any pending interrupts/aborts
   405 00005E49 8B4640              <1>     mov eax, [rsi + DW_IC_CLR_INTR]
   406 00005E4C 8B4654              <1>     mov eax, [rsi + DW_IC_CLR_TX_ABRT]
   407                              <1> 
   408                              <1>     ; Enable controller
   409 00005E4F C7466C01000000      <1>     mov dword [rsi + DW_IC_ENABLE], 1
   410                              <1> 
   411                              <1>     ; Wait for enabled
   412 00005E56 B988130000          <1>     mov ecx, 5000
   413                              <1> .wait_en:
   414 00005E5B 8B869C000000        <1>     mov eax, [rsi + DW_IC_ENABLE_STATUS]
   415 00005E61 A901000000          <1>     test eax, 1
   416 00005E66 7508                <1>     jnz .en_ok
   417 00005E68 FFC9                <1>     dec ecx
   418 00005E6A 75EF                <1>     jnz .wait_en
   419 00005E6C 31C0                <1>     xor eax, eax
   420 00005E6E 59                  <1>     pop rcx
   421 00005E6F C3                  <1>     ret
