     8                              <1> ; --- strlen: Get string length ---
     9                              <1> ; RDI = pointer to null-terminated string
    10                              <1> ; Returns: RAX = length
    11                              <1> global fn_strlen
    12                              <1> fn_strlen:
    13 0000CD8F 51                  <1>     push rcx
    14 0000CD90 57                  <1>     push rdi
    15 0000CD91 4831C9              <1>     xor rcx, rcx
    16 0000CD94 48FFC9              <1>     dec rcx                  ; RCX = -1 (max count)
    17 0000CD97 30C0                <1>     xor al, al              ; Searching for null
    18 0000CD99 F2AE                <1>     repne scasb
    19 0000CD9B 48F7D1              <1>     not rcx
    20 0000CD9E 48FFC9              <1>     dec rcx                  ; RCX = length
    21 0000CDA1 4889C8              <1>     mov rax, rcx
    22 0000CDA4 5F                  <1>     pop rdi
    23 0000CDA5 59                  <1>     pop rcx
    24 0000CDA6 C3                  <1>     ret
    25                              <1> 
    26                              <1> ; --- strcmp: Compare two strings ---
    27                              <1> ; RDI = string1, RSI = string2
    28                              <1> ; Returns: RAX = 0 if equal, <0 if s1<s2, >0 if s1>s2
    29                              <1> global fn_strcmp
    30                              <1> fn_strcmp:
    31 0000CDA7 53                  <1>     push rbx
    32                              <1> .cmp_loop:
    33 0000CDA8 8A07                <1>     mov al, [rdi]
    34 0000CDAA 8A1E                <1>     mov bl, [rsi]
    35 0000CDAC 38D8                <1>     cmp al, bl
    36 0000CDAE 750C                <1>     jne .cmp_diff
    37 0000CDB0 84C0                <1>     test al, al
    38 0000CDB2 7412                <1>     jz .cmp_equal
    39 0000CDB4 48FFC7              <1>     inc rdi
    40 0000CDB7 48FFC6              <1>     inc rsi
    41 0000CDBA EBEC                <1>     jmp .cmp_loop
    42                              <1> .cmp_diff:
    43 0000CDBC 0FB6C0              <1>     movzx eax, al
    44 0000CDBF 0FB6DB              <1>     movzx ebx, bl
    45 0000CDC2 29D8                <1>     sub eax, ebx
    46 0000CDC4 5B                  <1>     pop rbx
    47 0000CDC5 C3                  <1>     ret
    48                              <1> .cmp_equal:
    49 0000CDC6 31C0                <1>     xor eax, eax
    50 0000CDC8 5B                  <1>     pop rbx
    51 0000CDC9 C3                  <1>     ret
    52                              <1> 
    53                              <1> ; --- strcpy: Copy string ---
    54                              <1> ; RDI = dest, RSI = src
    55                              <1> ; Returns: RAX = dest
    56                              <1> global fn_strcpy
    57                              <1> fn_strcpy:
    58 0000CDCA 57                  <1>     push rdi
    59 0000CDCB 56                  <1>     push rsi
    60                              <1> .copy_loop:
    61 0000CDCC AC                  <1>     lodsb
    62 0000CDCD AA                  <1>     stosb
    63 0000CDCE 84C0                <1>     test al, al
    64 0000CDD0 75FA                <1>     jnz .copy_loop
    65 0000CDD2 5E                  <1>     pop rsi
    66 0000CDD3 488B0424            <1>     mov rax, [rsp]
    67 0000CDD7 5F                  <1>     pop rdi
    68 0000CDD8 4889F8              <1>     mov rax, rdi
    69 0000CDDB C3                  <1>     ret
    70                              <1> 
    71                              <1> ; --- memcpy: Copy bytes ---
    72                              <1> ; RDI = dest, RSI = src, RDX = count
    73                              <1> ; Returns: RAX = dest
    74                              <1> global fn_memcpy
    75                              <1> fn_memcpy:
    76 0000CDDC 57                  <1>     push rdi
    77 0000CDDD 51                  <1>     push rcx
    78 0000CDDE 4889D1              <1>     mov rcx, rdx
    79                              <1>     ; Copy qwords first
    80 0000CDE1 48C1E903            <1>     shr rcx, 3
    81 0000CDE5 F348A5              <1>     rep movsq
    82                              <1>     ; Copy remaining bytes
    83 0000CDE8 4889D1              <1>     mov rcx, rdx
    84 0000CDEB 4883E107            <1>     and rcx, 7
    85 0000CDEF F3A4                <1>     rep movsb
    86 0000CDF1 59                  <1>     pop rcx
    87 0000CDF2 5F                  <1>     pop rdi
    88 0000CDF3 4889F8              <1>     mov rax, rdi
    89 0000CDF6 C3                  <1>     ret
    90                              <1> 
    91                              <1> ; --- memset: Fill memory ---
    92                              <1> ; RDI = dest, ESI = byte value, RDX = count
    93                              <1> ; Returns: RAX = dest
    94                              <1> global fn_memset
    95                              <1> fn_memset:
    96 0000CDF7 57                  <1>     push rdi
    97 0000CDF8 51                  <1>     push rcx
    98 0000CDF9 4889F0              <1>     mov rax, rsi
    99 0000CDFC 4889D1              <1>     mov rcx, rdx
   100                              <1>     ; Fill qwords
   101 0000CDFF 88C4                <1>     mov ah, al
   102 0000CE01 0FB7C0              <1>     movzx eax, ax
   103 0000CE04 69C001010101        <1>     imul eax, 0x01010101     ; Replicate byte across dword
   104 0000CE0A 4989C0              <1>     mov r8, rax
   105 0000CE0D 48C1E020            <1>     shl rax, 32
   106 0000CE11 4C09C0              <1>     or rax, r8               ; Replicate across qword
   107 0000CE14 51                  <1>     push rcx
   108 0000CE15 48C1E903            <1>     shr rcx, 3
   109 0000CE19 F348AB              <1>     rep stosq
   110 0000CE1C 59                  <1>     pop rcx
   111 0000CE1D 4883E107            <1>     and rcx, 7
   112 0000CE21 4088F0              <1>     mov al, sil
   113 0000CE24 F3AA                <1>     rep stosb
   114 0000CE26 59                  <1>     pop rcx
   115 0000CE27 5F                  <1>     pop rdi
   116 0000CE28 4889F8              <1>     mov rax, rdi
   117 0000CE2B C3                  <1>     ret
   118                              <1> 
   119                              <1> ; --- memsetd: Fill memory with dwords ---
   120                              <1> ; RDI = dest, ESI = dword value, RDX = count (number of dwords)
   121                              <1> global fn_memsetd
   122                              <1> fn_memsetd:
   123 0000CE2C 57                  <1>     push rdi
   124 0000CE2D 51                  <1>     push rcx
   125 0000CE2E 50                  <1>     push rax
   126 0000CE2F 89F0                <1>     mov eax, esi
   127 0000CE31 4889D1              <1>     mov rcx, rdx
   128 0000CE34 F3AB                <1>     rep stosd
   129 0000CE36 58                  <1>     pop rax
   130 0000CE37 59                  <1>     pop rcx
   131 0000CE38 5F                  <1>     pop rdi
   132 0000CE39 C3                  <1>     ret
