   568 00003DB9 FFC9                <1>     dec ecx
   569 00003DBB 0F8498000000        <1>     jz .reset_fail
   570 00003DC1 488B05(F0000000)    <1>     mov rax, [tick_count]
   571 00003DC8 4839D8              <1>     cmp rax, rbx
   572 00003DCB 0F8D88000000        <1>     jge .reset_fail          ; Timeout
