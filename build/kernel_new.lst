   627                              <1> ; fat16_change_dir - Change current directory (load into ROOT_CACHE)
   628                              <1> ; ax = cluster number (0 = root)
   629                              <1> ; Returns: eax = 0 on success
   630                              <1> ; ============================================================================
   631                              <1> global fat16_change_dir
   632                              <1> fat16_change_dir:
   633 000077A2 53                  <1>     push rbx
   634 000077A3 51                  <1>     push rcx
   635 000077A4 52                  <1>     push rdx
   636 000077A5 57                  <1>     push rdi
   637 000077A6 56                  <1>     push rsi
   638 000077A7 4150                <1>     push r8
   639 000077A9 4151                <1>     push r9
   640 000077AB 4152                <1>     push r10
   641                              <1> 
   642 000077AD 0FB7D8              <1>     movzx ebx, ax          ; cluster
   643 000077B0 66891D(CA0D0000)    <1>     mov [fat16_cur_dir_cluster], bx
   644                              <1>     
   645                              <1>     ; Cluster 0 -> Load Root Directory
   646 000077B7 85DB                <1>     test ebx, ebx
   647 000077B9 7528                <1>     jnz .cd_subdir
   648                              <1>     
   649                              <1>     ; Load Root (contiguous)
   650 000077BB 8B3D(BA0D0000)      <1>     mov edi, [fat16_root_start_sect]
   651 000077C1 81C740010000        <1>     add edi, FAT16_PART_LBA
   652 000077C7 BE0010D100          <1>     mov rsi, FAT16_ROOT_CACHE
   653 000077CC 8B15(BE0D0000)      <1>     mov edx, [fat16_root_sectors]
   654 000077D2 E898BFFFFF          <1>     call ata_read_sectors
   655                              <1>     
   656                              <1>     ; Reset file count
   657 000077D7 E842FCFFFF          <1>     call fat16_count_root_files
   658 000077DC 31C0                <1>     xor eax, eax
   659 000077DE E982000000          <1>     jmp .cd_done
   660                              <1> 
   661                              <1> .cd_subdir:
   662                              <1>     ; Subdirectory: Read cluster chain into FAT16_ROOT_CACHE
   663                              <1>     ; Max entries restricted by ROOT_CACHE size (16KB = 512 entries)
   664                              <1>     ; Clear cache first
   665 000077E3 BF0010D100          <1>     mov rdi, FAT16_ROOT_CACHE
   666 000077E8 B900100000          <1>     mov ecx, 16384 / 4
   667 000077ED 31C0                <1>     xor eax, eax
   668 000077EF F3AB                <1>     rep stosd
   669                              <1>     
   670 000077F1 BE0010D100          <1>     mov rsi, FAT16_ROOT_CACHE ; Dest
   671 000077F6 4531D2              <1>     xor r10d, r10d            ; Total bytes read
   672                              <1>     
   673                              <1> .cd_loop:
   674 000077F9 83FB02              <1>     cmp ebx, 2
   675 000077FC 7C60                <1>     jl .cd_finish
   676 000077FE 81FBF8FF0000        <1>     cmp ebx, 0xFFF8
   677 00007804 7D58                <1>     jge .cd_finish
   678                              <1>     
   679                              <1>     ; Read cluster
   680 00007806 89D8                <1>     mov eax, ebx
   681 00007808 83E802              <1>     sub eax, 2
   682 0000780B 0FB615(AE0D0000)    <1>     movzx edx, byte [fat16_sect_per_clus]
   683 00007812 0FAFC2              <1>     imul eax, edx
   684 00007815 0305(C20D0000)      <1>     add eax, [fat16_data_start_sect]
   685 0000781B 0540010000          <1>     add eax, FAT16_PART_LBA
   686                              <1>     
   687 00007820 89C7                <1>     mov edi, eax
   688 00007822 0FB615(AE0D0000)    <1>     movzx edx, byte [fat16_sect_per_clus]
   689                              <1>     
   690                              <1>     ; Safety check for cache overflow
   691 00007829 89D0                <1>     mov eax, edx
   692 0000782B C1E009              <1>     shl eax, 9 ; bytes to read
   693 0000782E 67458D0C02          <1>     lea r9d, [r10d + eax]
   694 00007833 4181F900400000      <1>     cmp r9d, 16384
   695 0000783A 7F22                <1>     jg .cd_finish ; Truncate if too big
   696                              <1>     
   697 0000783C E82EBFFFFF          <1>     call ata_read_sectors
   698                              <1>     
   699                              <1>     ; Advance ptr
   700 00007841 0FB605(AE0D0000)    <1>     movzx eax, byte [fat16_sect_per_clus]
   701 00007848 C1E009              <1>     shl eax, 9
   702 0000784B 4801C6              <1>     add rsi, rax
   703 0000784E 4101C2              <1>     add r10d, eax
   704                              <1>     
   705                              <1>     ; Next cluster
   706 00007851 89D8                <1>     mov eax, ebx
   707 00007853 D1E0                <1>     shl eax, 1
   708 00007855 0FB7980010D000      <1>     movzx ebx, word [FAT16_FAT_CACHE + rax]
   709 0000785C EB9B                <1>     jmp .cd_loop
   710                              <1> 
   711                              <1> .cd_finish:
   712                              <1>     ; Recount files in new view
   713 0000785E E8BBFBFFFF          <1>     call fat16_count_root_files
   714 00007863 31C0                <1>     xor eax, eax
   715                              <1> 
   716                              <1> .cd_done:
   717 00007865 415A                <1>     pop r10
   718                              <1> 
   719 00007867 4159                <1>     pop r9
   720 00007869 4158                <1>     pop r8
   721 0000786B 5E                  <1>     pop rsi
   722 0000786C 5F                  <1>     pop rdi
   723 0000786D 5A                  <1>     pop rdx
   724 0000786E 59                  <1>     pop rcx
   725 0000786F 5B                  <1>     pop rbx
   726 00007870 C3                  <1>     ret
