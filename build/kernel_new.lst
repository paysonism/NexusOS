     7                              <1> section .text
     8                              <1> global pit_init
     9                              <1> pit_init:
    10 00001223 B036                <1>     mov al, 0x36
    11 00001225 E643                <1>     out 0x43, al
    12 00001227 66B89C2E            <1>     mov ax, PIT_DIVISOR
    13 0000122B E640                <1>     out 0x40, al
    14 0000122D 88E0                <1>     mov al, ah
    15 0000122F E640                <1>     out 0x40, al
    16                              <1> 
    17 00001231 48C705(F0000000)00- <1>     mov qword [tick_count], 0
    17 00001239 000000              <1>
    18 0000123C C705(F8000000)0000- <1>     mov dword [sub_ticks], 0
