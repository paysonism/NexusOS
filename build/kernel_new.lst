  1059 00006FD8 01D3                <1>     add ebx, edx                ; ebx = current distance
  1060                              <1>     ; Compute delta vs previous distance
  1061 00006FDA 8B15(7D0D0000)      <1>     mov edx, [gesture_pinch_dist_prev]
  1062 00006FE0 891D(7D0D0000)      <1>     mov [gesture_pinch_dist_prev], ebx
  1063 00006FE6 85D2                <1>     test edx, edx
  1064 00006FE8 741A                <1>     jz .check_3finger           ; no previous sample
  1065 00006FEA 29D3                <1>     sub ebx, edx                ; ebx = distance delta (positive=zoom in)
  1066                              <1>     ; Apply threshold to reduce noise (ignore if < 8 pixels)
  1067 00006FEC 89D9                <1>     mov ecx, ebx
  1068 00006FEE 85C9                <1>     test ecx, ecx
  1069 00006FF0 7902                <1>     jns .pinch_delta_pos
  1070 00006FF2 F7D9                <1>     neg ecx
  1071                              <1> .pinch_delta_pos:
  1072 00006FF4 83F908              <1>     cmp ecx, 8
  1073 00006FF7 7C0B                <1>     jl .check_3finger
  1074 00006FF9 C1FB02              <1>     sar ebx, 2                  ; scale down
  1075 00006FFC 891D(820D0000)      <1>     mov [mouse_pinch_delta], ebx
  1076 00007002 EB7C                <1>     jmp .gesture_done
