     8                              <1> %include "macros.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - Common Macros
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> %ifndef MACROS_INC
     6                              <2> %define MACROS_INC
     7                              <2> 
     8                              <2> ; Output character to COM1 for debugging
     9                              <2> %macro SER 1
    10                              <2>     push rax
    11                              <2>     push rdx
    12                              <2>     mov dx, 0x3F8
    13                              <2>     mov al, %1
    14                              <2>     out dx, al
    15                              <2>     pop rdx
    16                              <2>     pop rax
    17                              <2> %endmacro
    18                              <2> 
    19                              <2> ; Save all general-purpose registers (64-bit)
    20                              <2> %macro PUSH_ALL 0
    21                              <2>     push rax
    22                              <2>     push rbx
    23                              <2>     push rcx
    24                              <2>     push rdx
    25                              <2>     push rsi
    26                              <2>     push rdi
    27                              <2>     push rbp
    28                              <2>     push r8
    29                              <2>     push r9
    30                              <2>     push r10
    31                              <2>     push r11
    32                              <2>     push r12
    33                              <2>     push r13
    34                              <2>     push r14
    35                              <2>     push r15
    36                              <2> %endmacro
    37                              <2> 
    38                              <2> ; Offset of registers in PUSH_ALL frame
    39                              <2> ALL_R15 equ 0
    40                              <2> ALL_R14 equ 8
    41                              <2> ALL_R13 equ 16
    42                              <2> ALL_R12 equ 24
    43                              <2> ALL_R11 equ 32
    44                              <2> ALL_R10 equ 40
    45                              <2> ALL_R9  equ 48
    46                              <2> ALL_R8  equ 56
    47                              <2> ALL_RBP equ 64
    48                              <2> ALL_RDI equ 72
    49                              <2> ALL_RSI equ 80
    50                              <2> ALL_RDX equ 88
    51                              <2> ALL_RCX equ 96
    52                              <2> ALL_RBX equ 104
    53                              <2> ALL_RAX equ 112
    54                              <2> 
    55                              <2> ; Restore all general-purpose registers (64-bit)
    56                              <2> %macro POP_ALL 0
    57                              <2>     pop r15
    58                              <2>     pop r14
    59                              <2>     pop r13
    60                              <2>     pop r12
    61                              <2>     pop r11
    62                              <2>     pop r10
    63                              <2>     pop r9
    64                              <2>     pop r8
    65                              <2>     pop rbp
    66                              <2>     pop rdi
    67                              <2>     pop rsi
    68                              <2>     pop rdx
    69                              <2>     pop rcx
    70                              <2>     pop rbx
    71                              <2>     pop rax
    72                              <2> %endmacro
    73                              <2> 
    74                              <2> ; Output byte to port with I/O delay
    75                              <2> %macro OUTB 2
    76                              <2>     mov al, %2
    77                              <2>     out %1, al
    78                              <2> %endmacro
    79                              <2> 
    80                              <2> ; Input byte from port
    81                              <2> %macro INB 1
    82                              <2>     in al, %1
    83                              <2> %endmacro
    84                              <2> 
    85                              <2> ; I/O wait (small delay for PIC/PIT programming)
    86                              <2> %macro IO_WAIT 0
    87                              <2>     out 0x80, al
    88                              <2> %endmacro
    89                              <2> 
    90                              <2> ; Bochs magic breakpoint
    91                              <2> %macro BOCHS_BREAK 0
    92                              <2>     xchg bx, bx
    93                              <2> %endmacro
    94                              <2> 
    95                              <2> ; ISR stub that pushes a dummy error code (for exceptions without one)
    96                              <2> %macro ISR_NOERRCODE 1
    97                              <2> global isr_%1
    98                              <2> isr_%1:
    99                              <2>     push qword 0           ; Dummy error code
   100                              <2>     push qword %1          ; Interrupt number
   101                              <2>     jmp isr_common_stub
   102                              <2> %endmacro
   103                              <2> 
   104                              <2> ; ISR stub for exceptions that push their own error code
   105                              <2> %macro ISR_ERRCODE 1
   106                              <2> global isr_%1
   107                              <2> isr_%1:
   108                              <2>     push qword %1          ; Interrupt number (error code already on stack)
   109                              <2>     jmp isr_common_stub
   110                              <2> %endmacro
   111                              <2> 
   112                              <2> ; IRQ stub macro
   113                              <2> %macro IRQ_STUB 2
   114                              <2> global irq_%1
   115                              <2> irq_%1:
   116                              <2>     push qword 0           ; Dummy error code
   117                              <2>     push qword %2          ; Interrupt vector number
   118                              <2>     jmp irq_common_stub
   119                              <2> %endmacro
   120                              <2> 
   121                              <2> %endif
     9                              <1> 
    10                              <1> MAX_PROCESSES   equ 8
    11                              <1> PROCESS_POOL    equ 0x220000     ; 8 * 512 bytes = 4KB
    12                              <1> 
    13                              <1> GDT64_CODE_SEG    equ 0x08
    14                              <1> GDT64_DATA_SEG    equ 0x10
    15                              <1> GDT64_USER_DATA   equ 0x23
