    18                              <1> ; ============================================================================
    19                              <1> ; HID Item Tag constants (byte & 0xFC to mask off bSize)
    20                              <1> ; ============================================================================
    21                              <1> HID_USAGE_PAGE      equ 0x04    ; Global: Usage Page
    22                              <1> HID_LOGICAL_MIN     equ 0x14    ; Global: Logical Minimum
    23                              <1> HID_LOGICAL_MAX     equ 0x24    ; Global: Logical Maximum
    24                              <1> HID_PHYSICAL_MIN    equ 0x34    ; Global: Physical Minimum
    25                              <1> HID_PHYSICAL_MAX    equ 0x44    ; Global: Physical Maximum
    26                              <1> HID_REPORT_SIZE     equ 0x74    ; Global: Report Size (bits per field)
    27                              <1> HID_REPORT_ID       equ 0x84    ; Global: Report ID
    28                              <1> HID_REPORT_COUNT    equ 0x94    ; Global: Report Count (number of fields)
    29                              <1> HID_USAGE           equ 0x08    ; Local: Usage
    30                              <1> HID_USAGE_MIN       equ 0x18    ; Local: Usage Minimum
    31                              <1> HID_USAGE_MAX       equ 0x28    ; Local: Usage Maximum
    32                              <1> HID_INPUT           equ 0x80    ; Main: Input
    33                              <1> HID_COLLECTION      equ 0xA0   ; Main: Collection
    34                              <1> HID_END_COLLECTION  equ 0xC0   ; Main: End Collection
    35                              <1> 
