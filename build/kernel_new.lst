   761                              <1> ; ============================================================================
   762                              <1> ; xhci_submit_cmd - Submit a TRB to command ring and wait for completion
   763                              <1> ; Input: R8 = dword0, R9 = dword1, R10 = dword2, R11 = dword3 (type|flags, no cycle)
   764                              <1> ; Returns: EAX = completion code (1=success), 0 on timeout
   765                              <1> ;          RBX = completion TRB dword3 (contains slot ID etc)
   766                              <1> ; ============================================================================
   767                              <1> global xhci_submit_cmd
   768                              <1> xhci_submit_cmd:
   769                              <1>     ; NOTE: RBX is a return value (DWord3 of completion event) - do NOT save/restore it
   770 00003F3B 51                  <1>     push rcx
   771 00003F3C 52                  <1>     push rdx
   772 00003F3D 56                  <1>     push rsi
   773 00003F3E 57                  <1>     push rdi
   774                              <1> 
   775                              <1>     ; Get enqueue pointer
   776 00003F3F 8B3D(8A050000)      <1>     mov edi, [xhci_cmd_enqueue]
   777                              <1> 
   778                              <1>     ; Check for Link TRB (entry 255)
   779 00003F45 81FFFF0F0000        <1>     cmp edi, XHCI_RING_SIZE - 1
   780 00003F4B 7C3C                <1>     jl .no_wrap
   781                              <1> 
   782                              <1>     ; We hit the Link TRB - toggle cycle and wrap
   783                              <1>     
   784                              <1>     ; Debug: 'C'
   785 00003F4D 50                  <1>     push rax
   786 00003F4E 52                  <1>     push rdx
   787 00003F4F 66BAF803            <1>     mov dx, 0x3F8
   788 00003F53 B043                <1>     mov al, 'C'
   789 00003F55 EE                  <1>     out dx, al
   790 00003F56 5A                  <1>     pop rdx
   791 00003F57 58                  <1>     pop rax
   792                              <1>     
   793                              <1>     ; Update Link TRB cycle bit
   794 00003F58 BE00009100          <1>     mov rsi, XHCI_CMD_RING_ADDR
   795 00003F5D 488D86F0FF0000      <1>     lea rax, [rsi + (XHCI_RING_SIZE - 1) * XHCI_TRB_SIZE]
   796 00003F64 8B480C              <1>     mov ecx, [rax + 12]
   797                              <1>     ; Set/clear cycle bit based on current cmd_cycle
   798 00003F67 83E1FE              <1>     and ecx, ~1                   ; Clear cycle
   799 00003F6A 0FB615(8E050000)    <1>     movzx edx, byte [xhci_cmd_cycle]
   800 00003F71 09D1                <1>     or ecx, edx
   801 00003F73 89480C              <1>     mov [rax + 12], ecx
   802                              <1> 
   803                              <1>     ; Toggle cycle
   804 00003F76 8035(8E050000)01    <1>     xor byte [xhci_cmd_cycle], 1
   805 00003F7D C705(8A050000)0000- <1>     mov dword [xhci_cmd_enqueue], 0
   805 00003F85 0000                <1>
   806 00003F87 31FF                <1>     xor edi, edi
   807                              <1> 
   808                              <1> .no_wrap:
   809                              <1>     ; Write TRB at enqueue position
   810 00003F89 BE00009100          <1>     mov rsi, XHCI_CMD_RING_ADDR
   811 00003F8E 6BC710              <1>     imul eax, edi, XHCI_TRB_SIZE
   812 00003F91 4801C6              <1>     add rsi, rax
   813                              <1> 
   814 00003F94 448906              <1>     mov [rsi + 0], r8d            ; DWord 0
   815 00003F97 44894E04            <1>     mov [rsi + 4], r9d            ; DWord 1
   816 00003F9B 44895608            <1>     mov [rsi + 8], r10d           ; DWord 2
   817                              <1>     ; DWord 3: OR in cycle bit
   818 00003F9F 4489D8              <1>     mov eax, r11d
   819 00003FA2 0FB60D(8E050000)    <1>     movzx ecx, byte [xhci_cmd_cycle]
   820 00003FA9 09C8                <1>     or eax, ecx
   821 00003FAB 89460C              <1>     mov [rsi + 12], eax
   822                              <1> 
   823                              <1>     ; Advance enqueue
