    58                              <1> ; --- Set pixel ---
    59                              <1> ; EDI = x, ESI = y, EDX = color (0x00RRGGBB)
    60                              <1> global pixel_set
    61                              <1> pixel_set:
    62 00002561 50                  <1>     push rax
    63 00002562 53                  <1>     push rbx
    64                              <1>     ; Bounds check
    65 00002563 83FF00              <1>     cmp edi, 0
