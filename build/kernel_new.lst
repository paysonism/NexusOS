   825 00003FB0 893D(8A050000)      <1>     mov [xhci_cmd_enqueue], edi
   826                              <1> 
   827                              <1>     ; Ring doorbell 0 (host controller command)
   828 00003FB6 488B35(64050000)    <1>     mov rsi, [xhci_db_base]
   829 00003FBD C70600000000        <1>     mov dword [rsi], 0
   830                              <1> 
   831                              <1>     ; Serial: 'v' = doorbell rung
   832 00003FC3 50                  <1>     push rax
   833 00003FC4 52                  <1>     push rdx
   834 00003FC5 66BAF803            <1>     mov dx, 0x3F8
   835 00003FC9 B076                <1>     mov al, 'v'
   836 00003FCB EE                  <1>     out dx, al
   837 00003FCC 5A                  <1>     pop rdx
   838 00003FCD 58                  <1>     pop rax
   839                              <1> 
   840                              <1>     ; Poll event ring for Command Completion (PIT-based 2-second timeout + spin fallback)
   841 00003FCE 488B05(F0000000)    <1>     mov rax, [tick_count]
   842 00003FD5 4805C8000000        <1>     add rax, 200                  ; 200 ticks = 2 seconds at 100Hz
   843 00003FDB 488905(8F050000)    <1>     mov [xhci_cmd_deadline], rax  ; store deadline (not rbx - rbx is return value)
   844 00003FE2 B9005A6202          <1>     mov ecx, 40000000             ; ~20M iterations spin fallback
   845                              <1> .poll:
   846 00003FE7 51                  <1>     push rcx
   847 00003FE8 E85F000000          <1>     call xhci_poll_event
   848 00003FED 59                  <1>     pop rcx
   849 00003FEE 85C0                <1>     test eax, eax
   850 00003FF0 7530                <1>     jnz .got_event
   851                              <1> 
   852 00003FF2 FFC9                <1>     dec ecx
   853 00003FF4 741D                <1>     jz .cmd_fail_spin
   854                              <1> 
   855 00003FF6 488B05(F0000000)    <1>     mov rax, [tick_count]
   856 00003FFD 483B05(8F050000)    <1>     cmp rax, [xhci_cmd_deadline]
   857 00004004 7CE1                <1>     jl .poll
   858                              <1> 
   859                              <1>     ; PIT timeout
   860 00004006 50                  <1>     push rax
   861 00004007 52                  <1>     push rdx
   862 00004008 66BAF803            <1>     mov dx, 0x3F8
   863 0000400C B05A                <1>     mov al, 'Z'
   864 0000400E EE                  <1>     out dx, al
   865 0000400F 5A                  <1>     pop rdx
   866 00004010 58                  <1>     pop rax
   867 00004011 EB0B                <1>     jmp .cmd_fail
   868                              <1> 
   869                              <1> .cmd_fail_spin:
   870                              <1>     ; Spin counter timeout
   871 00004013 50                  <1>     push rax
   872 00004014 52                  <1>     push rdx
   873 00004015 66BAF803            <1>     mov dx, 0x3F8
   874 00004019 B07A                <1>     mov al, 'z'
   875 0000401B EE                  <1>     out dx, al
   876 0000401C 5A                  <1>     pop rdx
   877 0000401D 58                  <1>     pop rax
   878                              <1> 
   879                              <1> .cmd_fail:
   880                              <1>     ; Timeout
   881 0000401E 31C0                <1>     xor eax, eax
   882 00004020 EB25                <1>     jmp .cmd_ret
   883                              <1> 
   884                              <1> .got_event:
   885                              <1>     ; EAX = completion code, EBX = dword3
   886                              <1>     ; Check TRB type in dword3 - should be CMD_COMPLETION
   887 00004022 89D9                <1>     mov ecx, ebx
   888 00004024 81E100FC0000        <1>     and ecx, (0x3F << 10)         ; Type mask
   889 0000402A 81F900840000        <1>     cmp ecx, TRB_CMD_COMPLETION
   890 00004030 75B5                <1>     jne .poll                     ; Not our event, keep polling
   891                              <1> 
   892                              <1>     ; Serial: print completion code digit
   893 00004032 50                  <1>     push rax
   894 00004033 52                  <1>     push rdx
   895 00004034 66BAF803            <1>     mov dx, 0x3F8
   896 00004038 50                  <1>     push rax
   897 00004039 240F                <1>     and al, 0x0F
   898 0000403B 0430                <1>     add al, '0'
   899 0000403D 3C39                <1>     cmp al, '9'
   900 0000403F 7E02                <1>     jle .cc_ok
   901 00004041 0407                <1>     add al, 7
   902                              <1> .cc_ok:
   903 00004043 EE                  <1>     out dx, al
   904 00004044 58                  <1>     pop rax
   905 00004045 5A                  <1>     pop rdx
   906 00004046 58                  <1>     pop rax
   907                              <1> 
   908                              <1>     ; Return completion code
   909                              <1>     ; (already in EAX from xhci_poll_event)
   910                              <1> 
   911                              <1> .cmd_ret:
   912 00004047 5F                  <1>     pop rdi
   913 00004048 5E                  <1>     pop rsi
   914 00004049 5A                  <1>     pop rdx
   915 0000404A 59                  <1>     pop rcx
   916                              <1>     ; NOTE: rbx is NOT restored - it holds the return value (DWord3 of completion event)
   917 0000404B C3                  <1>     ret
   918                              <1> 
   919                              <1> ; ============================================================================
   920                              <1> ; xhci_poll_event - Check event ring for one event
   921                              <1> ; Returns: EAX = completion code (0 if no event), EBX = dword3, ECX = dword0
   922                              <1> ; ============================================================================
   923                              <1> global xhci_poll_event
   924                              <1> xhci_poll_event:
   925 0000404C 56                  <1>     push rsi
   926 0000404D 57                  <1>     push rdi
   927                              <1> 
   928 0000404E 8B3D(97050000)      <1>     mov edi, [xhci_evt_dequeue]
   929 00004054 BE00009300          <1>     mov rsi, XHCI_EVT_RING_ADDR
   930 00004059 6BC710              <1>     imul eax, edi, XHCI_TRB_SIZE
   931 0000405C 4801C6              <1>     add rsi, rax
   932                              <1> 
   933                              <1>     ; Check cycle bit
   934 0000405F 8B460C              <1>     mov eax, [rsi + 12]
   935 00004062 89C3                <1>     mov ebx, eax
   936 00004064 83E001              <1>     and eax, 1                    ; Cycle bit of TRB
   937 00004067 0FB60D(9B050000)    <1>     movzx ecx, byte [xhci_evt_cycle]
   938 0000406E 39C8                <1>     cmp eax, ecx
   939 00004070 7553                <1>     jne .no_event                 ; Cycle doesn't match, no new event
   940                              <1> 
   941                              <1>     ; We have an event!
   942 00004072 8B0E                <1>     mov ecx, [rsi + 0]            ; DWord 0 (TRB pointer low or slot-specific)
   943 00004074 8B5E0C              <1>     mov ebx, [rsi + 12]           ; DWord 3 (type, slot ID, etc.)
   944                              <1> 
   945                              <1>     ; Completion code from DWord 2, bits 31:24
   946 00004077 8B4608              <1>     mov eax, [rsi + 8]
   947 0000407A C1E818              <1>     shr eax, 24                   ; Completion code
   948                              <1> 
   949                              <1>     ; Advance dequeue
   950 0000407D FFC7                <1>     inc edi
   951 0000407F 81FF00100000        <1>     cmp edi, XHCI_RING_SIZE
   952 00004085 7C14                <1>     jl .no_evt_wrap
   953 00004087 31FF                <1>     xor edi, edi
   954 00004089 8035(9B050000)01    <1>     xor byte [xhci_evt_cycle], 1  ; Toggle cycle on wrap
   955                              <1>     
   956                              <1>     ; Debug: 'W' (Event Wrap)
   957 00004090 50                  <1>     push rax
   958 00004091 52                  <1>     push rdx
   959 00004092 66BAF803            <1>     mov dx, 0x3F8
   960 00004096 B057                <1>     mov al, 'W'
   961 00004098 EE                  <1>     out dx, al
   962 00004099 5A                  <1>     pop rdx
   963 0000409A 58                  <1>     pop rax
   964                              <1> 
   965                              <1> .no_evt_wrap:
   966 0000409B 893D(97050000)      <1>     mov [xhci_evt_dequeue], edi
   967                              <1> 
   968                              <1>     ; Update ERDP
   969 000040A1 50                  <1>     push rax
   970 000040A2 53                  <1>     push rbx
