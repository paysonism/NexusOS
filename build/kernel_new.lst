  1896 000048DD 66BAF803            <1>     mov dx, 0x3F8
  1897 000048E1 EE                  <1>     out dx, al
  1898 000048E2 5A                  <1>     pop rdx
  1899 000048E3 59                  <1>     pop rcx
  1900 000048E4 5B                  <1>     pop rbx
  1901 000048E5 58                  <1>     pop rax
  1902 000048E6 C3                  <1>     ret
