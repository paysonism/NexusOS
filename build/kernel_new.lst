   599 00009BD9 4C89E8              <1>     mov rax, r13
   600 00009BDC 4869C000010000      <1>     imul rax, WINDOW_STRUCT_SIZE
   601 00009BE3 480500007100        <1>     add rax, WINDOW_POOL_ADDR
