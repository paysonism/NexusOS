  2049 00000699 E869000000          <1>     call .writehex8
  2050                              <1> 
  2051                              <1>     ; EVT Ring
  2052 0000069E 488D35FC000000      <1>     lea rsi, [.s_evt]
  2053 000006A5 E850000000          <1>     call .copystr
  2054 000006AA 8B05E7FEFFFF        <1>     mov eax, [xhci_evt_dequeue]
  2055 000006B0 E852000000          <1>     call .writehex8
  2056 000006B5 C6033A              <1>     mov byte [rbx], ':'
  2057 000006B8 48FFC3              <1>     inc rbx
  2058 000006BB 0FB605D9FEFFFF      <1>     movzx eax, byte [xhci_evt_cycle]
  2059 000006C2 E840000000          <1>     call .writehex8
  2060                              <1> 
  2061                              <1>     ; INT Ring
  2062 000006C7 488D35D7000000      <1>     lea rsi, [.s_int]
  2063 000006CE E827000000          <1>     call .copystr
  2064 000006D3 8B05C8FEFFFF        <1>     mov eax, [xhci_int_enqueue]
  2065 000006D9 E829000000          <1>     call .writehex8
  2066 000006DE C6033A              <1>     mov byte [rbx], ':'
  2067 000006E1 48FFC3              <1>     inc rbx
  2068 000006E4 0FB605BAFEFFFF      <1>     movzx eax, byte [xhci_int_cycle]
  2069 000006EB E817000000          <1>     call .writehex8
  2070                              <1> 
  2071                              <1>     ; Null terminate
  2072 000006F0 C60300              <1>     mov byte [rbx], 0
  2073                              <1> 
  2074 000006F3 5A                  <1>     pop rdx
  2075 000006F4 59                  <1>     pop rcx
  2076 000006F5 5B                  <1>     pop rbx
  2077 000006F6 58                  <1>     pop rax
  2078 000006F7 5E                  <1>     pop rsi
  2079 000006F8 5F                  <1>     pop rdi
  2080 000006F9 C3                  <1>     ret
  2081                              <1> 
  2082                              <1> ; -- internal helpers --
  2083                              <1> .copystr:
  2084 000006FA AC                  <1>     lodsb
