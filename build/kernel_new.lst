   582                              <1> .shift:
   583                              <1>     ; Shift right by bit offset within byte
   584 00006AFA D3E8                <1>     shr eax, cl
   585                              <1> 
   586                              <1>     ; Mask to field size
   587 00006AFC 4489C1              <1>     mov ecx, r8d
   588 00006AFF 83F920              <1>     cmp ecx, 32
   589 00006B02 7D0B                <1>     jge .no_mask
   590 00006B04 BA01000000          <1>     mov edx, 1
   591 00006B09 D3E2                <1>     shl edx, cl
   592 00006B0B FFCA                <1>     dec edx                     ; mask = (1 << size) - 1
   593 00006B0D 21D0                <1>     and eax, edx
   594                              <1> .no_mask:
   595                              <1> 
   596 00006B0F 5E                  <1>     pop rsi
   597 00006B10 5A                  <1>     pop rdx
   598 00006B11 59                  <1>     pop rcx
   599 00006B12 5B                  <1>     pop rbx
   600 00006B13 C3                  <1>     ret
   601                              <1> 
   602                              <1> ; ============================================================================
   603                              <1> ; hid_extract_field_signed - Extract a signed field value
   604                              <1> ; Same as hid_extract_field but sign-extends the result
