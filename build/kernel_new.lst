   108 00007930 418B7004            <1>     mov esi, [r8 + 4]
   109 00007934 418B5008            <1>     mov edx, [r8 + 8]
   110 00007938 418B480C            <1>     mov ecx, [r8 + 12]
   111 0000793C E80FB1FFFF          <1>     call display_flip_rect
   112 00007941 58                  <1>     pop rax
   113                              <1> 
   114 00007942 FFC0                <1>     inc eax
   115 00007944 EBD8                <1>     jmp .flush_loop
   116                              <1> 
   117                              <1> .do_full:
   118 00007946 E858B0FFFF          <1>     call display_flip
   119 0000794B C605(E70E0000)00    <1>     mov byte [full_redraw], 0
   120                              <1> 
   121                              <1> .flush_done:
   122                              <1>     ; Reset dirty count
   123 00007952 C705(E30E0000)0000- <1>     mov dword [dirty_count], 0
   123 0000795A 0000                <1>
   124                              <1> 
   125 0000795C 5F                  <1>     pop rdi
   126 0000795D 5E                  <1>     pop rsi
   127 0000795E 5A                  <1>     pop rdx
   128 0000795F 59                  <1>     pop rcx
   129 00007960 5B                  <1>     pop rbx
   130 00007961 58                  <1>     pop rax
   131 00007962 C3                  <1>     ret
