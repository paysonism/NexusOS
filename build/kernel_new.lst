   150                              <1> 
   151 0000262D 486335(56020000)    <1>     movsxd rsi, dword [scr_pitch]
   152                              <1> 
   153                              <1>     ; Simple robust fill using rep stosd
   154 00002634 4889DF              <1>     mov rdi, rbx             ; RDI = starting address in back buffer
