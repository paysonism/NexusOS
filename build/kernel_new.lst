   703                              <1> ; ============================================================================
   704                              <1> ; xhci_setup_cmd_ring - Initialize Command Ring
   705                              <1> ; ============================================================================
   706                              <1> xhci_setup_cmd_ring:
   707 00003EAE 57                  <1>     push rdi
   708                              <1> 
   709                              <1>     ; Command Ring at XHCI_CMD_RING_ADDR, already zeroed
   710                              <1>     ; Set last TRB as Link TRB pointing back to start
   711 00003EAF BF00009100          <1>     mov rdi, XHCI_CMD_RING_ADDR
   712                              <1>     ; Link TRB at entry 255 (offset 255 * 16)
   713 00003EB4 488D87F0FF0000      <1>     lea rax, [rdi + (XHCI_RING_SIZE - 1) * XHCI_TRB_SIZE]
   714                              <1>     ; DWord 0-1: Ring Segment Pointer (64-bit) = start of ring
   715 00003EBB 48C70000009100      <1>     mov qword [rax], XHCI_CMD_RING_ADDR
   716                              <1>     ; DWord 2: 0 (Interrupter Target)
   717 00003EC2 C7400800000000      <1>     mov dword [rax + 8], 0
   718                              <1>     ; DWord 3: Type=Link (6), TC=1 (Toggle Cycle), Cycle=1
   719 00003EC9 C7400C03180000      <1>     mov dword [rax + 12], TRB_LINK | TRB_TC | TRB_CYCLE
   720                              <1> 
   721                              <1>     ; Initialize cmd ring state
   722 00003ED0 C705(8A050000)0000- <1>     mov dword [xhci_cmd_enqueue], 0
   722 00003ED8 0000                <1>
   723 00003EDA C605(8E050000)01    <1>     mov byte [xhci_cmd_cycle], 1
   724                              <1> 
   725 00003EE1 5F                  <1>     pop rdi
   726 00003EE2 C3                  <1>     ret
   727                              <1> 
   728                              <1> ; ============================================================================
   729                              <1> ; xhci_setup_event_ring - Initialize Event Ring and ERST
   730                              <1> ; ============================================================================
   731                              <1> xhci_setup_event_ring:
   732 00003EE3 56                  <1>     push rsi
   733                              <1> 
   734                              <1>     ; ERST entry 0: base = event ring address, size = 256
   735 00003EE4 BF00009200          <1>     mov rdi, XHCI_ERST_ADDR
   736 00003EE9 48C70700009300      <1>     mov qword [rdi + 0], XHCI_EVT_RING_ADDR    ; Ring Segment Base Address
   737 00003EF0 C7470800100000      <1>     mov dword [rdi + 8], XHCI_RING_SIZE         ; Ring Segment Size
   738 00003EF7 C7470C00000000      <1>     mov dword [rdi + 12], 0                      ; Reserved
   739                              <1> 
   740                              <1>     ; Initialize event ring state
   741 00003EFE C705(97050000)0000- <1>     mov dword [xhci_evt_dequeue], 0
   741 00003F06 0000                <1>
   742 00003F08 C605(9B050000)01    <1>     mov byte [xhci_evt_cycle], 1
   743                              <1> 
   744                              <1>     ; Program Runtime Registers for Interrupter 0
   745 00003F0F 488B35(6C050000)    <1>     mov rsi, [xhci_rt_base]
   746                              <1> 
   747                              <1>     ; ERSTSZ = 1
   748 00003F16 C7462801000000      <1>     mov dword [rsi + XHCI_RT_IR0_ERSTSZ], 1
   749                              <1> 
   750                              <1>     ; ERDP = event ring start
   751 00003F1D C7463800009300      <1>     mov dword [rsi + XHCI_RT_IR0_ERDP_LO], XHCI_EVT_RING_ADDR
   752 00003F24 C7463C00000000      <1>     mov dword [rsi + XHCI_RT_IR0_ERDP_HI], 0
   753                              <1> 
   754                              <1>     ; ERSTBA = ERST address (must be written AFTER ERSTSZ)
   755 00003F2B C7463000009200      <1>     mov dword [rsi + XHCI_RT_IR0_ERSTBA_LO], XHCI_ERST_ADDR
   756 00003F32 C7463400000000      <1>     mov dword [rsi + XHCI_RT_IR0_ERSTBA_HI], 0
   757                              <1> 
   758 00003F39 5E                  <1>     pop rsi
   759 00003F3A C3                  <1>     ret
