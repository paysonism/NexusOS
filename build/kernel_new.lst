   188                              <1> ; ============================================================================
   189                              <1> ; Handle desktop clicks: RDI=mouseX, RSI=mouseY
   190                              <1> ; Returns RAX: 0=not handled, 1=handled
   191                              <1> ; ============================================================================
   192                              <1> desktop_handle_click:
   193 000090E4 53                  <1>     push rbx
   194 000090E5 4154                <1>     push r12
   195 000090E7 4155                <1>     push r13
   196                              <1> 
   197                              <1>     ; Close start menu
