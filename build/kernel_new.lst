    55                              <1> ; l3_prepare_test_callback - copy demo user code into slot app arena
    56                              <1> ; EDI = slot, RAX = entry pointer in APP_DATA space
    57                              <1> l3_prepare_test_callback:
    58 000013B1 89F8                <1>     mov eax, edi
    59 000013B3 4869C000000100      <1>     imul rax, APP_SLOT_SIZE
    60 000013BA 480500008000        <1>     add rax, APP_DATA_ADDR
    61 000013C0 4889C7              <1>     mov rdi, rax
    62 000013C3 4989C0              <1>     mov r8, rax
    63 000013C6 488D3506040000      <1>     lea rsi, [rel l3_test_blob]
    64 000013CD B926000000          <1>     mov ecx, l3_test_blob_end - l3_test_blob
    65 000013D2 F3A4                <1>     rep movsb
    66 000013D4 4C89C0              <1>     mov rax, r8
    67 000013D7 C3                  <1>     ret
