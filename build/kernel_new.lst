   199                              <1> 
   200                              <1>     ; Check if click is in icon column
   201 000090F0 83FF18              <1>     cmp edi, ICON_X
   202 000090F3 7C4D                <1>     jl .click_none
   203 000090F5 83FF48              <1>     cmp edi, ICON_X + ICON_SIZE
   204 000090F8 7F48                <1>     jg .click_none
   205                              <1> 
   206                              <1>     ; Find which icon slot
   207 000090FA 4531E4              <1>     xor r12d, r12d
   208 000090FD 41BD18000000        <1>     mov r13d, ICON_BASE_Y
   209                              <1> 
