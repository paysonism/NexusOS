   151 000014A6 4C89C6              <1>     mov rsi, r8
   152 000014A9 B9D8020000          <1>     mov ecx, app_terminal_blob_end - app_terminal_draw
   153 000014AE FC                  <1>     cld
   154 000014AF F3A4                <1>     rep movsb
   155 000014B1 4889D0              <1>     mov rax, rdx
   156 000014B4 4C29C0              <1>     sub rax, r8
   157 000014B7 5E                  <1>     pop rsi
