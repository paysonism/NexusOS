   115                              <1>     
   116 000018F2 4489EF              <1>     mov edi, r13d
   117 000018F5 E832FBFFFF          <1>     call l3_syscall_stack_top
   118 000018FA 488983B8000000      <1>     mov [rbx + process_t.kernel_rsp], rax
   119                              <1>     
   120                              <1>     ; Setup Selectors and RFLAGS
