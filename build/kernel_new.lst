    30                              <1> ; Battery indicator layout (to the left of the clock)
    31                              <1> BAT_IND_W       equ 88           ; total width of battery area
    32                              <1> BAT_IND_X       equ (CLOCK_X - BAT_IND_W - 6)
    33                              <1> BAT_IND_Y       equ (TASKBAR_Y + 4)
    34                              <1> BAT_IND_H       equ (TASKBAR_HEIGHT - 8)
    35                              <1> 
    36                              <1> ; Battery state constants (must match battery.asm)
    37                              <1> BAT_STATE_UNKNOWN   equ 0
