    40                              <1> ; SPI-HID packet constants
    41                              <1> SPI_SYNC_HOST       equ 0xFF    ; host->device sync byte
    42                              <1> SPI_SYNC_DEV        equ 0x80    ; device->host sync byte (when data ready)
    43                              <1> SPI_SYNC_IDLE       equ 0x00    ; bus idle
    44                              <1> 
    45                              <1> SPI_CID_OUTPUT      equ 0x0F    ; input report request
    46                              <1> SPI_CID_RESET       equ 0x04    ; reset/command
    47                              <1> SPI_CID_DESC        equ 0x05    ; device descriptor
    48                              <1> 
    49                              <1> ; Poll state
    50                              <1> SPI_STATE_IDLE      equ 0
    51                              <1> SPI_STATE_WAIT      equ 1       ; waiting for device ready
    52                              <1> 
    53                              <1> section .text
    54                              <1> global spi_hid_init
    55                              <1> global spi_hid_poll
    56                              <1> 
    57                              <1> ; ============================================================================
    58                              <1> ; spi_hid_init - Initialize SPI HID touchpad
    59                              <1> ; Returns: EAX = 1 if found and initialized, 0 otherwise
    60                              <1> ; ============================================================================
    61                              <1> spi_hid_init:
    62 000058B0 53                  <1>     push rbx
    63 000058B1 51                  <1>     push rcx
    64 000058B2 52                  <1>     push rdx
    65 000058B3 57                  <1>     push rdi
    66 000058B4 56                  <1>     push rsi
    67                              <1> 
    68 000058B5 C605(0B090000)00    <1>     mov byte [spi_hid_active], 0
    69 000058BC C605(0C090000)00    <1>     mov byte [spi_poll_state], SPI_STATE_IDLE
    70                              <1> 
    71                              <1>     ; Init SPI controller
    72 000058C3 E8A1FDFFFF          <1>     call spi_init
    73 000058C8 85C0                <1>     test eax, eax
    74 000058CA 742A                <1>     jz .fail
    75                              <1> 
    76                              <1>     ; Send reset
    77 000058CC E82D000000          <1>     call spi_hid_send_reset
    78                              <1>     ; Wait for device ready (~20ms equivalent in loops)
    79 000058D1 B980841E00          <1>     mov ecx, 2000000
    80                              <1> .reset_wait:
    81 000058D6 FFC9                <1>     dec ecx
    82 000058D8 75FC                <1>     jnz .reset_wait
    83                              <1> 
    84                              <1>     ; Fetch HID device descriptor
    85 000058DA E863000000          <1>     call spi_hid_get_device_desc
    86 000058DF 85C0                <1>     test eax, eax
    87 000058E1 7413                <1>     jz .fail
    88                              <1> 
    89                              <1>     ; Fetch and parse HID report descriptor
