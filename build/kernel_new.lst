    52                              <1> 
    53                              <1> ; Input item flags
    54                              <1> HID_INPUT_CONSTANT  equ (1 << 0)   ; 0=Data, 1=Constant
    55                              <1> HID_INPUT_VARIABLE  equ (1 << 1)   ; 0=Array, 1=Variable
    56                              <1> HID_INPUT_RELATIVE  equ (1 << 2)   ; 0=Absolute, 1=Relative
