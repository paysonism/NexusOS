  1285 0000093C 14                  <1>     db 0x14             ; Goodix
  1286 0000093D 5D                  <1>     db 0x5D             ; Goodix alternate
  1287 0000093E 2A                  <1>     db 0x2A             ; Synaptics secondary
  1288 0000093F 3C                  <1>     db 0x3C             ; ALPS I2C-HID
  1289 00000940 20                  <1>     db 0x20             ; Pixart
  1290 00000941 34                  <1>     db 0x34             ; FocalTech
  1291 00000942 16                  <1>     db 0x16             ; ELAN variant 2
  1292 00000943 2D                  <1>     db 0x2D             ; Synaptics variant
  1293                              <1> I2C_TP_ADDR_COUNT   equ ($ - i2c_tp_addrs)
  1294                              <1> 
  1295                              <1> ; I2C-HID state
  1296                              <1> global i2c_hid_active
  1297 00000944 00                  <1> i2c_hid_active:     db 0
  1298 00000945 00                  <1> i2c_dev_addr:       db 0
  1299 00000946 00                  <1> i2c_poll_state:     db 0        ; 0=issue, 1=read header, 2=read data
  1300 00000947 00                  <1> i2c_is_intel:       db 0        ; 1 if controller found via PCI (Intel LPSS)
  1301 00000948 00                  <1> i2c_use_parsed:     db 0        ; 1 if HID report descriptor was parsed successfully
  1302 00000949 0000000000000000    <1> i2c_base_addr:      dq 0
  1303 00000951 0000                <1> i2c_hid_desc_len:   dw 0
  1304 00000953 00000000            <1> i2c_error_count:    dd 0        ; consecutive error counter for bus reset
  1305 00000957 0000                <1> i2c_pending_len:    dw 0        ; bytes pending in state 2
  1306                              <1> 
  1307                              <1> ; I2C-HID register addresses (from HID descriptor, with defaults)
  1308 00000959 0500                <1> i2c_hid_cmd_reg:    dw 0x0005
  1309 0000095B 0300                <1> i2c_hid_input_reg:  dw 0x0003
  1310 0000095D 0700                <1> i2c_hid_data_reg:   dw 0x0007
  1311 0000095F 4000                <1> i2c_max_input_len:  dw 64       ; wMaxInputLength from descriptor
  1312                              <1> 
  1313                              <1> ; Report descriptor info
  1314 00000961 0000                <1> i2c_report_desc_len:    dw 0    ; wReportDescLength
  1315 00000963 0000                <1> i2c_report_desc_reg:    dw 0    ; wReportDescRegister
  1316 00000965 0000                <1> i2c_rdesc_read_len:     dw 0    ; actual bytes to read
  1317                              <1> 
  1318                              <1> ; Buffers
  1319 00000967 00<rep 20h>         <1> i2c_desc_buf:       times 32 db 0   ; Raw HID descriptor (30 bytes)
  1320 00000987 00<rep 100h>        <1> i2c_report_buf:     times 256 db 0  ; Input report buffer (variable length)
  1321                              <1> 
  1322                              <1> I2C_RDESC_BUF_SIZE  equ 512
  1323 00000A87 00<rep 200h>        <1> i2c_rdesc_buf:      times I2C_RDESC_BUF_SIZE db 0  ; Report descriptor buffer
  1324                              <1> 
