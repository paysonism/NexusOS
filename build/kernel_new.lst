   124 000025E0 4501D4              <1>     add r12d, r10d
   125 000025E3 4531D2              <1>     xor r10d, r10d
   126                              <1> .clip_bottom:
   127 000025E6 4489D0              <1>     mov eax, r10d
   128 000025E9 4401E0              <1>     add eax, r12d
   129 000025EC 3B05(52020000)      <1>     cmp eax, [scr_height]
   130 000025F2 7E0A                <1>     jle .clip_done
   131 000025F4 448B25(52020000)    <1>     mov r12d, [scr_height]
   132 000025FB 4529D4              <1>     sub r12d, r10d
   133                              <1> .clip_done:
   134                              <1>     ; Validate dimensions
   135 000025FE 4183FB00            <1>     cmp r11d, 0
   136 00002602 7E47                <1>     jle .rect_done
   137 00002604 4183FC00            <1>     cmp r12d, 0
   138 00002608 7E41                <1>     jle .rect_done
   139                              <1> 
   140                              <1>     ; Calculate starting offset
   141 0000260A 4489D0              <1>     mov eax, r10d
