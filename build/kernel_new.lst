   604 000029CD 660F6F4E10          <1>     movdqa xmm1, [rsi + 16]
   605 000029D2 660F6F5620          <1>     movdqa xmm2, [rsi + 32]
   606 000029D7 660F6F5E30          <1>     movdqa xmm3, [rsi + 48]
   607 000029DC 660F6F6640          <1>     movdqa xmm4, [rsi + 64]
   608 000029E1 660F6F6E50          <1>     movdqa xmm5, [rsi + 80]
   609 000029E6 660F6F7660          <1>     movdqa xmm6, [rsi + 96]
   610 000029EB 660F6F7E70          <1>     movdqa xmm7, [rsi + 112]
   611                              <1>     ; Store 128 bytes to VRAM (non-temporal, bypasses cache)
   612 000029F0 660FE707            <1>     movntdq [rdi], xmm0
