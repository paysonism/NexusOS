   558                              <1> ; ============================================================================
   559                              <1> ; app_open_file - Open a file, routing by extension
   560                              <1> ; RDI = pointer to FAT16 dir entry (32 bytes)
   561                              <1> ; ============================================================================
   562                              <1> global app_open_file
   563                              <1> app_open_file:
   564                              <1>     ; Check extension at entry+8 (3 bytes)
   565                              <1>     ; BMP files: extension = "BMP"
   566 00009B99 807F0842            <1>     cmp byte [rdi + 8], 'B'
   567 00009B9D 7511                <1>     jne .open_not_bmp
   568 00009B9F 807F094D            <1>     cmp byte [rdi + 9], 'M'
   569 00009BA3 750B                <1>     jne .open_not_bmp
   570 00009BA5 807F0A50            <1>     cmp byte [rdi + 10], 'P'
   571 00009BA9 7505                <1>     jne .open_not_bmp
   572 00009BAB E929280000          <1>     jmp app_open_file_in_bmpview
   573                              <1> .open_not_bmp:
   574 00009BB0 EB00                <1>     jmp app_open_file_in_notepad
