   134                              <1> ; --- itoa: Convert integer to ASCII string ---
   135                              <1> ; RDI = value (unsigned 64-bit), RSI = buffer, EDX = radix (10 or 16)
   136                              <1> ; Returns: RAX = pointer to buffer
   137                              <1> global fn_itoa
   138                              <1> fn_itoa:
   139 0000CE3A 53                  <1>     push rbx
   140 0000CE3B 51                  <1>     push rcx
   141 0000CE3C 57                  <1>     push rdi
   142 0000CE3D 56                  <1>     push rsi
   143 0000CE3E 4150                <1>     push r8
   144                              <1> 
   145 0000CE40 4889F8              <1>     mov rax, rdi             ; Value
   146 0000CE43 4989F0              <1>     mov r8, rsi              ; Buffer start
   147 0000CE46 4889F3              <1>     mov rbx, rsi             ; Working pointer
   148 0000CE49 89D1                <1>     mov ecx, edx             ; Radix
   149                              <1> 
   150                              <1>     ; Special case: 0
   151 0000CE4B 4885C0              <1>     test rax, rax
   152 0000CE4E 7508                <1>     jnz .itoa_loop
   153 0000CE50 C60330              <1>     mov byte [rbx], '0'
   154 0000CE53 48FFC3              <1>     inc rbx
   155 0000CE56 EB3C                <1>     jmp .itoa_terminate
   156                              <1> 
   157                              <1> .itoa_loop:
   158 0000CE58 4885C0              <1>     test rax, rax
   159 0000CE5B 7419                <1>     jz .itoa_reverse
   160 0000CE5D 31D2                <1>     xor edx, edx
   161 0000CE5F 48F7F1              <1>     div rcx                  ; RAX = quotient, RDX = remainder
   162 0000CE62 80FA0A              <1>     cmp dl, 10
   163 0000CE65 7C05                <1>     jl .digit
   164 0000CE67 80C237              <1>     add dl, 'A' - 10
   165 0000CE6A EB03                <1>     jmp .store
   166                              <1> .digit:
   167 0000CE6C 80C230              <1>     add dl, '0'
   168                              <1> .store:
   169 0000CE6F 8813                <1>     mov [rbx], dl
   170 0000CE71 48FFC3              <1>     inc rbx
   171 0000CE74 EBE2                <1>     jmp .itoa_loop
   172                              <1> 
   173                              <1> .itoa_reverse:
   174                              <1>     ; Null-terminate
   175 0000CE76 C60300              <1>     mov byte [rbx], 0
   176 0000CE79 48FFCB              <1>     dec rbx                  ; Point to last digit
   177                              <1> 
   178                              <1>     ; Reverse the string
   179 0000CE7C 4C89C7              <1>     mov rdi, r8              ; Start
   180                              <1> .rev_loop:
   181 0000CE7F 4839DF              <1>     cmp rdi, rbx
   182 0000CE82 7D13                <1>     jge .itoa_done
   183 0000CE84 8A07                <1>     mov al, [rdi]
   184 0000CE86 8A0B                <1>     mov cl, [rbx]
   185 0000CE88 880F                <1>     mov [rdi], cl
   186 0000CE8A 8803                <1>     mov [rbx], al
   187 0000CE8C 48FFC7              <1>     inc rdi
   188 0000CE8F 48FFCB              <1>     dec rbx
   189 0000CE92 EBEB                <1>     jmp .rev_loop
   190                              <1> 
   191                              <1> .itoa_terminate:
   192 0000CE94 C60300              <1>     mov byte [rbx], 0
   193                              <1> 
   194                              <1> .itoa_done:
   195 0000CE97 4C89C0              <1>     mov rax, r8              ; Return buffer pointer
   196                              <1> 
   197 0000CE9A 4158                <1>     pop r8
   198 0000CE9C 5E                  <1>     pop rsi
   199 0000CE9D 5F                  <1>     pop rdi
   200 0000CE9E 59                  <1>     pop rcx
   201 0000CE9F 5B                  <1>     pop rbx
   202 0000CEA0 C3                  <1>     ret
   203                              <1> 
   204                              <1> ; --- itoa_dec2: Format a number as 2-digit decimal with leading zero ---
   205                              <1> ; EDI = value (0-99), RSI = buffer (at least 3 bytes)
   206                              <1> global fn_itoa_dec2
   207                              <1> fn_itoa_dec2:
   208 0000CEA1 50                  <1>     push rax
   209 0000CEA2 52                  <1>     push rdx
   210                              <1> 
   211 0000CEA3 89F8                <1>     mov eax, edi
   212 0000CEA5 31D2                <1>     xor edx, edx
   213 0000CEA7 B90A000000          <1>     mov ecx, 10
   214 0000CEAC F7F1                <1>     div ecx                  ; EAX = tens, EDX = ones
   215                              <1> 
   216 0000CEAE 0430                <1>     add al, '0'
   217 0000CEB0 8806                <1>     mov [rsi], al
   218 0000CEB2 80C230              <1>     add dl, '0'
   219 0000CEB5 885601              <1>     mov [rsi + 1], dl
   220 0000CEB8 C6460200            <1>     mov byte [rsi + 2], 0
   221                              <1> 
   222 0000CEBC 5A                  <1>     pop rdx
   223 0000CEBD 58                  <1>     pop rax
   224 0000CEBE C3                  <1>     ret
   225                              <1> 
   226                              <1> ; --- uint32_to_str: Wrapper for fn_itoa (decimal) ---
   227                              <1> global uint32_to_str
   228                              <1> uint32_to_str:
   229 0000CEBF BA0A000000          <1>     mov edx, 10
   230 0000CEC4 E971FFFFFF          <1>     jmp fn_itoa
