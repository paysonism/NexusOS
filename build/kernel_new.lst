  1103 00007049 C605(810D0000)01    <1>     mov byte [gesture_swipe_dir], 1
  1104 00007050 8B1D(23050000)      <1>     mov ebx, [mouse_x]
  1105 00007056 891D(790D0000)      <1>     mov [gesture_scroll_ref_x], ebx
  1106 0000705C EB22                <1>     jmp .gesture_done
  1107                              <1> .swipe_left:
  1108 0000705E C605(810D0000)FF    <1>     mov byte [gesture_swipe_dir], -1
  1109 00007065 8B1D(23050000)      <1>     mov ebx, [mouse_x]
  1110 0000706B 891D(790D0000)      <1>     mov [gesture_scroll_ref_x], ebx
  1111 00007071 EB0D                <1>     jmp .gesture_done
  1112                              <1> .swipe_set_ref:
  1113 00007073 891D(790D0000)      <1>     mov [gesture_scroll_ref_x], ebx
  1114 00007079 C605(810D0000)00    <1>     mov byte [gesture_swipe_dir], 0
