    23                              <1> TB_BTN_Y        equ (TASKBAR_Y + 4)
    24                              <1> TB_CLOSE_SIZE   equ 14           ; X button size inside taskbar button
    25                              <1> TB_CLOSE_OFF_X  equ (TB_BTN_W - TB_CLOSE_SIZE - 4) ; X button offset from button left
    26                              <1> 
    27                              <1> WIN_OFF_FLAGS   equ 40
    28                              <1> WIN_OFF_TITLE   equ 48
