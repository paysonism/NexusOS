  1078                              <1> .check_3finger:
  1079                              <1>     ; Clear pinch distance when not 2 fingers
  1080 00007004 83F802              <1>     cmp eax, 2
  1081 00007007 7477                <1>     je .gesture_done
  1082 00007009 C705(7D0D0000)0000- <1>     mov dword [gesture_pinch_dist_prev], 0
  1082 00007011 0000                <1>
  1083 00007013 C705(820D0000)0000- <1>     mov dword [mouse_pinch_delta], 0
  1083 0000701B 0000                <1>
  1084                              <1> 
  1085                              <1>     ; --- 3-finger swipe detection ---
  1086 0000701D 83F803              <1>     cmp eax, 3
  1087 00007020 755E                <1>     jne .gesture_done
  1088                              <1>     ; Use finger0 X motion vs reference to detect swipe direction
  1089 00007022 803D(740D0000)01    <1>     cmp byte [gesture_scroll_active], 1
  1090 00007029 7455                <1>     je .gesture_done            ; don't swipe while scroll active
  1091 0000702B 8B1D(23050000)      <1>     mov ebx, [mouse_x]
  1092 00007031 8B0D(790D0000)      <1>     mov ecx, [gesture_scroll_ref_x]
  1093 00007037 85C9                <1>     test ecx, ecx
  1094 00007039 7438                <1>     jz .swipe_set_ref           ; first frame with 3 fingers
  1095 0000703B 29CB                <1>     sub ebx, ecx                ; ebx = X delta from ref
  1096                              <1>     ; Threshold: > 40px horizontal motion = swipe
  1097 0000703D 83FB28              <1>     cmp ebx, 40
  1098 00007040 7D07                <1>     jge .swipe_right
  1099 00007042 83FBD8              <1>     cmp ebx, -40
  1100 00007045 7E17                <1>     jle .swipe_left
  1101 00007047 EB37                <1>     jmp .gesture_done
