   170 0000264D 415C                <1>     pop r12
   171 0000264F 415B                <1>     pop r11
   172 00002651 415A                <1>     pop r10
   173 00002653 4159                <1>     pop r9
   174 00002655 5E                  <1>     pop rsi
   175 00002656 5F                  <1>     pop rdi
   176 00002657 5A                  <1>     pop rdx
