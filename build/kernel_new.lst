   611 00009BFF 488D35(EE9E0200)    <1>     lea rsi, [notepad_buf]   ; dest = notepad buffer
   612 00009C06 BAFF090000          <1>     mov rdx, NP_BUF_SIZE - 1 ; max bytes
   613                              <1>     SYS_FS_READ rdi, rsi, rdx
