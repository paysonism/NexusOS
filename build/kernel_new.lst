    91                              <1>     ; Ignore parse failure - will use fallback
    92                              <1> 
    93 000058E8 C605(0B090000)01    <1>     mov byte [spi_hid_active], 1
    94 000058EF B801000000          <1>     mov eax, 1
    95 000058F4 EB02                <1>     jmp .ret
    96                              <1> 
    97                              <1> .fail:
    98 000058F6 31C0                <1>     xor eax, eax
    99                              <1> .ret:
   100 000058F8 5E                  <1>     pop rsi
   101 000058F9 5F                  <1>     pop rdi
   102 000058FA 5A                  <1>     pop rdx
   103 000058FB 59                  <1>     pop rcx
   104 000058FC 5B                  <1>     pop rbx
   105 000058FD C3                  <1>     ret
