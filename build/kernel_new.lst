    81                              <1> ; --- Flush dirty rectangles to framebuffer ---
    82                              <1> render_flush:
    83 00007903 50                  <1>     push rax
    84 00007904 53                  <1>     push rbx
    85 00007905 51                  <1>     push rcx
    86 00007906 52                  <1>     push rdx
    87 00007907 56                  <1>     push rsi
