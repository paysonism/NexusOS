    37                              <1> UP_GENERIC_DESKTOP  equ 0x01
    38                              <1> UP_BUTTON           equ 0x09
    39                              <1> UP_DIGITIZER        equ 0x0D
    40                              <1> 
    41                              <1> ; Usages (Generic Desktop)
    42                              <1> USAGE_X             equ 0x30
    43                              <1> USAGE_Y             equ 0x31
    44                              <1> 
    45                              <1> ; Usages (Digitizer)
    46                              <1> USAGE_TIP_SWITCH    equ 0x42
    47                              <1> USAGE_CONTACT_ID    equ 0x51
    48                              <1> USAGE_CONTACT_COUNT equ 0x54
    49                              <1> USAGE_FINGER        equ 0x22
    50                              <1> USAGE_TOUCHPAD      equ 0x05
