   157 000079A6 660F7F4F10          <1>     movdqa [rdi + 16], xmm1
   158 000079AB 660F7F5720          <1>     movdqa [rdi + 32], xmm2
   159 000079B0 660F7F5F30          <1>     movdqa [rdi + 48], xmm3
   160 000079B5 660F7F6740          <1>     movdqa [rdi + 64], xmm4
   161 000079BA 660F7F6F50          <1>     movdqa [rdi + 80], xmm5
   162 000079BF 660F7F7760          <1>     movdqa [rdi + 96], xmm6
   163 000079C4 660F7F7F70          <1>     movdqa [rdi + 112], xmm7
   164 000079C9 4881C680000000      <1>     add rsi, 128
   165 000079D0 4881C780000000      <1>     add rdi, 128
   166 000079D7 FFC9                <1>     dec ecx
