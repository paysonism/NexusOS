   588                              <1> 
   589 00009BBA 4989FC              <1>     mov r12, rdi             ; save dir entry ptr
   590                              <1> 
   591                              <1>     ; Launch notepad (resets buffer) via syscall
   592 00009BBD BF04000000          <1>     mov rdi, APP_NOTEPAD
   593                              <1>     SYS_APP_LAUNCH rdi
    96 00009BC2 B80C000000          <2>  mov rax, 12
    97 00009BC7 4889FF              <2>  mov rdi, %1
