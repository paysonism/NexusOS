    28                                  %include "src/kernel/memory.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - Physical Page Allocator
     3                              <1> ; Bitmap-based, 4KB pages, initialized from E820 memory map
     4                              <1> ; ============================================================================
     5                              <1> bits 64
     6                              <1> 
     7                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> L3_SYSCALL_STACK_ADDR equ 0xC00000   ; Kernel-only syscall stacks
    33                              <2> 
    34                              <2> ; --- Stage 2 disk layout ---
    35                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    36                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    37                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    38                              <2> 
    39                              <2> ; --- Screen ---
    40                              <2> SCREEN_WIDTH        equ 1024
    41                              <2> SCREEN_HEIGHT       equ 768
    42                              <2> SCREEN_BPP          equ 32
    43                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    44                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    45                              <2> 
    46                              <2> 
    47                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    48                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    49                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    50                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    51                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    52                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    53                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    54                              <2> 
    55                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    56                              <2> COLOR_BLACK         equ 0x00000000
    57                              <2> COLOR_WHITE         equ 0x00FFFFFF
    58                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    59                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    60                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    61                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    62                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    63                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    64                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    65                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    66                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    67                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    68                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    69                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    70                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    71                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    72                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    73                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    74                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    75                              <2> COLOR_START_HOVER    equ 0x00338833
    76                              <2> 
    77                              <2> ; --- Window Manager ---
    78                              <2> MAX_WINDOWS         equ 8
    79                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    80                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    81                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    82                              <2> TITLEBAR_HEIGHT     equ 24
    83                              <2> BORDER_WIDTH        equ 2
    84                              <2> CLOSE_BTN_SIZE      equ 18
    85                              <2> MIN_BTN_SIZE        equ 18
    86                              <2> MIN_WINDOW_W        equ 200
    87                              <2> MIN_WINDOW_H        equ 100
    88                              <2> 
    89                              <2> ; --- Taskbar ---
    90                              <2> TASKBAR_HEIGHT      equ 36
    91                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    92                              <2> START_BTN_W         equ 70
    93                              <2> START_BTN_H         equ 28
    94                              <2> START_BTN_X         equ 4
    95                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    96                              <2> CLOCK_WIDTH         equ 64
    97                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    98                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    99                              <2> 
   100                              <2> ; --- Keyboard ---
   101                              <2> KB_BUFFER_SIZE      equ 64
   102                              <2> 
   103                              <2> ; --- Mouse ---
   104                              <2> MOUSE_BUFFER_SIZE   equ 64
   105                              <2> CURSOR_WIDTH        equ 12
   106                              <2> CURSOR_HEIGHT       equ 19
   107                              <2> 
   108                              <2> ; --- PIT ---
   109                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   110                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   111                              <2> 
   112                              <2> ; --- PIC vectors ---
   113                              <2> IRQ_BASE_MASTER     equ 32
   114                              <2> IRQ_BASE_SLAVE      equ 40
   115                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   116                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   117                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   118                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   119                              <2> 
   120                              <2> ; --- Font ---
   121                              <2> FONT_WIDTH          equ 8
   122                              <2> FONT_HEIGHT         equ 16
   123                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   124                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   125                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   126                              <2> 
   127                              <2> ; --- Window flags ---
   128                              <2> WF_VISIBLE          equ 0x01
   129                              <2> WF_FOCUSED          equ 0x02
   130                              <2> WF_DRAGGING         equ 0x04
   131                              <2> WF_MINIMIZED        equ 0x08
   132                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   133                              <2> 
   134                              <2> ; --- Mouse event types ---
   135                              <2> MEVT_MOVE           equ 1
   136                              <2> MEVT_LCLICK         equ 2
   137                              <2> MEVT_RCLICK         equ 3
   138                              <2> MEVT_LRELEASE       equ 4
   139                              <2> MEVT_RRELEASE       equ 5
   140                              <2> 
   141                              <2> ; --- Key modifier flags ---
   142                              <2> KMOD_SHIFT          equ 0x01
   143                              <2> KMOD_CTRL           equ 0x02
   144                              <2> KMOD_ALT            equ 0x04
   145                              <2> 
   146                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   147                              <2> KEY_F1              equ 0xF1
   148                              <2> KEY_F2              equ 0xF2
   149                              <2> KEY_F3              equ 0xF3
   150                              <2> KEY_F4              equ 0xF4
   151                              <2> KEY_F5              equ 0xF5
   152                              <2> KEY_F6              equ 0xF6
   153                              <2> KEY_F7              equ 0xF7
   154                              <2> KEY_F8              equ 0xF8
   155                              <2> KEY_F9              equ 0xF9
   156                              <2> KEY_F10             equ 0xFA
   157                              <2> KEY_F11             equ 0xFB
   158                              <2> KEY_F12             equ 0xFC
   159                              <2> 
   160                              <2> ; --- USB/XHCI Memory Layout ---
   161                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   162                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   163                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   164                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   165                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   166                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   167                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   168                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   169                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   170                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   171                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   172                              <2> ; Slot 2 device support
   173                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   174                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   175                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   176                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   177                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   178                              <2> 
   179                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   180                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   181                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   182                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   183                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   184                              <2> XHCI_CAP_DBOFF      equ 0x14
   185                              <2> XHCI_CAP_RTSOFF     equ 0x18
   186                              <2> 
   187                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   188                              <2> XHCI_OP_USBCMD      equ 0x00
   189                              <2> XHCI_OP_USBSTS      equ 0x04
   190                              <2> XHCI_OP_PAGESIZE     equ 0x08
   191                              <2> XHCI_OP_DNCTRL      equ 0x14
   192                              <2> XHCI_OP_CRCR_LO     equ 0x18
   193                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   194                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   195                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   196                              <2> XHCI_OP_CONFIG      equ 0x38
   197                              <2> 
   198                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   199                              <2> XHCI_PORTSC         equ 0x00
   200                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   201                              <2> 
   202                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   203                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   204                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   205                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   206                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   207                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   208                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   209                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   210                              <2> 
   211                              <2> ; --- USBCMD bits ---
   212                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   213                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   214                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   215                              <2> 
   216                              <2> ; --- USBSTS bits ---
   217                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   218                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   219                              <2> 
   220                              <2> ; --- PORTSC bits ---
   221                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   222                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   223                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   224                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   225                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   226                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   227                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   228                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   229                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   230                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   231                              <2> 
   232                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   233                              <2> TRB_NORMAL           equ (1 << 10)
   234                              <2> TRB_SETUP            equ (2 << 10)
   235                              <2> TRB_DATA             equ (3 << 10)
   236                              <2> TRB_STATUS           equ (4 << 10)
   237                              <2> TRB_LINK             equ (6 << 10)
   238                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   239                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   240                              <2> TRB_CONFIG_EP        equ (12 << 10)
   241                              <2> TRB_EVAL_CTX         equ (13 << 10)
   242                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   243                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   244                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   245                              <2> 
   246                              <2> ; --- TRB Flag Bits (dword 3) ---
   247                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   248                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   249                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   250                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   251                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   252                              <2> 
   253                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   254                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   255                              <2> TRB_TRT_OUT          equ (2 << 16)
   256                              <2> TRB_TRT_IN           equ (3 << 16)
   257                              <2> 
   258                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   259                              <2> TRB_DIR_OUT          equ (0 << 16)
   260                              <2> TRB_DIR_IN           equ (1 << 16)
   261                              <2> 
   262                              <2> ; --- Ring sizes ---
   263                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   264                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   265                              <2> 
   266                              <2> ; --- USB Standard Request Codes ---
   267                              <2> USB_REQ_GET_DESC     equ 0x06
   268                              <2> USB_REQ_SET_CONFIG   equ 0x09
   269                              <2> USB_REQ_SET_IFACE    equ 0x0B
   270                              <2> 
   271                              <2> ; --- USB HID Request Codes ---
   272                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   273                              <2> 
   274                              <2> ; --- USB Descriptor Types ---
   275                              <2> USB_DESC_DEVICE      equ 0x01
   276                              <2> USB_DESC_CONFIG      equ 0x02
   277                              <2> USB_DESC_INTERFACE   equ 0x04
   278                              <2> USB_DESC_ENDPOINT    equ 0x05
   279                              <2> USB_DESC_HID         equ 0x21
   280                              <2> 
   281                              <2> ; --- USB Endpoint Types ---
   282                              <2> USB_EP_CONTROL       equ 0
   283                              <2> USB_EP_ISOCH         equ 1
   284                              <2> USB_EP_BULK          equ 2
   285                              <2> USB_EP_INTERRUPT     equ 3
   286                              <2> 
   287                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   288                              <2> XHCI_EP_NOT_VALID    equ 0
   289                              <2> XHCI_EP_ISOCH_OUT    equ 1
   290                              <2> XHCI_EP_BULK_OUT     equ 2
   291                              <2> XHCI_EP_INT_OUT      equ 3
   292                              <2> XHCI_EP_CONTROL      equ 4
   293                              <2> XHCI_EP_ISOCH_IN     equ 5
   294                              <2> XHCI_EP_BULK_IN      equ 6
   295                              <2> XHCI_EP_INT_IN       equ 7
   296                              <2> 
   297                              <2> ; --- XHCI Port Speeds ---
   298                              <2> XHCI_SPEED_FULL      equ 1
   299                              <2> XHCI_SPEED_LOW       equ 2
   300                              <2> XHCI_SPEED_HIGH      equ 3
   301                              <2> XHCI_SPEED_SUPER     equ 4
     8                              <1> 
     9                              <1> section .text
    10                              <1> 
    11                              <1> ; --- Initialize page allocator from E820 map ---
    12                              <1> global memory_init
    13                              <1> memory_init:
    14 00000FC4 53                  <1>     push rbx
    15 00000FC5 4154                <1>     push r12
    16 00000FC7 4155                <1>     push r13
    17 00000FC9 4156                <1>     push r14
    18                              <1> 
    19                              <1>     ; Clear the entire bitmap (mark all pages as USED initially)
    20 00000FCB BF00003000          <1>     mov rdi, PAGE_BITMAP_ADDR
    21 00000FD0 B0FF                <1>     mov al, 0xFF             ; All bits set = all pages used
    22 00000FD2 B900001000          <1>     mov rcx, 0x100000        ; 1MB of bitmap = covers 32GB of RAM
    23 00000FD7 F3AA                <1>     rep stosb
    24                              <1> 
    25                              <1> 
    26 00000FD9 4D85E4              <1>     test r12, r12
    27 00000FDC 0F84A9000000        <1>     jz .done
    28                              <1> 
    29                              <1> .entry_loop:
    30                              <1>     ; Read entry
    31 00000FE2 498B4500            <1>     mov rax, [r13]            ; Base address
    32 00000FE6 498B5D08            <1>     mov rbx, [r13 + 8]       ; Length
    33 00000FEA 418B4D10            <1>     mov ecx, [r13 + 16]      ; Type
    34                              <1> 
    35                              <1>     ; Only process type 1 (usable memory)
    36 00000FEE 83F901              <1>     cmp ecx, 1
    37 00000FF1 0F8587000000        <1>     jne .next_entry
    38                              <1> 
    39                              <1>     ; Skip memory below 1MB (reserved for boot structures)
    40 00000FF7 483D00001000        <1>     cmp rax, 0x100000
    41 00000FFD 7D1E                <1>     jge .process_range
    42                              <1>     ; Adjust: if range extends above 1MB, clip it
    43 00000FFF 4889C2              <1>     mov rdx, rax
    44 00001002 4801DA              <1>     add rdx, rbx             ; End address
    45 00001005 4881FA00001000      <1>     cmp rdx, 0x100000
    46 0000100C 7E70                <1>     jle .next_entry
    47                              <1>     ; Clip start to 1MB
    48 0000100E 4881EA00001000      <1>     sub rdx, 0x100000
    49 00001015 4889D3              <1>     mov rbx, rdx             ; New length
    50 00001018 B800001000          <1>     mov rax, 0x100000        ; New base
    51                              <1> 
    52                              <1> .process_range:
    53                              <1>     ; Skip pages used by kernel and system structures (below 0xD00000)
    54 0000101D 483D0000D000        <1>     cmp rax, 0xD00000
    55 00001023 7D1E                <1>     jge .mark_free
    56 00001025 4889C2              <1>     mov rdx, rax
    57 00001028 4801DA              <1>     add rdx, rbx
    58 0000102B 4881FA0000D000      <1>     cmp rdx, 0xD00000
    59 00001032 7E4A                <1>     jle .next_entry
    60                              <1>     ; Clip
    61 00001034 4881EA0000D000      <1>     sub rdx, 0xD00000
    62 0000103B 4889D3              <1>     mov rbx, rdx
    63 0000103E B80000D000          <1>     mov rax, 0xD00000
    64                              <1> 
    65                              <1> .mark_free:
    66                              <1>     ; Mark pages in this range as free
    67                              <1>     ; RAX = base (page-aligned), RBX = length
    68 00001043 48C1E80C            <1>     shr rax, 12              ; Convert to page number
    69 00001047 4889DA              <1>     mov rdx, rbx
    70 0000104A 48C1EA0C            <1>     shr rdx, 12              ; Convert to page count
    71 0000104E 4885D2              <1>     test rdx, rdx
    72 00001051 742B                <1>     jz .next_entry
    73                              <1> 
    74                              <1> .free_loop:
    75                              <1>     ; Clear bit in bitmap to mark page as free
    76 00001053 4889C1              <1>     mov rcx, rax
    77 00001056 48C1E903            <1>     shr rcx, 3               ; Byte index (saved in RCX)
    78 0000105A 4989C6              <1>     mov r14, rax
    79 0000105D 4983E607            <1>     and r14, 7               ; Bit index (in R14)
    80 00001061 51                  <1>     push rcx                 ; Save byte index
    81 00001062 41B001              <1>     mov r8b, 1
    82 00001065 4488F1              <1>     mov cl, r14b             ; Shift count
    83 00001068 41D2E0              <1>     shl r8b, cl
    84 0000106B 41F6D0              <1>     not r8b
    85 0000106E 59                  <1>     pop rcx                  ; Restore byte index
    86 0000106F 44208100003000      <1>     and [PAGE_BITMAP_ADDR + rcx], r8b
    87                              <1> 
    88 00001076 48FFC0              <1>     inc rax                  ; Next page
    89 00001079 48FFCA              <1>     dec rdx
    90 0000107C 75D5                <1>     jnz .free_loop
    91                              <1> 
    92                              <1>     ; Note: free_page_count is recounted properly in count_free_pages below
    93                              <1> 
    94                              <1> .next_entry:
    95 0000107E 4983C518            <1>     add r13, 24              ; Next E820 entry (24 bytes each)
    96 00001082 49FFCC              <1>     dec r12
    97 00001085 0F8557FFFFFF        <1>     jnz .entry_loop
    98                              <1> 
    99                              <1> .done:
   100                              <1>     ; Recount free pages properly
   101 0000108B E890000000          <1>     call count_free_pages
   102                              <1> 
   103 00001090 415E                <1>     pop r14
   104 00001092 415D                <1>     pop r13
   105 00001094 415C                <1>     pop r12
   106 00001096 5B                  <1>     pop rbx
   107 00001097 C3                  <1>     ret
   108                              <1> 
   109                              <1> ; --- Allocate one physical page ---
   110                              <1> ; Returns: RAX = physical address of 4KB page, or 0 if out of memory
   111                              <1> global page_alloc
   112                              <1> page_alloc:
   113 00001098 53                  <1>     push rbx
   114 00001099 51                  <1>     push rcx
   115 0000109A 52                  <1>     push rdx
   116                              <1> 
   117                              <1>     ; Scan bitmap for first free bit (0 = free)
   118 0000109B BF00003000          <1>     mov rdi, PAGE_BITMAP_ADDR
   119 000010A0 B900001000          <1>     mov rcx, 0x100000        ; Bitmap size in bytes
   120                              <1> 
   121                              <1> .scan:
   122 000010A5 803FFF              <1>     cmp byte [rdi], 0xFF     ; All used?
   123 000010A8 750D                <1>     jne .found_byte
   124 000010AA 48FFC7              <1>     inc rdi
   125 000010AD 48FFC9              <1>     dec rcx
   126 000010B0 75F3                <1>     jnz .scan
   127                              <1>     ; Out of memory
   128 000010B2 4831C0              <1>     xor rax, rax
   129 000010B5 EB37                <1>     jmp .alloc_done
   130                              <1> 
   131                              <1> .found_byte:
   132                              <1>     ; Find which bit is 0 in this byte
   133 000010B7 8A07                <1>     mov al, [rdi]
   134 000010B9 4889FB              <1>     mov rbx, rdi
   135 000010BC 4881EB00003000      <1>     sub rbx, PAGE_BITMAP_ADDR  ; Byte offset
   136 000010C3 48C1E303            <1>     shl rbx, 3                 ; * 8 = base page number for this byte
   137                              <1> 
   138 000010C7 31C9                <1>     xor ecx, ecx
   139                              <1> .find_bit:
   140 000010C9 0FA3C8              <1>     bt eax, ecx
   141 000010CC 730C                <1>     jnc .got_bit
   142 000010CE FFC1                <1>     inc ecx
   143 000010D0 83F908              <1>     cmp ecx, 8
   144 000010D3 7CF4                <1>     jl .find_bit
   145                              <1>     ; Shouldn't reach here
   146 000010D5 4831C0              <1>     xor rax, rax
   147 000010D8 EB14                <1>     jmp .alloc_done
   148                              <1> 
   149                              <1> .got_bit:
   150                              <1>     ; Mark as used
   151 000010DA 0FAB0F              <1>     bts dword [rdi], ecx
   152                              <1> 
   153                              <1>     ; Calculate physical address
   154 000010DD 4801CB              <1>     add rbx, rcx              ; Page number
   155 000010E0 48C1E30C            <1>     shl rbx, 12               ; * 4096 = physical address
   156 000010E4 4889D8              <1>     mov rax, rbx
   157                              <1> 
   158 000010E7 48FF0D(DE000000)    <1>     dec qword [free_page_count]
   159                              <1> 
   160                              <1> .alloc_done:
   161 000010EE 5A                  <1>     pop rdx
   162 000010EF 59                  <1>     pop rcx
   163 000010F0 5B                  <1>     pop rbx
   164 000010F1 C3                  <1>     ret
   165                              <1> 
   166                              <1> ; --- Free a physical page ---
   167                              <1> ; RDI = physical address
   168                              <1> global page_free
   169                              <1> page_free:
   170 000010F2 50                  <1>     push rax
   171 000010F3 51                  <1>     push rcx
   172                              <1> 
   173 000010F4 48C1EF0C            <1>     shr rdi, 12              ; Convert to page number
   174 000010F8 4889F8              <1>     mov rax, rdi
   175 000010FB 48C1E803            <1>     shr rax, 3               ; Byte index
   176 000010FF 4889F9              <1>     mov rcx, rdi
   177 00001102 4883E107            <1>     and rcx, 7               ; Bit index
   178                              <1> 
   179                              <1>     ; Clear the bit (mark as free)
   180                              <1>     ; RAX = byte index, CL = bit index (from and rcx, 7 above)
   181 00001106 41B001              <1>     mov r8b, 1
   182 00001109 41D2E0              <1>     shl r8b, cl
   183 0000110C 41F6D0              <1>     not r8b
   184 0000110F 44208000003000      <1>     and [PAGE_BITMAP_ADDR + rax], r8b
   185                              <1> 
   186 00001116 48FF05(DE000000)    <1>     inc qword [free_page_count]
   187                              <1> 
   188 0000111D 59                  <1>     pop rcx
   189 0000111E 58                  <1>     pop rax
   190 0000111F C3                  <1>     ret
   191                              <1> 
   192                              <1> ; --- Count free pages ---
   193                              <1> count_free_pages:
   194 00001120 53                  <1>     push rbx
   195 00001121 51                  <1>     push rcx
   196                              <1> 
   197 00001122 4831C0              <1>     xor rax, rax             ; Counter
   198 00001125 BF00003000          <1>     mov rdi, PAGE_BITMAP_ADDR
   199 0000112A B900001000          <1>     mov rcx, 0x100000        ; Bitmap bytes
   200                              <1> 
   201                              <1> .count_loop:
   202 0000112F 8A1F                <1>     mov bl, [rdi]
   203 00001131 F6D3                <1>     not bl                   ; Invert: 1 = free
   204                              <1>     ; Count set bits (popcount)
   205 00001133 31D2                <1>     xor edx, edx
   206                              <1> .popcount:
   207 00001135 84DB                <1>     test bl, bl
   208 00001137 740E                <1>     jz .next_byte
   209 00001139 4188D8              <1>     mov r8b, bl
   210 0000113C 41FEC8              <1>     dec r8b
   211 0000113F 4420C3              <1>     and bl, r8b              ; Clear lowest set bit
   212 00001142 48FFC0              <1>     inc rax
   213 00001145 EBEE                <1>     jmp .popcount
   214                              <1> 
   215                              <1> .next_byte:
   216 00001147 48FFC7              <1>     inc rdi
   217 0000114A 48FFC9              <1>     dec rcx
   218 0000114D 75E0                <1>     jnz .count_loop
   219                              <1> 
   220 0000114F 488905(DE000000)    <1>     mov [free_page_count], rax
   221                              <1> 
   222 00001156 59                  <1>     pop rcx
   223 00001157 5B                  <1>     pop rbx
   224 00001158 C3                  <1>     ret
   225                              <1> 
   226                              <1> ; --- Get free page count ---
   227                              <1> global memory_get_free
   228                              <1> memory_get_free:
   229 00001159 488B05(DE000000)    <1>     mov rax, [free_page_count]
   230 00001160 C3                  <1>     ret
   231                              <1> 
   232                              <1> section .data
   233                              <1> global free_page_count
   234 000000DE 0000000000000000    <1> free_page_count: dq 0
    29                                  section .text
    30                                  %include "src/kernel/pic.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - 8259A PIC Driver
     3                              <1> ; Remaps IRQs to vectors 32-47, provides EOI and masking
     4                              <1> ; ============================================================================
     5                              <1> bits 64
     6                              <1> 
     7                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> L3_SYSCALL_STACK_ADDR equ 0xC00000   ; Kernel-only syscall stacks
    33                              <2> 
    34                              <2> ; --- Stage 2 disk layout ---
    35                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    36                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    37                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    38                              <2> 
    39                              <2> ; --- Screen ---
    40                              <2> SCREEN_WIDTH        equ 1024
    41                              <2> SCREEN_HEIGHT       equ 768
    42                              <2> SCREEN_BPP          equ 32
    43                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    44                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    45                              <2> 
    46                              <2> 
    47                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    48                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    49                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    50                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    51                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    52                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    53                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    54                              <2> 
    55                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    56                              <2> COLOR_BLACK         equ 0x00000000
    57                              <2> COLOR_WHITE         equ 0x00FFFFFF
    58                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    59                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    60                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    61                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    62                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    63                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    64                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    65                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    66                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    67                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    68                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    69                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    70                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    71                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    72                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    73                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    74                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    75                              <2> COLOR_START_HOVER    equ 0x00338833
    76                              <2> 
    77                              <2> ; --- Window Manager ---
    78                              <2> MAX_WINDOWS         equ 8
    79                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    80                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    81                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    82                              <2> TITLEBAR_HEIGHT     equ 24
    83                              <2> BORDER_WIDTH        equ 2
    84                              <2> CLOSE_BTN_SIZE      equ 18
    85                              <2> MIN_BTN_SIZE        equ 18
    86                              <2> MIN_WINDOW_W        equ 200
    87                              <2> MIN_WINDOW_H        equ 100
    88                              <2> 
    89                              <2> ; --- Taskbar ---
    90                              <2> TASKBAR_HEIGHT      equ 36
    91                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    92                              <2> START_BTN_W         equ 70
    93                              <2> START_BTN_H         equ 28
    94                              <2> START_BTN_X         equ 4
    95                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    96                              <2> CLOCK_WIDTH         equ 64
    97                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    98                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    99                              <2> 
   100                              <2> ; --- Keyboard ---
   101                              <2> KB_BUFFER_SIZE      equ 64
   102                              <2> 
   103                              <2> ; --- Mouse ---
   104                              <2> MOUSE_BUFFER_SIZE   equ 64
   105                              <2> CURSOR_WIDTH        equ 12
   106                              <2> CURSOR_HEIGHT       equ 19
   107                              <2> 
   108                              <2> ; --- PIT ---
   109                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   110                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   111                              <2> 
   112                              <2> ; --- PIC vectors ---
   113                              <2> IRQ_BASE_MASTER     equ 32
   114                              <2> IRQ_BASE_SLAVE      equ 40
   115                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   116                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   117                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   118                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   119                              <2> 
   120                              <2> ; --- Font ---
   121                              <2> FONT_WIDTH          equ 8
   122                              <2> FONT_HEIGHT         equ 16
   123                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   124                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   125                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   126                              <2> 
   127                              <2> ; --- Window flags ---
   128                              <2> WF_VISIBLE          equ 0x01
   129                              <2> WF_FOCUSED          equ 0x02
   130                              <2> WF_DRAGGING         equ 0x04
   131                              <2> WF_MINIMIZED        equ 0x08
   132                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   133                              <2> 
   134                              <2> ; --- Mouse event types ---
   135                              <2> MEVT_MOVE           equ 1
   136                              <2> MEVT_LCLICK         equ 2
   137                              <2> MEVT_RCLICK         equ 3
   138                              <2> MEVT_LRELEASE       equ 4
   139                              <2> MEVT_RRELEASE       equ 5
   140                              <2> 
   141                              <2> ; --- Key modifier flags ---
   142                              <2> KMOD_SHIFT          equ 0x01
   143                              <2> KMOD_CTRL           equ 0x02
   144                              <2> KMOD_ALT            equ 0x04
   145                              <2> 
   146                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   147                              <2> KEY_F1              equ 0xF1
   148                              <2> KEY_F2              equ 0xF2
   149                              <2> KEY_F3              equ 0xF3
   150                              <2> KEY_F4              equ 0xF4
   151                              <2> KEY_F5              equ 0xF5
   152                              <2> KEY_F6              equ 0xF6
   153                              <2> KEY_F7              equ 0xF7
   154                              <2> KEY_F8              equ 0xF8
   155                              <2> KEY_F9              equ 0xF9
   156                              <2> KEY_F10             equ 0xFA
   157                              <2> KEY_F11             equ 0xFB
   158                              <2> KEY_F12             equ 0xFC
   159                              <2> 
   160                              <2> ; --- USB/XHCI Memory Layout ---
   161                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   162                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   163                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   164                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   165                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   166                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   167                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   168                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   169                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   170                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   171                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   172                              <2> ; Slot 2 device support
   173                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   174                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   175                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   176                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   177                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   178                              <2> 
   179                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   180                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   181                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   182                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   183                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   184                              <2> XHCI_CAP_DBOFF      equ 0x14
   185                              <2> XHCI_CAP_RTSOFF     equ 0x18
   186                              <2> 
   187                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   188                              <2> XHCI_OP_USBCMD      equ 0x00
   189                              <2> XHCI_OP_USBSTS      equ 0x04
   190                              <2> XHCI_OP_PAGESIZE     equ 0x08
   191                              <2> XHCI_OP_DNCTRL      equ 0x14
   192                              <2> XHCI_OP_CRCR_LO     equ 0x18
   193                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   194                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   195                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   196                              <2> XHCI_OP_CONFIG      equ 0x38
   197                              <2> 
   198                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   199                              <2> XHCI_PORTSC         equ 0x00
   200                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   201                              <2> 
   202                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   203                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   204                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   205                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   206                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   207                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   208                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   209                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   210                              <2> 
   211                              <2> ; --- USBCMD bits ---
   212                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   213                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   214                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   215                              <2> 
   216                              <2> ; --- USBSTS bits ---
   217                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   218                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   219                              <2> 
   220                              <2> ; --- PORTSC bits ---
   221                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   222                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   223                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   224                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   225                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   226                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   227                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   228                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   229                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   230                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   231                              <2> 
   232                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   233                              <2> TRB_NORMAL           equ (1 << 10)
   234                              <2> TRB_SETUP            equ (2 << 10)
   235                              <2> TRB_DATA             equ (3 << 10)
   236                              <2> TRB_STATUS           equ (4 << 10)
   237                              <2> TRB_LINK             equ (6 << 10)
   238                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   239                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   240                              <2> TRB_CONFIG_EP        equ (12 << 10)
   241                              <2> TRB_EVAL_CTX         equ (13 << 10)
   242                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   243                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   244                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   245                              <2> 
   246                              <2> ; --- TRB Flag Bits (dword 3) ---
   247                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   248                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   249                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   250                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   251                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   252                              <2> 
   253                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   254                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   255                              <2> TRB_TRT_OUT          equ (2 << 16)
   256                              <2> TRB_TRT_IN           equ (3 << 16)
   257                              <2> 
   258                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   259                              <2> TRB_DIR_OUT          equ (0 << 16)
   260                              <2> TRB_DIR_IN           equ (1 << 16)
   261                              <2> 
   262                              <2> ; --- Ring sizes ---
   263                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   264                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   265                              <2> 
   266                              <2> ; --- USB Standard Request Codes ---
   267                              <2> USB_REQ_GET_DESC     equ 0x06
   268                              <2> USB_REQ_SET_CONFIG   equ 0x09
   269                              <2> USB_REQ_SET_IFACE    equ 0x0B
   270                              <2> 
   271                              <2> ; --- USB HID Request Codes ---
   272                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   273                              <2> 
   274                              <2> ; --- USB Descriptor Types ---
   275                              <2> USB_DESC_DEVICE      equ 0x01
   276                              <2> USB_DESC_CONFIG      equ 0x02
   277                              <2> USB_DESC_INTERFACE   equ 0x04
   278                              <2> USB_DESC_ENDPOINT    equ 0x05
   279                              <2> USB_DESC_HID         equ 0x21
   280                              <2> 
   281                              <2> ; --- USB Endpoint Types ---
   282                              <2> USB_EP_CONTROL       equ 0
   283                              <2> USB_EP_ISOCH         equ 1
   284                              <2> USB_EP_BULK          equ 2
   285                              <2> USB_EP_INTERRUPT     equ 3
   286                              <2> 
   287                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   288                              <2> XHCI_EP_NOT_VALID    equ 0
   289                              <2> XHCI_EP_ISOCH_OUT    equ 1
   290                              <2> XHCI_EP_BULK_OUT     equ 2
   291                              <2> XHCI_EP_INT_OUT      equ 3
   292                              <2> XHCI_EP_CONTROL      equ 4
   293                              <2> XHCI_EP_ISOCH_IN     equ 5
   294                              <2> XHCI_EP_BULK_IN      equ 6
   295                              <2> XHCI_EP_INT_IN       equ 7
   296                              <2> 
   297                              <2> ; --- XHCI Port Speeds ---
   298                              <2> XHCI_SPEED_FULL      equ 1
   299                              <2> XHCI_SPEED_LOW       equ 2
   300                              <2> XHCI_SPEED_HIGH      equ 3
   301                              <2> XHCI_SPEED_SUPER     equ 4
     8                              <1> %include "macros.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - Common Macros
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> %ifndef MACROS_INC
     6                              <2> %define MACROS_INC
     7                              <2> 
     8                              <2> ; Output character to COM1 for debugging
     9                              <2> %macro SER 1
    10                              <2>     push rax
    11                              <2>     push rdx
    12                              <2>     mov dx, 0x3F8
    13                              <2>     mov al, %1
    14                              <2>     out dx, al
    15                              <2>     pop rdx
    16                              <2>     pop rax
    17                              <2> %endmacro
    18                              <2> 
    19                              <2> ; Save all general-purpose registers (64-bit)
    20                              <2> %macro PUSH_ALL 0
    21                              <2>     push rax
    22                              <2>     push rbx
    23                              <2>     push rcx
    24                              <2>     push rdx
    25                              <2>     push rsi
    26                              <2>     push rdi
    27                              <2>     push rbp
    28                              <2>     push r8
    29                              <2>     push r9
    30                              <2>     push r10
    31                              <2>     push r11
    32                              <2>     push r12
    33                              <2>     push r13
    34                              <2>     push r14
    35                              <2>     push r15
    36                              <2> %endmacro
    37                              <2> 
    38                              <2> ; Offset of registers in PUSH_ALL frame
    39                              <2> ALL_R15 equ 0
    40                              <2> ALL_R14 equ 8
    41                              <2> ALL_R13 equ 16
    42                              <2> ALL_R12 equ 24
    43                              <2> ALL_R11 equ 32
    44                              <2> ALL_R10 equ 40
    45                              <2> ALL_R9  equ 48
    46                              <2> ALL_R8  equ 56
    47                              <2> ALL_RBP equ 64
    48                              <2> ALL_RDI equ 72
    49                              <2> ALL_RSI equ 80
    50                              <2> ALL_RDX equ 88
    51                              <2> ALL_RCX equ 96
    52                              <2> ALL_RBX equ 104
    53                              <2> ALL_RAX equ 112
    54                              <2> 
    55                              <2> ; Restore all general-purpose registers (64-bit)
    56                              <2> %macro POP_ALL 0
    57                              <2>     pop r15
    58                              <2>     pop r14
    59                              <2>     pop r13
    60                              <2>     pop r12
    61                              <2>     pop r11
    62                              <2>     pop r10
    63                              <2>     pop r9
    64                              <2>     pop r8
    65                              <2>     pop rbp
    66                              <2>     pop rdi
    67                              <2>     pop rsi
    68                              <2>     pop rdx
    69                              <2>     pop rcx
    70                              <2>     pop rbx
    71                              <2>     pop rax
    72                              <2> %endmacro
    73                              <2> 
    74                              <2> ; Output byte to port with I/O delay
    75                              <2> %macro OUTB 2
    76                              <2>     mov al, %2
    77                              <2>     out %1, al
    78                              <2> %endmacro
    79                              <2> 
    80                              <2> ; Input byte from port
    81                              <2> %macro INB 1
    82                              <2>     in al, %1
    83                              <2> %endmacro
    84                              <2> 
    85                              <2> ; I/O wait (small delay for PIC/PIT programming)
    86                              <2> %macro IO_WAIT 0
    87                              <2>     out 0x80, al
    88                              <2> %endmacro
    89                              <2> 
    90                              <2> ; Bochs magic breakpoint
    91                              <2> %macro BOCHS_BREAK 0
    92                              <2>     xchg bx, bx
    93                              <2> %endmacro
    94                              <2> 
    95                              <2> ; ISR stub that pushes a dummy error code (for exceptions without one)
    96                              <2> %macro ISR_NOERRCODE 1
    97                              <2> global isr_%1
    98                              <2> isr_%1:
    99                              <2>     push qword 0           ; Dummy error code
   100                              <2>     push qword %1          ; Interrupt number
   101                              <2>     jmp isr_common_stub
   102                              <2> %endmacro
   103                              <2> 
   104                              <2> ; ISR stub for exceptions that push their own error code
   105                              <2> %macro ISR_ERRCODE 1
   106                              <2> global isr_%1
   107                              <2> isr_%1:
   108                              <2>     push qword %1          ; Interrupt number (error code already on stack)
   109                              <2>     jmp isr_common_stub
   110                              <2> %endmacro
   111                              <2> 
   112                              <2> ; IRQ stub macro
   113                              <2> %macro IRQ_STUB 2
   114                              <2> global irq_%1
   115                              <2> irq_%1:
   116                              <2>     push qword 0           ; Dummy error code
   117                              <2>     push qword %2          ; Interrupt vector number
   118                              <2>     jmp irq_common_stub
   119                              <2> %endmacro
   120                              <2> 
   121                              <2> %endif
     9                              <1> 
    10                              <1> section .text
    11                              <1> 
    12                              <1> ; --- Initialize and remap the 8259A PICs ---
    13                              <1> ; Master PIC: IRQs 0-7 -> vectors 32-39
    14                              <1> ; Slave PIC:  IRQs 8-15 -> vectors 40-47
    15                              <1> global pic_init
    16                              <1> pic_init:
    17                              <1>     ; Save current masks
    18 00001161 E421                <1>     in al, 0x21
    19 00001163 8805(E6000000)      <1>     mov [pic_mask_save], al
    20 00001169 E4A1                <1>     in al, 0xA1
    21 0000116B 8805(E7000000)      <1>     mov [pic_mask_save + 1], al
    22                              <1> 
    23                              <1>     ; ICW1: Initialize + ICW4 needed
    24 00001171 B011                <1>     mov al, 0x11
    25 00001173 E620                <1>     out 0x20, al            ; Master command
    26 00001175 E84E000000          <1>     call .io_wait
    27 0000117A E6A0                <1>     out 0xA0, al            ; Slave command
    28 0000117C E847000000          <1>     call .io_wait
    29                              <1> 
    30                              <1>     ; ICW2: Vector offsets
    31 00001181 B020                <1>     mov al, IRQ_BASE_MASTER ; 32
    32 00001183 E621                <1>     out 0x21, al            ; Master data
    33 00001185 E83E000000          <1>     call .io_wait
    34 0000118A B028                <1>     mov al, IRQ_BASE_SLAVE  ; 40
    35 0000118C E6A1                <1>     out 0xA1, al            ; Slave data
    36 0000118E E835000000          <1>     call .io_wait
    37                              <1> 
    38                              <1>     ; ICW3: Master/Slave wiring
    39 00001193 B004                <1>     mov al, 0x04            ; Master: slave on IRQ2 (bit 2)
    40 00001195 E621                <1>     out 0x21, al
    41 00001197 E82C000000          <1>     call .io_wait
    42 0000119C B002                <1>     mov al, 0x02            ; Slave: cascade identity 2
    43 0000119E E6A1                <1>     out 0xA1, al
    44 000011A0 E823000000          <1>     call .io_wait
    45                              <1> 
    46                              <1>     ; ICW4: 8086 mode
    47 000011A5 B001                <1>     mov al, 0x01
    48 000011A7 E621                <1>     out 0x21, al
    49 000011A9 E81A000000          <1>     call .io_wait
    50 000011AE E6A1                <1>     out 0xA1, al
    51 000011B0 E813000000          <1>     call .io_wait
    52                              <1> 
    53                              <1>     ; Unmask IRQ0 (timer), IRQ1 (keyboard), IRQ12 (mouse); mask rest
    54 000011B5 B0F8                <1>     mov al, 11111000b       ; Unmask IRQ0,1,2(cascade) on master
    55 000011B7 E621                <1>     out 0x21, al
    56 000011B9 E80A000000          <1>     call .io_wait
    57 000011BE B0EF                <1>     mov al, 11101111b       ; Unmask IRQ12 (mouse) on slave
    58 000011C0 E6A1                <1>     out 0xA1, al
    59 000011C2 E801000000          <1>     call .io_wait
    60                              <1> 
    61 000011C7 C3                  <1>     ret
    62                              <1> 
    63                              <1> .io_wait:
    64                              <1>     ; Small delay for PIC programming
    65 000011C8 E680                <1>     out 0x80, al
    66 000011CA C3                  <1>     ret
    67                              <1> 
    68                              <1> ; --- Send End Of Interrupt to master PIC ---
    69                              <1> global pic_eoi_master
    70                              <1> pic_eoi_master:
    71 000011CB B020                <1>     mov al, 0x20
    72 000011CD E620                <1>     out 0x20, al
    73 000011CF C3                  <1>     ret
    74                              <1> 
    75                              <1> ; --- Send End Of Interrupt to slave PIC (and master cascade) ---
    76                              <1> global pic_eoi_slave
    77                              <1> pic_eoi_slave:
    78 000011D0 B020                <1>     mov al, 0x20
    79 000011D2 E6A0                <1>     out 0xA0, al            ; EOI to slave
    80 000011D4 E620                <1>     out 0x20, al            ; EOI to master (cascade)
    81 000011D6 C3                  <1>     ret
    82                              <1> 
    83                              <1> ; --- Mask a specific IRQ line ---
    84                              <1> ; RDI = IRQ number (0-15)
    85                              <1> global pic_mask_irq
    86                              <1> pic_mask_irq:
    87 000011D7 83FF08              <1>     cmp edi, 8
    88 000011DA 7D0E                <1>     jge .slave
    89                              <1>     ; Master PIC
    90 000011DC 4088F9              <1>     mov cl, dil
    91 000011DF B401                <1>     mov ah, 1
    92 000011E1 D2E4                <1>     shl ah, cl
    93 000011E3 E421                <1>     in al, 0x21
    94 000011E5 08E0                <1>     or al, ah
    95 000011E7 E621                <1>     out 0x21, al
    96 000011E9 C3                  <1>     ret
    97                              <1> .slave:
    98 000011EA 83EF08              <1>     sub edi, 8
    99 000011ED 4088F9              <1>     mov cl, dil
   100 000011F0 B401                <1>     mov ah, 1
   101 000011F2 D2E4                <1>     shl ah, cl
   102 000011F4 E4A1                <1>     in al, 0xA1
   103 000011F6 08E0                <1>     or al, ah
   104 000011F8 E6A1                <1>     out 0xA1, al
   105 000011FA C3                  <1>     ret
   106                              <1> 
   107                              <1> ; --- Unmask a specific IRQ line ---
   108                              <1> ; RDI = IRQ number (0-15)
   109                              <1> global pic_unmask_irq
   110                              <1> pic_unmask_irq:
   111 000011FB 83FF08              <1>     cmp edi, 8
   112 000011FE 7D10                <1>     jge .slave
   113                              <1>     ; Master PIC
   114 00001200 4088F9              <1>     mov cl, dil
   115 00001203 B401                <1>     mov ah, 1
   116 00001205 D2E4                <1>     shl ah, cl
   117 00001207 F6D4                <1>     not ah
   118 00001209 E421                <1>     in al, 0x21
   119 0000120B 20E0                <1>     and al, ah
   120 0000120D E621                <1>     out 0x21, al
   121 0000120F C3                  <1>     ret
   122                              <1> .slave:
   123 00001210 83EF08              <1>     sub edi, 8
   124 00001213 4088F9              <1>     mov cl, dil
   125 00001216 B401                <1>     mov ah, 1
   126 00001218 D2E4                <1>     shl ah, cl
   127 0000121A F6D4                <1>     not ah
   128 0000121C E4A1                <1>     in al, 0xA1
   129 0000121E 20E0                <1>     and al, ah
   130 00001220 E6A1                <1>     out 0xA1, al
   131 00001222 C3                  <1>     ret
   132                              <1> 
   133                              <1> section .data
   134 000000E6 0000                <1> pic_mask_save: db 0, 0
    31                                  section .text
    32                                  %include "src/kernel/pit.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - PIT Timer Driver
     3                              <1> ; ============================================================================
     4                              <1> bits 64
     5                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> L3_SYSCALL_STACK_ADDR equ 0xC00000   ; Kernel-only syscall stacks
    33                              <2> 
    34                              <2> ; --- Stage 2 disk layout ---
    35                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    36                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    37                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    38                              <2> 
    39                              <2> ; --- Screen ---
    40                              <2> SCREEN_WIDTH        equ 1024
    41                              <2> SCREEN_HEIGHT       equ 768
    42                              <2> SCREEN_BPP          equ 32
    43                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    44                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    45                              <2> 
    46                              <2> 
    47                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    48                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    49                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    50                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    51                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    52                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    53                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    54                              <2> 
    55                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    56                              <2> COLOR_BLACK         equ 0x00000000
    57                              <2> COLOR_WHITE         equ 0x00FFFFFF
    58                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    59                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    60                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    61                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    62                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    63                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    64                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    65                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    66                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    67                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    68                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    69                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    70                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    71                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    72                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    73                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    74                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    75                              <2> COLOR_START_HOVER    equ 0x00338833
    76                              <2> 
    77                              <2> ; --- Window Manager ---
    78                              <2> MAX_WINDOWS         equ 8
    79                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    80                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    81                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    82                              <2> TITLEBAR_HEIGHT     equ 24
    83                              <2> BORDER_WIDTH        equ 2
    84                              <2> CLOSE_BTN_SIZE      equ 18
    85                              <2> MIN_BTN_SIZE        equ 18
    86                              <2> MIN_WINDOW_W        equ 200
    87                              <2> MIN_WINDOW_H        equ 100
    88                              <2> 
    89                              <2> ; --- Taskbar ---
    90                              <2> TASKBAR_HEIGHT      equ 36
    91                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    92                              <2> START_BTN_W         equ 70
    93                              <2> START_BTN_H         equ 28
    94                              <2> START_BTN_X         equ 4
    95                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    96                              <2> CLOCK_WIDTH         equ 64
    97                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    98                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    99                              <2> 
   100                              <2> ; --- Keyboard ---
   101                              <2> KB_BUFFER_SIZE      equ 64
   102                              <2> 
   103                              <2> ; --- Mouse ---
   104                              <2> MOUSE_BUFFER_SIZE   equ 64
   105                              <2> CURSOR_WIDTH        equ 12
   106                              <2> CURSOR_HEIGHT       equ 19
   107                              <2> 
   108                              <2> ; --- PIT ---
   109                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   110                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   111                              <2> 
   112                              <2> ; --- PIC vectors ---
   113                              <2> IRQ_BASE_MASTER     equ 32
   114                              <2> IRQ_BASE_SLAVE      equ 40
   115                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   116                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   117                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   118                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   119                              <2> 
   120                              <2> ; --- Font ---
   121                              <2> FONT_WIDTH          equ 8
   122                              <2> FONT_HEIGHT         equ 16
   123                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   124                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   125                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   126                              <2> 
   127                              <2> ; --- Window flags ---
   128                              <2> WF_VISIBLE          equ 0x01
   129                              <2> WF_FOCUSED          equ 0x02
   130                              <2> WF_DRAGGING         equ 0x04
   131                              <2> WF_MINIMIZED        equ 0x08
   132                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   133                              <2> 
   134                              <2> ; --- Mouse event types ---
   135                              <2> MEVT_MOVE           equ 1
   136                              <2> MEVT_LCLICK         equ 2
   137                              <2> MEVT_RCLICK         equ 3
   138                              <2> MEVT_LRELEASE       equ 4
   139                              <2> MEVT_RRELEASE       equ 5
   140                              <2> 
   141                              <2> ; --- Key modifier flags ---
   142                              <2> KMOD_SHIFT          equ 0x01
   143                              <2> KMOD_CTRL           equ 0x02
   144                              <2> KMOD_ALT            equ 0x04
   145                              <2> 
   146                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   147                              <2> KEY_F1              equ 0xF1
   148                              <2> KEY_F2              equ 0xF2
   149                              <2> KEY_F3              equ 0xF3
   150                              <2> KEY_F4              equ 0xF4
   151                              <2> KEY_F5              equ 0xF5
   152                              <2> KEY_F6              equ 0xF6
   153                              <2> KEY_F7              equ 0xF7
   154                              <2> KEY_F8              equ 0xF8
   155                              <2> KEY_F9              equ 0xF9
   156                              <2> KEY_F10             equ 0xFA
   157                              <2> KEY_F11             equ 0xFB
   158                              <2> KEY_F12             equ 0xFC
   159                              <2> 
   160                              <2> ; --- USB/XHCI Memory Layout ---
   161                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   162                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   163                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   164                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   165                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   166                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   167                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   168                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   169                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   170                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   171                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   172                              <2> ; Slot 2 device support
   173                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   174                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   175                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   176                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   177                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   178                              <2> 
   179                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   180                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   181                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   182                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   183                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   184                              <2> XHCI_CAP_DBOFF      equ 0x14
   185                              <2> XHCI_CAP_RTSOFF     equ 0x18
   186                              <2> 
   187                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   188                              <2> XHCI_OP_USBCMD      equ 0x00
   189                              <2> XHCI_OP_USBSTS      equ 0x04
   190                              <2> XHCI_OP_PAGESIZE     equ 0x08
   191                              <2> XHCI_OP_DNCTRL      equ 0x14
   192                              <2> XHCI_OP_CRCR_LO     equ 0x18
   193                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   194                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   195                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   196                              <2> XHCI_OP_CONFIG      equ 0x38
   197                              <2> 
   198                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   199                              <2> XHCI_PORTSC         equ 0x00
   200                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   201                              <2> 
   202                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   203                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   204                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   205                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   206                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   207                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   208                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   209                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   210                              <2> 
   211                              <2> ; --- USBCMD bits ---
   212                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   213                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   214                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   215                              <2> 
   216                              <2> ; --- USBSTS bits ---
   217                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   218                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   219                              <2> 
   220                              <2> ; --- PORTSC bits ---
   221                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   222                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   223                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   224                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   225                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   226                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   227                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   228                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   229                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   230                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   231                              <2> 
   232                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   233                              <2> TRB_NORMAL           equ (1 << 10)
   234                              <2> TRB_SETUP            equ (2 << 10)
   235                              <2> TRB_DATA             equ (3 << 10)
   236                              <2> TRB_STATUS           equ (4 << 10)
   237                              <2> TRB_LINK             equ (6 << 10)
   238                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   239                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   240                              <2> TRB_CONFIG_EP        equ (12 << 10)
   241                              <2> TRB_EVAL_CTX         equ (13 << 10)
   242                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   243                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   244                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   245                              <2> 
   246                              <2> ; --- TRB Flag Bits (dword 3) ---
   247                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   248                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   249                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   250                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   251                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   252                              <2> 
   253                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   254                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   255                              <2> TRB_TRT_OUT          equ (2 << 16)
   256                              <2> TRB_TRT_IN           equ (3 << 16)
   257                              <2> 
   258                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   259                              <2> TRB_DIR_OUT          equ (0 << 16)
   260                              <2> TRB_DIR_IN           equ (1 << 16)
   261                              <2> 
   262                              <2> ; --- Ring sizes ---
   263                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   264                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   265                              <2> 
   266                              <2> ; --- USB Standard Request Codes ---
   267                              <2> USB_REQ_GET_DESC     equ 0x06
   268                              <2> USB_REQ_SET_CONFIG   equ 0x09
   269                              <2> USB_REQ_SET_IFACE    equ 0x0B
   270                              <2> 
   271                              <2> ; --- USB HID Request Codes ---
   272                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   273                              <2> 
   274                              <2> ; --- USB Descriptor Types ---
   275                              <2> USB_DESC_DEVICE      equ 0x01
   276                              <2> USB_DESC_CONFIG      equ 0x02
   277                              <2> USB_DESC_INTERFACE   equ 0x04
   278                              <2> USB_DESC_ENDPOINT    equ 0x05
   279                              <2> USB_DESC_HID         equ 0x21
   280                              <2> 
   281                              <2> ; --- USB Endpoint Types ---
   282                              <2> USB_EP_CONTROL       equ 0
   283                              <2> USB_EP_ISOCH         equ 1
   284                              <2> USB_EP_BULK          equ 2
   285                              <2> USB_EP_INTERRUPT     equ 3
   286                              <2> 
   287                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   288                              <2> XHCI_EP_NOT_VALID    equ 0
   289                              <2> XHCI_EP_ISOCH_OUT    equ 1
   290                              <2> XHCI_EP_BULK_OUT     equ 2
   291                              <2> XHCI_EP_INT_OUT      equ 3
   292                              <2> XHCI_EP_CONTROL      equ 4
   293                              <2> XHCI_EP_ISOCH_IN     equ 5
   294                              <2> XHCI_EP_BULK_IN      equ 6
   295                              <2> XHCI_EP_INT_IN       equ 7
   296                              <2> 
   297                              <2> ; --- XHCI Port Speeds ---
   298                              <2> XHCI_SPEED_FULL      equ 1
   299                              <2> XHCI_SPEED_LOW       equ 2
   300                              <2> XHCI_SPEED_HIGH      equ 3
   301                              <2> XHCI_SPEED_SUPER     equ 4
