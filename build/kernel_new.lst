    84                              <1>     ; Find free slot in process pool
    85 0000187D BB00002200          <1>     mov rbx, PROCESS_POOL
    86 00001882 31C9                <1>     xor ecx, ecx
    87                              <1> .find_loop:
    88 00001884 83BB9800000000      <1>     cmp dword [rbx + process_t.state], 0 ; EMPTY = 0
    89 0000188B 741A                <1>     je .found
    90 0000188D 4881C300020000      <1>     add rbx, 512
    91 00001894 FFC1                <1>     inc ecx
    92 00001896 83F908              <1>     cmp ecx, MAX_PROCESSES
