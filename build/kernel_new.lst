   604                              <1> ; Handle click on taskbar / start menu
   605                              <1> ; RDI = Mouse X, RSI = Mouse Y
   606                              <1> ; Returns: RAX = 0 (not handled), 1 (handled, no app), or 2..6 (menu item 0..4 clicked)
   607                              <1> tb_handle_click:
   608 00008AD1 53                  <1>     push rbx
   609 00008AD2 51                  <1>     push rcx
   610 00008AD3 52                  <1>     push rdx
   611 00008AD4 4154                <1>     push r12
   612 00008AD6 4155                <1>     push r13
   613                              <1> 
   614                              <1>     ; Check if start menu is open and click is inside it
   615 00008AD8 803D(97110000)00    <1>     cmp byte [tb_start_menu_open], 0
   616 00008ADF 7466                <1>     je .check_taskbar
   617                              <1> 
   618                              <1>     ; Check bounds of start menu
   619 00008AE1 4883FF04            <1>     cmp rdi, START_MENU_X
   620 00008AE5 7C4F                <1>     jl .close_menu
   621 00008AE7 4881FFCC000000      <1>     cmp rdi, START_MENU_X + START_MENU_W
   622 00008AEE 7F46                <1>     jg .close_menu
   623 00008AF0 4881FE14020000      <1>     cmp rsi, START_MENU_Y
   624 00008AF7 7C3D                <1>     jl .close_menu
   625 00008AF9 4881FEDC020000      <1>     cmp rsi, TASKBAR_Y
   626 00008B00 7D45                <1>     jge .check_taskbar
   627                              <1> 
   628                              <1>     ; Click inside menu - determine which item
   629 00008B02 4889F0              <1>     mov rax, rsi
   630 00008B05 482D14020000        <1>     sub rax, START_MENU_Y
   631 00008B0B 4883E808            <1>     sub rax, 8
   632 00008B0F 4883F800            <1>     cmp rax, 0
   633 00008B13 7C21                <1>     jl .close_menu
   634 00008B15 4831D2              <1>     xor rdx, rdx
   635 00008B18 B91C000000          <1>     mov rcx, MENU_ITEM_H
   636 00008B1D 48F7F1              <1>     div rcx
   637                              <1> 
   638                              <1>     ; Validate range
   639 00008B20 4883F806            <1>     cmp rax, MENU_ITEM_COUNT
   640 00008B24 7D10                <1>     jge .close_menu
   641                              <1> 
