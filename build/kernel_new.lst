    18                              <1> ; Taskbar button layout
    19                              <1> TB_BTN_START_X  equ (START_BTN_X + START_BTN_W + 8)  ; after start button
    20                              <1> TB_BTN_W        equ 130          ; width per app button
    21                              <1> TB_BTN_H        equ 28
