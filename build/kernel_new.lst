    39                              <1> 
    40 00001296 C705(FC000000)0000- <1>     mov dword [time_seconds], 0
    40 0000129E 0000                <1>
    41 000012A0 FF05(00010000)      <1>     inc dword [time_minutes]
    42 000012A6 833D(00010000)3C    <1>     cmp dword [time_minutes], 60
    43 000012AD 7C23                <1>     jl .done
    44                              <1> 
    45 000012AF C705(00010000)0000- <1>     mov dword [time_minutes], 0
    45 000012B7 0000                <1>
    46 000012B9 FF05(04010000)      <1>     inc dword [time_hours]
    47 000012BF 833D(04010000)18    <1>     cmp dword [time_hours], 24
    48 000012C6 7C0A                <1>     jl .done
    49 000012C8 C705(04010000)0000- <1>     mov dword [time_hours], 0
    49 000012D0 0000                <1>
