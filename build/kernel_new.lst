   243                              <1>     ; === FAST PATH: No clipping needed ===
   244                              <1>     ; Pre-calculate row start in back buffer
   245 00002712 4489D8              <1>     mov eax, r11d
   246 00002715 0FAF05(56020000)    <1>     imul eax, [scr_pitch]
   247 0000271C 67428D0490          <1>     lea eax, [eax + r10d * 4]
   248 00002721 4C8B35(46020000)    <1>     mov r14, [bb_addr]
   249 00002728 4901C6              <1>     add r14, rax              ; r14 = pointer to first pixel of char in BB
   250                              <1> 
   251 0000272B 4C633D(56020000)    <1>     movsxd r15, dword [scr_pitch]  ; pitch for row advance
   252                              <1> 
