   615 000029FE 660FE75F30          <1>     movntdq [rdi + 48], xmm3
   616 00002A03 660FE76740          <1>     movntdq [rdi + 64], xmm4
   617 00002A08 660FE76F50          <1>     movntdq [rdi + 80], xmm5
   618 00002A0D 660FE77760          <1>     movntdq [rdi + 96], xmm6
   619 00002A12 660FE77F70          <1>     movntdq [rdi + 112], xmm7
