    77                                  section .text
    78                                  %include "src/drivers/spi.asm"
     1                              <1> ; ============================================================================
     2                              <1> ; NexusOS v3.0 - SPI Controller Driver
     3                              <1> ; Supports:
     4                              <1> ;   - AMD FCH GSPI (fixed MMIO 0xFEC00000)
     5                              <1> ;   - AMD Sensor Fusion Hub (PCI 0x1022:0x15E4, BAR0)
     6                              <1> ;   - Intel GSPI (PCI 0x8086:various, BAR0 = DW SPI MMIO)
     7                              <1> ; ============================================================================
     8                              <1> bits 64
     9                              <1> 
    10                              <1> %include "constants.inc"
     1                              <2> ; ============================================================================
     2                              <2> ; NexusOS v3.0 - System Constants
     3                              <2> ; ============================================================================
     4                              <2> 
     5                              <2> ; --- Memory Layout ---
     6                              <2> STAGE2_LOAD_ADDR    equ 0x7E00       ; Stage 2 load address
     7                              <2> E820_COUNT_ADDR     equ 0x1FF0       ; Number of E820 entries (dword)
     8                              <2> E820_MAP_ADDR       equ 0x2000       ; E820 memory map entries
     9                              <2> VBE_INFO_ADDR       equ 0x9000       ; VBE mode info block
    10                              <2> BOOT_DRIVE_ADDR     equ 0x9100       ; Saved boot drive number (byte)
    11                              <2> PAGE_TABLE_ADDR     equ 0x70000      ; PML4 page table base
    12                              <2> KERNEL_LOAD_ADDR    equ 0x100000     ; 1MB - kernel load address
    13                              <2> KERNEL_STACK_TOP    equ 0x200000     ; 2MB - top of kernel stack
    14                              <2> IDT_ADDR            equ 0x200000     ; IDT location (same as stack top for now, risky? No, IDT is small)
    15                              <2> ; IDT is 256*16 = 4KB. If stack grows down from 2MB, IDT at 2MB grows up?
    16                              <2> ; IDT structure is fixed size.
    17                              <2> ; If Stack Top is 0x200000, IDT at 0x200000 overlaps stack top!
    18                              <2> ; Stack grows DOWN. IDT grows UP (fixed size).
    19                              <2> ; If IDT is at 0x200000, it occupies 0x200000 to 0x201000.
    20                              <2> ; If Stack starts at 0x200000, a push writes to 0x1FFFF8.
    21                              <2> ; So they don't overlap. This is safe.
    22                              <2> 
    23                              <2> KERNEL_DATA_ADDR    equ 0x210000     ; Kernel data/heap
    24                              <2> PAGE_BITMAP_ADDR    equ 0x300000     ; Physical page bitmap
    25                              <2> BACK_BUFFER_ADDR    equ 0x400000     ; Display back buffer
    26                              <2> BACK_BUFFER_SAVE_ADDR equ 0xA00000     ; Saved back buffer (at 10MB)
    27                              <2> CURSOR_BG_ADDR      equ 0x700000     ; Cursor background save area
    28                              <2> WINDOW_POOL_ADDR    equ 0x710000     ; Window structure pool
    29                              <2> EVENT_BUFFER_ADDR   equ 0x720000     ; Event buffers
    30                              <2> APP_DATA_ADDR       equ 0x800000     ; Application data
    31                              <2> APP_SLOT_SIZE       equ 0x10000      ; 64 KB private app arena per window/process
    32                              <2> L3_SYSCALL_STACK_ADDR equ 0xC00000   ; Kernel-only syscall stacks
    33                              <2> 
    34                              <2> ; --- Stage 2 disk layout ---
    35                              <2> STAGE2_SECTORS      equ 63           ; Sectors 1-63
    36                              <2> KERNEL_START_SECTOR equ 64           ; Kernel starts at sector 64
    37                              <2> KERNEL_SECTORS      equ 256          ; 128KB max kernel
    38                              <2> 
    39                              <2> ; --- Screen ---
    40                              <2> SCREEN_WIDTH        equ 1024
    41                              <2> SCREEN_HEIGHT       equ 768
    42                              <2> SCREEN_BPP          equ 32
    43                              <2> SCREEN_PITCH        equ (SCREEN_WIDTH * 4)   ; 4096 bytes per scanline
    44                              <2> FRAMEBUFFER_SIZE    equ (SCREEN_WIDTH * SCREEN_HEIGHT * 4)  ; 3145728 = ~3MB
    45                              <2> 
    46                              <2> 
    47                              <2> ; --- VBE info offsets (at VBE_INFO_ADDR) ---
    48                              <2> VBE_FB_ADDR_OFF     equ 0x00         ; Framebuffer physical address (8 bytes)
    49                              <2> VBE_WIDTH_OFF       equ 0x08         ; Screen width (4 bytes)
    50                              <2> VBE_HEIGHT_OFF      equ 0x0C         ; Screen height (4 bytes)
    51                              <2> VBE_PITCH_OFF       equ 0x10         ; Bytes per scanline (4 bytes)
    52                              <2> VBE_BPP_OFF         equ 0x14         ; Bits per pixel (4 bytes)
    53                              <2> VBE_SPP_OFF         equ 0x18         ; EFI_SIMPLE_POINTER_PROTOCOL interface ptr (qword, 0=none)
    54                              <2> 
    55                              <2> ; --- Colors (32-bit 0x00RRGGBB, stored as BGRX in memory) ---
    56                              <2> COLOR_BLACK         equ 0x00000000
    57                              <2> COLOR_WHITE         equ 0x00FFFFFF
    58                              <2> COLOR_DESKTOP_BG    equ 0x00335577   ; Blue-gray desktop
    59                              <2> COLOR_TASKBAR_BG    equ 0x001A1A2E   ; Dark blue-gray taskbar
    60                              <2> COLOR_TASKBAR_TOP   equ 0x002A2A4E   ; Taskbar top highlight
    61                              <2> COLOR_TITLEBAR      equ 0x000055AA   ; Blue title bar (focused)
    62                              <2> COLOR_TITLEBAR_UNF  equ 0x00555555   ; Gray title bar (unfocused)
    63                              <2> COLOR_WINDOW_BG     equ 0x00F0F0F0   ; Light gray window background
    64                              <2> COLOR_WINDOW_BORDER equ 0x00333333   ; Window border
    65                              <2> COLOR_CLOSE_BTN     equ 0x00CC2222   ; Red close button
    66                              <2> COLOR_CLOSE_HOVER   equ 0x00FF4444   ; Red close hover
    67                              <2> COLOR_MIN_BTN       equ 0x00CCAA22   ; Yellow minimize button
    68                              <2> COLOR_TEXT_WHITE     equ 0x00FFFFFF
    69                              <2> COLOR_TEXT_BLACK     equ 0x00000000
    70                              <2> COLOR_TEXT_GRAY      equ 0x00888888
    71                              <2> COLOR_TEXT_TITLE     equ 0x00FFFFFF   ; Title bar text
    72                              <2> COLOR_HIGHLIGHT      equ 0x003399FF   ; Selection highlight
    73                              <2> COLOR_CURSOR         equ 0x00FFFFFF   ; Cursor color
    74                              <2> COLOR_START_BTN      equ 0x00226622   ; Start button green
    75                              <2> COLOR_START_HOVER    equ 0x00338833
    76                              <2> 
    77                              <2> ; --- Window Manager ---
    78                              <2> MAX_WINDOWS         equ 8
    79                              <2> WINDOW_STRUCT_SIZE  equ 256          ; Bytes per window struct
    80                              <2> L3_USER_STACK_SIZE  equ 16384        ; 16 KB user stack per L3 window callback context
    81                              <2> L3_SYSCALL_STACK_SIZE equ 4096       ; 4 KB syscall stack per L3 context
    82                              <2> TITLEBAR_HEIGHT     equ 24
    83                              <2> BORDER_WIDTH        equ 2
    84                              <2> CLOSE_BTN_SIZE      equ 18
    85                              <2> MIN_BTN_SIZE        equ 18
    86                              <2> MIN_WINDOW_W        equ 200
    87                              <2> MIN_WINDOW_H        equ 100
    88                              <2> 
    89                              <2> ; --- Taskbar ---
    90                              <2> TASKBAR_HEIGHT      equ 36
    91                              <2> TASKBAR_Y           equ (SCREEN_HEIGHT - TASKBAR_HEIGHT)
    92                              <2> START_BTN_W         equ 70
    93                              <2> START_BTN_H         equ 28
    94                              <2> START_BTN_X         equ 4
    95                              <2> START_BTN_Y         equ (TASKBAR_Y + 4)
    96                              <2> CLOCK_WIDTH         equ 64
    97                              <2> CLOCK_X             equ (SCREEN_WIDTH - CLOCK_WIDTH - 8)
    98                              <2> CLOCK_Y             equ (TASKBAR_Y + 10)
    99                              <2> 
   100                              <2> ; --- Keyboard ---
   101                              <2> KB_BUFFER_SIZE      equ 64
   102                              <2> 
   103                              <2> ; --- Mouse ---
   104                              <2> MOUSE_BUFFER_SIZE   equ 64
   105                              <2> CURSOR_WIDTH        equ 12
   106                              <2> CURSOR_HEIGHT       equ 19
   107                              <2> 
   108                              <2> ; --- PIT ---
   109                              <2> PIT_FREQUENCY       equ 100          ; 100Hz = 10ms per tick
   110                              <2> PIT_DIVISOR         equ 11932        ; 1193182 / 100
   111                              <2> 
   112                              <2> ; --- PIC vectors ---
   113                              <2> IRQ_BASE_MASTER     equ 32
   114                              <2> IRQ_BASE_SLAVE      equ 40
   115                              <2> IRQ_TIMER           equ 32           ; IRQ0 -> vector 32
   116                              <2> IRQ_KEYBOARD        equ 33           ; IRQ1 -> vector 33
   117                              <2> IRQ_CASCADE         equ 34           ; IRQ2 -> vector 34
   118                              <2> IRQ_MOUSE           equ 44           ; IRQ12 -> vector 44
   119                              <2> 
   120                              <2> ; --- Font ---
   121                              <2> FONT_WIDTH          equ 8
   122                              <2> FONT_HEIGHT         equ 16
   123                              <2> FONT_FIRST_CHAR     equ 32           ; Space
   124                              <2> FONT_LAST_CHAR      equ 126          ; Tilde
   125                              <2> FONT_NUM_CHARS      equ 95           ; 126 - 32 + 1
   126                              <2> 
   127                              <2> ; --- Window flags ---
   128                              <2> WF_VISIBLE          equ 0x01
   129                              <2> WF_FOCUSED          equ 0x02
   130                              <2> WF_DRAGGING         equ 0x04
   131                              <2> WF_MINIMIZED        equ 0x08
   132                              <2> WF_ACTIVE           equ 0x10         ; Slot is in use
   133                              <2> 
   134                              <2> ; --- Mouse event types ---
   135                              <2> MEVT_MOVE           equ 1
   136                              <2> MEVT_LCLICK         equ 2
   137                              <2> MEVT_RCLICK         equ 3
   138                              <2> MEVT_LRELEASE       equ 4
   139                              <2> MEVT_RRELEASE       equ 5
   140                              <2> 
   141                              <2> ; --- Key modifier flags ---
   142                              <2> KMOD_SHIFT          equ 0x01
   143                              <2> KMOD_CTRL           equ 0x02
   144                              <2> KMOD_ALT            equ 0x04
   145                              <2> 
   146                              <2> ; --- Virtual Key Codes (ASCII byte in kb_buffer for non-printable keys) ---
   147                              <2> KEY_F1              equ 0xF1
   148                              <2> KEY_F2              equ 0xF2
   149                              <2> KEY_F3              equ 0xF3
   150                              <2> KEY_F4              equ 0xF4
   151                              <2> KEY_F5              equ 0xF5
   152                              <2> KEY_F6              equ 0xF6
   153                              <2> KEY_F7              equ 0xF7
   154                              <2> KEY_F8              equ 0xF8
   155                              <2> KEY_F9              equ 0xF9
   156                              <2> KEY_F10             equ 0xFA
   157                              <2> KEY_F11             equ 0xFB
   158                              <2> KEY_F12             equ 0xFC
   159                              <2> 
   160                              <2> ; --- USB/XHCI Memory Layout ---
   161                              <2> XHCI_DCBAA_ADDR     equ 0x900000     ; Device Context Base Address Array
   162                              <2> XHCI_CMD_RING_ADDR  equ 0x910000     ; Command Ring (4096 TRBs)
   163                              <2> XHCI_ERST_ADDR      equ 0x920000     ; Event Ring Segment Table
   164                              <2> XHCI_EVT_RING_ADDR  equ 0x930000     ; Event Ring (4096 TRBs)
   165                              <2> XHCI_SCRATCH_ADDR   equ 0x940000     ; Scratchpad array + buffers
   166                              <2> XHCI_DEV_CTX_ADDR   equ 0x950000     ; Output Device Context (slot 1)
   167                              <2> XHCI_INPUT_CTX_ADDR equ 0x960000     ; Input Context
   168                              <2> XHCI_CTRL_RING_ADDR equ 0x970000     ; Control EP0 Transfer Ring
   169                              <2> XHCI_INT_RING_ADDR  equ 0x980000     ; Interrupt IN Transfer Ring
   170                              <2> XHCI_CTRL_BUF_ADDR  equ 0x990000     ; Control transfer data buffers
   171                              <2> XHCI_MOUSE_BUF_ADDR equ 0x9A0000     ; Mouse interrupt data buffers (slot 1)
   172                              <2> ; Slot 2 device support
   173                              <2> XHCI_DEV_CTX2_ADDR  equ 0x9B0000     ; Output Device Context (slot 2)
   174                              <2> XHCI_INT_RING2_ADDR equ 0x9C0000     ; Interrupt IN Transfer Ring (slot 2)
   175                              <2> XHCI_MOUSE_BUF2_ADDR equ 0x9D0000   ; Mouse interrupt data buffers (slot 2)
   176                              <2> XHCI_CTRL_RING2_ADDR equ 0x9E0000   ; Control EP0 Transfer Ring (slot 2)
   177                              <2> XHCI_MEM_END        equ 0x9F0000     ; End of XHCI memory region
   178                              <2> 
   179                              <2> ; --- XHCI Capability Register Offsets (from MMIO base) ---
   180                              <2> XHCI_CAP_CAPLENGTH  equ 0x00
   181                              <2> XHCI_CAP_HCSPARAMS1 equ 0x04
   182                              <2> XHCI_CAP_HCSPARAMS2 equ 0x08
   183                              <2> XHCI_CAP_HCCPARAMS1 equ 0x10
   184                              <2> XHCI_CAP_DBOFF      equ 0x14
   185                              <2> XHCI_CAP_RTSOFF     equ 0x18
   186                              <2> 
   187                              <2> ; --- XHCI Operational Register Offsets (from OpBase) ---
   188                              <2> XHCI_OP_USBCMD      equ 0x00
   189                              <2> XHCI_OP_USBSTS      equ 0x04
   190                              <2> XHCI_OP_PAGESIZE     equ 0x08
   191                              <2> XHCI_OP_DNCTRL      equ 0x14
   192                              <2> XHCI_OP_CRCR_LO     equ 0x18
   193                              <2> XHCI_OP_CRCR_HI     equ 0x1C
   194                              <2> XHCI_OP_DCBAAP_LO   equ 0x30
   195                              <2> XHCI_OP_DCBAAP_HI   equ 0x34
   196                              <2> XHCI_OP_CONFIG      equ 0x38
   197                              <2> 
   198                              <2> ; --- XHCI Port Register Offsets (from OpBase + 0x400) ---
   199                              <2> XHCI_PORTSC         equ 0x00
   200                              <2> XHCI_PORT_REG_SIZE  equ 0x10         ; 16 bytes per port
   201                              <2> 
   202                              <2> ; --- XHCI Runtime Register Offsets (from RtBase) ---
   203                              <2> XHCI_RT_IR0_IMAN    equ 0x20
   204                              <2> XHCI_RT_IR0_IMOD    equ 0x24
   205                              <2> XHCI_RT_IR0_ERSTSZ  equ 0x28
   206                              <2> XHCI_RT_IR0_ERSTBA_LO equ 0x30
   207                              <2> XHCI_RT_IR0_ERSTBA_HI equ 0x34
   208                              <2> XHCI_RT_IR0_ERDP_LO equ 0x38
   209                              <2> XHCI_RT_IR0_ERDP_HI equ 0x3C
   210                              <2> 
   211                              <2> ; --- USBCMD bits ---
   212                              <2> XHCI_CMD_RS         equ (1 << 0)     ; Run/Stop
   213                              <2> XHCI_CMD_HCRST      equ (1 << 1)     ; Host Controller Reset
   214                              <2> XHCI_CMD_INTE       equ (1 << 2)     ; Interrupter Enable
   215                              <2> 
   216                              <2> ; --- USBSTS bits ---
   217                              <2> XHCI_STS_HCH        equ (1 << 0)     ; HC Halted
   218                              <2> XHCI_STS_CNR        equ (1 << 11)    ; Controller Not Ready
   219                              <2> 
   220                              <2> ; --- PORTSC bits ---
   221                              <2> XHCI_PORTSC_CCS     equ (1 << 0)     ; Current Connect Status
   222                              <2> XHCI_PORTSC_PED     equ (1 << 1)     ; Port Enabled/Disabled
   223                              <2> XHCI_PORTSC_PR      equ (1 << 4)     ; Port Reset
   224                              <2> XHCI_PORTSC_PLS_SHIFT equ 5          ; Port Link State shift
   225                              <2> XHCI_PORTSC_PP      equ (1 << 9)     ; Port Power
   226                              <2> XHCI_PORTSC_SPEED_SHIFT equ 10       ; Port Speed shift
   227                              <2> XHCI_PORTSC_CSC     equ (1 << 17)    ; Connect Status Change
   228                              <2> XHCI_PORTSC_PRC     equ (1 << 21)    ; Port Reset Change
   229                              <2> ; Bits that are RW1CS (write 1 to clear) - must preserve when writing other bits
   230                              <2> XHCI_PORTSC_CHANGE_BITS equ ((1<<17)|(1<<18)|(1<<20)|(1<<21)|(1<<22)|(1<<23))
   231                              <2> 
   232                              <2> ; --- TRB Types (shifted into bits 15:10 of dword 3) ---
   233                              <2> TRB_NORMAL           equ (1 << 10)
   234                              <2> TRB_SETUP            equ (2 << 10)
   235                              <2> TRB_DATA             equ (3 << 10)
   236                              <2> TRB_STATUS           equ (4 << 10)
   237                              <2> TRB_LINK             equ (6 << 10)
   238                              <2> TRB_ENABLE_SLOT      equ (9 << 10)
   239                              <2> TRB_ADDRESS_DEV      equ (11 << 10)
   240                              <2> TRB_CONFIG_EP        equ (12 << 10)
   241                              <2> TRB_EVAL_CTX         equ (13 << 10)
   242                              <2> TRB_TRANSFER_EVT     equ (32 << 10)
   243                              <2> TRB_CMD_COMPLETION   equ (33 << 10)
   244                              <2> TRB_PORT_STATUS_CHG  equ (34 << 10)
   245                              <2> 
   246                              <2> ; --- TRB Flag Bits (dword 3) ---
   247                              <2> TRB_CYCLE            equ (1 << 0)     ; Cycle bit
   248                              <2> TRB_TC               equ (1 << 1)     ; Toggle Cycle (Link TRB)
   249                              <2> TRB_IOC              equ (1 << 5)     ; Interrupt On Completion
   250                              <2> TRB_IDT              equ (1 << 6)     ; Immediate Data
   251                              <2> TRB_BSR              equ (1 << 9)     ; Block Set Address Request
   252                              <2> 
   253                              <2> ; --- TRB Setup stage Transfer Type (bits 17:16 of dword 3) ---
   254                              <2> TRB_TRT_NO_DATA      equ (0 << 16)
   255                              <2> TRB_TRT_OUT          equ (2 << 16)
   256                              <2> TRB_TRT_IN           equ (3 << 16)
   257                              <2> 
   258                              <2> ; --- TRB Data stage Direction (bit 16 of dword 3) ---
   259                              <2> TRB_DIR_OUT          equ (0 << 16)
   260                              <2> TRB_DIR_IN           equ (1 << 16)
   261                              <2> 
   262                              <2> ; --- Ring sizes ---
   263                              <2> XHCI_RING_SIZE       equ 4096         ; TRBs per ring (64KB)
   264                              <2> XHCI_TRB_SIZE        equ 16           ; Bytes per TRB
   265                              <2> 
   266                              <2> ; --- USB Standard Request Codes ---
   267                              <2> USB_REQ_GET_DESC     equ 0x06
   268                              <2> USB_REQ_SET_CONFIG   equ 0x09
   269                              <2> USB_REQ_SET_IFACE    equ 0x0B
   270                              <2> 
   271                              <2> ; --- USB HID Request Codes ---
   272                              <2> USB_HID_SET_PROTOCOL equ 0x0B
   273                              <2> 
   274                              <2> ; --- USB Descriptor Types ---
   275                              <2> USB_DESC_DEVICE      equ 0x01
   276                              <2> USB_DESC_CONFIG      equ 0x02
   277                              <2> USB_DESC_INTERFACE   equ 0x04
   278                              <2> USB_DESC_ENDPOINT    equ 0x05
   279                              <2> USB_DESC_HID         equ 0x21
   280                              <2> 
   281                              <2> ; --- USB Endpoint Types ---
   282                              <2> USB_EP_CONTROL       equ 0
   283                              <2> USB_EP_ISOCH         equ 1
   284                              <2> USB_EP_BULK          equ 2
   285                              <2> USB_EP_INTERRUPT     equ 3
   286                              <2> 
   287                              <2> ; --- XHCI Endpoint Types (for Endpoint Context) ---
   288                              <2> XHCI_EP_NOT_VALID    equ 0
   289                              <2> XHCI_EP_ISOCH_OUT    equ 1
   290                              <2> XHCI_EP_BULK_OUT     equ 2
   291                              <2> XHCI_EP_INT_OUT      equ 3
   292                              <2> XHCI_EP_CONTROL      equ 4
   293                              <2> XHCI_EP_ISOCH_IN     equ 5
   294                              <2> XHCI_EP_BULK_IN      equ 6
   295                              <2> XHCI_EP_INT_IN       equ 7
   296                              <2> 
   297                              <2> ; --- XHCI Port Speeds ---
   298                              <2> XHCI_SPEED_FULL      equ 1
   299                              <2> XHCI_SPEED_LOW       equ 2
   300                              <2> XHCI_SPEED_HIGH      equ 3
   301                              <2> XHCI_SPEED_SUPER     equ 4
    11                              <1> 
    12                              <1> extern pci_read_conf_dword
    13                              <1> extern debug_print
    14                              <1> 
    15                              <1> ; DesignWare SPI register offsets
    16                              <1> %define DW_SPI_CTRLR0     0x00   ; Control 0
    17                              <1> %define DW_SPI_CTRLR1     0x04   ; Control 1 (NDF-1 for receive-only)
    18                              <1> %define DW_SPI_SSIENR     0x08   ; Enable (1=enabled)
    19                              <1> %define DW_SPI_SER        0x10   ; Slave enable register
    20                              <1> %define DW_SPI_BAUDR      0x14   ; Baud rate (div = ssi_clk / SCLK)
    21                              <1> %define DW_SPI_TXFTLR     0x18   ; TX FIFO threshold
    22                              <1> %define DW_SPI_RXFTLR     0x1C   ; RX FIFO threshold
    23                              <1> %define DW_SPI_TXFLR      0x20   ; TX FIFO level
    24                              <1> %define DW_SPI_RXFLR      0x24   ; RX FIFO level
    25                              <1> %define DW_SPI_SR         0x28   ; Status (bit0=busy, bit1=TFNF, bit2=TFE, bit3=RFNE)
    26                              <1> %define DW_SPI_DR         0x60   ; Data register (FIFO read/write)
    27                              <1> 
    28                              <1> ; CTRLR0 fields: DFS[3:0]=7 (8-bit), TMOD[9:8]=0 (TX+RX), SCPOL=0, SCPH=0
    29                              <1> %define SPI_CTRLR0_8BIT   0x00000007
    30                              <1> ; AMD FCH GSPI fixed base
    31                              <1> %define AMD_FCH_GSPI_BASE  0xFEC00000
    32                              <1> 
    33                              <1> ; Intel GSPI PCI vendor/device
    34                              <1> %define INTEL_VENDOR       0x8086
    35                              <1> ; AMD Sensor Fusion Hub PCI ID
    36                              <1> %define AMD_VENDOR         0x1022
    37                              <1> %define AMD_SFH_DEVID      0x15E4
    38                              <1> 
    39                              <1> section .text
    40                              <1> global spi_init
    41                              <1> global spi_transfer
    42                              <1> global spi_type
    43                              <1> 
    44                              <1> ; ============================================================================
    45                              <1> ; spi_init - Detect and initialize SPI controller
    46                              <1> ; Returns: EAX = 1 success, 0 fail
    47                              <1> ; Sets spi_base and spi_type
    48                              <1> ; ============================================================================
    49                              <1> spi_init:
    50 00005669 53                  <1>     push rbx
    51 0000566A 51                  <1>     push rcx
    52 0000566B 52                  <1>     push rdx
    53 0000566C 57                  <1>     push rdi
    54 0000566D 4155                <1>     push r13
    55 0000566F 4156                <1>     push r14
    56 00005671 4157                <1>     push r15
    57                              <1> 
    58 00005673 C605(0A090000)00    <1>     mov byte [spi_type], 0
    59 0000567A 48C705(02090000)00- <1>     mov qword [spi_base], 0
    59 00005682 000000              <1>
    60                              <1> 
    61                              <1>     ; === Phase 1: Try AMD FCH GSPI at fixed MMIO ===
    62                              <1>     ; NOTE: 0xFEC00000 is also the IOAPIC base in QEMU - must verify DW SPI signature.
    63                              <1>     ; A real idle DW SPI SR has TFE(bit2)+TFNF(bit1) set = bits [2:1] = 0x06.
    64                              <1>     ; The IOAPIC at this address returns values without this pattern.
    65 00005685 41BF0000C0FE        <1>     mov r15, AMD_FCH_GSPI_BASE
    66 0000568B 418B4728            <1>     mov eax, [r15 + DW_SPI_SR]
    67 0000568F 83F8FF              <1>     cmp eax, 0xFFFFFFFF
    68 00005692 741D                <1>     je .try_pci
    69                              <1>     ; Verify DW SPI idle signature: bits [2:1] must be set (TFE+TFNF)
    70 00005694 89C1                <1>     mov ecx, eax
    71 00005696 83E106              <1>     and ecx, 0x06
    72 00005699 83F906              <1>     cmp ecx, 0x06
    73 0000569C 7513                <1>     jne .try_pci
    74                              <1> 
    75                              <1>     ; Confirmed DW SPI - init it
    76 0000569E 4C893D(02090000)    <1>     mov [spi_base], r15
    77 000056A5 C605(0A090000)01    <1>     mov byte [spi_type], SPI_TYPE_AMD_FCH
    78 000056AC E9EF000000          <1>     jmp .init_dw_spi
    79                              <1> 
    80                              <1> .try_pci:
    81                              <1>     ; === Phase 2: PCI scan for AMD SFH and Intel GSPI ===
    82 000056B1 4531ED              <1>     xor r13d, r13d          ; bus
    83                              <1> .pci_bus:
    84 000056B4 4181FD00010000      <1>     cmp r13d, 256
    85 000056BB 0F8DDB000000        <1>     jge .fail
    86 000056C1 4531F6              <1>     xor r14d, r14d          ; device
    87                              <1> .pci_dev:
    88 000056C4 4183FE20            <1>     cmp r14d, 32
    89 000056C8 0F8DC6000000        <1>     jge .next_bus
    90                              <1>     ; Read vendor/device at func 0
    91 000056CE 4489E8              <1>     mov eax, r13d
    92 000056D1 C1E010              <1>     shl eax, 16
    93 000056D4 4489F1              <1>     mov ecx, r14d
    94 000056D7 C1E10B              <1>     shl ecx, 11
    95 000056DA 09C8                <1>     or eax, ecx
    96                              <1>     ; reg 0 = vendorID:deviceID
    97 000056DC 50                  <1>     push rax
    98 000056DD E816E2FFFF          <1>     call pci_read_conf_dword
    99 000056E2 83F8FF              <1>     cmp eax, 0xFFFFFFFF
   100 000056E5 0F84A0000000        <1>     je .pci_next
   101                              <1> 
   102                              <1>     ; Check AMD SFH
   103 000056EB 89C1                <1>     mov ecx, eax
   104 000056ED 81E1FFFF0000        <1>     and ecx, 0xFFFF         ; vendor
   105 000056F3 81F922100000        <1>     cmp ecx, AMD_VENDOR
   106 000056F9 7533                <1>     jne .check_intel
   107 000056FB C1E810              <1>     shr eax, 16             ; device ID
   108 000056FE 3DE4150000          <1>     cmp eax, AMD_SFH_DEVID
   109 00005703 0F8582000000        <1>     jne .pci_next
   110                              <1>     ; Found AMD SFH - get BAR0
   111 00005709 58                  <1>     pop rax
   112 0000570A 50                  <1>     push rax
   113 0000570B 83C810              <1>     or eax, 0x10            ; BAR0 register
   114 0000570E E8E5E1FFFF          <1>     call pci_read_conf_dword
   115 00005713 83E0F0              <1>     and eax, 0xFFFFFFF0
   116 00005716 85C0                <1>     test eax, eax
   117 00005718 7471                <1>     jz .pci_next
   118 0000571A 4189C7              <1>     mov r15d, eax          ; BAR0 as 32-bit (< 4GB)
   119 0000571D 4C893D(02090000)    <1>     mov [spi_base], r15
   120 00005724 C605(0A090000)02    <1>     mov byte [spi_type], SPI_TYPE_AMD_SFH
   121 0000572B 58                  <1>     pop rax
   122 0000572C EB72                <1>     jmp .init_dw_spi
   123                              <1> 
   124                              <1> .check_intel:
   125                              <1>     ; Check Intel GSPI: vendor 0x8086, class 0x0C80 or specific device IDs
   126 0000572E 25FFFF0000          <1>     and eax, 0xFFFF         ; restore vendor
   127 00005733 3D86800000          <1>     cmp eax, INTEL_VENDOR
   128 00005738 7551                <1>     jne .pci_next
   129                              <1>     ; Read class code
   130 0000573A 58                  <1>     pop rax
   131 0000573B 50                  <1>     push rax
   132 0000573C 83C808              <1>     or eax, 0x08
   133 0000573F E8B4E1FFFF          <1>     call pci_read_conf_dword
   134 00005744 C1E808              <1>     shr eax, 8              ; class:subclass:prog_if
   135 00005747 25FFFF0000          <1>     and eax, 0xFFFF
   136 0000574C 3D800C0000          <1>     cmp eax, 0x0C80         ; Serial Bus / Other
   137 00005751 7407                <1>     je .intel_spi_candidate
   138                              <1>     ; Also accept class 0x0C00 SPI
   139 00005753 3D000C0000          <1>     cmp eax, 0x0C00
   140 00005758 7531                <1>     jne .pci_next
   141                              <1> .intel_spi_candidate:
   142                              <1>     ; Read BAR0
   143 0000575A 58                  <1>     pop rax
   144 0000575B 50                  <1>     push rax
   145 0000575C 83C810              <1>     or eax, 0x10
   146 0000575F E894E1FFFF          <1>     call pci_read_conf_dword
   147 00005764 83E0F0              <1>     and eax, 0xFFFFFFF0
   148 00005767 85C0                <1>     test eax, eax
   149 00005769 7420                <1>     jz .pci_next
   150                              <1>     ; Verify DW SPI signature: SR should read 0x00000006 when idle (TFE+TFNF)
   151 0000576B 4189C7              <1>     mov r15d, eax
   152 0000576E 418B4F28            <1>     mov ecx, [r15 + DW_SPI_SR]
   153 00005772 83E106              <1>     and ecx, 0x06
   154 00005775 83F906              <1>     cmp ecx, 0x06
   155 00005778 7511                <1>     jne .pci_next
   156 0000577A 4C893D(02090000)    <1>     mov [spi_base], r15
   157 00005781 C605(0A090000)03    <1>     mov byte [spi_type], SPI_TYPE_INTEL_GSPI
   158 00005788 58                  <1>     pop rax
   159 00005789 EB15                <1>     jmp .init_dw_spi
   160                              <1> 
   161                              <1> .pci_next:
   162 0000578B 58                  <1>     pop rax
   163 0000578C 41FFC6              <1>     inc r14d
   164 0000578F E930FFFFFF          <1>     jmp .pci_dev
   165                              <1> .next_bus:
   166 00005794 41FFC5              <1>     inc r13d
   167 00005797 E918FFFFFF          <1>     jmp .pci_bus
   168                              <1> 
   169                              <1> .fail:
   170 0000579C 31C0                <1>     xor eax, eax
   171 0000579E EB4C                <1>     jmp .ret
   172                              <1> 
   173                              <1> .init_dw_spi:
   174                              <1>     ; Disable SPI controller
   175 000057A0 4C8B3D(02090000)    <1>     mov r15, [spi_base]
   176 000057A7 41C7470800000000    <1>     mov dword [r15 + DW_SPI_SSIENR], 0
   177                              <1> 
   178                              <1>     ; Configure: 8-bit, master, Motorola mode 0 (CPOL=0, CPHA=0)
   179 000057AF 41C70707000000      <1>     mov dword [r15 + DW_SPI_CTRLR0], SPI_CTRLR0_8BIT
   180                              <1> 
   181                              <1>     ; Baud rate: safe slow rate for init (div=64)
   182 000057B6 41C7471440000000    <1>     mov dword [r15 + DW_SPI_BAUDR], 64
   183                              <1> 
   184                              <1>     ; Slave select: CS0
   185 000057BE 41C7471001000000    <1>     mov dword [r15 + DW_SPI_SER], 1
   186                              <1> 
   187                              <1>     ; FIFO thresholds
   188 000057C6 41C7471800000000    <1>     mov dword [r15 + DW_SPI_TXFTLR], 0
   189 000057CE 41C7471C00000000    <1>     mov dword [r15 + DW_SPI_RXFTLR], 0
   190                              <1> 
   191                              <1>     ; Enable
   192 000057D6 41C7470801000000    <1>     mov dword [r15 + DW_SPI_SSIENR], 1
   193                              <1> 
   194                              <1>     ; Verify not frozen
   195 000057DE 418B4728            <1>     mov eax, [r15 + DW_SPI_SR]
   196 000057E2 83F8FF              <1>     cmp eax, 0xFFFFFFFF
   197 000057E5 74B5                <1>     je .fail
   198                              <1> 
   199 000057E7 B801000000          <1>     mov eax, 1
   200                              <1> .ret:
   201 000057EC 415F                <1>     pop r15
   202 000057EE 415E                <1>     pop r14
   203 000057F0 415D                <1>     pop r13
   204 000057F2 5F                  <1>     pop rdi
   205 000057F3 5A                  <1>     pop rdx
   206 000057F4 59                  <1>     pop rcx
   207 000057F5 5B                  <1>     pop rbx
   208 000057F6 C3                  <1>     ret
   209                              <1> 
   210                              <1> ; ============================================================================
   211                              <1> ; spi_transfer - Full-duplex SPI transfer (polled)
   212                              <1> ; RDI = TX buffer (or NULL for dummy TX)
   213                              <1> ; RSI = TX length
   214                              <1> ; RDX = RX buffer (or NULL to discard)
   215                              <1> ; RCX = RX length
   216                              <1> ; Returns: EAX = 1 success, 0 fail
   217                              <1> ; ============================================================================
   218                              <1> spi_transfer:
   219 000057F7 53                  <1>     push rbx
   220 000057F8 4150                <1>     push r8
   221 000057FA 4151                <1>     push r9
   222 000057FC 4152                <1>     push r10
   223 000057FE 4153                <1>     push r11
   224 00005800 4154                <1>     push r12
   225                              <1> 
   226 00005802 4C8B05(02090000)    <1>     mov r8, [spi_base]
   227 00005809 4D85C0              <1>     test r8, r8
   228 0000580C 0F8490000000        <1>     jz .fail_xfer
   229                              <1> 
   230                              <1>     ; Total bytes = max(TX, RX)
   231 00005812 4989F3              <1>     mov r11, rsi
   232 00005815 4839F1              <1>     cmp rcx, rsi
   233 00005818 7E03                <1>     jle .tx_start
   234 0000581A 4989CB              <1>     mov r11, rcx
   235                              <1> 
   236                              <1> .tx_start:
   237 0000581D 4D31C9              <1>     xor r9, r9              ; TX index
   238 00005820 4D31D2              <1>     xor r10, r10            ; RX index
   239                              <1> 
   240                              <1> .xfer_loop:
   241 00005823 4D39DA              <1>     cmp r10, r11
   242 00005826 735D                <1>     jae .xfer_done
   243                              <1> 
   244                              <1>     ; --- TX: write byte if TX FIFO not full ---
   245 00005828 418B4028            <1>     mov eax, [r8 + DW_SPI_SR]
   246 0000582C A902000000          <1>     test eax, 0x02          ; TFNF (TX FIFO not full)
   247 00005831 7420                <1>     jz .try_rx
   248                              <1> 
   249 00005833 4D39D9              <1>     cmp r9, r11
   250 00005836 731B                <1>     jae .try_rx             ; Nothing more to send
   251                              <1> 
   252                              <1>     ; Pick byte: from TX buffer or dummy 0
   253 00005838 31C0                <1>     xor eax, eax
   254 0000583A 4885FF              <1>     test rdi, rdi
   255 0000583D 740B                <1>     jz .send_dummy
   256 0000583F 4939F1              <1>     cmp r9, rsi
   257 00005842 7306                <1>     jae .send_dummy
   258 00005844 428A040F            <1>     mov al, byte [rdi + r9]
   259 00005848 EB02                <1>     jmp .do_tx
   260                              <1> .send_dummy:
   261 0000584A 31C0                <1>     xor eax, eax
   262                              <1> .do_tx:
   263 0000584C 41894060            <1>     mov [r8 + DW_SPI_DR], eax
   264 00005850 49FFC1              <1>     inc r9
   265                              <1> 
   266                              <1> .try_rx:
   267                              <1>     ; --- RX: read byte if RX FIFO not empty ---
   268                              <1>     ; Use timeout to avoid infinite loop when hardware is stuck or missing
   269 00005853 41BC10270000        <1>     mov r12d, 10000 ; Skip if no data after reasonable spin
   270                              <1> .wait_rx:
   271 00005859 418B4028            <1>     mov eax, [r8 + DW_SPI_SR]
   272 0000585D A908000000          <1>     test eax, 0x08          ; RFNE (RX FIFO not empty)
   273 00005862 750A                <1>     jnz .do_rx
   274 00005864 41FFCC              <1>     dec r12d
   275 00005867 75F0                <1>     jnz .wait_rx
   276                              <1>     ; Timeout: count this as a missed byte (0) so loop terminates
   277 00005869 49FFC2              <1>     inc r10
   278 0000586C EBB5                <1>     jmp .xfer_loop
   279                              <1> 
   280                              <1> .do_rx:
   281 0000586E 418B4060            <1>     mov eax, [r8 + DW_SPI_DR]
   282 00005872 4885D2              <1>     test rdx, rdx
   283 00005875 7409                <1>     jz .skip_store
   284 00005877 4939CA              <1>     cmp r10, rcx
   285 0000587A 7304                <1>     jae .skip_store
   286 0000587C 42880412            <1>     mov byte [rdx + r10], al
   287                              <1> .skip_store:
   288 00005880 49FFC2              <1>     inc r10
   289 00005883 EB9E                <1>     jmp .xfer_loop
   290                              <1> 
   291                              <1> .xfer_done:
   292                              <1>     ; Wait for not-busy
   293 00005885 41BCA0860100        <1>     mov r12d, 100000
   294                              <1> .wait_idle:
   295 0000588B 418B4028            <1>     mov eax, [r8 + DW_SPI_SR]
   296 0000588F A901000000          <1>     test eax, 0x01          ; BSY
   297 00005894 7405                <1>     jz .xfer_ok
   298 00005896 41FFCC              <1>     dec r12d
   299 00005899 75F0                <1>     jnz .wait_idle
   300                              <1> .xfer_ok:
   301 0000589B B801000000          <1>     mov eax, 1
   302 000058A0 EB02                <1>     jmp .xfer_ret
   303                              <1> .fail_xfer:
   304 000058A2 31C0                <1>     xor eax, eax
   305                              <1> .xfer_ret:
   306 000058A4 415C                <1>     pop r12
   307 000058A6 415B                <1>     pop r11
   308 000058A8 415A                <1>     pop r10
   309 000058AA 4159                <1>     pop r9
   310 000058AC 4158                <1>     pop r8
   311 000058AE 5B                  <1>     pop rbx
   312 000058AF C3                  <1>     ret
   313                              <1> 
   314                              <1> section .data
   315                              <1> global spi_base
   316                              <1> global spi_type
   317                              <1> 
   318                              <1> ; SPI type constants
   319                              <1> SPI_TYPE_AMD_FCH    equ 1
   320                              <1> SPI_TYPE_AMD_SFH    equ 2
