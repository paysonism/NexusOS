   114                              <1> .clip_right:
   115 000025C2 4489C8              <1>     mov eax, r9d
   116 000025C5 4401D8              <1>     add eax, r11d
   117 000025C8 3B05(4E020000)      <1>     cmp eax, [scr_width]
   118 000025CE 7E0A                <1>     jle .clip_top
   119 000025D0 448B1D(4E020000)    <1>     mov r11d, [scr_width]
   120 000025D7 4529CB              <1>     sub r11d, r9d
   121                              <1> .clip_top:
   122 000025DA 4183FA00            <1>     cmp r10d, 0
