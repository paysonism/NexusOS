   646 00000797 48C744243000400000          mov qword [rsp+48], 16384       ; Reset size
   647 000007A0 488B0DA1030000              mov rcx, [v_bs]
   648 000007A7 488B4138                    mov rax, [rcx + BS_GETMEMMAP]
   649 000007AB 488D4C2430                  lea rcx, [rsp+48]               ; &mmap_size
   650 000007B0 488B15F5030000              mov rdx, [v_mmap_buf]           ; buffer
   651 000007B7 4C8D442438                  lea r8, [rsp+56]                ; &map_key
   652 000007BC 4C8D4C2440                  lea r9, [rsp+64]                ; &desc_size
   653 000007C1 488D5C2448                  lea rbx, [rsp+72]
