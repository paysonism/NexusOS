   569                                  ; SETUP_PAGING - Build identity-mapped page tables at 0x70000
   570                                  ; Maps first 4GB with 2MB pages (same as BIOS path)
   571                                  ; ============================================================================
   572                                  setup_paging:
   573 000006DA 53                          push rbx
   574 000006DB 4154                        push r12
   575                                  
   576                                      ; Clear page table area (24KB: PML4 + PDPT + 4*PD)
   577 000006DD BF00000700                  mov rdi, PAGE_TBL_ADDR
   578 000006E2 31C0                        xor eax, eax
   579 000006E4 B900180000                  mov ecx, (6 * 4096) / 4         ; 6 pages, clear as dwords
   580 000006E9 F3AB                        rep stosd
   581                                  
   582                                      ; PML4[0] -> PDPT at 0x71000
   583 000006EB BF00000700                  mov rdi, PAGE_TBL_ADDR           ; 0x70000
   584 000006F0 48C70703100700              mov qword [rdi], 0x71000 | 3     ; Present + Writable
   585                                  
   586                                      ; PDPT[0..3] -> PD tables at 0x72000..0x75000
   587 000006F7 BF00100700                  mov rdi, PAGE_TBL_ADDR + 0x1000  ; 0x71000 = PDPT
   588 000006FC 48C70703200700              mov qword [rdi],    0x72000 | 3
   589 00000703 48C7470803300700            mov qword [rdi+8],  0x73000 | 3
   590 0000070B 48C7471003400700            mov qword [rdi+16], 0x74000 | 3
   591 00000713 48C7471803500700            mov qword [rdi+24], 0x75000 | 3
   592                                  
   593                                      ; Fill 4 Page Directories: 512 entries each, 2MB pages
   594                                      ; Entry format: physical_addr | 0x83 (Present + Writable + PageSize=2MB)
   595 0000071B BF00200700                  mov rdi, PAGE_TBL_ADDR + 0x2000  ; 0x72000 = first PD
   596 00000720 4831DB                      xor rbx, rbx                     ; Starting physical address = 0
   597 00000723 41BC00080000                mov r12d, 512 * 4                ; Total entries across 4 PDs
   598                                  
   599                                  .pt_loop:
   600 00000729 4889D8                      mov rax, rbx
   601 0000072C 480D83000000                or rax, 0x83                     ; Present | Writable | PS (2MB)
   602 00000732 488907                      mov [rdi], rax
   603 00000735 4883C708                    add rdi, 8
   604 00000739 4881C300002000              add rbx, 0x200000               ; Next 2MB
   605 00000740 41FFCC                      dec r12d
   606 00000743 75E4                        jnz .pt_loop
   607                                  
   608 00000745 415C                        pop r12
   609 00000747 5B                          pop rbx
   610 00000748 C3                          ret
