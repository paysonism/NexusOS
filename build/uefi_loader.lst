   619 0000074C 4883EC58                    sub rsp, 88                      ; 16+88=104 → 8 mod 16 (aligned for calls)
   620                                  
   621                                      ; Stack layout (from RSP):
   622                                      ;   [rsp+0..31]  = shadow space for calls
   623                                      ;   [rsp+32]     = 5th arg slot for GetMemoryMap
   624                                      ;   [rsp+48]     = mmap_size (local)
   625                                      ;   [rsp+56]     = map_key (local)
   626                                      ;   [rsp+64]     = desc_size (local)
   627                                      ;   [rsp+72]     = desc_version (local)
