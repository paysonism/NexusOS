use svg2

app "SvgSmoke" { stack = 4096; }

str smoke_svg = "<svg version=\"2\" viewBox=\"0 0 100 100\" style=\"background:rgb(1,2,3)\"><g transform=\"translate(2,3) scale(1,1)\" style=\"fill:#336699;stroke:white;stroke-width:1\"><rect x=\"4\" y=\"4\" width=\"20\" height=\"10\"/><circle cx=\"50\" cy=\"20\" r=\"8\" style=\"fill:#f80\"/><ellipse cx=\"76\" cy=\"22\" rx=\"10\" ry=\"6\" fill=\"green\"/><line x1=\"0\" y1=\"40\" x2=\"100\" y2=\"40\" stroke=\"red\" stroke-width=\"2\"/><clipPath id=\"cp\"><rect x=\"0\" y=\"0\" width=\"50\" height=\"100\"/></clipPath><rect x=\"40\" y=\"44\" width=\"40\" height=\"8\" fill=\"#999\" clip-path=\"url(#cp)\"/><text x=\"8\" y=\"54\" fill=\"white\" text-anchor=\"start\">O<tspan dx=\"2\">K</tspan></text><polygon points=\"10,60 30,60 20,80\" fill=\"blue\"/><polyline points=\"40,60 50,70 60,60\" fill=\"none\" stroke=\"#00ffff\"/><path d=\"M 70 60 Q 80 50 90 60 A 5 5 0 0 1 90 80 Z\" fill=\"none\" stroke=\"#ff00ff\"/></g></svg>";
str pass_msg = "[nxhl] svg2 render pass";
str fail_msg = "[nxhl] svg2 render fail";

fn smoke_draw(win) {
    if svg_render(&smoke_svg, 812, 0, 0, 200, 200) != 0 {
        syscall(SYS_PRINT, &fail_msg);
        return;
    }
    if xml_last_error_code() != XML_ERR_OK {
        syscall(SYS_PRINT, &fail_msg);
        return;
    }
    syscall(SYS_PRINT, &pass_msg);
}
