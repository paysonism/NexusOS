use svg2

app "SvgSurfaceFull" { stack = 4096; }

str full_svg = "<svg viewBox=\"0 0 120 80\" preserveAspectRatio=\"xMidYMid meet\"><defs><style>.hot{fill:#f80;stroke:#004}</style><linearGradient id=\"lg\" gradientTransform=\"rotate(5)\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\" gradientUnits=\"objectBoundingBox\"><stop offset=\"0\" stop-color=\"#123\"/><stop offset=\"100\" stop-color=\"#def\"/></linearGradient><pattern id=\"pat\" width=\"6\" height=\"6\"><rect width=\"6\" height=\"6\" fill=\"#0a0\"/></pattern><path id=\"curve\" d=\"M 4 70 C 30 45 80 95 116 60\"/><symbol id=\"sym\"><circle cx=\"8\" cy=\"8\" r=\"6\" fill=\"url(#lg)\"/></symbol><filter id=\"fx\"><feFlood flood-color=\"#00f\" flood-opacity=\"64\" result=\"f\"/><feComposite in=\"SourceGraphic\" in2=\"f\" operator=\"over\"/></filter><mask id=\"m\" mask-type=\"alpha\"><rect x=\"0\" y=\"0\" width=\"120\" height=\"80\" fill=\"white\"/></mask></defs><rect class=\"hot\" x=\"4\" y=\"4\" width=\"28\" height=\"16\" stroke-dasharray=\"3 2\" stroke-linejoin=\"bevel\"/><rect x=\"36\" y=\"4\" width=\"28\" height=\"16\" fill=\"url(#pat)\" mask=\"url(#m)\"/><use href=\"#sym\" x=\"70\" y=\"4\"/><image href=\"#sym\" x=\"90\" y=\"4\" width=\"18\" height=\"18\"/><g filter=\"url(#fx)\"><text x=\"6\" y=\"44\" letter-spacing=\"1\" word-spacing=\"2\">A B</text><text><textPath href=\"#curve\">PATH</textPath></text></g></svg>";
str full_pass = "[nxhl] svg surface full pass";
str full_fail = "[nxhl] svg surface full fail";

fn smoke_draw(win) {
    if svg_render(&full_svg, 1180, 0, 0, 240, 160) != 0 {
        syscall(SYS_PRINT, &full_fail);
        return;
    }
    syscall(SYS_PRINT, &full_pass);
}
