use xml

app "XmlDiagSmoke" { stack = 4096; }

str good_xml = "<root><child name=\"ok\">text</child></root>";
str cdata_xml = "<root><code><![CDATA[a < b]]></code></root>";
str bad_xml = "<root><child></root>";
str single_a = "<a/>";
str single_b = "<b><c/></b>";
str mixed_xml = "<p>one<b/>two<i/>three</p>";
str ns_xml = "<svg:path xmlns:svg=\"urn:svg\"/>";
str entity_xml = "<!DOCTYPE doc [<!ENTITY brand \"NexusOS\">]><doc>&brand;</doc>";
str prefix_svg = "svg";
str entity_brand = "brand";
str pass_msg = "[nxhl] xml diag pass";
str fail_msg = "[nxhl] xml diag fail";

state {
    xml_test_buf: 32;
}

fn fail() {
    syscall(SYS_PRINT, &fail_msg);
}

fn smoke_draw(win) {
    if xml_parse(&good_xml, 42) != 1 { fail(); return; }
    let root = xml_root();
    if root < 0 { fail(); return; }
    if xml_node_count() < 2 { fail(); return; }
    let child = xml_first_child_safe(root);
    if child < 0 { fail(); return; }
    if xml_parent(child) != root { fail(); return; }
    if xml_text(child, &xml_test_buf, 32) != 4 { fail(); return; }
    if lb(&xml_test_buf) != 116 { fail(); return; }
    if lb(&xml_test_buf + 3) != 116 { fail(); return; }

    if xml_parse(&cdata_xml, 43) != 1 { fail(); return; }
    let cdata_root = xml_root();
    let code = xml_first_child_safe(cdata_root);
    if xml_text(code, &xml_test_buf, 32) != 5 { fail(); return; }
    if lb(&xml_test_buf + 2) != 60 { fail(); return; }

    if xml_parse(&bad_xml, 20) != 0 { fail(); return; }
    if xml_last_error_code() != XML_ERR_MISMATCH { fail(); return; }
    if xml_last_error_offset() == 0 { fail(); return; }

    if xml_parse(&single_a, 4) != 1 { fail(); return; }
    let a_root = xml_root();
    if xml_parse(&single_b, 11) != 1 { fail(); return; }
    let b_root = xml_root();
    if b_root == a_root { fail(); return; }
    if xml_tag_name(b_root, &xml_test_buf, 32) != 1 { fail(); return; }
    if lb(&xml_test_buf) != 98 { fail(); return; }

    if xml_parse(&mixed_xml, 26) != 1 { fail(); return; }
    let mixed_root = xml_root();
    if xml_text_runs(mixed_root) != 3 { fail(); return; }
    if xml_text_run(mixed_root, 1, &xml_test_buf, 32) != 3 { fail(); return; }
    if lb(&xml_test_buf) != 116 { fail(); return; }
    if lb(&xml_test_buf + 1) != 119 { fail(); return; }
    if lb(&xml_test_buf + 2) != 111 { fail(); return; }

    if xml_parse(&ns_xml, 31) != 1 { fail(); return; }
    let ns_root = xml_root();
    if xml_tag_name(ns_root, &xml_test_buf, 32) != 8 { fail(); return; }
    if lb(&xml_test_buf + 3) != 58 { fail(); return; }
    if xml_node_namespace(ns_root, &xml_test_buf, 32) != 7 { fail(); return; }
    if lb(&xml_test_buf) != 117 { fail(); return; }
    if lb(&xml_test_buf + 6) != 103 { fail(); return; }
    if xml_namespace(ns_root, &prefix_svg, 3, &xml_test_buf, 32) != 7 { fail(); return; }

    if xml_parse(&entity_xml, 60) != 1 { fail(); return; }
    let entity_root = xml_root();
    if xml_text(entity_root, &xml_test_buf, 32) != 7 { fail(); return; }
    if lb(&xml_test_buf) != 78 { fail(); return; }
    if xml_entity_value(&entity_brand, 5, &xml_test_buf, 32) != 7 { fail(); return; }
    if lb(&xml_test_buf + 6) != 83 { fail(); return; }

    syscall(SYS_PRINT, &pass_msg);
    xml_free();
}
