module "noasm_intrinsics";

unsafe kernel_priv;
unsafe kernel_int;
unsafe raw_mem;

global nxh_test_noasm_intrinsics;

data test_gdtr: 10 = 0;
data test_buf: 64 = 0;
data test_buf2: 64 = 0;
data test_lock: 4 = 0;

fn nxh_test_noasm_intrinsics() {
    let cr0 = read_cr0();
    let cr4 = read_cr4();

    write_cr0(cr0);
    write_cr4(cr4);
    lgdt(&test_gdtr);
    lidt(&test_gdtr);
    ltr(0x30);
    load_ds(0x10);
    load_es(0x10);
    load_fs(0x10);
    load_gs(0x10);
    load_ss(0x10);
    intn(0x10);

    # dword block fill/copy + atomic exchange (driver fast-path / spinlock prims)
    rep_stosd(&test_buf, 0, 8);
    rep_movsd(&test_buf2, &test_buf, 8);
    let old = atomic_xchg(&test_lock, 1);

    # SSE2 XMM data path (display non-temporal blit + dword-broadcast fill + isqrt)
    xmm_loadu(xmm0, &test_buf);
    xmm_store_nt(&test_buf2, xmm0);
    xmm_bcast32(xmm1, 0xFF00FF00);
    xmm_store(&test_buf, xmm1);
    sfence();
    let r = isqrt(old);
    return r;
}
