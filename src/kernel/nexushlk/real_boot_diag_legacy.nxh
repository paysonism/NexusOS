    asm "";
    asm "    lea rdi, [ovl_buf]";
    asm "    lea rsi, [s_dmub_gpint]";
    asm "    call ovl_puts";
    asm "    mov edx, [amd_dcn_dmub_gpint_in]";
    asm "    call ovl_puth32";
    asm "    lea rsi, [s_dmub_out]";
    asm "    call ovl_puts";
    asm "    mov edx, [amd_dcn_dmub_gpint_out]";
    asm "    call ovl_puth32";
    asm "    lea rsi, [s_dmub_ifault]";
    asm "    call ovl_puts";
    asm "    mov edx, [amd_dcn_dmub_inst_fault]";
    asm "    call ovl_puth32";
    asm "    lea rsi, [s_dmub_dfault]";
    asm "    call ovl_puts";
    asm "    mov edx, [amd_dcn_dmub_data_fault]";
    asm "    call ovl_puth32";
    asm "    lea rsi, [s_dmub_ufault]";
    asm "    call ovl_puts";
    asm "    mov edx, [amd_dcn_dmub_undef_fault]";
    asm "    call ovl_puth32";
    asm "    mov byte [rdi], 0";
    asm "    call diag_emit_line";
    asm "";
    asm "    lea rdi, [ovl_buf]";
    asm "    lea rsi, [s_dcn_cfg]";
    asm "    call ovl_puts";
    asm "    mov edx, [amd_dcn_cfg_base]";
    asm "    call ovl_puth32";
    asm "    lea rsi, [s_dcn_cmd_pre]";
    asm "    call ovl_puts";
    asm "    mov edx, [amd_dcn_cmd_pre]";
    asm "    call ovl_puth32";
    asm "    lea rsi, [s_dcn_cmd_post]";
    asm "    call ovl_puts";
    asm "    mov edx, [amd_dcn_cmd_post]";
    asm "    call ovl_puth32";
    asm "    mov byte [rdi], 0";
    asm "    call diag_emit_line";
    asm "";
    asm "    lea rdi, [ovl_buf]";
    asm "    lea rsi, [s_dcn_r0]";
    asm "    call ovl_puts";
    asm "    mov edx, [amd_dcn_reg0000]";
    asm "    call ovl_puth32";
    asm "    lea rsi, [s_dcn_r4]";
    asm "    call ovl_puts";
    asm "    mov edx, [amd_dcn_reg0004]";
    asm "    call ovl_puth32";
    asm "    lea rsi, [s_dcn_r8]";
    asm "    call ovl_puts";
    asm "    mov edx, [amd_dcn_reg0008]";
    asm "    call ovl_puth32";
    asm "    lea rsi, [s_dcn_rC]";
    asm "    call ovl_puts";
    asm "    mov edx, [amd_dcn_reg000C]";
    asm "    call ovl_puth32";
    asm "    mov byte [rdi], 0";
    asm "    call diag_emit_line";
    asm "";
    asm "    ; ---- DCN IP-block enumeration (Task B) ----";
    asm "    ; One dword sample per 4KB page across the 1MB UC mapping. Emit only";
    asm "    ; non-zero entries, 4 per line, format \"IP+xxxxx=hhhhhhhh\".";
    asm "    push r12";
    asm "    push r13";
    asm "    extern amd_dcn_ip_table";
    asm "    extern amd_dcn_ip_count";
    asm "    extern amd_dcn_bl_table";
    asm "    extern amd_dcn_bl_count";
    asm "    extern amd_dcn_bl_base";
    asm "    extern amd_dcn_bl_stride";
    asm "    lea rdi, [ovl_buf]";
    asm "    lea rsi, [s_dcn_ip_hdr]";
    asm "    call ovl_puts";
    asm "    mov byte [rdi], 0";
    asm "    call diag_emit_line";
    asm "";
    asm "    xor r12d, r12d                       ; index";
    asm "    xor r13d, r13d                       ; per-line counter";
    asm "    lea rdi, [ovl_buf]";
    asm ".ip_dump_loop:";
    asm "    mov ecx, [amd_dcn_ip_count]";
    asm "    cmp r12d, ecx";
    asm "    jae .ip_dump_flush";
    asm "    lea rbx, [amd_dcn_ip_table]";
    asm "    mov eax, [rbx + r12*4]";
    asm "    test eax, eax";
    asm "    jz  .ip_dump_next";
    asm "    ; emit \"IP+xxxxx=hhhhhhhh \"";
    asm "    lea rsi, [s_dcn_ip_pfx]";
    asm "    call ovl_puts";
    asm "    mov edx, r12d";
    asm "    shl edx, 12                          ; offset = idx * 0x1000";
    asm "    call ovl_puth32";
    asm "    lea rsi, [s_dcn_eq]";
    asm "    call ovl_puts";
    asm "    mov edx, [rbx + r12*4]";
    asm "    call ovl_puth32";
    asm "    lea rsi, [s_dcn_sp]";
    asm "    call ovl_puts";
    asm "    inc r13d";
    asm "    cmp r13d, 4";
    asm "    jb  .ip_dump_next";
    asm "    mov byte [rdi], 0";
    asm "    call diag_emit_line";
    asm "    lea rdi, [ovl_buf]";
    asm "    xor r13d, r13d";
    asm ".ip_dump_next:";
    asm "    inc r12d";
    asm "    jmp .ip_dump_loop";
    asm ".ip_dump_flush:";
    asm "    test r13d, r13d";
    asm "    jz  .ip_dump_done";
    asm "    mov byte [rdi], 0";
    asm "    call diag_emit_line";
    asm ".ip_dump_done:";
    asm "";
    asm "    ; DCN BL register sweep disabled: DCN 3.1+/3.5 has no CPU-accessible";
    asm "    ; BL_PWM register. Backlight is owned by DMUB firmware via the inbox";
    asm "    ; ring (cmd.panel_cntl) â€” confirmed in drm/amd/display/dc/resource/";
    asm "    ; dcn35/dcn35_resource.c which reuses dcn31_panel_cntl. Brightness";
    asm "    ; will be controlled either via EC scratch byte (see acpi_ec_dump_mid)";
    asm "    ; or by sending a DMUB packet.";
    asm "    pop r13";
    asm "    pop r12";
    asm "";
    asm "    ; ---- ACPI EC RAM dump (low + high zones) ----";
    asm "    extern acpi_ec_dump_zone";
    asm "    extern acpi_ec_dump_ok";
    asm "    extern acpi_ec_dump_low";
    asm "    extern acpi_ec_dump_high";
    asm "    call acpi_ec_dump_zone";
    asm "";
    asm "    lea rdi, [ovl_buf]";
    asm "    lea rsi, [s_ec_hdr]";
    asm "    call ovl_puts";
    asm "    movzx edx, byte [acpi_ec_dump_ok]";
    asm "    call ovl_putu";
    asm "    mov byte [rdi], 0";
    asm "    call diag_emit_line";
    asm "";
    asm "    ; Low zone (0x00..0x1F) as 32 hex bytes";
    asm "    lea rdi, [ovl_buf]";
    asm "    lea rsi, [s_ec_low]";
    asm "    call ovl_puts";
    asm "    lea rbx, [acpi_ec_dump_low]";
    asm "    mov ecx, 32";
    asm "    call diag_emit_hexbytes";
    asm "    mov byte [rdi], 0";
    asm "    call diag_emit_line";
    asm "";
    asm "    ; Mid zone (0x20..0x6F) â€” 80 bytes";
    asm "    extern acpi_ec_dump_mid";
    asm "    lea rdi, [ovl_buf]";
    asm "    lea rsi, [s_ec_mid]";
    asm "    call ovl_puts";
    asm "    lea rbx, [acpi_ec_dump_mid]";
    asm "    mov ecx, 80";
    asm "    call diag_emit_hexbytes";
    asm "    mov byte [rdi], 0";
    asm "    call diag_emit_line";
    asm "";
    asm "    ; High zone (0x70..0x8F)";
    asm "    lea rdi, [ovl_buf]";
    asm "    lea rsi, [s_ec_high]";
    asm "    call ovl_puts";
    asm "    lea rbx, [acpi_ec_dump_high]";
    asm "    mov ecx, 32";
    asm "    call diag_emit_hexbytes";
    asm "    mov byte [rdi], 0";
    asm "    call diag_emit_line";
    asm "%endif ; NEXUS_DIAG_LEGACY (DCN/IP/EC)";
    asm "    ret";
}
