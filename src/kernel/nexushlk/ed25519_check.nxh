data ed_sh_h: 8 x 8;
data ed_sh_w: 80 x 8;
data ed_sh_buf: 128;
data ed_sh_buflen: 1;
data ed_sh_total: 8;
data ed_sh_out: 64;

# ---- scratch (single-threaded; see header note) -----------------------------
data ed_mul_t: 16 x 4;     # 512-bit product
data ed_red_t: 9 x 4;      # reduction fold
data ed_pw_b: 8 x 4;       # fe_pow base copy
data ed_pw_r: 8 x 4;       # fe_pow accumulator
# point-add temporaries (a,b,c,d,e,f,g,h + 2 sub/add scratch)
data ed_pa_ta: 8 x 4;
data ed_pa_tb: 8 x 4;
data ed_pa_tc: 8 x 4;
data ed_pa_td: 8 x 4;
data ed_pa_te: 8 x 4;
data ed_pa_tf: 8 x 4;
data ed_pa_tg: 8 x 4;
data ed_pa_th: 8 x 4;
data ed_pa_t1: 8 x 4;
data ed_pa_t2: 8 x 4;
# decompress temporaries
data ed_dc_u: 8 x 4;
data ed_dc_v: 8 x 4;
data ed_dc_x: 8 x 4;
data ed_dc_t1: 8 x 4;
data ed_dc_t2: 8 x 4;
data ed_dc_chk: 8 x 4;
# verify working set
data ed_pt_a: 32 x 4;      # decompressed public key A
data ed_pt_r: 32 x 4;      # decompressed R from the signature
data ed_pt_b: 32 x 4;      # basepoint B
data ed_pt_p1: 32 x 4;     # [S]B
data ed_pt_p2: 32 x 4;     # [h]A + R
data ed_sm_q: 32 x 4;      # scalar-mult input copy
data ed_sc_s: 8 x 4;       # signature scalar S
data ed_sc_h: 8 x 4;       # H(R||A||M) mod L
data ed_eq_t1: 8 x 4;      # projective-equality cross products
data ed_eq_t2: 8 x 4;

# ============================================================================
# little-endian loads/stores built from byte ops (alignment-free)
# ============================================================================
fn ed_rd_u32(p) {
    return lb(p) | (lb(p + 1) << 8) | (lb(p + 2) << 16) | (lb(p + 3) << 24);
}

fn ed_wr_u32(p, v) {
    sb(p, v & 0xFF);
    sb(p + 1, (v >> 8) & 0xFF);
    sb(p + 2, (v >> 16) & 0xFF);
    sb(p + 3, (v >> 24) & 0xFF);
}

# digit access on a 32-bit-digit big number at ptr
fn ed_dig(a, i) { return lw(a + i * 4) & ED_M32; }
fn ed_setdig(a, i, v) { sw(a + i * 4, v & ED_M32); }

# ============================================================================
# generic n-digit big-number helpers (digits are 32-bit, little-endian)
# ============================================================================
fn ed_big_zero(r, n) {
    let i = 0;
    while i < n { ed_setdig(r, i, 0); i = i + 1; }
    return 0;
}

fn ed_big_copy(r, a, n) {
    let i = 0;
    while i < n { ed_setdig(r, i, ed_dig(a, i)); i = i + 1; }
    return 0;
}

# 0 if a == b, 1 if a > b, 2 if a < b
fn ed_big_cmp(a, b, n) {
    let i = n - 1;
    while i >= 0 {
        let da = ed_dig(a, i);
        let db = ed_dig(b, i);
        if da > db { return 1; }
        if da < db { return 2; }
        i = i - 1;
    }
    return 0;
}

# r = a + b (n digits); returns the carry out (0/1). Aliasing-safe.
fn ed_big_add(r, a, b, n) {
    let carry = 0;
    let i = 0;
    while i < n {
        let s = ed_dig(a, i) + ed_dig(b, i) + carry;
        ed_setdig(r, i, s);
        carry = s >> 32;
        i = i + 1;
    }
    return carry;
}

# r = a - b (n digits); returns the borrow out (0/1). The +2^32 bias keeps
# every intermediate non-negative (no signed-wrap divergence). Aliasing-safe.
fn ed_big_sub(r, a, b, n) {
    let borrow = 0;
    let i = 0;
    while i < n {
        let s = ed_dig(a, i) + 0x100000000 - ed_dig(b, i) - borrow;
        ed_setdig(r, i, s);
        borrow = 1 - (s >> 32);
        i = i + 1;
    }
    return borrow;
}

# r = r << 1 (n digits); top carry returned (callers keep values small enough
# that it is always 0).
fn ed_big_shl1(r, n) {
    let carry = 0;
    let i = 0;
    while i < n {
        let s = (ed_dig(r, i) << 1) | carry;
        ed_setdig(r, i, s);
        carry = (s >> 32) & 1;
        i = i + 1;
    }
    return carry;
}

# ============================================================================
# field arithmetic mod p = 2^255 - 19 (8 digits, canonical < p in/out)
# ============================================================================
fn ed_fe_canon(r) {
    while ed_big_cmp(r, &ed_p, 8) != 2 {
        ed_big_sub(r, r, &ed_p, 8);
    }
    return 0;
}

fn ed_fe_set_small(r, v) {
    ed_big_zero(r, 8);
    ed_setdig(r, 0, v);
    return 0;
}

fn ed_fe_add(r, a, b) {
    ed_big_add(r, a, b, 8);      # a,b < p so the carry out is 0
    ed_fe_canon(r);
    return 0;
}

fn ed_fe_sub(r, a, b) {
    let borrow = ed_big_sub(r, a, b, 8);
    if borrow != 0 {
        ed_big_add(r, r, &ed_p, 8);   # discard carry: (a-b+2^256)+p-2^256
    }
    return 0;
}

# ed_mul_t = a * b (8x8 -> 16 digits). One product per step + carry keeps the
# 64-bit accumulator below 2^64.
fn ed_big_mul8(a, b) {
    ed_big_zero(&ed_mul_t, 16);
    let i = 0;
    while i < 8 {
        let carry = 0;
        let ai = ed_dig(a, i);
        let j = 0;
        while j < 8 {
            let acc = ed_dig(&ed_mul_t, i + j) + ai * ed_dig(b, j) + carry;
            ed_setdig(&ed_mul_t, i + j, acc);
            carry = acc >> 32;
            j = j + 1;
        }
        ed_setdig(&ed_mul_t, i + 8, carry);
        i = i + 1;
    }
    return 0;
}

# r = ed_mul_t mod p, canonical. 2^256 = 2p + 38, so x = hi*2^256 + lo
# folds as lo + hi*38 (twice, then a tiny third fold, then canon).
fn ed_fe_reduce512(r) {
    # first fold: ed_red_t(9) = lo8 + hi8*38
    let carry = 0;
    let i = 0;
    while i < 8 {
        let acc = ed_dig(&ed_mul_t, i) + ed_dig(&ed_mul_t, i + 8) * 38 + carry;
        ed_setdig(&ed_red_t, i, acc);
        carry = acc >> 32;
        i = i + 1;
    }
    ed_setdig(&ed_red_t, 8, carry);     # <= 38
    # second fold: r8 = low8 + top*38
    let top = ed_dig(&ed_red_t, 8);
    let acc2 = ed_dig(&ed_red_t, 0) + top * 38;
    ed_setdig(r, 0, acc2);
    let carry2 = acc2 >> 32;
    i = 1;
    while i < 8 {
        let acc3 = ed_dig(&ed_red_t, i) + carry2;
        ed_setdig(r, i, acc3);
        carry2 = acc3 >> 32;
        i = i + 1;
    }
    # third fold: a final carry of 1 means +2^256 == +38 (mod p), and the low
    # digits are tiny at that point so this cannot carry again.
    if carry2 != 0 {
        ed_setdig(r, 0, ed_dig(r, 0) + 38);
    }
    ed_fe_canon(r);
    return 0;
}

fn ed_fe_mul(r, a, b) {
    ed_big_mul8(a, b);
    ed_fe_reduce512(r);
    return 0;
}

fn ed_fe_sq(r, a) {
    ed_fe_mul(r, a, a);
    return 0;
}

# r = base ^ exp, exp given as a 32-byte little-endian string. Square-and-
# multiply MSB-first; r may alias base (base is copied first).
fn ed_fe_pow(r, base, exp) {
    ed_big_copy(&ed_pw_b, base, 8);
    ed_fe_set_small(&ed_pw_r, 1);
    let i = 255;
    while i >= 0 {
        ed_fe_sq(&ed_pw_r, &ed_pw_r);
        let bit = (lb(exp + (i >> 3)) >> (i & 7)) & 1;
        if bit != 0 {
            ed_fe_mul(&ed_pw_r, &ed_pw_r, &ed_pw_b);
        }
        i = i - 1;
    }
    ed_big_copy(r, &ed_pw_r, 8);
    return 0;
}

fn ed_fe_from_bytes(r, p) {
    let i = 0;
    while i < 8 {
        ed_setdig(r, i, ed_rd_u32(p + i * 4));
        i = i + 1;
    }
    return 0;
}

fn ed_fe_is_zero(a) {
    let i = 0;
    while i < 8 {
        if ed_dig(a, i) != 0 { return 0; }
        i = i + 1;
    }
    return 1;
}

# ============================================================================
# point ops — extended twisted-Edwards (X,Y,Z,T at +0/+32/+64/+96)
# ============================================================================
fn ed_pt_identity(p) {
    ed_fe_set_small(p, 0);          # X
    ed_fe_set_small(p + 32, 1);     # Y
    ed_fe_set_small(p + 64, 1);     # Z
    ed_fe_set_small(p + 96, 0);     # T
    return 0;
}

fn ed_pt_copy(r, p) {
    ed_big_copy(r, p, 32);
    return 0;
}

# r = p + q  (hwcd unified addition; complete on this curve, so it also
# doubles). All inputs are read into temporaries before r is written, so
# r may alias p and/or q.
fn ed_pt_add(r, p, q) {
    ed_fe_sub(&ed_pa_t1, p + 32, p);            # Y1 - X1
    ed_fe_sub(&ed_pa_t2, q + 32, q);            # Y2 - X2
    ed_fe_mul(&ed_pa_ta, &ed_pa_t1, &ed_pa_t2); # A
    ed_fe_add(&ed_pa_t1, p + 32, p);            # Y1 + X1
    ed_fe_add(&ed_pa_t2, q + 32, q);            # Y2 + X2
    ed_fe_mul(&ed_pa_tb, &ed_pa_t1, &ed_pa_t2); # B
    ed_fe_mul(&ed_pa_tc, p + 96, q + 96);       # T1*T2
    ed_fe_mul(&ed_pa_tc, &ed_pa_tc, &ed_d2);    # C = 2d*T1*T2
    ed_fe_mul(&ed_pa_td, p + 64, q + 64);       # Z1*Z2
    ed_fe_add(&ed_pa_td, &ed_pa_td, &ed_pa_td); # D = 2*Z1*Z2
    ed_fe_sub(&ed_pa_te, &ed_pa_tb, &ed_pa_ta); # E = B - A
    ed_fe_sub(&ed_pa_tf, &ed_pa_td, &ed_pa_tc); # F = D - C
    ed_fe_add(&ed_pa_tg, &ed_pa_td, &ed_pa_tc); # G = D + C
    ed_fe_add(&ed_pa_th, &ed_pa_tb, &ed_pa_ta); # H = B + A
    ed_fe_mul(r, &ed_pa_te, &ed_pa_tf);         # X3 = E*F
    ed_fe_mul(r + 32, &ed_pa_tg, &ed_pa_th);    # Y3 = G*H
    ed_fe_mul(r + 64, &ed_pa_tf, &ed_pa_tg);    # Z3 = F*G
    ed_fe_mul(r + 96, &ed_pa_te, &ed_pa_th);    # T3 = E*H
    return 0;
}

# r = [s]q, s an 8-digit scalar (< L so bits 253..255 are clear, but the loop
# covers all 256 anyway). Double-and-add MSB-first; q is copied so r may
# alias q.
fn ed_pt_scalarmult(r, s, q) {
    ed_pt_copy(&ed_sm_q, q);
    ed_pt_identity(r);
    let i = 255;
    while i >= 0 {
        ed_pt_add(r, r, r);
        let bit = (ed_dig(s, i >> 5) >> (i & 31)) & 1;
        if bit != 0 {
            ed_pt_add(r, r, &ed_sm_q);
        }
        i = i - 1;
    }
    return 0;
}

# Decompress 32 bytes at b into point r. Returns 1 ok / 0 reject.
fn ed_pt_decompress(r, b) {
    # y = low 255 bits, must already be canonical (< p)
    ed_fe_from_bytes(r + 32, b);
    ed_setdig(r + 32, 7, ed_dig(r + 32, 7) & 0x7FFFFFFF);
    if ed_big_cmp(r + 32, &ed_p, 8) != 2 { return 0; }
    let sign = lb(b + 31) >> 7;
    # u = y^2 - 1, v = d*y^2 + 1  (x^2 = u/v)
    ed_fe_sq(&ed_dc_t1, r + 32);                 # y^2
    ed_fe_set_small(&ed_dc_t2, 1);
    ed_fe_sub(&ed_dc_u, &ed_dc_t1, &ed_dc_t2);   # u
    ed_fe_mul(&ed_dc_v, &ed_dc_t1, &ed_d2);      # 2d*y^2
    # halve: we have 2d*y^2; v = d*y^2 + 1 = (2d*y^2)*inv2 + 1. Cheaper to
    # recompute with d = 2d * inv(2)? Avoid an extra constant: v = d*y^2 + 1
    # via (2d*y^2 + 2) * inv(2) would need inv2 anyway, so just multiply u/v
    # forms by 2: x^2 = u/v = (2u)/(2v) — scale both sides instead.
    # 2v = 2d*y^2 + 2:
    ed_fe_add(&ed_dc_t2, &ed_dc_t2, &ed_dc_t2);  # 2
    ed_fe_add(&ed_dc_v, &ed_dc_v, &ed_dc_t2);    # 2v
    ed_fe_add(&ed_dc_u, &ed_dc_u, &ed_dc_u);     # 2u
    # x = (2u) * (2v)^3 * ((2u) * (2v)^7) ^ ((p-5)/8)
    ed_fe_sq(&ed_dc_t1, &ed_dc_v);               # v2
    ed_fe_mul(&ed_dc_t2, &ed_dc_t1, &ed_dc_v);   # v3
    ed_fe_sq(&ed_dc_t1, &ed_dc_t2);              # v6
    ed_fe_mul(&ed_dc_t1, &ed_dc_t1, &ed_dc_v);   # v7
    ed_fe_mul(&ed_dc_t1, &ed_dc_t1, &ed_dc_u);   # u*v7
    ed_fe_pow(&ed_dc_t1, &ed_dc_t1, &ed_exp_p58);
    ed_fe_mul(&ed_dc_x, &ed_dc_u, &ed_dc_t2);    # u*v3
    ed_fe_mul(&ed_dc_x, &ed_dc_x, &ed_dc_t1);    # candidate x
    # check v*x^2 == u  or  v*x^2 == -u (then multiply by sqrt(-1))
    ed_fe_sq(&ed_dc_t1, &ed_dc_x);
    ed_fe_mul(&ed_dc_chk, &ed_dc_t1, &ed_dc_v);  # v*x^2
    if ed_big_cmp(&ed_dc_chk, &ed_dc_u, 8) != 0 {
        ed_fe_set_small(&ed_dc_t2, 0);
        ed_fe_sub(&ed_dc_t1, &ed_dc_t2, &ed_dc_u);   # -u
        if ed_big_cmp(&ed_dc_chk, &ed_dc_t1, 8) != 0 { return 0; }
        ed_fe_mul(&ed_dc_x, &ed_dc_x, &ed_sqrtm1);
    }
    if ed_fe_is_zero(&ed_dc_x) != 0 {
        if sign != 0 { return 0; }
    }
    if (ed_dig(&ed_dc_x, 0) & 1) != sign {
        ed_fe_set_small(&ed_dc_t2, 0);
        ed_fe_sub(&ed_dc_x, &ed_dc_t2, &ed_dc_x);
    }
    ed_big_copy(r, &ed_dc_x, 8);                 # X
    ed_fe_set_small(r + 64, 1);                  # Z
    ed_fe_mul(r + 96, r, r + 32);                # T = X*Y
    return 1;
}

# projective equality: X1*Z2 == X2*Z1 and Y1*Z2 == Y2*Z1
fn ed_pt_eq(p, q) {
    ed_fe_mul(&ed_eq_t1, p, q + 64);
    ed_fe_mul(&ed_eq_t2, q, p + 64);
    if ed_big_cmp(&ed_eq_t1, &ed_eq_t2, 8) != 0 { return 0; }
    ed_fe_mul(&ed_eq_t1, p + 32, q + 64);
    ed_fe_mul(&ed_eq_t2, q + 32, p + 64);
    if ed_big_cmp(&ed_eq_t1, &ed_eq_t2, 8) != 0 { return 0; }
    return 1;
}

# ============================================================================
# SHA-512 (streaming, mirrors the crypto.nxh SHA-256 structure)
# ============================================================================
fn ed_ror64(x, n) {
    return ((x >> n) | (x << (64 - n))) & ED_M64;
}

fn ed_sh_bsig0(x) { return ed_ror64(x, 28) ^ ed_ror64(x, 34) ^ ed_ror64(x, 39); }
fn ed_sh_bsig1(x) { return ed_ror64(x, 14) ^ ed_ror64(x, 18) ^ ed_ror64(x, 41); }
fn ed_sh_ssig0(x) { return ed_ror64(x, 1) ^ ed_ror64(x, 8) ^ (x >> 7); }
fn ed_sh_ssig1(x) { return ed_ror64(x, 19) ^ ed_ror64(x, 61) ^ (x >> 6); }
fn ed_sh_ch(x, y, z) { return (x & y) ^ ((x ^ ED_M64) & z); }
fn ed_sh_maj(x, y, z) { return (x & y) ^ (x & z) ^ (y & z); }

fn ed_rd_be64(p) {
    return (lb(p) << 56) | (lb(p + 1) << 48) | (lb(p + 2) << 40)
         | (lb(p + 3) << 32) | (lb(p + 4) << 24) | (lb(p + 5) << 16)
         | (lb(p + 6) << 8) | lb(p + 7);
}

fn ed_wr_be64(p, v) {
    sb(p, (v >> 56) & 0xFF);
    sb(p + 1, (v >> 48) & 0xFF);
    sb(p + 2, (v >> 40) & 0xFF);
    sb(p + 3, (v >> 32) & 0xFF);
    sb(p + 4, (v >> 24) & 0xFF);
    sb(p + 5, (v >> 16) & 0xFF);
    sb(p + 6, (v >> 8) & 0xFF);
    sb(p + 7, v & 0xFF);
}

fn ed_sha512_init() {
    sq(&ed_sh_h + 0,  0x6A09E667F3BCC908);
    sq(&ed_sh_h + 8,  0xBB67AE8584CAA73B);
    sq(&ed_sh_h + 16, 0x3C6EF372FE94F82B);
    sq(&ed_sh_h + 24, 0xA54FF53A5F1D36F1);
    sq(&ed_sh_h + 32, 0x510E527FADE682D1);
    sq(&ed_sh_h + 40, 0x9B05688C2B3E6C1F);
    sq(&ed_sh_h + 48, 0x1F83D9ABFB41BD6B);
    sq(&ed_sh_h + 56, 0x5BE0CD19137E2179);
    sq(&ed_sh_total, 0);
    sb(&ed_sh_buflen, 0);
    return 0;
}

fn ed_sha512_compress(block) {
    let i = 0;
    while i < 16 {
        sq(&ed_sh_w + i * 8, ed_rd_be64(block + i * 8));
        i = i + 1;
    }
    while i < 80 {
        let v = (ed_sh_ssig1(lq(&ed_sh_w + (i - 2) * 8)) + lq(&ed_sh_w + (i - 7) * 8)
               + ed_sh_ssig0(lq(&ed_sh_w + (i - 15) * 8)) + lq(&ed_sh_w + (i - 16) * 8)) & ED_M64;
        sq(&ed_sh_w + i * 8, v);
        i = i + 1;
    }
    let a = lq(&ed_sh_h + 0);  let b = lq(&ed_sh_h + 8);
    let c = lq(&ed_sh_h + 16); let d = lq(&ed_sh_h + 24);
    let e = lq(&ed_sh_h + 32); let f = lq(&ed_sh_h + 40);
    let g = lq(&ed_sh_h + 48); let h = lq(&ed_sh_h + 56);
    i = 0;
    while i < 80 {
        let t1 = (h + ed_sh_bsig1(e) + ed_sh_ch(e, f, g)
                + lq(&sha512_k + i * 8) + lq(&ed_sh_w + i * 8)) & ED_M64;
        let t2 = (ed_sh_bsig0(a) + ed_sh_maj(a, b, c)) & ED_M64;
        h = g; g = f; f = e; e = (d + t1) & ED_M64;
        d = c; c = b; b = a; a = (t1 + t2) & ED_M64;
        i = i + 1;
    }
    sq(&ed_sh_h + 0,  (lq(&ed_sh_h + 0) + a) & ED_M64);
    sq(&ed_sh_h + 8,  (lq(&ed_sh_h + 8) + b) & ED_M64);
    sq(&ed_sh_h + 16, (lq(&ed_sh_h + 16) + c) & ED_M64);
    sq(&ed_sh_h + 24, (lq(&ed_sh_h + 24) + d) & ED_M64);
    sq(&ed_sh_h + 32, (lq(&ed_sh_h + 32) + e) & ED_M64);
    sq(&ed_sh_h + 40, (lq(&ed_sh_h + 40) + f) & ED_M64);
    sq(&ed_sh_h + 48, (lq(&ed_sh_h + 48) + g) & ED_M64);
    sq(&ed_sh_h + 56, (lq(&ed_sh_h + 56) + h) & ED_M64);
    return 0;
}

fn ed_sha512_update(src, len) {
    let p = src;
    let left = len;
    sq(&ed_sh_total, lq(&ed_sh_total) + len);
    while left > 0 {
        let used = lb(&ed_sh_buflen);
        if used == 0 {
            while left >= 128 {
                ed_sha512_compress(p);
                p = p + 128;
                left = left - 128;
            }
            if left == 0 { return 0; }
        }
        let take = 128 - used;
        if take > left { take = left; }
        let i = 0;
        while i < take {
            sb(&ed_sh_buf + used + i, lb(p + i));
            i = i + 1;
        }
        used = used + take;
        sb(&ed_sh_buflen, used);
        p = p + take;
        left = left - take;
        if used == 128 {
            ed_sha512_compress(&ed_sh_buf);
            sb(&ed_sh_buflen, 0);
        }
    }
    return 0;
}

fn ed_sha512_final(out) {
    let bit_len = lq(&ed_sh_total) * 8;
    let used = lb(&ed_sh_buflen);
    sb(&ed_sh_buf + used, 0x80);
    used = used + 1;
    if used > 112 {
        while used < 128 {
            sb(&ed_sh_buf + used, 0);
            used = used + 1;
        }
        ed_sha512_compress(&ed_sh_buf);
        used = 0;
    }
    while used < 120 {
        sb(&ed_sh_buf + used, 0);
        used = used + 1;
    }
    # 128-bit big-endian length; messages here are far below 2^61 bytes so the
    # high qword of the bit count is always 0 (it occupies bytes 112..119).
    ed_wr_be64(&ed_sh_buf + 112, 0);
    ed_wr_be64(&ed_sh_buf + 120, bit_len);
    ed_sha512_compress(&ed_sh_buf);
    let i = 0;
    while i < 8 {
        ed_wr_be64(out + i * 8, lq(&ed_sh_h + i * 8));
        i = i + 1;
    }
    return 0;
}

# ============================================================================
# scalar reduction mod L over the 64-byte SHA-512 output (bitwise long
# division: 512 shifts, simple and exactly mirrors the host semantics)
# ============================================================================
fn ed_sc_reduce64(r, h64) {
    ed_big_zero(r, 8);
    let i = 511;
    while i >= 0 {
        ed_big_shl1(r, 8);     # r < L < 2^253, so the shifted value fits
        let bit = (lb(h64 + (i >> 3)) >> (i & 7)) & 1;
        if bit != 0 {
            ed_setdig(r, 0, ed_dig(r, 0) | 1);
        }
        if ed_big_cmp(r, &ed_l, 8) != 2 {
            ed_big_sub(r, r, &ed_l, 8);
        }
        i = i - 1;
    }
    return 0;
}

# ============================================================================
# RFC 8032 Ed25519 signature verification
# ============================================================================
fn ed25519_check_abi_version() {
    return 1;
}

# pub32: public key bytes; msg/msg_len: signed bytes; sig64: R(32) || S(32).
# Returns 1 only if the signature is valid.
fn ed25519_verify(pub32, msg, msg_len, sig64) {
    if pub32 == 0 { return 0; }
    if sig64 == 0 { return 0; }
    if ed_pt_decompress(&ed_pt_a, pub32) == 0 { return 0; }
    if ed_pt_decompress(&ed_pt_r, sig64) == 0 { return 0; }
    # S must be canonical (< L) — rejects signature malleability
    ed_fe_from_bytes(&ed_sc_s, sig64 + 32);
    if ed_big_cmp(&ed_sc_s, &ed_l, 8) != 2 { return 0; }
    # h = SHA-512(R || A || M) mod L
    ed_sha512_init();
    ed_sha512_update(sig64, 32);
    ed_sha512_update(pub32, 32);
    ed_sha512_update(msg, msg_len);
    ed_sha512_final(&ed_sh_out);
    ed_sc_reduce64(&ed_sc_h, &ed_sh_out);
    # basepoint B in extended coordinates
    ed_big_copy(&ed_pt_b, &ed_gx, 8);
    ed_big_copy(&ed_pt_b + 32, &ed_gy, 8);
    ed_fe_set_small(&ed_pt_b + 64, 1);
    ed_fe_mul(&ed_pt_b + 96, &ed_gx, &ed_gy);
    # accept iff [S]B == R + [h]A
    ed_pt_scalarmult(&ed_pt_p1, &ed_sc_s, &ed_pt_b);
    ed_pt_scalarmult(&ed_pt_p2, &ed_sc_h, &ed_pt_a);
    ed_pt_add(&ed_pt_p2, &ed_pt_p2, &ed_pt_r);
    return ed_pt_eq(&ed_pt_p1, &ed_pt_p2);
}

# ============================================================================
# Track-2 envelope threshold-signature check
# ============================================================================
fn ed25519_role_pubkey(role) {
    if role < 1 { return 0; }
    if role > 6 { return 0; }
    return &ed_role_pubs + (role - 1) * 32;
}

# Verify the detached signature block of an envelope whose STRUCTURE has
# already been accepted by envelope_verify:
#   base       : envelope start
#   signed_len : header_len + payload_len (the canonical signed bytes)
#   sig_total  : signature-block length (validated multiple of 64, <= 4096)
#   min_count / allowed_mask / required_mask: the validated COSIGNER_ROLES
# Each 64-byte signature may satisfy at most one role; a role counts once.
# Accept iff >= min_count distinct allowed roles verified and every
# required role verified.
fn ed25519_envelope_sigs_ok(base, signed_len, sig_total, min_count, allowed_mask, required_mask) {
    let count = sig_total >> 6;
    let verified = 0;
    let i = 0;
    while i < count {
        let sp = base + signed_len + i * 64;
        let role = 1;
        let matched = 0;
        while role <= 6 {
            if matched == 0 {
                let bit = 1 << (role - 1);
                if (allowed_mask & bit) != 0 {
                    if (verified & bit) == 0 {
                        if ed25519_verify(ed25519_role_pubkey(role), base, signed_len, sp) != 0 {
                            verified = verified | bit;
                            matched = 1;
                        }
                    }
                }
            }
            role = role + 1;
        }
        i = i + 1;
    }
    # Publish the distinct-role set that actually verified, BEFORE the quorum
    # verdict: the quorum-change tracking path (envelope_gate.nxh) re-judges
    # this same set against BOTH the old and the new quorum rule.
    sw(&ed_verified_roles, verified);
    if security_threshold_popcount6(verified) < min_count { return 0; }
    if (verified & required_mask) != required_mask { return 0; }
    return 1;
}

# Role bitmask of the signatures that cryptographically verified during the
# most recent ed25519_envelope_sigs_ok run. Only meaningful immediately after
# a FRESH (non-cached) envelope_verify_signed call on the same envelope.
data ed_verified_roles: 1 x 4;

fn ed25519_last_verified_roles() {
    return lw(&ed_verified_roles);
}

# Full verification: structure + semantics (envelope_verify) AND real
# Ed25519 threshold signatures over the canonical bytes. This is the entry
# point boot/update call sites bind to.
fn envelope_verify_signed(base, total_len, computed_hash, now, device_id, device_class, required_version, required_counter, required_epoch) {
    let rc = envelope_verify(base, total_len, computed_hash, now, device_id, device_class, required_version, required_counter, required_epoch);
    if rc != 0 { return rc; }
    # Structure is fully validated; re-read the header geometry and the
    # COSIGNER_ROLES field (id 10) for the quorum parameters.
    let header_len = lb(base + 12) | (lb(base + 13) << 8);
    let payload_len = lb(base + 14) | (lb(base + 15) << 8) | (lb(base + 16) << 16) | (lb(base + 17) << 24);
    let p = base + 18;
    let hdr_end = base + header_len;
    let min_count = 0;
    let allowed_mask = 0;
    let required_mask = 0;
    while p < hdr_end {
        let id_width = lb(p);
        let field_id = envelope_rd_scalar(p + 1, id_width);
        let len_width = lb(p + 1 + id_width);
        let field_len = envelope_rd_scalar(p + 2 + id_width, len_width);
        let vptr = p + 2 + id_width + len_width;
        if field_id == 10 {
            min_count = lb(vptr) | (lb(vptr + 1) << 8);
            allowed_mask = lb(vptr + 2) | (lb(vptr + 3) << 8);
            required_mask = lb(vptr + 4) | (lb(vptr + 5) << 8);
        }
        p = vptr + field_len;
    }
    let signed_len = header_len + payload_len;
    let sig_total = total_len - signed_len;
    if ed25519_envelope_sigs_ok(base, signed_len, sig_total, min_count, allowed_mask, required_mask) == 0 {
        return ENVR_ERR_SIGCRYPTO;
    }
    return 0;
}
