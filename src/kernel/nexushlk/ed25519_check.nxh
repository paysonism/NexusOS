# ============================================================================
# ed25519_check.nxh - zero-asm RFC 8032 Ed25519 verification + the Track-2
# envelope threshold-signature check (the "actual signature crypto" the
# envelope reader was waiting on).
#
# Public symbols:
#   ed25519_verify(pub32, msg, msg_len, sig64)       -> 1 valid / 0 invalid
#   ed25519_envelope_sigs_ok(base, signed_len, sig_total,
#                            min_count, allowed_mask, required_mask) -> 1/0
#   envelope_verify_signed(...same 9 args as envelope_verify...)
#       -> ENVR_OK / ENVR_ERR_* / ENVR_ERR_SIGCRYPTO(22)
#
# Implementation notes (all chosen so the host eval harness, which executes
# this exact source through the production nxhc frontend, has IDENTICAL
# semantics to the compiled kernel):
#   - Field elements mod p = 2^255-19 are 8 little-endian 32-bit digits.
#     Every fe_* routine returns a CANONICAL (< p) result.
#   - All 64-bit intermediates stay below 2^64 (digit products are accumulated
#     one at a time with carry), so `imul`/`add` never wrap, and nothing with
#     bit 63 set is ever fed to a signed compare.
#   - SHA-512 words are masked with ED_M64 after every combining step, which
#     is a no-op on hardware (AND with all-ones) and makes the arbitrary-
#     precision host evaluation match the hardware's mod-2^64 wrap exactly.
#   - Borrow/carry chains are computed via the +2^32 bias trick so no
#     intermediate is ever negative.
#   - Points are extended twisted-Edwards coordinates (X, Y, Z, T), 4 fe's
#     at struct offsets +0/+32/+64/+96. The hwcd unified addition formula is
#     complete on this curve, so the same routine doubles and adds.
#   - Scratch state is global and single-threaded, like crypto.nxh: envelope
#     verification runs on the boot/update path before concurrent callers.
#
# DEV KEYS: ed_role_pubs holds the six threshold-role public keys derived by
# scripts/build/ed25519_host.py from fixed development seeds (no secrecy —
# production signing re-bakes this table from HSM-held keys). The eval
# harness asserts this table matches the host derivation so they cannot
# drift.
# ============================================================================

module "ed25519_check";

unsafe raw_mem;          # lb/sb over fe digit arrays, hash state, envelopes

global ed25519_verify;
global ed25519_envelope_sigs_ok;
global envelope_verify_signed;
global ed25519_last_verified_roles;
global ed25519_check_abi_version;

const ED_M32 = 0xFFFFFFFF;
const ED_M64 = 0xFFFFFFFFFFFFFFFF;
const ENVR_ERR_SIGCRYPTO = 22;   # bad/missing threshold signature crypto

# ---- curve / scalar-field constants (little-endian 32-bit digits) ----------
data ed_p: 8 x 4 = [0xFFFFFFED, 0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF, 0xFFFFFFFF, 0x7FFFFFFF];
data ed_l: 8 x 4 = [0x5CF5D3ED, 0x5812631A, 0xA2F79CD6, 0x14DEF9DE, 0x00000000, 0x00000000, 0x00000000, 0x10000000];
