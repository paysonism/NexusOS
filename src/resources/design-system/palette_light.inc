; palette_light.inc — modern light theme
NPL1_MAGIC equ 0x314C504E

align 8
nx_palette_light:
    db "NPL1"
    dw 16
    db 3, 0
nx_palette_light_data:
    db 0xF5, 0xF6, 0xFA  ;  0 #F5F6FA  bg-base
