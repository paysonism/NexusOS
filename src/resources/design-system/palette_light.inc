    db 0xEC, 0xEF, 0xF4  ;  2 #ECEFF4  surface-2
    db 0xD8, 0xDD, 0xE3  ;  3 #D8DDE3  border
    db 0xC4, 0xCB, 0xD3  ;  4 #C4CBD3  border-strong
    db 0x0F, 0x14, 0x1E  ;  5 #0F141E  text-primary
    db 0x4B, 0x55, 0x63  ;  6 #4B5563  text-secondary
    db 0x8A, 0x93, 0x9F  ;  7 #8A939F  text-tertiary
    db 0x4C, 0x8B, 0xFF  ;  8 #4C8BFF  accent-light
    db 0x2A, 0x6F, 0xFF  ;  9 #2A6FFF  accent
    db 0x1A, 0x55, 0xD6  ; 10 #1A55D6  accent-dark
    db 0x36, 0xC0, 0xE0  ; 11 #36C0E0  cyan
    db 0x12, 0x91, 0xB0  ; 12 #1291B0  cyan-dark
    db 0xE5, 0x47, 0x4D  ; 13 #E5474D  error
    db 0xF7, 0xB5, 0x2C  ; 14 #F7B52C  warning
    db 0x2E, 0xB5, 0x6E  ; 15 #2EB56E  success
nx_palette_light_end:
