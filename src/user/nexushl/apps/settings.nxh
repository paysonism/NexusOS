# NexusHL Settings app — tabbed redesign.
#
# Four tabs (Debug only appears on debug builds): General, Display, Security,
# Debug. Each tab's content fits inside the 380x340 window with no overflow —
# the old single-scroll layout ran past the client area. Colors resolve through
# the active theme (UI_COL_* sentinels) so Settings follows light/dark.
#
# The Security tab reads the kernel's runtime hardening inventory via
# SYS_SYSINFO selectors 200..240 (src/kernel/core/security_status.asm) and shows
# a status pill per feature. A feature that failed to engage shows "FAILED" in
# red instead of bricking the box — the kernel reports it rather than halting.

use gui
use svg

app "Settings" { stack = 4096; }

# --- Layout metrics ----------------------------------------------------------
const PAD            = 12
const TABBAR_H       = 26
const CONTENT_Y0     = 34            # first content row, just below the tab bar

const RES_W          = 78            # preset resolution button width
const BG_W           = 82            # wallpaper button width
const NATIVE_BTN_W   = 92
const TOGGLE_COL_W   = 130
const PILL_W         = 80            # security status pill width
const FB_DUMP_W      = 130

# --- Per-tab content Y cursors (client coords) -------------------------------
# Display tab.
const Y_DISP_CUR     = 34
const Y_DISP_NAT     = 50
const Y_DISP_NATBTN  = 48
const Y_DISP_RESCAP  = 74
const Y_DISP_RES     = 92
const Y_DISP_TOG1    = 122
const Y_DISP_TOG2    = 146
# General tab.
const Y_GEN_SYS      = 34
const Y_GEN_RAM      = 56
const Y_GEN_CPU      = 72
const Y_GEN_GPU      = 88
const Y_GEN_GPUID    = 104
const Y_GEN_APP      = 130
const Y_GEN_BG       = 152
# Debug tab.
const Y_DBG_TITLE    = 34
const Y_DBG_L1       = 56
const Y_DBG_L2       = 70
const Y_DBG_L3       = 84
const Y_DBG_L4       = 98
const Y_DBG_L5       = 112
const Y_DBG_L6       = 126
const Y_DBG_DUMP     = 148
# Security tab.
const Y_SEC_SUMMARY  = 34
const Y_SEC_LIST     = 58
const SEC_ROW_H      = 18

# --- Security status SYS_SYSINFO selectors (security_status.asm) --------------
const SEC_SI_DEBUG   = 200
const SEC_SI_COUNT   = 201
const SEC_SI_ANYFAIL = 202
const SEC_SI_READY   = 203
const SEC_SI_FME_MODE = 204
const SEC_SI_FEAT0   = 210

# Per-feature status codes (mirror security_status.asm).
const SECST_OFF      = 0
const SECST_ACTIVE   = 1
const SECST_SOFTWARE = 2
const SECST_UNSUPP   = 3
const SECST_FAILED   = 4
const SEC_FME_MODE_NONE = 0
const SEC_FME_MODE_TME  = 1
const SEC_FME_MODE_SME  = 2

# --- fbperf selectors used by the Debug tab ----------------------------------
const FB_SI_FLIPS_TOTAL  = 100
const FB_SI_FULL_FLIPS   = 101
const FB_SI_RECT_FLIPS   = 102
const FB_SI_BYTES_LO     = 103
const FB_SI_TSC_MIN      = 107
const FB_SI_TSC_MAX      = 108
const FB_SI_TSC_LAST     = 109
const FB_SI_PAT_LO       = 120
const FB_SI_PAT_HI       = 121
const FB_SI_MTRR_COUNT   = 123
const FB_SI_PTE_LEVEL    = 126
const FB_SI_CACHING_TYPE = 127
const FB_SI_WC_ARMED     = 130
const FB_SI_WC_ACTIVATED = 131
const FB_SI_INIT_DONE    = 134
const FB_SI_DUMP_SERIAL  = 199

state {
    active_tab: 4;
    settings_flags: 4;
    settings_last_mode_result: 4;
    settings_bg_cache: 4;
    current_label_buf: 24;
    native_label_buf:  24;
    ram_label_buf:     40;
    cpu_label_buf:     48;
    gpu_name_buf:      48;
    gpu_id_buf:        56;
    fb_line1_buf:      64;
    fb_line2_buf:      64;
    fb_line3_buf:      64;
    fb_line4_buf:      64;
    fb_line5_buf:      64;
    fb_line6_buf:      64;
}

# Tab + section labels.
str tab_general   = "General";
str tab_display   = "Display";
str tab_security  = "Security";
str tab_debug     = "Debug";
str t_system      = "System";
str t_appearance  = "Appearance";
str t_resolution  = "Resolution";
str t_displaysec  = "Display";
str t_fbsec       = "Framebuffer (debug)";

# Display tab strings.
str label_vsync   = "VSync";
str label_fps     = "Show FPS";
str label_stretch = "Stretch to fill";
str btn_native    = "Use Native";
str res_800       = "800x600";
str res_1024      = "1024x768";
str res_1280      = "1280x720";
str prefix_current= "Current: ";
str prefix_native = "Native:  ";
str mode_ok       = "Ready";
str mode_failed   = "Mode switch failed";
str status_hint   = "NexusOS Settings";

# General tab strings.
str lbl_ram       = "RAM: ";
str lbl_ram_suf   = " MB";
str lbl_cpu       = "CPU: ";
str lbl_mhz       = " MHz, ";
str lbl_cores     = " cores";
str prefix_gpu    = "GPU: ";
str prefix_gpu_id = "ID: ";
str prefix_bdf    = "  BDF: ";
str gpu_none      = "No discrete display";
str gpu_780m      = "AMD Radeon 780M";
str gpu_amd       = "AMD display";
str bg_metal      = "Metal";
str bg_ribbons    = "Ribbons";
str bg_bloom      = "Bloom";

# Security tab strings.
str sec_all_ok    = "All hardening features active";
str sec_some_fail = "One or more features degraded";
